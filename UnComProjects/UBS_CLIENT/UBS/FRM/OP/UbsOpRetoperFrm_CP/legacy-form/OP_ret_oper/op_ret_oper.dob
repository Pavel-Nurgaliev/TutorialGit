Private Property Get UBSChild_ActualParameter() As Variant

End Property

Private Property Get UBSChild_Height() As Integer
     UBSChild_Height = 4455
End Property

Private Property Let UBSChild_HeightBrowser(ByVal RHS As Variant)
If RHS < 4455 Then RHS = 4455
End Property

Private Property Get UBSChild_ImageList(Key As String) As Object
    Key = "CARD"
End Property

Private Property Get UBSChild_IsExistParam(ByVal NameParam As String) As Boolean
    UBSChild_IsExistParam = objFormParam.ExistParameter(NameParam)
End Property

Private Sub UBSChild_NotifyCloseWindow(ByVal NumWindow As Integer)
    If NumParentWindow <> 0 And NumParentWindow = NumWindow Then
        bParentWindowClose = True
        'Если закрываемое окно - родительское и оно не пришпилено вызвать процедуру закрытия окна
        btnExit_Click()
    End If

End Sub

Private Sub UBSChild_NotifyFixWindow(ByVal NumWindow As Variant, ByVal FixState As Boolean)


    If NumWindow = NumWin And FixState Then
        'Если пришпиливают наше окно
        NumParentWindow = 0
    End If
End Sub
Private Property Let UBSChild_NumWindow(ByVal RHS As Integer)
     NumWin = RHS
End Property

Private Property Let UBSChild_ParamInfo(ByVal NameParam As String, ByVal RHS As Variant)
Dim ItemArray As Variant

On Error GoTo errorCode

If Not objFormParam.ExistParameter(NameParam) Then
objErr.UbsErrRaise "Проверка поддержки параметров",
            "Параметер '" & NameParam & "' не поддерживается"
      End If

If NameParam = "InitParamForm" Then
Initialize
NumParentWindow = RHS(0)
ItemArray = RHS(1)
StrCommand = RHS(2)
If Not IsEmpty(ItemArray) Then
idOper = ItemArray(0)
Else
MsgBox "Список ценностей пуст.", vbCritical, "Новая операция"
          Parent.CloseWindow NumWin
          Exit Property
End If

UbsChannel.Run "CheckCash", objParamIn, objParamOut
        If objParamOut.Parameter("Error") <> "" Then
         MsgBox objParamOut.Parameter("Error"), vbCritical, "Новая операция"
         Parent.CloseWindow NumWin
         Exit Property
End If
initedDoc = False
initDoc
If initedDoc = False Then Exit Property
        Parent.WindowDraw(NumWin) = True
objInterfaces.NextCtrl
objInterfaces.PrevCtrl
If valMinusCB.Enabled Then
valMinusCB.SetFocus
Else
payMoney.SetFocus
End If
End If

If NameParam = "SetFocus" Then
If Not objFocusCtrl Is Nothing Then
objFocusCtrl.SetFocus
End If
End If



Exit Property

errorCode:
objErr.UbsErrMsg "UBSChild_ParamInfo", "ошибка выполнения"
    If CheckParamForClose(NameParam) Then
btnExit_Click
End If

End Property

Private Property Get UBSChild_ParamInfo(ByVal NameParam As String) As Variant
If NameParam = "WaitShow" Then
UBSChild_ParamInfo = True
End If
End Property

Private Property Let UBSChild_Parrent(ByVal RHS As Object)
    Set Parent = RHS
End Property

Private Property Let UBSChild_RunParameter(ByVal RHS As String)

End Property
Private Function CheckParamForClose(ByVal NameParam As String) As Boolean
    CheckParamForClose = False
    If NameParam = "LoadFromMenu" Or
        NameParam = "InitParamForm" Or
        NameParam = "InitParamGrid" Then
        CheckParamForClose = True
    End If
End Function


Private Property Get UBSChild_Sizable() As Boolean
      UBSChild_Sizable = True
End Property

Private Property Get UBSChild_TitleWindow() As String
    UBSChild_TitleWindow = "Операция возмещения"
End Property

Private Property Get UBSChild_Width() As Integer
    UBSChild_Width = 6735
End Property

Private Property Let UBSChild_WidthBrowser(ByVal RHS As Variant)

If RHS < 6735 Then RHS = 6735
'    Info.Width = RHS - 2685
    
End Property

Private Sub ArrayParam()
    objFormParam.Parameter("WaitShow") = True
    objFormParam.Parameter("InitParamForm") = True
    objFormParam.Parameter("SetFocus") = True
    objFormParam.Parameter("LostFocus") = True
    objFormParam.Parameter("RetFromGrid") = True
End Sub

Private Sub SaveBtn_Click()

    On Error GoTo errorCode
    UbsDDX.UpdateData True
   Dim RSChange As Variant, i As Integer
    If Not Check() Then Exit Sub
    UbsDDX.MembersValue RSChange

    Dim resSQL As Variant, name As String

    objParamIn.clearParameters
    objParamIn.Parameters = RSChange

    If valMinusCB.ListIndex <> -1 Then objParamIn.Parameter("Валюта выданная") = valMinusCB.ItemData(valMinusCB.ListIndex) Else objParamIn.Parameter("Валюта выданная") = 0
    If valComis.ListIndex <> -1 Then objParamIn.Parameter("Валюта комиссии") = valComis.ItemData(valComis.ListIndex)
    objParamIn.Parameter("Валюта принятая") = 0
    objParamIn.Parameter("Сумма принятая") = 0
    objParamIn.Parameter("Платежный документ") = 0

    If payMoney.Value = 0 Then
        objParamIn.Parameter("Валюта выданная") = CInt(valNom.Text)
        objParamIn.Parameter("Сумма выданная") = nomPDoc.CurrencyValue
        objParamIn.Parameter("Платежный документ") = idPayDoc
    End If


    objParamIn.Parameter("Номер квитанции(справки)") = idFOper
    'MsgBox objParamIn.Parameter("Номер квитанции(справки)")
    For i = 0 To UBound(operArr, 2)
        If sidOper = "INCASH" And operArr(2, i) = "INCASH_RET" Then
            objParamIn.Parameter("SID операции") = "INCASH_RET"
            objParamIn.Parameter("Операция") = operArr(0, i)
        End If
        If sidOper = "INCASH_PAYDOC" And operArr(2, i) = "INCASH_RET_PAYDOC" Then
            objParamIn.Parameter("SID операции") = "INCASH_RET_PAYDOC"
            objParamIn.Parameter("Операция") = operArr(0, i)
        End If

        If sidOper = "EXPERT" And operArr(2, i) = "EXPERT_RET" Then
            objParamIn.Parameter("SID операции") = "EXPERT_RET"
            objParamIn.Parameter("Операция") = operArr(0, i)

        End If
        If sidOper = "EXPERT_PAYDOC" And operArr(2, i) = "EXPERT_RET_PAYDOC" Then
            objParamIn.Parameter("SID операции") = "EXPERT_RET_PAYDOC"
            objParamIn.Parameter("Операция") = operArr(0, i)
        End If
    Next

    objParamIn.Parameter("idClient") = selectedClient
    UbsChannel.Run "Save", objParamIn, objParamOut
    UbsDDX.SetInitMemberData

    If objParamOut.Parameter("Error") <> "" Then
        MsgBox objParamOut.Parameter("Error"), vbExclamation, "Операция с платежными документами"
    Else
        bNeedRefreshGrid = True
        Info.Caption = "Данные сохранены!"
        Info.Show
        ' initDoc
        valMinusCB.SetFocus
        SaveBtn.Enabled = False
    End If

    Exit Sub
errorCode:
    objErr.UbsErrMsg "SaveBtn_Click", "ошибка выполнения"
End Sub

Private Sub UserDocument_Hide()
    On Error GoTo errorCode
  
    Set objErr = Nothing
    Set objInterfaces = Nothing
    Set objFormParam = Nothing
    Set objFocusCtrl = Nothing
    Set objParamIn = Nothing
    Set objParamOut = Nothing

    If Not bParentWindowClose And Parent.IsExistParam(NumParentWindow, "NeedRefreshGrid") = True Then
        Parent.ParamInfo(NumParentWindow, "NeedRefreshGrid") = bNeedRefreshGrid
    End If
    UbsDDX.ReleaseControlData
    Exit Sub
errorCode:
    objErr.UbsErrMsg "UserDocument_Hide", "ошибка выполнения"
End Sub

Private Sub UserDocument_Initialize()
    Set objFormParam = CreateObject("ToolPubs.IUbsParam")
     ArrayParam()
End Sub

Private Sub Initialize()
    Set objErr = CreateObject("ToolPubs.IUbsError")
    Set objInterfaces = CreateObject("ToolPubs.Interfaces")
    Set objParamIn = CreateObject("ToolPubs.IUbsParam")
    Set objParamOut = CreateObject("ToolPubs.IUbsParam")
    UbsChannel.HostAddress = Parent.LoaderParamInfo(NumWin, "HostAddress")
    UbsChannel.UserGUID = Parent.LoaderParamInfo(NumWin, "GuidSession")
    UbsChannel.ParentHwnd = UserDocument.hWnd
    UbsChannel.LoadResource = "VBS:UBS_VBS\OP\opers.vbs"
End Sub

Private Sub initDoc()
    On Error GoTo errorCode
    UbsDDX.InitControlData

    Dim i As Integer, docArr, pArr, errStr As String
    errStr = ""

    objParamIn.Parameter("Тип операции") = "ret"
    objParamIn.Parameter("initedDoc") = initedDoc
    objParamIn.Parameter("Id операции") = idOper
    'MsgBox objParamIn.Parameter("initedDoc")
    UbsChannel.Run "InitForm", objParamIn, objParamOut

  errStr = objParamOut.Parameter("Error")
    If errStr <> "" Then
        MsgBox errStr, vbExclamation, "Возврат(возмещение)"

          btnExit_Click()
        Exit Sub
    End If

    If objParamOut.ExistParameter("Список операций") Then operArr = objParamOut.Parameter("Список операций")
    sidOper = objParamOut.Parameter("SID операции")
    idFOper = objParamOut.Parameter("Id операции")
    idPayDoc = objParamOut.Parameter("Id ценности")
    selectedClient = objParamOut.Parameter("Id клиента")
    If sidOper = "EXPERT_PAYDOC" Then
        payMoney.Enabled = True
        payMoney.Value = 0
        valMinusCB.Enabled = False
    Else
        payMoney.Enabled = False
        payMoney.Value = 1
    End If

    If objParamOut.ExistParameter("Список документов") Then
        docArr = objParamOut.Parameter("Список документов")
        If IsArray(docArr) Then
            For i = 0 To UBound(docArr, 2)
                docCB.AddItem docArr(1, i)
  '   docCB.ItemData(i) = docArr(0, i)
            Next
        End If
    End If

    If objParamOut.ExistParameter("Список валют") Then
        valArr = objParamOut.Parameter("Список валют")
        If IsArray(valArr) Then
            For i = 0 To UBound(valArr, 2)
                valMinusCB.AddItem valArr(2, i)
    valMinusCB.ItemData(i) = valArr(0, i)
                valComis.AddItem valArr(2, i)
    valComis.ItemData(i) = valArr(0, i)
            Next
        End If
    End If

    UbsDDX.InitMemberData(clientTxt) = ""
    UbsDDX.InitMemberData(serTxt) = "XXX"
    UbsDDX.InitMemberData(numTxt) = "XXX"
    'UbsDDX.InitMemberData(sprNumCur) = objParamOut.Parameter("Номер справки")
    'UbsDDX.InitMemberData(sprSerTxt) = objParamOut.Parameter("Серия справки")
    UbsDDX.InitMemberData(docCB) = ""
    UbsDDX.InitMemberData(resCHB) = 1
    UbsDDX.InitMemberData(rateCur) = 1
    UbsDDX.InitMemberData(NU) = 1
    UbsDDX.InitMemberData(valMinusCB) = -1
    pArr = objParamOut.Parameters
    If IsArray(pArr) Then
        For i = 0 To UBound(pArr, 2)
            If InStr(pArr(0, i), "Список") = 0 And pArr(0, i) <> "Подоходный налог" Then
                'MsgBox pArr(0, i)
                UbsDDX.InitMemberData(pArr(0, i)) = pArr(1, i)
            End If
        Next
    End If


    initedDoc = True
    UbsDDX.UpdateData False
Exit Sub
errorCode:
    objErr.UbsErrMsg "InitDoc", "ошибка выполнения"

End Sub

Private Sub UserDocument_KeyDown(KeyCode As Integer, Shift As Integer)
    If Shift = 2 And KeyCode = vbKeyTab Then
                Set objFocusCtrl = UserDocument.ActiveControl
                Parent.LoaderParamInfo(0, "NextWindow") = NumWin
    End If
End Sub

Private Sub UserDocument_KeyPress(KeyAscii As Integer)
    Select Case (KeyAscii)
        Case 13                              'Enter
            KeyAscii = 0
            objInterfaces.NextCtrl        'SendKeys "{TAB}"
        Case 27                              'Esc
            KeyAscii = 0
            objInterfaces.PrevCtrl        'SendKeys "+{TAB}"
    End Select
End Sub


Function Check()

    Check = False


    If valMinusCB.ListIndex = -1 And payMoney.Value <> 0 Then
        MsgBox "Выберите валюту.", vbExclamation, "Сохранение операции"
  valMinusCB.SetFocus
        Exit Function
    End If

    Check = True
End Function





Private Sub valMinusCB_Click()
    On Error GoTo errorCode
    Dim i As Integer
    If valMinusCB.ListIndex = -1 Then Exit Sub


    objParamIn.Parameter("idPov") = idPov
    objParamIn.Parameter("SID Операции") = "BUY"
    objParamIn.Parameter("Валюта принятая") = CInt(valNom.Text)
    objParamIn.Parameter("Валюта выданная") = valMinusCB.ItemData(valMinusCB.ListIndex)
    objParamIn.Parameter("Платежный документ") = idPayDoc


    For i = 0 To UBound(operArr, 2)
        If sidOper = "INCASH" And operArr(2, i) = "INCASH_RET" Then
            objParamIn.Parameter("SID операции") = "INCASH_RET"
            objParamIn.Parameter("Операция") = operArr(0, i)
        End If
        If sidOper = "INCASH_PAYDOC" And operArr(2, i) = "INCASH_RET_PAYDOC" Then
            objParamIn.Parameter("SID операции") = "INCASH_RET"
            objParamIn.Parameter("Операция") = operArr(0, i)
        End If

        If sidOper = "EXPERT" And operArr(2, i) = "EXPERT_RET" Then
            objParamIn.Parameter("SID операции") = "EXPERT_RET"
            objParamIn.Parameter("Операция") = operArr(0, i)

        End If
        If sidOper = "EXPERT_PAYDOC" And operArr(2, i) = "EXPERT_RET_PAYDOC" Then
            objParamIn.Parameter("SID операции") = "EXPERT_RET_PAYDOC"
            objParamIn.Parameter("Операция") = operArr(0, i)
        End If
    Next

    UbsChannel.Run "GetOperParam", objParamIn, objParamOut

 sumKom = objParamOut.Parameter("Комиссия")
    isKomCur = objParamOut.Parameter("Комиссия в валюте")
    isKomPer = objParamOut.Parameter("Комиссия в процентах")

    If isKomCur = False Then
        objInterfaces.SetFocusCombo valComis, 810
 Else
        ' 'MsgBox operArr(0, operCB.ListIndex)
        '   If operArr(2, operCB.ListIndex) = "BUY" Or operArr(2, operCB.ListIndex) = "INCASH" Or operArr(2, operCB.ListIndex) = "EXPERT" Then
        '     objInterfaces.setFocusCombo valComiss, valPlusCB.ItemData(valPlusCB.ListIndex)
        '   Else
        objInterfaces.SetFocusCombo valComis, valMinusCB.ItemData(valMinusCB.ListIndex)
'   End If
    End If

    If isKomPer = False Then
        komCur.CurrencyValue = sumKom
    End If

    If objParamOut.ExistParameter("Курс") Then
        rateCur.CurrencyValue = objParamOut.Parameter("Курс")
        NU.CurrencyValue = objParamOut.Parameter("Курс за(единиц)")
    Else
        NU.CurrencyValue = 1
        rateCur.CurrencyValue = 1
    End If

    If objParamOut.ExistParameter("Курс") Then
        rateCur.CurrencyValue = objParamOut.Parameter("Курс")
        NU.CurrencyValue = objParamOut.Parameter("Курс за(единиц)")
        NU_TextChange()
        NU.Text = NU.Text
    Else
        rateCur.CurrencyValue = 1
        NU.CurrencyValue = 1
    End If
    'If operArr(2, operCB.ListIndex) = "BUY_PAYDOC" Then
    'sumMinusCur.CurrencyValue = rateCur.CurrencyValue * sumPlusCur.CurrencyValue
    'ElseIf operArr(2, operCB.ListIndex) = "SALE_PAYDOC" Then
    ''  If sumMinusCur.CurrencyValue <> 0 Then sumPlusCur.CurrencyValue = rateCur.CurrencyValue * sumMinusCur.CurrencyValue
    'End If
    Exit Sub
errorCode:
    objErr.UbsErrMsg "valPlusCB_Click", "ошибка выполнения"

End Sub

