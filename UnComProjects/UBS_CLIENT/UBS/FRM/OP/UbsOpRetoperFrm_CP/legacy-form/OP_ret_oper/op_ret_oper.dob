Attribute VB_Name = "OP_ret_oper_ud"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = True
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = True
Option Explicit On
Implements UBSChild
Dim NumWin As Integer, NumParentWindow As Integer, numChildWin As Integer
Dim Parent As UBSParrent
Dim selectedClient As Long
Dim StrCommand As String
Dim objErr As Object, objInterfaces As Object
Dim operArr As Variant, valArr As Variant
Dim sidOper As String
Dim idPayDoc As Integer, idPov As Integer
Dim idFOper
Dim objFormParam As Object
Dim bNeedRefreshGrid As Boolean, bParentWindowClose As Boolean
Dim objFocusCtrl As Object
Dim isKomPer As Boolean, isKomCur As Boolean, isBlank As Boolean, serBlank, numBlank
Dim sumKom As Currency
Dim initedDoc As Boolean
Dim idOper As Long
Dim objParamIn As Object, objParamOut As Object


Private Sub btnExit_Click()
    Parent.CloseWindow NumWin
End Sub


Private Sub NU_TextChange()
    ' MsgBox "!"
    sumMinusCur.CurrencyValue = nomPDoc.CurrencyValue * rateCur.CurrencyValue / NU.CurrencyValue
    If isKomPer Then
        If valMinusCB.ItemData(valMinusCB.ListIndex) = 810 And isKomCur = False Or valMinusCB.ItemData(valMinusCB.ListIndex) <> 810 And isKomCur = True Then
            komCur.CurrencyValue = sumMinusCur.CurrencyValue * sumKom / 100
        End If
    End If
End Sub

Private Sub payMoney_Click()
    If payMoney.Value = 0 Then
        valMinusCB.Enabled = False
        objInterfaces.SetFocusCombo valMinusCB, nomPDoc.CurrencyValue
' podNalCur.CurrencyValue = nomPDoc.CurrencyValue
        sumMinusCur.CurrencyValue = 0
    Else
        valMinusCB.Enabled = True
    End If
End Sub

Private Sub rateCur_TextChange()
    NU_TextChange()
End Sub







