Private Property Let UBSChild_ParamInfo(ByVal NameParam As String, ByVal RHS As Variant)
On Error GoTo ErrorCode

Dim ItemArray As Variant
Dim IdObject As Long
Dim ArrRez As Variant
Dim intPos As Integer

If Not objFormParam.ExistParameter(NameParam) Then
objError.UbsErrRaise "Проверка поддержки параметров",
                "Параметер '" & NameParam & "' не поддерживаетcя"
    End If

If NameParam = "InitParamForm" Then
blnSetFocus = False
NumParentWindow = RHS(0)
RSIdent = RHS(1)
strRunParam = RHS(2)

If strRunParam <> "EDIT" Then
intPos = InStr(1, strRunParam, "#")
intVidTrade = Mid(strRunParam, intPos + 1, 1)
End If

If IsEmpty(RHS(1)) And strRunParam = "EDIT" Then ' если с пустой формы вызываем на редактирование
MsgBox "Не выбрана запись для редактирования", vbCritical + vbOKOnly, "Ошибка"
           cmdExit_Click
Exit Property
End If

UserDocument_Initialize
DDX.InitControlData
InitChannel
InitDoc
IParent.WindowDraw(Numwin) = True
objInterfaces.NextCtrl
objInterfaces.PrevCtrl
' в связи с возможным НЕРЕДАКТИРОВАНИЕМ СДЕЛКИ
If strRunParam = "EDIT" Then
If blnWasOper Then
cmdExit.SetFocus
Else
txtTradeDate.SetFocus
blnSetFocus = True
End If
Else
txtTradeDate.SetFocus
End If
'-----------------------------------------------------

End If

If NameParam = "SetFocus" Then
If Not objFocusCtrl Is Nothing And Not SSTabs Is Nothing Then
If intFocusTab = SSTabs.SelectedTab.Index Then
objFocusCtrl.SetFocus
End If
End If
End If


If NameParam = "LostFocus" Then
If Not UserDocument.ActiveControl Is Nothing Then Set objFocusCtrl = UserDocument.ActiveControl
        If Not UserDocument.ActiveControl Is Nothing And Not SSTabs Is Nothing Then intFocusTab = SSTabs.SelectedTab.Index
    End If


If Not objFormParam.ExistParameter(NameParam) Then
objError.UbsErrRaise "Проверка поддержки параметров",
            "Параметер '" & NameParam & "' не поддерживается"
    End If

' ---------------------------------------------
' Работа со списком
If NameParam = "RetFromGrid" Then

'продавец
If NumChildWinContract1 = RHS(0) Then
ItemArray = RHS(1)
If Not IsEmpty(ItemArray) Then
DDX.MemberData("Продавец") = ItemArray(0)
Else
MsgBox "Не выбрано записи для добавления.", vbCritical + vbOKOnly, "Ошибка"
                Exit Property
End If

' получить данные контракта
Call FillControlContract(DDX.MemberData("Продавец"), txtContractCode1, txtClientName1, IdClient1)

IdComission1 = objParamOut.Parameter("Идентификатор комиссии")

'идентификатор комисии
If cmbContractType1.ItemData(cmbContractType1.ListIndex) = 1 And
                cmbContractType2.ItemData(cmbContractType2.ListIndex) <> 1 Then

For n = 0 To cmbComission.ListCount - 1
If cmbComission.ItemData(n) = IdComission1 Then
cmbComission.ListIndex = n
End If
Next
Else
cmbComission.ListIndex = -1
End If
'--------------------------------
IParent.CloseWindow NumChildWinContract1
            IParent.SetFocusToWindow Numwin
            objInterfaces.NextCtrl
End If

'покупатель
If NumChildWinContract2 = RHS(0) Then
ItemArray = RHS(1)
If Not IsEmpty(ItemArray) Then
DDX.MemberData("Покупатель") = ItemArray(0)
Else
MsgBox "Не выбрано записи для добавления.", vbCritical + vbOKOnly, "Ошибка"
                Exit Property
End If

' получить данные контракта
Call FillControlContract(DDX.MemberData("Покупатель"), txtContractCode2, txtClientName2, IdClient2)

IdComission2 = objParamOut.Parameter("Идентификатор комиссии")

'идентификатор комисии
If cmbContractType2.ItemData(cmbContractType2.ListIndex) = 1 And
                    cmbContractType1.ItemData(cmbContractType1.ListIndex) <> 1 Then

For n = 0 To cmbComission.ListCount - 1
If cmbComission.ItemData(n) = IdComission2 Then
cmbComission.ListIndex = n
End If
Next
Else
cmbComission.ListIndex = -1
End If
UpdateDisplayNDS
UpdateDisplayExport
'--------------------------------
IParent.CloseWindow NumChildWinContract2
            IParent.SetFocusToWindow Numwin
            objInterfaces.NextCtrl
End If

'хранилище
If NumChildWinStorage = RHS(0) Then
ItemArray = RHS(1)
If Not IsEmpty(ItemArray) Then
DDX.MemberData("Инструкция по поставке") = ItemArray(0)
'-------------------------------------------------------
Else
MsgBox "Не выбрано записи для добавления.", vbCritical + vbOKOnly, "Ошибка"
                Exit Property
End If

' получить данные хранилища
Call FillControlStorage
'--------------------------------
IParent.CloseWindow NumChildWinStorage
            IParent.SetFocusToWindow Numwin
            objInterfaces.NextCtrl
End If

'объект
If NumChildWinObject = RHS(0) Then
ItemArray = RHS(1)
If Not IsEmpty(ItemArray) Then
IdObject = ItemArray(0)
Else
MsgBox "Не выбрано записи для добавления.", vbCritical + vbOKOnly, "Ошибка"
                Exit Property
End If
Dim blnFill As Boolean
If FillDataObject(IdObject) Then
'lstViewObject.SetFocus
'--------------------------------
IParent.CloseWindow NumChildWinObject
               IParent.SetFocusToWindow Numwin
               objInterfaces.NextCtrl
End If
End If

'расчетный счет
If NumChildWinAccount = RHS(0) Then
ItemArray = RHS(1)
If Not IsEmpty(ItemArray) Then
IdAccount = ItemArray(0)
Else
MsgBox "Не выбрано записи для добавления.", vbCritical + vbOKOnly, "Ошибка"
                Exit Property
End If

' получить наименование расчетного счета
objParamIn.ClearParameters
objParamOut.ClearParameters
objParamIn.Parameter("IdAccount") = IdAccount
UbsChannel1.Run "TradeGetAccountPM", objParamIn, objParamOut
            txtRS(intTabAcc).Text = objParamOut.Parameter("Account Name")
'--------------------------------
IParent.CloseWindow NumChildWinAccount
            IParent.SetFocusToWindow Numwin
            objInterfaces.NextCtrl
End If
End If
' Конец работы со списком
' ---------------------------------------------

Exit Property

ErrorCode:
objError.UbsErrMsg "UBSChild_ParamInfo", "ошибка выполнения"

    If CheckParamForClose(NameParam) Then
cmdExit_Click
End If

End Property

