Private Sub cmdListInstr_Click(Index As Integer)
    On Error GoTo ErrorCode

    If Index = 0 Then ' нужны инструкции по покупателю
        ClearOpl(0)
        If Len(Trim(txtContractCode2.Text)) = 0 Or Trim(txtContractCode2.Text) = "банк" Then
            MsgBox "Заполните данные о покупателе", vbExclamation + vbOKOnly, "Ошибка ввода"
      SSTabs.Tabs(1).Selected = True
            cmdContract2.SetFocus
            Exit Sub
        End If
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("ID_CONTRACT") = DDX.MemberData("Покупатель")
        UbsChannel1.Run "TradeFillInstr", objParamIn, objParamOut
   Call StartDialog(0)
    ElseIf Index = 1 Then ' нужны инструкции по продавцу
        ClearOpl(1)
        If Len(Trim(txtContractCode1.Text)) = 0 Or Trim(txtContractCode1.Text) = "банк" Then
            MsgBox "Заполните данные о продавце", vbExclamation + vbOKOnly, "Ошибка ввода"
      SSTabs.Tabs(1).Selected = True
            cmdContract1.SetFocus
            Exit Sub
        End If
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("ID_CONTRACT") = DDX.MemberData("Продавец")
        UbsChannel1.Run "TradeFillInstr", objParamIn, objParamOut
   Call StartDialog(1)
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmdListInstr_Click", "ошибка выполнения"

End Sub

Private Sub cmdSave_Click()
    On Error GoTo ErrorCode

    Dim blnRun
    Dim ArrChanged As Variant
    Dim arrOblig As Variant
    Dim varDataOpl

    blnRun = False

    DDX.UpdateData(True)

    If Not CheckData() Then Exit Sub
    If Not CheckDatesOblig() Then Exit Sub

    objParamIn.ClearParameters
    objParamOut.ClearParameters

    If strRunParam = "EDIT" Then
        objParamIn.Parameter("ID_TRADE") = DDX.MemberData("ID_TRADE")
    Else
        objParamIn.Parameter("ID_TRADE") = 0
    End If

    ' нам нужно передать массив инструкции по оплате
    If SSActiveTabs1.Tabs(1).Visible = True Then
        ' Данные из контролов Инструкции по Оплате в массив
        Call FillArrDataInstr(0, varDataOpl)
        objParamIn.Parameter("Инструкция по оплате для покупателя") = varDataOpl
    End If
    ' и второй массив инструкции по оплате
    If SSActiveTabs1.Tabs(2).Visible = True Then
        Call FillArrDataInstr(1, varDataOpl)
        objParamIn.Parameter("Инструкция по оплате для продавца") = varDataOpl
    End If
    objParamIn.Parameter("IsNDS") = chkNDS.Value
    objParamIn.Parameter("IsExport") = chkExport.Value
    '6060
    objParamIn.Parameter("IsExternalStorage") = chkExternalStorage.Value



    '-----------------------------------------------
    'изменение основных полей
    If DDX.IsChange Then
        DDX.ChangeMembersValue ArrChanged
        objParamTrade.Parameters = ArrChanged
        If objParamTrade.ExistParameter("Идентификатор валюты оплаты") Then
            objParamTrade.Parameter("Идентификатор валюты оплаты") = cmbCurrencyOpl.ItemData(cmbCurrencyOpl.ListIndex)
        End If
        If objParamTrade.ExistParameter("Идентификатор драг.металла") Then
            objParamTrade.Parameter("Идентификатор драг.металла") = cmbCurrencyPost.ItemData(cmbCurrencyPost.ListIndex)
        End If
        If objParamTrade.ExistParameter("Вид поставки по сделке") Then
            objParamTrade.Parameter("Вид поставки по сделке") = cmbKindSupplyTrade.Text
        End If
        If objParamTrade.ExistParameter("Идентификатор комиссии") Then
            If Not cmbComission.ListIndex = -1 Then
                objParamTrade.Parameter("Идентификатор комиссии") = cmbComission.ItemData(cmbComission.ListIndex)
            Else
                objParamTrade.Parameter("Идентификатор комиссии") = 0
            End If
        End If
        objParamIn.Parameter("Основные данные") = objParamTrade

        blnRun = True
    End If

    'изменение списка обязательств
    If bNeedSendOblig Then
        blnRun = True

        objParamIn.Parameter("ID_CLIENT1") = IdClient1
        objParamIn.Parameter("ID_CLIENT2") = IdClient2

        FillArrOblig arrOblig 'заполняем массив обязательств
        objParamIn.Parameter("Обязательства сделки") = arrOblig
        objParamIn.Parameter("Обязательства сделки2") = objParamOblig

    End If

    'изменение доп.полей
    If blnAddFlChanged And strRunParam = "EDIT" Then
        blnRun = True
    End If

    If blnRun Then
        UbsChannel1.Run "ModifyTrade", objParamIn, objParamOut
        If objParamOut.ExistParameter("Ошибка") Then
            MsgBox objParamOut.Parameter("Ошибка"), vbExclamation + vbOKOnly, "Ошибка ввода"
        Else
            DDX.MemberData("ID_TRADE") = objParamOut.Parameter("ID_TRADE")
            strRunParam = "EDIT"

            blnNeedRefresh = True
            blnNeedSelect = True
            blnCloseForm = True
            blnAddFlChanged = False
            Info.Caption = "Данные сохранены"
            Info.Visible = True
            Info.Show
            DDX.SetInitMemberData
        End If
    End If

    If blnCloseForm Then
        IParent.CloseWindow Numwin
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmdSave_Click", "ошибка выполнения"

End Sub

Private Sub cmdExit_Click()
    On Error GoTo ErrorCode

    IParent.CloseWindow Numwin

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmdExit_Click", "ошибка выполнения"

End Sub

Private Sub SSTabs_BeforeTabClick(ByVal NewTab As ActiveTabs.SSTab, ByVal Cancel As ActiveTabs.SSReturnBoolean)
    On Error GoTo ErrorCode

    If cmbContractType1.ItemData(cmbContractType1.ListIndex) =
        cmbContractType2.ItemData(cmbContractType2.ListIndex) Then
        MsgBox "Тип договора покупателя и продавца не может совпадать", vbOKOnly + vbCritical, "Проверка свойств"
        cmbContractType1.SetFocus
        Cancel = True
        Exit Sub
    End If

    If NewTab.Index = 2 Then 'переход на вкладку "Обязательства"
        If txtTradeDate.DateValue = #1/1/2222# Or Not txtTradeDate.IsValid Then
            MsgBox "Не указана дата сделки", vbOKOnly + vbCritical, "Проверка свойств"
            If SSTabs.Tabs(1).Selected Then txtTradeDate.SetFocus
            Cancel = True
            Exit Sub
        End If

        If cmbCurrencyPost.ListIndex = -1 Then 'драг.металл не выбран
            MsgBox "Не выбран драг.металл.", vbOKOnly + vbCritical, "Проверка свойств"
            cmbCurrencyPost.SetFocus
            Cancel = True
            Exit Sub
        End If

        If IsEmpty(DDX.MemberData("Покупатель")) Then
            MsgBox "Не выбран покупатель", vbExclamation + vbOKOnly, "Ошибка ввода"
            If cmdContract2.Enabled Then
                cmdContract2.SetFocus
            ElseIf cmbContractType2.Enabled Then
                cmbContractType2.SetFocus
            End If
            Cancel = True
            Exit Sub
        End If

        If cmbKindSupplyTrade.ListIndex = -1 Then
            MsgBox "Не выбран вид поставки по сделке", vbExclamation + vbOKOnly, "Ошибка ввода"
            cmbKindSupplyTrade.SetFocus
            Cancel = True
            Exit Sub
        End If

        If cmbKindSupplyTrade.Text = "физическая" Then
            cmbUnit.ListIndex = 0
            cmbUnit.Enabled = False
            txtMassa.Enabled = False
        ElseIf cmbKindSupplyTrade.Text = "обезличенная" Then
            txtMassa.Enabled = True
            cmbUnit.Enabled = True
        End If
    End If

    If NewTab.Index = 3 Then 'переход на вкладку "Данные"
        If lstViewOblig.ListItems.Count <> 0 Then
            cmdSave.Visible = False
            cmdExit.Visible = False

            If Not blnAddOblig And Not blnEditOblig Then 'переход в режиме просмотра
                cmdApplayOblig.Visible = False
                cmdExitOblig.Visible = False

                'все контролы на вкладке disabled
                Call EnableWindow(SSTabs1Panel1.hwnd, 0&)
                Call EnableWindow(SSTabs1Panel4.hwnd, 0&)

                cmdAddObject.Enabled = False
                cmdDelObject.Enabled = False

                SSTabs1.Tabs(1).Selected = True 'переход на вкладку "Обязательство"

                'заполнение данных обязательства
                StrNumInPart = lstViewOblig.SelectedItem.SubItems(1)
                sType = "Edit"
                CallOblig sType
        Else 'режим Add или Edit
                cmdApplayOblig.Visible = True
                cmdExitOblig.Visible = True

                'контролы на вкладке enabled
                Call EnableWindow(SSTabs1Panel1.hwnd, 1&)
                Call EnableWindow(SSTabs1Panel4.hwnd, 1&)

                If cmbKindSupplyTrade.Text = "физическая" Then
                    cmdAddObject.Enabled = True
                    cmdDelObject.Enabled = True
                End If
            End If
        End If
    Else 'переход на какую-нибудь другую вкладку, кроме "Данные"
        cmdSave.Visible = True
        cmdExit.Visible = True
    End If

    If cmbContractType1.ItemData(cmbContractType1.ListIndex) = 0 Then
        If Not CBool(SSActiveTabs1.Tabs(1).Visible) Then SSActiveTabs1.Tabs(1).Visible = True
        SSActiveTabs1.Tabs(1).Selected = True
        If CBool(SSActiveTabs1.Tabs(2).Visible) Then SSActiveTabs1.Tabs(2).Visible = False
    ElseIf cmbContractType2.ItemData(cmbContractType2.ListIndex) = 0 Then
        If Not CBool(SSActiveTabs1.Tabs(2).Visible) Then SSActiveTabs1.Tabs(2).Visible = True
        SSActiveTabs1.Tabs(2).Selected = True
        If CBool(SSActiveTabs1.Tabs(1).Visible) Then SSActiveTabs1.Tabs(1).Visible = False
    Else
        If Not CBool(SSActiveTabs1.Tabs(1).Visible) Then SSActiveTabs1.Tabs(1).Visible = True
        If Not CBool(SSActiveTabs1.Tabs(2).Visible) Then SSActiveTabs1.Tabs(2).Visible = True
        SSActiveTabs1.Tabs(1).Selected = True
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "SSTabs_BeforeTabClick", "ошибка выполнения"

End Sub

Private Sub SSTabs1_BeforeTabClick(ByVal NewTab As ActiveTabs.SSTab, ByVal Cancel As ActiveTabs.SSReturnBoolean)
    On Error GoTo ErrorCode

    If NewTab.Index = 4 Then 'переход на вкладку "Объекты"
        'заполняем данные по обязательству
        lblObligInfo1.Caption = "Дата оплаты: " & txtDateOpl.Text & Space(3) &
            "Дата поставки: " & txtDatePost.Text

        lblObligInfo2.Caption = "Цена: " & txtCostUnit.CurrencyValue & Space(3) &
            "Масса: " & txtMassa.Text & Space(3) &
            "Сумма: " & txtSumOpl.Text
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "SSTabs1_BeforeTabClick", "ошибка выполнения"

End Sub

Private Sub txtMassa_LostFocus()
    On Error GoTo ErrorCode
    '-------------------------------------------------------------------------
    GetMassaGramm() ' масса в граммах
    GetSumOblig()   ' сумма в валюте обязательства = цена за ед. в валюте обязательства * кол-во грамм
    GetSumOpl()     ' сумма в валюте оплаты
    '-------------------------------------------------------------------------
    Exit Sub
ErrorCode:
    objError.UbsErrMsg "txtMassa_LostFocus", "ошибка выполнения"
End Sub

Private Sub txtCostUnit_LostFocus()
    On Error GoTo ErrorCode
    GetSumOblig()

    If chkSumInCurValue.Value = 1 Then ' если вводим сразу Цену в сумме оплаты, то "скачем" от нее
        GetRateCurOblig() ' курс
    Else
        ' Цена за ед. в валюте оплаты = цена за ед. в валюте обязательства * курс
        'txtCostCurOpl.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtRateCurOblig.CurrencyValue, 4)
        txtCostCurOpl.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtRateCurOblig.VariantValue, 4)
    End If
    '----------------------------------------------------
    GetSumOpl()

    Exit Sub
ErrorCode:
    objError.UbsErrMsg "txtCostUnit_LostFocus", "ошибка выполнения"

End Sub


Private Sub txtRateCurOblig_LostFocus()
    On Error GoTo ErrorCode
    ' Цена за ед. в валюте оплаты = цена за ед. в валюте обязательства * курс
    'txtCostCurOpl.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtRateCurOblig.CurrencyValue, 4)
    txtCostCurOpl.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtRateCurOblig.VariantValue, 4)
    GetSumOpl()
    '----------------------------------------------------
    Exit Sub
ErrorCode:
    objError.UbsErrMsg "txtRateCurOblig_LostFocus", "ошибка выполнения"
End Sub

Private Sub txtCostCurOpl_LostFocus()
    On Error GoTo ErrorCode
    GetRateCurOblig() ' Курс = Цена за ед. в валюте оплаты/цена за ед. в валюте обязательства
    ' Сумма в валюте оплаты
    GetSumOpl()
    '----------------------------------------------------
    chkSumInCurValue.Value = 0
    chkRate.Value = 1

    Exit Sub
ErrorCode:
    objError.UbsErrMsg "txtCostCurOpl_LostFocus", "ошибка выполнения"
End Sub

Private Sub txtTradeDate_LostFocus()
    If Not txtTradeDate.IsValid Then
        MsgBox "Введите корректную дату.", vbOKOnly + vbCritical, "Проверка свойств"
       txtTradeDate.SetFocus
        Exit Sub
    End If
    If CheckDatesOblig() Then 'наличные сделки
        DDX.MemberData("DATE_TRADE") = txtTradeDate.DateValue
        If Not Not cmbCurOblig.ListIndex = -1 _
           And Not cmbCurrencyOpl.ListIndex = -1 _
           And Not cmbCurrencyPost.ListIndex = -1 Then
            GetRate_CB()
            GetRateForPM()
        End If
        bNeedSendOblig = True
    End If
    If blnSetFocus Then
        txtTradeDate.SetFocus
        blnSetFocus = False
    End If
End Sub

