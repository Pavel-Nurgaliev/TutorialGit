Private Property Let UBSChild_HeightBrowser(ByVal RHS As Variant)
On Error GoTo ErrorCode

Dim SSTabs_Bottom As Long, SSTabsPanel1_Bottom As Long
Dim SSTabs1_Bottom As Long, SSTabs1Panel1_Bottom As Long
Dim lstViewOblig_Bottom As Long, lstViewObject_Bottom As Long

If RHS < UserDocument.MinHeight Then RHS = UserDocument.MinHeight
        
    SSTabs.Height = RHS - 165
ucpParam.Height = RHS - 1300
cmdExit.Top = RHS - 630
cmdSave.Top = RHS - 630
Info.Top = RHS - 600
'------------------------------------------------------------
SSTabs_Bottom = 105
SSTabsPanel1_Bottom = 30
SSTabs1_Bottom = 570
SSTabs1Panel1_Bottom = 30
lstViewOblig_Bottom = 690
lstViewObject_Bottom = 570
'------------------------------------------------------------
lstViewOblig.Height = RHS - (
    SSTabs.Top + SSTabsPanel1.Top + lstViewOblig.Top +
    SSTabs_Bottom + SSTabsPanel1_Bottom + lstViewOblig_Bottom)
'------------------------------------------------------------
SSTabs1.Height = RHS - (
    SSTabs.Top + SSTabsPanel1.Top + SSTabs1.Top +
    SSTabs_Bottom + SSTabsPanel1_Bottom + SSTabs1_Bottom)
'------------------------------------------------------------
lstViewObject.Height = RHS - (
    SSTabs.Top + SSTabsPanel1.Top + SSTabs1.Top + SSTabs1Panel1.Top +
    lstViewObject.Top +
    SSTabs_Bottom + SSTabsPanel1_Bottom + SSTabs1_Bottom + SSTabs1Panel1_Bottom +
    lstViewObject_Bottom)
'------------------------------------------------------------
cmdApplayOblig.Top = SSTabs1.Height - 120 - cmdApplayOblig.Height
cmdExitOblig.Top = SSTabs1.Height - 120 - cmdExitOblig.Height

cmdAccounts.Top = SSTabs1.Height - cmdApplayOblig.Height
lblAccounts.Top = SSTabs1.Height - cmdApplayOblig.Height + 60

Exit Property

ErrorCode:
objError.UbsErrMsg "UBSChild_HeightBrowser", "ошибка выполнения"

End Property

