Private Sub cmdApplayOblig_Click()
    On Error GoTo ErrorCode

    Dim NumPart As Integer, NumInPart As Integer
    Dim ArrDataInstr As Variant, ArrObject As Variant

    If CheckDataOblig() = False Then
        UserDocument.MousePointer = 0
        Exit Sub
    End If

    blnAddOblig = False
    blnEditOblig = False

    SSTabs1.Tabs(1).Selected = True
    SSTabs.Tabs(3).Enabled = False ' Данные
    SSTabs.Tabs(5).Enabled = True ' Поставка
    SSTabs.Tabs(6).Enabled = True ' Дополнительные
    '----------------------------------------
    SSTabs.Tabs(1).Enabled = True ' Основные
    SSTabs.Tabs(2).Enabled = True ' Обязательства
    SSTabs.Tabs(4).Enabled = True ' Оплата

    SSTabs.Tabs(2).Selected = True

    '============================================================
    'увеличиваем номер в части при сохранении нового обязательства
    'номер в части: 1 цифра - номер части, остальные - номер в части
    If sType = "Add" Then
        NumPart = cmbNaprTrade.ItemData(cmbNaprTrade.ListIndex)
        Select Case NumPart
            Case 1
                DDX.MemberData("Макс.номер в части 1") = DDX.MemberData("Макс.номер в части 1") + 1
                NumInPart = DDX.MemberData("Макс.номер в части 1")
            Case 2
                DDX.MemberData("Макс.номер в части 2") = DDX.MemberData("Макс.номер в части 2") + 1
                NumInPart = DDX.MemberData("Макс.номер в части 2")
        End Select
        StrNumInPart = Trim(CStr(NumPart)) + "." + Trim(CStr(NumInPart))

        objParamOblig.Parameter("Add" & StrNumInPart) = True
    ElseIf sType = "Edit" Then
        If cmbNaprTrade.Text <> strNaprTrade Then
            NumPart = cmbNaprTrade.ItemData(cmbNaprTrade.ListIndex)
            Select Case NumPart
                Case 1
                    DDX.MemberData("Макс.номер в части 1") = DDX.MemberData("Макс.номер в части 1") + 1
                    NumInPart = DDX.MemberData("Макс.номер в части 1")
                Case 2
                    DDX.MemberData("Макс.номер в части 2") = DDX.MemberData("Макс.номер в части 2") + 1
                    NumInPart = DDX.MemberData("Макс.номер в части 2")
            End Select
            StrNumInPart = Trim(CStr(NumPart)) + "." + Trim(CStr(NumInPart))
        Else
            StrNumInPart = lstViewOblig.SelectedItem.SubItems(1)
        End If

        objParamOblig.Parameter("Edit" & StrNumInPart) = True
    End If
    '============================================================
    'сохраняем доп.данные обязательства сделки
    ArrObject = Empty
    FillArrObject ArrObject 'заполнить массив объектов
    objParamOblig.Parameter("Object" + StrNumInPart) = ArrObject
    '============================================================
    bNeedSendOblig = True
    SetResultsListOblig sType

    cmdAddOblig.SetFocus

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmdApplayOblig_Click", "ошибка выполнения"

End Sub

Private Sub cmdDelOblig_Click()
    'удаляем элемент из списка
    On Error GoTo ErrorCode

    Dim StrNumInPartDel As String

    If IsExistOblig() Then
        Set objList = lstViewOblig.SelectedItem
        
        'при удалении обязательства удаляются его доп.данные
        StrNumInPartDel = objList.SubItems(1)

        'objParamOblig.ClearParameter ("Instr" + StrNumInPartDel)
        'objParamOblig.ClearParameter ("Storage" + StrNumInPartDel)
        objParamOblig.ClearParameter("Object" + StrNumInPartDel)

        lstViewOblig.ListItems.Remove(objList.Index)

        objParamOblig.Parameter("Delete" & StrNumInPartDel) = True
    End If
    lstViewOblig.Refresh
    cmdAddOblig.SetFocus
    bNeedSendOblig = True

    If IsExistOblig() Then
        SSTabs.Tabs(3).Enabled = True
    Else
        SSTabs.Tabs(3).Enabled = False
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmdDelOblig_Click", "ошибка выполнения"

End Sub

