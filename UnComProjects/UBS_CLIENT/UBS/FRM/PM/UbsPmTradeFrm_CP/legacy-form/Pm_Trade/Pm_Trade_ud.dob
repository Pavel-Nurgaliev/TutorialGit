Attribute VB_Name = "Pm_Trade_ud"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = True
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = True
Option Explicit On
Implements UBSChild

Private Declare Function EnableWindow Lib "user32" (ByVal hwnd As Long, ByVal fEnable As Long) As Long

Dim IParent As UBSParrent
Dim objError As Object
Dim objFocusCtrl As Object
Dim objParamIn As Object
Dim objParamOut As Object
Dim objInterfaces As Object
Dim objFormParam As Object
Dim objStub As Object
Dim objFormat As Object
Dim objArray As Object
Dim objList As Object
Dim objListObject As Object
Dim objParamOblig As Object 'данные по всем обязательствам сделки
Dim objParamTrade As Object 'основные данные сделки
'-----------------------------
Dim strRunParam As String
Dim sType As String
Dim strOurBIK As String
Dim StrNumInPart As String '1 цифра - номер части, остальные - номер в части
Dim strCurrencyPost As String
Dim strNaprTrade As String
Dim strCB As String
'-----------------------------
Dim bParentWindowClose As Boolean
Dim blnNeedRefresh As Boolean
Dim blnAddFlChanged As Boolean
Dim blnCloseForm As Boolean
Dim blnNeedSelect As Boolean
Dim bNeedSendOblig As Boolean
Dim blnAddOblig As Boolean
Dim blnEditOblig As Boolean
Dim blnConvert As Boolean
Dim blnClearContr1 As Boolean
Dim blnClearContr2 As Boolean
Dim blnClearOblig As Boolean
Dim blnCurrencyPostClick As Boolean
Dim blnCheckType2 As Boolean
Dim blnChangeBuyer As Boolean
Dim blnWasOper As Boolean
Dim blnSetFocus As Boolean
Dim blnAddObject As Boolean
'-----------------------------
Dim RSIdent As Variant
Dim arrCurrency As Variant
'-----------------------------
Dim NumChildWinContract1 As Integer
Dim NumChildWinContract2 As Integer
Dim NumChildWinStorage As Integer
Dim NumChildWinInstr As Integer
Dim NumChildWinObject As Integer
Dim NumChildWinAccount As Integer
Dim NumChildWinAccountsByObligation As Integer
Dim Numwin As Integer
Dim NumParentWindow As Integer
Dim intVidTrade As Integer
Dim intFocusTab As Integer
Dim IdComission1 As Integer
Dim IdComission2 As Integer
Dim intTabAcc As Integer
Dim intSave As Integer
'-----------------------------
Dim IdClient1 As Long
Dim IdClient2 As Long
Dim IdAccount As Long
Dim IdStorage As Long
Dim n As Long
Dim idBaseCurrency As Long

Private Sub chkCash_Click(Index As Integer)

    If CBool(chkCash(Index).Value) Then

        cmdListInstr(Index).Visible = False
        lblCheckInstr(Index).Visible = False

        objParamIn.ClearParameters
        objParamOut.ClearParameters
        UbsChannel1.Run "GetInstructionOplataCash", objParamIn, objParamOut

   Call FillControlInstrOplata(Index, objParamOut.Parameter("Инструкции по оплате для расчета через кассу"))

    Else

        cmdListInstr(Index).Visible = True
        lblCheckInstr(Index).Visible = True
        Call ClearOpl(Index)

    End If
End Sub


Private Sub chkIsComposit_Click()
    Dim NumP As Integer, pos As Integer, ArrRez As Variant
    On Error GoTo ErrorCode

    If chkIsComposit Then 'составная
        cmbNaprTrade.Enabled = True
        cmbNaprTrade.ListIndex = -1
    Else 'не составная
        cmbNaprTrade.Text = "прямая"
        cmbNaprTrade.Enabled = False

        'удаление обязательств обратной сделки
        If DDX.MemberData("Макс.номер в части 2") > 0 Then 'есть обязательства обратной сделки
            If MsgBox("Удалить обязательства обратной сделки ?",
                vbYesNo + vbInformation, "Предупреждение") = vbYes Then 'удаляем обязательства обратной сделки

                bNeedSendOblig = True

                'доп.данные обязательств
                If objParamOblig.CountParameters > 0 Then
                    ArrRez = Empty
                    ArrRez = objParamOblig.Parameters
                    For n = LBound(ArrRez, 2) To UBound(ArrRez, 2)
                        'список объектов
                        pos = 6
                        If Left(ArrRez(0, n), pos) = "Object" Then
                            NumP = Mid(ArrRez(0, n), pos + 1, 1)
                            If NumP = 2 Then
                                objParamOblig.ClearParameter("Object" + Mid(ArrRez(0, n), pos + 1))
                            End If
                        End If
                    Next
                End If

                'основные данные обязательств обратной сделки
Trade:          For n = 1 To lstViewOblig.ListItems.Count
                    If lstViewOblig.ListItems(n) = "обратная" Then
                        lstViewOblig.ListItems.Remove(n)
                        GoTo Trade
                    End If
                Next
            Else 'не удаляем обязательства обратной сделки
                chkIsComposit.Value = 1
            End If 'удаляем обязательства обратной сделки
        End If 'есть обязательства обратной сделки
    End If 'не составная
    Exit Sub

ErrorCode:
    objError.UbsErrMsg "chkIsComposit_Click", "ошибка выполнения"

End Sub
Private Sub chkNDS_Click()
    UpdateDisplayExport()
End Sub

Private Sub chkRate_Click()
    If chkRate.Value = 1 Then
        txtRateCurOblig.Enabled = True
        chkSumInCurValue.Value = False
        txtCostCurOpl.Enabled = False
    Else
        txtRateCurOblig.Enabled = False
    End If
End Sub

Private Sub chkSumInCurValue_Click()
    If chkSumInCurValue.Value = 1 Then
        chkRate.Value = False
        txtRateCurOblig.Enabled = False
        txtCostCurOpl.Enabled = True
    Else
        txtCostCurOpl.Enabled = False
    End If
End Sub

Private Sub cmbContractType1_Click()
    On Error GoTo ErrorCode

    ClearOpl(1)
    chkCash(1).Visible = False
    ' Если хотя бы одна из сторон сделки является БРОКЕРСКИМ ДОГОВОРОМ С КЛИЕНТОМ, ТО
    ' мы должны запретить физ. поставку
    If cmbContractType1.ItemData(cmbContractType1.ListIndex) = 1 Then
        If Not cmbContractType2.ListIndex = -1 Then
            Label8.Visible = CBool(cmbContractType2.ItemData(cmbContractType2.ListIndex) <> 0)
            cmbComission.Visible = CBool(cmbContractType2.ItemData(cmbContractType2.ListIndex) <> 0)
            cmbKindSupplyTrade.Text = "обезличенная"
            cmbKindSupplyTrade.Enabled = False
        End If
        If intVidTrade = 0 Then
            chkCash(1).Visible = True
            chkCash(1).Value = 0
        End If
    Else
        If Not cmbContractType2.ListIndex = -1 Then
            If cmbContractType2.ItemData(cmbContractType2.ListIndex) = 1 Then
                Label8.Visible = CBool(cmbContractType1.ItemData(cmbContractType1.ListIndex) <> 0)
                cmbComission.Visible = CBool(cmbContractType1.ItemData(cmbContractType1.ListIndex) <> 0)
                cmbKindSupplyTrade.Text = "обезличенная"
                cmbKindSupplyTrade.Enabled = False
            Else
                Label8.Visible = False
                cmbComission.Visible = False
                cmbKindSupplyTrade.Enabled = True
            End If
        End If

    End If

    If Not CBool(lblCheckInstr(1).Visible) Then lblCheckInstr(1).Visible = True
    If Not CBool(cmdListInstr(1).Visible) Then cmdListInstr(1).Visible = True

    If cmbContractType1.ItemData(cmbContractType1.ListIndex) = 0 Then
        If Not CBool(SSActiveTabs1.Tabs(1).Visible) Then SSActiveTabs1.Tabs(1).Visible = True
        SSActiveTabs1.Tabs(1).Selected = True
        If CBool(SSActiveTabs1.Tabs(2).Visible) Then SSActiveTabs1.Tabs(2).Visible = False
    Else
        If Not CBool(SSActiveTabs1.Tabs(1).Visible) Then SSActiveTabs1.Tabs(1).Visible = True
        If Not CBool(SSActiveTabs1.Tabs(2).Visible) Then SSActiveTabs1.Tabs(2).Visible = True
        SSActiveTabs1.Tabs(1).Selected = True
    End If
    '----------------------------------------------------------------------
    If cmbContractType1.ItemData(cmbContractType1.ListIndex) <> 0 Then
        If strRunParam <> "EDIT" Then
            txtContractCode1.Text = ""
            txtClientName1.Text = ""
        Else
            If blnClearContr1 Then
                txtContractCode1.Text = ""
                txtClientName1.Text = ""
            Else
                blnClearContr1 = True
            End If
        End If
        cmdContract1.Enabled = True
    Else
        DDX.MemberData("Продавец") = 0

        Call FillControlContract(DDX.MemberData("Продавец"), txtContractCode1, txtClientName1, IdClient1)

        cmdContract1.Enabled = False

        'идентификатор комисии
        cmbComission.ListIndex = -1

        If blnCheckType2 Then
            If cmbContractType2.ItemData(cmbContractType2.ListIndex) = 1 Then
                For n = 0 To cmbComission.ListCount - 1
                    If cmbComission.ItemData(n) = IdComission2 Then
                        cmbComission.ListIndex = n
                    End If
                Next
            End If
        End If
        blnClearContr1 = True
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmbContractType1_Click", "ошибка выполнения"

End Sub

Private Sub cmbContractType2_Click()
    On Error GoTo ErrorCode

    ClearOpl(0)

    chkCash(0).Visible = False

    If cmbContractType2.ItemData(cmbContractType2.ListIndex) = 1 Then
        Label8.Visible = CBool(cmbContractType1.ItemData(cmbContractType1.ListIndex) <> 0)
        cmbComission.Visible = CBool(cmbContractType1.ItemData(cmbContractType1.ListIndex) <> 0)
        cmbKindSupplyTrade.Text = "обезличенная"
        cmbKindSupplyTrade.Enabled = False

        If intVidTrade = 0 Then
            chkCash(0).Visible = True
            chkCash(0).Value = 0
        End If

    Else
        If cmbContractType1.ItemData(cmbContractType1.ListIndex) = 1 Then
            Label8.Visible = CBool(cmbContractType2.ItemData(cmbContractType2.ListIndex) <> 0)
            cmbComission.Visible = CBool(cmbContractType2.ItemData(cmbContractType2.ListIndex) <> 0)
            cmbKindSupplyTrade.Text = "обезличенная"
            cmbKindSupplyTrade.Enabled = False
        Else
            Label8.Visible = False
            cmbComission.Visible = False
            cmbKindSupplyTrade.Enabled = True
        End If
    End If

    If Not CBool(lblCheckInstr(0).Visible) Then lblCheckInstr(0).Visible = True
    If Not CBool(cmdListInstr(0).Visible) Then cmdListInstr(0).Visible = True
    '----------------------------------------------------------------------
    If cmbContractType2.ItemData(cmbContractType2.ListIndex) = 0 Then
        If Not CBool(SSActiveTabs1.Tabs(2).Visible) Then SSActiveTabs1.Tabs(2).Visible = True
        SSActiveTabs1.Tabs(2).Selected = True
        If CBool(SSActiveTabs1.Tabs(1).Visible) Then SSActiveTabs1.Tabs(1).Visible = False
    Else
        If Not CBool(SSActiveTabs1.Tabs(1).Visible) Then SSActiveTabs1.Tabs(1).Visible = True
        SSActiveTabs1.Tabs(1).Selected = True
    End If

    If cmbContractType2.ItemData(cmbContractType2.ListIndex) <> 0 Then
        If strRunParam <> "EDIT" Then
            txtContractCode2.Text = ""
            txtClientName2.Text = ""
        Else
            If blnClearContr2 Then
                txtContractCode2.Text = ""
                txtClientName2.Text = ""
            Else
                blnClearContr2 = True
            End If
        End If
        cmdContract2.Enabled = True
    Else
        DDX.MemberData("Покупатель") = 0

        ' получить данные контракта
        Call FillControlContract(DDX.MemberData("Покупатель"), txtContractCode2, txtClientName2, IdClient2)

        cmdContract2.Enabled = False



        'идентификатор комисии
        If cmbContractType1.ItemData(cmbContractType1.ListIndex) = 1 Then
            For n = 0 To cmbComission.ListCount - 1
                If cmbComission.ItemData(n) = IdComission1 Then
                    cmbComission.ListIndex = n
                End If
            Next
        Else
            cmbComission.ListIndex = -1
        End If
        blnClearContr2 = True
    End If

    UpdateDisplayNDS()
    UpdateDisplayExport()

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmbContractType2_Click", "ошибка выполнения"

End Sub
Private Sub cmbCurOblig_Click()
    On Error GoTo ErrorCode
    If Not cmbCurOblig.ListIndex = -1 And Not cmbCurrencyOpl.ListIndex = -1 Then
        GetRate_CB()
        GetRateForPM()
    End If
    Exit Sub
ErrorCode:
    objError.UbsErrMsg "cmbCurOblig_Click", "ошибка выполнения"
End Sub
Private Sub cmbCurrencyOpl_Click()
    On Error GoTo ErrorCode
    If Not cmbCurOblig.ListIndex = -1 And
   Not cmbCurrencyOpl.ListIndex = -1 And
   Not cmbCurrencyPost.ListIndex = -1 Then
        GetRate_CB()
        GetRateForPM()
    End If
    Exit Sub
ErrorCode:
    objError.UbsErrMsg "cmbCurrencyOpl_Click", "ошибка выполнения"
End Sub
Function GetRate_CB()
    On Error GoTo ErrorCode
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    objParamIn.Parameter("Id_Currency_Opl") = cmbCurrencyOpl.ItemData(cmbCurrencyOpl.ListIndex)
    objParamIn.Parameter("Id_Currency_Oblig") = cmbCurOblig.ItemData(cmbCurOblig.ListIndex)
    objParamIn.Parameter("Date") = DDX.MemberData("DATE_TRADE")
    UbsChannel1.Run "GetRate_CB", objParamIn, objParamOut
  ' Курс пересчета
    txtRateCurOblig.VariantValue = objFormat.Round(objParamOut.Parameter("Rate"), 10)
    ' Цена за ед. в валюте оплаты
    If Len(Trim(txtRateCurOblig.VariantValue)) > 0 And Len(Trim(txtCostUnit.CurrencyValue)) > 0 Then
        'txtCostCurOpl.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtRateCurOblig.CurrencyValue, 4)
        txtCostCurOpl.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtRateCurOblig.VariantValue, 4)
        GetSumOpl()
    End If
    Exit Function
ErrorCode:
    objError.UbsErrMsg "GetRate_CB", "ошибка выполнения"
End Function
Function GetRateForPM()
    On Error GoTo ErrorCode
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    objParamIn.Parameter("Id_Pm") = cmbCurrencyPost.ItemData(cmbCurrencyPost.ListIndex)
    objParamIn.Parameter("Id_Currency_Oblig") = cmbCurOblig.ItemData(cmbCurOblig.ListIndex)
    objParamIn.Parameter("Date") = DDX.MemberData("DATE_TRADE")
    UbsChannel1.Run "GetRateForPM", objParamIn, objParamOut
  ' Цена за ед. в валюте обязательства
    If cmbUnit.ListIndex = 1 Then
        txtCostUnit.CurrencyValue = objFormat.Round(objParamOut.Parameter("Rate_PM") * 31.1035, 4)
    Else
        txtCostUnit.CurrencyValue = objFormat.Round(objParamOut.Parameter("Rate_PM"), 4)
    End If
    If Len(Trim(txtRateCurOblig.VariantValue)) > 0 And Len(Trim(txtCostUnit.CurrencyValue)) > 0 Then
        ' Цена за ед. в валюте оплаты
        'txtCostCurOpl.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtRateCurOblig.CurrencyValue, 4)
        txtCostCurOpl.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtRateCurOblig.VariantValue, 4)
        GetSumOblig()
        GetSumOpl()
    End If
    Exit Function
ErrorCode:
    objError.UbsErrMsg "GetRateForPM", "ошибка выполнения"
End Function
Private Sub cmbCurrencyPost_click()
    On Error GoTo ErrorCode
    'В соответствии с Инструкцией № 94-И: масса металла в граммах
    'определяется с точностью:

    ' Золото в стандартных ¦Масса химически  ¦Граммы, с  точностью  до¦
    '¦и  мерных  слитках  и¦чистого          ¦0,1 г                   ¦
    '¦прокате              ¦драгоценного     ¦                        ¦
    '¦                     ¦металла          ¦                        ¦
    '+---------------------+-----------------+------------------------+
    '¦Серебро в стандартных¦Масса в лигатуре ¦Граммы,  с точностью  до¦
    '¦и   мерных   слитках,¦                 ¦1 г                     ¦
    '¦гранулах и прокате   ¦                 ¦                        ¦
    '+---------------------+-----------------+------------------------+
    '¦Металлы    платиновой¦Масса в лигатуре ¦Граммы, с  точностью  до¦
    '¦группы  в стандартных¦                 ¦0,1 г                   ¦
    '¦и   мерных   слитках,¦                 ¦                        ¦
    '¦прокате , порошке
    If cmbCurrencyPost.ItemData(cmbCurrencyPost.ListIndex) = intSave Then Exit Sub
    If Not cmbCurrencyPost.ListIndex = -1 Then
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("IdCurrency") = cmbCurrencyPost.ItemData(cmbCurrencyPost.ListIndex)
        UbsChannel1.Run "DefineCodCurrency", objParamIn, objParamOut
   strCB = objParamOut.Parameter("CodCB")
        txtMassaGramm.Precision = IIf(strCB = "A99", 0, 1)
        If Not cmbUnit.ListIndex = -1 Then GetMassaPrecision()

        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("CodCB") = strCB
        UbsChannel1.Run "PMConvert", objParamIn, objParamOut
   blnConvert = objParamOut.Parameter("Флаг пересчета")
    End If


    '==================================================================
    Dim ArrRez As Variant
    ArrRez = Empty

    If blnCurrencyPostClick And ExistObject() Then
        Call DefineArrStrNumInPart(ArrRez)
        'удаляем список объектов по всем обязательствам
        For n = LBound(ArrRez) To UBound(ArrRez)
            objParamOblig.ClearParameter("Object" & ArrRez(n))
        Next

        bNeedSendOblig = True
    End If

    If Not cmbCurrencyPost.ListIndex = -1 And
       Not cmbCurOblig.ListIndex = -1 And
       Not cmbCurrencyPost.ListIndex = -1 Then
        GetRateForPM()
    End If
    '-----------------------------------------------
    intSave = cmbCurrencyPost.ItemData(cmbCurrencyPost.ListIndex)
    Exit Sub
ErrorCode:
    objError.UbsErrMsg "cmbCurrencyPost_click", "ошибка выполнения"

End Sub

Private Sub UpdateDisplayNDS()
    On Error GoTo ErrorCode
    Dim IsLegalEnterprice, IsCheck

    MsgBox "пам.2", vbOKOnly + vbCritical, "Проверка свойств"

    If IdClient2 <> 0 Then
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("ClientId") = IdClient2
        UbsChannel1.Run "IsClientLegalEnterprise", objParamIn, objParamOut
        IsLegalEnterprice = objParamOut.Parameter("Result")
        IsCheck = Trim(cmbKindSupplyTrade.Text) = "физическая" _
            And Trim(txtContractCode1.Text) = "банк" _
            And Trim(txtContractCode2.Text) <> "банк" _
            And IsLegalEnterprice
    Else
        IsCheck = False
    End If

    If IsCheck Then
        chkNDS.Visible = True
    Else
        chkNDS.Visible = False
        chkNDS.Value = 0
    End If
    Exit Sub
ErrorCode:
    objError.UbsErrMsg "UpdateDisplayNDS", "ошибка выполнения"
End Sub

Private Sub UpdateDisplayExport()
    On Error GoTo ErrorCode
    Dim IsNotResident, IsCheck

    MsgBox "пам.3", vbOKOnly + vbCritical, "Проверка свойств"

    If IdClient2 <> 0 Then
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("ClientId") = IdClient2
        UbsChannel1.Run "IsClientNotResident", objParamIn, objParamOut
        IsNotResident = objParamOut.Parameter("Result")
        IsCheck = CBool(chkNDS.Value) And IsNotResident
    Else
        IsCheck = False
    End If

    If IsCheck Then
        chkExport.Visible = True
    Else
        chkExport.Visible = False
        chkExport.Value = 0
    End If
    Exit Sub
ErrorCode:
    objError.UbsErrMsg "UpdateDisplayExport", "ошибка выполнения"
End Sub

Private Sub cmbKindSupplyTrade_click()
    On Error GoTo ErrorCode

    Dim ArrRez As Variant
    ArrRez = Empty

    If cmbKindSupplyTrade.Text = "обезличенная" Then
        txtStorageCode.Text = ""
        txtStorageName.Text = ""
        SSTabs.Tabs(4).Visible = False
        If CBool(SSTabs1.Tabs(2).Visible) Then SSTabs1.Tabs(2).Visible = False
    ElseIf cmbKindSupplyTrade.Text = "физическая" Then
        SSTabs.Tabs(4).Visible = True
        SSTabs1.Tabs(2).Visible = True
    End If
    '----------------------------------------------------------------------
    If strRunParam <> "EDIT" Then
        DelOblig()
    Else
        If blnClearOblig Then
            DelOblig()
            If SSTabs.Tabs(3).Enabled Then SSTabs.Tabs(3).Enabled = False
        Else
            blnClearOblig = True
        End If
    End If

    UpdateDisplayNDS()
    UpdateDisplayExport()

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmbKindSupplyTrade_click", "ошибка выполнения"

End Sub
Private Function DelOblig()
    On Error GoTo ErrorCode
    Dim StrNumInPartDel As String
    Dim arrIdObl As Variant
    Dim itmX As ListItem
    Dim n, t As Integer
    If IsExistOblig() Then
        If lstViewOblig.ListItems.Count > 0 Then
            ReDim arrIdObl(lstViewOblig.ListItems.Count)
            n = 1
            For Each itmX In lstViewOblig.ListItems
                arrIdObl(n) = lstViewOblig.ListItems.Item(n).SubItems(1)
                n = n + 1
            Next
            For t = 1 To UBound(arrIdObl)
                'при удалении обязательства удаляются его доп.данные
                StrNumInPartDel = arrIdObl(t)
                'objParamOblig.ClearParameter ("Instr" + StrNumInPartDel)
                'objParamOblig.ClearParameter ("Storage" + StrNumInPartDel)
                objParamOblig.ClearParameter("Object" + StrNumInPartDel)
                objParamOblig.Parameter("Delete" & StrNumInPartDel) = True
            Next
        End If
        lstViewOblig.ListItems.Clear
        lstViewOblig.Refresh
        bNeedSendOblig = True
    End If
    Exit Function
ErrorCode:
    objError.UbsErrMsg "DelOblig", "ошибка выполнения"
End Function
Private Sub cmbUnit_Click()
    GetMassaPrecision()
    txtMassa.CurrencyValue = 0
    txtMassaGramm.CurrencyValue = 0
    If Not cmbCurOblig.ListIndex = -1 And Not cmbCurrencyOpl.ListIndex = -1 Then
        GetRateForPM()
    End If
End Sub


Private Sub cmdAccounts_Click()
    On Error GoTo ErrorCode

    If NumChildWinAccountsByObligation <> 0 Then
        IParent.SetFocusToWindow NumChildWinAccountsByObligation
        Exit Sub
    End If
    cmdAddObject.Enabled = False
    IParent.GetWindow "UBS_FLT\PM\PM_ACCOUNTS_BY_OBLIGATION.flt", NumChildWinAccountsByObligation
    '-------------------------------------------------------------------------------------

    If NumChildWinAccountsByObligation <> 0 Then
        Dim objGridF As Object
        Dim InitParamGrid As Variant
        ReDim InitParamGrid(2)
   
        Set objGridF = IParent.ParamInfo(NumChildWinAccountsByObligation, "UbsGridList")
        objGridF.ClearWhereList
        objGridF.AddWhereItem "Идентификатор обязательства", 4, lstViewOblig.SelectedItem.Tag

        If IParent.IsExistParam(NumChildWinAccountsByObligation, "InitParamGrid") Then
            InitParamGrid(0) = Numwin
            InitParamGrid(2) = True
            IParent.ParamInfo(NumChildWinAccountsByObligation, "InitParamGrid") = InitParamGrid
            IParent.SetFocusToWindow NumChildWinAccountsByObligation
        End If
    End If

    Exit Sub
ErrorCode:
    objError.UbsErrMsg "cmdAccounts_Click", "ошибка выполнения"
End Sub

