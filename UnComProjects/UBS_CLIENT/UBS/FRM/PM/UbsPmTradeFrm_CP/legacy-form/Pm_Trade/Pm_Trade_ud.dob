Private Sub cmdAccount_Click(Index As Integer)
    'вызываем списки
    On Error GoTo ErrorCode

    If NumChildWinAccount <> 0 Then
        IParent.SetFocusToWindow NumChildWinAccount
        Exit Sub
    End If
    cmdAccount(Index).Enabled = False
    IParent.GetWindow "UBS_FLT\OD\account0.flt", NumChildWinAccount
    intTabAcc = Index

    If NumChildWinAccount <> 0 Then
        Dim objGridF As Object
        Dim InitParamGrid As Variant
        ReDim InitParamGrid(2)
   
        Set objGridF = IParent.ParamInfo(NumChildWinAccount, "UbsGridList")
        objGridF.ClearWhereList
        objGridF.AddWhereItem "Идентификатор счета", 5, 0

        objGridF.AddWhereItem "Идентификатор клиента", 4, IdClient2
        objGridF.AddWhereItem "Идентификатор валюты", 3, 1000

        If IParent.IsExistParam(NumChildWinAccount, "InitParamGrid") Then
            InitParamGrid(0) = Numwin
            InitParamGrid(2) = True
            IParent.ParamInfo(NumChildWinAccount, "InitParamGrid") = InitParamGrid
            IParent.SetFocusToWindow NumChildWinAccount
        End If
    End If
    cmdAccount(Index).Enabled = True
    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmdAccount_Click", "ошибка выполнения"

End Sub

Private Sub StartDialog(g As Integer)
    On Error GoTo ErrorCode

    Dim ArrOut As Variant

    Load frmInstr
    Call frmInstr.StartForm(objError, objParamOut.Parameter("ArrInstr"))
    frmInstr.Show vbModal, Me

    If frmInstr.IsChoice Then 'нажали кнопку "Выбор"
        ArrOut = frmInstr.GetInstr 'считываем выбранные данные

        'заполняем контролы выбранными данными
        txtBIK(g).Text = ArrOut(0)
        txtName(g).Text = ArrOut(1)
        txtKS(g).Text = ArrOut(2)
        txtRS(g).Text = ArrOut(3)
        txtClient(g).Text = ArrOut(4)
        txtNote(g).Text = ArrOut(5)
        txtINN(g).Text = ArrOut(6)
        chkNotAkcept(g).Value = CInt(ArrOut(7))

        If txtBIK(g).Text = strOurBIK Then 'наш БИК
            txtRS(g).Enabled = False
            cmdAccount(g).Enabled = True
            cmdAccount(g).SetFocus
        Else
            txtRS(g).Enabled = True
            cmdAccount(g).Enabled = False
            txtRS(g).SetFocus
        End If
    End If
    Unload frmInstr

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "StartDialog", "ошибка выполнения"

End Sub

Private Function IsExistOblig() As Boolean
    On Error GoTo ErrorCode

    IsExistOblig = CBool(lstViewOblig.ListItems.Count > 0)

    Exit Function

ErrorCode:
    objError.UbsMsgRaise "IsExistOblig", "ошибка выполнения"

End Function

Private Sub CallOblig(ByVal sType As String)
    On Error GoTo ErrorCode

    Dim strNapr As String
    Dim dDateOpl As Variant, dDatePost As Variant, curCostUnit As Currency
    Dim curSumOpl As Currency, curMassa As Currency
    Dim h As Integer

    If sType = "Add" Then
        strNapr = "прямая"
        StrNumInPart = ""
        If intVidTrade = 0 Then
            'наличные сделки
            dDateOpl = txtTradeDate.DateValue
            dDatePost = txtTradeDate.DateValue

            txtDateOpl.Enabled = False
            txtDatePost.Enabled = False
        Else
            dDateOpl = Date
            dDatePost = Date
        End If

        curCostUnit = 0
        curMassa = 0
        curSumOpl = 0

        txtDateOpl.DateValue = dDateOpl
        txtDatePost.DateValue = dDatePost
        txtSumOpl.CurrencyValue = curSumOpl
        txtMassa.CurrencyValue = curMassa
        txtMassaGramm.CurrencyValue = curMassa
        txtSumOblig.CurrencyValue = 0
        lblObligInfo2.Caption = "Цена: " & txtCostUnit.CurrencyValue & Space(3) &
        "Масса: " & txtMassa.Text & Space(3) &
        "Сумма: " & txtSumOpl.Text
        chkRate.Value = 0
        ClearDataOblig() 'очистка контролов
    Else '"Edit"
        If Not IsExistOblig() Then Exit Sub

        'наличные сделки
        txtDateOpl.Enabled = CBool(intVidTrade <> 0)
        txtDatePost.Enabled = CBool(intVidTrade <> 0)

        strNapr = lstViewOblig.SelectedItem ' направление
        StrNumInPart = lstViewOblig.SelectedItem.SubItems(1) ' номер в части
        dDateOpl = lstViewOblig.SelectedItem.SubItems(2) ' дата оплаты
        dDatePost = lstViewOblig.SelectedItem.SubItems(3) ' дата поставки
        curMassa = lstViewOblig.SelectedItem.SubItems(5) ' масса

        For h = 0 To UBound(arrCurrency, 2)
            If arrCurrency(0, h) = lstViewOblig.SelectedItem.SubItems(7) Then ' Валюта обязательства
                cmbCurOblig.Text = arrCurrency(1, h)
            End If
        Next
        'txtRateCurOblig.CurrencyValue = lstViewOblig.SelectedItem.SubItems(8) ' Курс пересчета
        txtRateCurOblig.VariantValue = lstViewOblig.SelectedItem.SubItems(8) ' Курс пересчета
        '--------------------------------------------------------------
        cmbUnit.ListIndex = IIf(lstViewOblig.SelectedItem.SubItems(9) = "грамм", 0, 1)
        txtCostUnit.CurrencyValue = lstViewOblig.SelectedItem.SubItems(4) ' цена за ед. в валюте обяз.
        'curCostUnit = objFormat.Round((txtCostUnit.CurrencyValue * txtRateCurOblig.CurrencyValue), 4) ' цена за ед. в валюте оплаты
        curCostUnit = objFormat.Round((txtCostUnit.CurrencyValue * txtRateCurOblig.VariantValue), 4) ' цена за ед. в валюте оплаты
        txtSumOblig.CurrencyValue = lstViewOblig.SelectedItem.SubItems(6) ' сумма в валюте обяз.

        'curSumOpl = objFormat.Round(txtSumOblig.CurrencyValue * txtRateCurOblig.CurrencyValue, 2)   ' сумма в валюте оплаты
        curSumOpl = objFormat.Round(txtSumOblig.CurrencyValue * txtRateCurOblig.VariantValue, 2)   ' сумма в валюте оплаты
        strNaprTrade = strNapr

        txtDateOpl.DateValue = dDateOpl
        txtDatePost.DateValue = dDatePost
        txtMassa.CurrencyValue = curMassa
        GetMassaGramm()
        txtCostCurOpl.CurrencyValue = curCostUnit
        txtSumOpl.CurrencyValue = curSumOpl
        '=================================================================================
        chkRate.Value = lstViewOblig.SelectedItem.SubItems(10)
        FillDataOblig() 'заполнение контролов
    End If

    If Len(strNapr) = 0 Then
        If chkIsComposit Then
            cmbNaprTrade.ListIndex = -1
        End If
    Else
        cmbNaprTrade.Text = strNapr
    End If

    If blnAddOblig Or blnEditOblig Then 'не в режиме просмотра
        SSTabs.Tabs(3).Selected = True
        SSTabs1.SetFocus
        SSTabs1.Tabs(1).Selected = True
        If cmbNaprTrade.Enabled Then
            cmbNaprTrade.SetFocus
        Else
            cmbCurOblig.SetFocus
        End If
        '------------------------
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "CallOblig", "ошибка выполнения"

End Sub

Function CheckDataOblig() As Boolean
    On Error GoTo ErrorCode

    Dim eTitle As String, n As Long
    eTitle = "Проверка свойств"

    'направление
    If cmbNaprTrade.ListIndex = -1 Then
        MsgBox "Не указано направление.", vbOKOnly + vbCritical, "Проверка свойств"
        CheckDataOblig = False
        Exit Function
    End If

    'обязательство
    If txtCostUnit.CurrencyValue = 0 Then
        MsgBox "Не указана цена за единицу.", vbOKOnly + vbCritical, "Проверка свойств"
        SSTabs.Tabs(3).Selected = True
        SSTabs1.Tabs(1).Selected = True
        txtCostUnit.SetFocus
        CheckDataOblig = False
        Exit Function
    End If

    If txtDatePost.DateValue = #1/1/2222# Or Not txtDatePost.IsValid Then
        MsgBox "Не указана дата поставки.", vbOKOnly + vbCritical, "Проверка свойств"
        If SSTabs.Tabs(3).Selected And SSTabs1.Tabs(1).Selected Then
            txtDatePost.SetFocus
        End If
        CheckDataOblig = False
        Exit Function
    End If

    If txtDatePost.DateValue < txtTradeDate.DateValue Then
        MsgBox "Дата поставки не может быть меньше даты сделки.", vbOKOnly + vbCritical, "Проверка свойств"
        If SSTabs.Tabs(3).Selected And SSTabs1.Tabs(1).Selected Then
            txtDatePost.SetFocus
        End If
        CheckDataOblig = False
        Exit Function
    End If

    If txtDateOpl.DateValue = #1/1/2222# Or Not txtDateOpl.IsValid Then
        MsgBox "Не указана дата оплаты.", vbOKOnly + vbCritical, "Проверка свойств"
        If SSTabs.Tabs(3).Selected And SSTabs1.Tabs(1).Selected Then
            txtDateOpl.SetFocus
        End If
        CheckDataOblig = False
        Exit Function
    End If

    If txtDateOpl.DateValue < txtTradeDate.DateValue Then
        MsgBox "Дата оплаты не может быть меньше даты сделки.", vbOKOnly + vbCritical, "Проверка свойств"
        If SSTabs.Tabs(3).Selected And SSTabs1.Tabs(1).Selected Then
            txtDateOpl.SetFocus
        End If
        CheckDataOblig = False
        Exit Function
    End If

    ' проверка курса пересчета
    If txtRateCurOblig.CurrencyValue = 0 Then
        MsgBox "Не указан курс пересчета", vbOKOnly + vbCritical, "Проверка свойств"
       SSTabs.Tabs(3).Selected = True
        SSTabs1.Tabs(1).Selected = True
        txtRateCurOblig.SetFocus
        CheckDataOblig = False
        Exit Function
    End If

    'масса для обезличенной сделки
    If cmbKindSupplyTrade.ItemData(cmbKindSupplyTrade.ListIndex) = 1 Then
        If txtMassa.CurrencyValue = 0 Then
            MsgBox "Не указана масса металла.", vbOKOnly + vbCritical, "Проверка свойств"
            SSTabs.Tabs(3).Selected = True
            SSTabs1.Tabs(1).Selected = True
            txtMassa.SetFocus
            CheckDataOblig = False
            Exit Function
        End If
    End If

    '----------------------------------------------------------------------
    'список объектов для физической сделки
    If cmbKindSupplyTrade.ItemData(cmbKindSupplyTrade.ListIndex) = 2 Then
        If lstViewObject.ListItems.Count = 0 Then
            MsgBox "Не заполнен список объектов по обязательству", vbOKOnly + vbCritical, eTitle
            SSTabs.Tabs(3).Selected = True
            SSTabs1.Tabs(2).Selected = True
            cmdAddObject.SetFocus
            CheckDataOblig = False
            Exit Function
        End If
    End If

    CheckDataOblig = True

    Exit Function

ErrorCode:
    objError.UbsMsgRaise "CheckDataOblig", "ошибка выполнения"

End Function

Private Sub SetResultsListOblig(ByVal sType As String)
    On Error GoTo ErrorCode

    If sType = "Add" Then
        Set objList = lstViewOblig.ListItems.Add(, , cmbNaprTrade.Text) ' направление
        objList.SubItems(1) = StrNumInPart      ' номер в части
        objList.SubItems(2) = txtDateOpl.DateValue   ' дата оплаты
        objList.SubItems(3) = txtDatePost.DateValue  ' дата поставки
        objList.SubItems(4) = txtCostUnit.CurrencyValue ' цена за ед. в валюте обяз.
        objList.SubItems(5) = txtMassa.CurrencyValue    ' масса
        objList.SubItems(6) = txtSumOblig.CurrencyValue   ' сумма в валюте обязат.
        objList.SubItems(7) = cmbCurOblig.ItemData(cmbCurOblig.ListIndex)  ' Валюта обязательства
        'objList.SubItems(8) = txtRateCurOblig.CurrencyValue  ' Курс пересчета
        objList.SubItems(8) = txtRateCurOblig.VariantValue    ' Курс пересчета
        objList.SubItems(9) = cmbUnit.Text ' Единица измерения веса
        objList.SubItems(10) = Abs(CInt(chkRate.Value))  ' Курс пересчета - фиксированный
        '---------------------------------------
        Set objList = lstViewOblig.SelectedItem
    Else
        lstViewOblig.SelectedItem.Text = cmbNaprTrade.Text
        lstViewOblig.SelectedItem.SubItems(1) = StrNumInPart
        lstViewOblig.SelectedItem.SubItems(2) = txtDateOpl.DateValue
        lstViewOblig.SelectedItem.SubItems(3) = txtDatePost.DateValue
        lstViewOblig.SelectedItem.SubItems(4) = txtCostUnit.CurrencyValue
        lstViewOblig.SelectedItem.SubItems(5) = txtMassa.CurrencyValue
        lstViewOblig.SelectedItem.SubItems(6) = txtSumOblig.CurrencyValue
        lstViewOblig.SelectedItem.SubItems(7) = cmbCurOblig.ItemData(cmbCurOblig.ListIndex)  ' Валюта обязательства
        'lstViewOblig.SelectedItem.SubItems(8) = txtRateCurOblig.CurrencyValue  ' Курс пересчета
        lstViewOblig.SelectedItem.SubItems(8) = txtRateCurOblig.VariantValue    ' Курс пересчета
        lstViewOblig.SelectedItem.SubItems(9) = cmbUnit.Text ' Единица измерения веса
        objList.SubItems(10) = Abs(CInt(chkRate.Value))  ' Курс пересчета - фиксированный
        '---------------------------------------

    End If

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "SetResultsListOblig", "ошибка выполнения"

End Sub

Private Sub cmdDelObject_Click()
    'удаляем элемент из списка
    On Error GoTo ErrorCode

    Dim curLigMassa As Currency, curProba As Currency

    If lstViewObject.ListItems.Count <> 0 Then
        Set objListObject = lstViewObject.SelectedItem
        
        curLigMassa = objListObject.SubItems(2)
        curProba = objListObject.SubItems(3)

        lstViewObject.ListItems.Remove(objListObject.Index)
    End If
    lstViewObject.Refresh
    lstViewObject.SetFocus

    If lstViewObject.ListItems.Count = 0 Then
        txtMassa.CurrencyValue = 0
    Else
        ' пересчитываем массу для металлов, которые указаны в установке
        If blnConvert Then
            If cmbUnit.Text = "грамм" Then
                curLigMassa = IIf(strCB = "A99", (objFormat.Round((CCur(curLigMassa) * CCur(curProba) / 100), 0)), (objFormat.Round((CCur(curLigMassa) * CCur(curProba) / 100), 1)))
            Else
                curLigMassa = objFormat.Round((CCur(curLigMassa) * CCur(curProba) / 100), 2)
            End If
        End If
        txtMassa.CurrencyValue = txtMassa.CurrencyValue - CCur(curLigMassa)
    End If

    GetMassaGramm()
    GetSumOblig()
    GetSumOpl()

    lblObligInfo2.Caption = "Цена: " & txtCostUnit.CurrencyValue & Space(3) &
        "Масса: " & txtMassa.Text & Space(3) &
        "Сумма: " & txtSumOpl.Text

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmdDelObject_Click", "ошибка выполнения"

End Sub

Private Function CheckKey(g As Integer) As Boolean
    'проверяем ключ
    On Error GoTo ErrorCode

    CheckKey = False
    If Len(txtBIK(g).Text) > 0 And Len(txtRS(g).Text) > 0 Then
        objParamIn.ClearParameters
        objParamOut.ClearParameters

        objParamIn.Parameter("БИК") = txtBIK(g).Text
        objParamIn.Parameter("РС") = txtRS(g).Text
        objParamIn.Parameter("КС") = txtKS(g).Text

        UbsChannel1.Run "TradeCheckKey", objParamIn, objParamOut
        If Len(objParamOut.Parameter("Отчет")) > 0 Then
            MsgBox objParamOut.Parameter("Отчет"), vbCritical + vbOKOnly, "Проверка ключа"
            Exit Function
        End If
    End If
    CheckKey = True

    Exit Function

ErrorCode:
    UserDocument.MousePointer = 0
    objError.UbsErrMsg "CheckKey", "ошибка выполнения"

End Function

Private Function CheckINN(g As Integer)
    'проверяем ИНН
    On Error GoTo ErrorCode

    CheckINN = False
    objParamIn.ClearParameters
    objParamOut.ClearParameters

    objParamIn.Parameter("ИНН") = txtINN(g).Text

    UbsChannel1.Run "TradeCheckINN", objParamIn, objParamOut
    If Len(objParamOut.Parameter("Отчет")) > 0 Then
        MsgBox objParamOut.Parameter("Отчет"), vbCritical + vbOKOnly, "Проверка ИНН"
        Exit Function
    End If
    CheckINN = True

    Exit Function

ErrorCode:
    UserDocument.MousePointer = 0
    objError.UbsErrMsg "CheckINN", "ошибка выполнения"

End Function

Function FillKS(g As Integer) As Boolean
    On Error GoTo ErrorCode

    FillKS = False
    txtClient(g).Locked = False
    txtNote(g).Locked = False

    objParamIn.ClearParameters
    objParamOut.ClearParameters
    objParamIn.Parameter("БИК") = txtBIK(g).Text
    UbsChannel1.Run "FillRekv", objParamIn, objParamOut

    If objParamOut.ExistParameter("Отчет") Then
        MsgBox objParamOut.Parameter("Отчет"), vbCritical + vbOKOnly, "Проверка БИК"
        txtName(g).Text = ""
        txtKS(g).Text = ""
        txtBIK(g).SetFocus
        Exit Function
    End If

    txtName(g).Text = objParamOut.Parameter("Банк")

    If objParamOut.ExistParameter("КС") Then
        txtKS(g).Text = objParamOut.Parameter("КС")
    End If

    If objParamOut.Parameter("Наш БИК") = True Then
        txtRS(g).Enabled = False
        cmdAccount(g).Enabled = True
        If SSTabs1.Tabs(2).Selected Then
            cmdAccount(g).SetFocus
        End If

        If objParamOut.ExistParameter("КС") Then
            txtKS(g).Text = objParamOut.Parameter("КС")
        End If
    Else
        txtRS(g).Enabled = True
        cmdAccount(g).Enabled = False
        If SSTabs1.Tabs(2).Selected Then
            txtRS(g).SetFocus
        End If
    End If

    'проверяем ключ
    If Not CheckKey(g) Then
        If txtRS(g).Enabled Then
            txtRS(g).SetFocus
        Else
            cmdAccount(g).SetFocus
        End If
    End If

    FillKS = True

    Exit Function

ErrorCode:
    objError.UbsMsgRaise "FillKS", "ошибка выполнения"

End Function

Private Sub FillArrOblig(varArr As Variant)
    On Error GoTo ErrorCode

    If lstViewOblig.ListItems.Count > 0 Then
        ReDim varArr(11, lstViewOblig.ListItems.Count - 1)
        For n = 1 To lstViewOblig.ListItems.Count
            varArr(0, n - 1) = lstViewOblig.ListItems(n)
            varArr(1, n - 1) = lstViewOblig.ListItems(n).SubItems(1)
            varArr(2, n - 1) = lstViewOblig.ListItems(n).SubItems(2)
            varArr(3, n - 1) = lstViewOblig.ListItems(n).SubItems(3)
            varArr(4, n - 1) = CCur(lstViewOblig.ListItems(n).SubItems(4))
            varArr(5, n - 1) = CCur(lstViewOblig.ListItems(n).SubItems(5))
            varArr(6, n - 1) = CCur(lstViewOblig.ListItems(n).SubItems(6))
            varArr(7, n - 1) = cmbCurrencyOpl.ItemData(cmbCurrencyOpl.ListIndex) 'ид.валюты оплаты
            varArr(8, n - 1) = cmbCurrencyPost.ItemData(cmbCurrencyPost.ListIndex) 'ид.валюты поставки
            varArr(9, n - 1) = lstViewOblig.ListItems(n).SubItems(7)
            If lstViewOblig.ListItems(n).SubItems(10) = 1 Then
                varArr(10, n - 1) = CDbl(lstViewOblig.ListItems(n).SubItems(8))
            Else
                varArr(10, n - 1) = CCur(0)
            End If
            varArr(11, n - 1) = lstViewOblig.ListItems(n).SubItems(9)
        Next
    End If

    Exit Sub
ErrorCode:
    objError.UbsMsgRaise "FillArrOblig", "ошибка выполнения"

End Sub

Private Sub FillArrObject(varArr As Variant)
    On Error GoTo ErrorCode

    If lstViewObject.ListItems.Count > 0 Then
        ReDim varArr(0, lstViewObject.ListItems.Count - 1)
        For n = 1 To lstViewObject.ListItems.Count
            varArr(0, n - 1) = lstViewObject.ListItems(n).SubItems(6) 'id объекта
        Next
    End If

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "FillArrObject", "ошибка выполнения"

End Sub

Sub FillControlInstrOplata(k As Integer, varOplata As Variant)

    If Not IsArray(varOplata) Then Exit Sub

    txtBIK(k).Text = varOplata(0, 0)
    txtName(k).Text = varOplata(1, 0)
    txtKS(k).Text = varOplata(2, 0)
    txtRS(k).Text = varOplata(3, 0)
    txtClient(k).Text = varOplata(4, 0)
    txtNote(k).Text = varOplata(5, 0)
    txtINN(k).Text = varOplata(6, 0)
    chkNotAkcept(k).Value = Abs(CInt(varOplata(7, 0)))

End Sub

Private Sub FillArrDataInstr(ByVal k As Integer, ByRef varArr As Variant)
    On Error GoTo ErrorCode

    ReDim varArr(7, 0)

    varArr(0, 0) = txtBIK(k).Text
    varArr(1, 0) = txtName(k).Text
    varArr(2, 0) = txtKS(k).Text
    varArr(3, 0) = txtRS(k).Text
    varArr(4, 0) = txtClient(k).Text
    varArr(5, 0) = txtNote(k).Text
    varArr(6, 0) = txtINN(k).Text
    varArr(7, 0) = Abs(CInt(chkNotAkcept(k).Value))

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "FillArrDataInstr", "ошибка выполнения"

End Sub

Private Sub FillListOblig(arrOblig As Variant)
    On Error GoTo ErrorCode
    If Not IsEmpty(arrOblig) Then
        Dim opIn As Object, opOut As Object
        
        Set opIn = CreateObject("Lib2.IUbsParam")
        Set opOut = CreateObject("Lib2.IUbsParam")
        For n = LBound(arrOblig, 2) To UBound(arrOblig, 2)
            Set objList = lstViewOblig.ListItems.Add(, , arrOblig(0, n)) 'направление
            
            objList.Tag = arrOblig(11, n)

            objList.SubItems(1) = arrOblig(1, n) 'номер в части
            objList.SubItems(2) = arrOblig(2, n) 'дата оплаты
            objList.SubItems(3) = arrOblig(3, n) 'дата поставки
            objList.SubItems(4) = arrOblig(4, n) 'цена за единицу
            objList.SubItems(5) = arrOblig(5, n) 'масса
            objList.SubItems(6) = arrOblig(6, n) 'сумма оплаты
            objList.SubItems(7) = arrOblig(7, n) 'ид валюты обязательства
            If arrOblig(8, n) <> 0 Then
                objList.SubItems(8) = arrOblig(8, n) 'курс пересчета - фиксированный
                objList.SubItems(10) = 1
            Else
                opIn.ClearParameters
                opOut.ClearParameters
                opIn.Parameter("Id_Currency_Opl") = cmbCurrencyOpl.ItemData(DDX.MemberData("Идентификатор валюты оплаты"))
                opIn.Parameter("Id_Currency_Oblig") = arrOblig(7, n)
                opIn.Parameter("Date") = DDX.MemberData("DATE_TRADE")
                UbsChannel1.Run "GetRate_CB", opIn, opOut
                objList.SubItems(8) = objFormat.Round(opOut.Parameter("Rate"), 10) 'курс пересчета
                objList.SubItems(10) = 0
            End If
            objList.SubItems(9) = arrOblig(9, n)
        Next
        Set opIn = Nothing
        Set opOut = Nothing
    End If

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "FillListOblig", "ошибка выполнения"

End Sub

Private Sub ClearDataOblig()
    On Error GoTo ErrorCode

    'очистка контролов
    '================
    'список объектов
    lstViewObject.ListItems.Clear

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "ClearDataOblig", "ошибка выполнения"

End Sub

Private Sub FillDataOblig()
    On Error GoTo ErrorCode
    Dim ArrInstr As Variant, ArrObject As Variant, i As Integer

    'заполнение контролов
    '====================
    'обязательство

    If objParamOblig.ExistParameter("Object" & StrNumInPart) Then
        ArrObject = objParamOblig.Parameter("Object" & StrNumInPart)
        If IsArray(ArrObject) Then
            lstViewObject.ListItems.Clear
            txtMassa.CurrencyValue = 0
            For i = LBound(ArrObject, 2) To UBound(ArrObject, 2)
                FillDataObject(ArrObject(0, i)) 'add item
            Next
        End If
    Else 'нет объектов
        If cmbKindSupplyTrade.Text = "физическая" Then
            txtMassa.CurrencyValue = 0
            txtSumOpl.CurrencyValue = 0

            lblObligInfo2.Caption = "Цена: " & txtCostUnit.CurrencyValue & Space(3) &
            "Масса: " & txtMassa.Text & Space(3) &
            "Сумма: " & txtSumOpl.Text

            lstViewObject.ListItems.Clear
        End If
    End If

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "FillDataOblig", "ошибка выполнения"

End Sub

Private Function ExistObject() As Boolean
    On Error GoTo ErrorCode

    'true - если есть объекты
    'false - иначе

    Dim ArrTemp As Variant

    ArrTemp = Empty
    If objParamOblig.CountParameters > 0 Then
        ArrTemp = objParamOblig.Parameters
    End If
    ExistObject = False

    If Not IsEmpty(ArrTemp) Then
        For n = LBound(ArrTemp, 2) To UBound(ArrTemp, 2)
            If Left(ArrTemp(0, n), 6) = "Object" Then
                ExistObject = True
                Exit For
            End If
        Next
    End If

    Exit Function

ErrorCode:
    objError.UbsMsgRaise "ExistObject", "ошибка выполнения"

End Function

Private Function FillDataObject(IdObject As Long) As Boolean
    Dim arrIdObj, varCheck, varParam, varObject As Variant
    Dim n, m, p, i, intCheck As Integer
    Dim itmX As ListItem
    On Error GoTo ErrorCode
    FillDataObject = False
    Dim ArrOut As Variant
    Dim curLigMassa As Currency, curProba As Currency
    ' проверка на повторяющиеся объекты учета в одном списке
    ' ========================================================
    If lstViewObject.ListItems.Count > 0 Then
        ReDim arrIdObj(lstViewObject.ListItems.Count - 1)
        n = 0
        For Each itmX In lstViewObject.ListItems
            arrIdObj(n) = lstViewObject.ListItems.Item(n + 1).SubItems(6)
            n = n + 1
        Next
        For i = 0 To UBound(arrIdObj)
            If IdObject = arrIdObj(i) Then
                MsgBox "Объект Учета с Идентификатором " & IdObject & " в списке уже существует. Выберите другой объект пожалуйста!", vbCritical + vbOKOnly, "Ошибка"
              Exit Function
            End If
        Next
    End If
    ' проверка на повторяющиеся объекты учета в разных обязательствах одного направления
    ' ========================================================
    If blnAddObject And lstViewOblig.ListItems.Count > 0 Then
        intCheck = cmbNaprTrade.ItemData(cmbNaprTrade.ListIndex)
        varCheck = objParamOblig.Parameters
        If IsArray(varCheck) Then
            For m = 0 To UBound(varCheck, 2)
                If Left(varCheck(0, m), 7) = "Object" & intCheck Then
                    varParam = objParamOblig.Parameter(varCheck(0, m))
                    For p = 0 To UBound(varParam, 2)
                        If varParam(0, p) = IdObject Then
                            MsgBox "Объект Учета с Идентификатором " & IdObject & " уже существует в обязательстве " & Mid(varCheck(0, m), 7, 3) & ". Выберите другой объект пожалуйста!", vbCritical + vbOKOnly, "Ошибка"
                   Exit Function
                        End If
                    Next
                End If
            Next
        End If
    End If
    '=========================================================
    ' получить данные объекта
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    objParamIn.Parameter("ID_OBJECT") = IdObject
    UbsChannel1.Run "GetObjectPM", objParamIn, objParamOut

    ArrOut = objParamOut.Parameter("Данные объекта")
    Set objListObject = lstViewObject.ListItems.Add(, , cmbCurrencyPost.Text)
    For n = 1 To UBound(ArrOut, 1) + 1
        objListObject.SubItems(n) = ArrOut(n - 1, 0)
    Next

    'форматирование

    'лигатурная масса
    objListObject.SubItems(2) = FormatNumber(objListObject.SubItems(2), 2)
    curLigMassa = objListObject.SubItems(2)

    'проба
    objListObject.SubItems(3) = FormatNumber(objListObject.SubItems(3), 2)
    curProba = objListObject.SubItems(3)
 
    Set objListObject = lstViewObject.SelectedItem

    'добавляем массу выбранного объекта к массе по обязательству
    If blnConvert Then
        If cmbUnit.Text = "грамм" Then
            curLigMassa = IIf(strCB = "A99", (objFormat.Round((CCur(curLigMassa) * CCur(curProba) / 100), 0)), (objFormat.Round((CCur(curLigMassa) * CCur(curProba) / 100), 1)))
        ElseIf cmbUnit.Text = "унция" Then
            curLigMassa = objFormat.Round((CCur(curLigMassa) * CCur(curProba) / 100), 2)
        End If
    End If
    txtMassa.CurrencyValue = txtMassa.CurrencyValue + CCur(curLigMassa)

    GetMassaGramm()
    GetSumOblig()
    GetSumOpl()
    '------------------------------------------------

    lblObligInfo2.Caption = "Цена: " & txtCostUnit.CurrencyValue & Space(3) &
        "Масса: " & txtMassa.Text & Space(3) &
        "Сумма: " & txtSumOpl.Text
    FillDataObject = True
    Exit Function

ErrorCode:
    objError.UbsMsgRaise "FillDataObject", "ошибка выполнения"

End Function

Private Sub DefineArrStrNumInPart(ArrRez As Variant)
    On Error GoTo ErrorCode

    'получить список пар (номер части,номер в части)
    'одномерный массив

    If lstViewOblig.ListItems.Count > 0 Then
        ReDim ArrRez(lstViewOblig.ListItems.Count - 1)
        For n = 1 To lstViewOblig.ListItems.Count
            ArrRez(n - 1) = lstViewOblig.ListItems(n).SubItems(1)
        Next
    End If

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "DefineArrStrNumInPart", "ошибка выполнения"

End Sub

Private Function ClearOpl(g As Integer)
    ' очистка контролов обязательства оплаты
    ' необходимо при клике cmbContractType1, _
    cmbContractType2,
                       cmdContract1,
                       cmdContract2,
                       cmdListInstr
txtBIK(g).Text = ""
    txtName(g).Text = ""
    txtKS(g).Text = 0
    txtRS(g).Text = 0
    txtClient(g).Text = ""
    txtNote(g).Text = ""
    txtINN(g).Text = ""
    chkNotAkcept(g).Value = 0

    '---------------------------------------
End Function

Private Function CheckDatesOblig()
    On Error GoTo ErrorCode
    Dim dDateOpl As Variant
    Dim dDatePost As Variant

    Dim strCurrNumInPart As String, arrCurrInstr As Variant, strCurrRS As String
    Dim strCodCurrencyRS As String, strCodCurrencyOpl As String
    Dim strCodCurrencyRS_1 As String
    Dim objTools As Object

    MsgBox "пам.1", vbOKOnly + vbCritical, "Проверка свойств"
    
    Set objTools = CreateObject("LibTools.IUbsTools")

    CheckDatesOblig = True
    If txtTradeDate.DateValue = #1/1/2222# Or Not txtTradeDate.IsValid Then
        MsgBox "Укажите дату сделки", vbOKOnly + vbCritical, "Проверка свойств"
       SSTabs.Tabs(1).Selected = True
        txtTradeDate.SetFocus
        CheckDatesOblig = False
        Exit Function
    End If

    If lstViewOblig.ListItems.Count > 0 Then
        For n = 1 To lstViewOblig.ListItems.Count

            dDateOpl = CDate(lstViewOblig.ListItems(n).SubItems(2))
            dDatePost = CDate(lstViewOblig.ListItems(n).SubItems(3))

            If intVidTrade = 0 Then 'наличные сделки
                lstViewOblig.ListItems(n).SubItems(2) = txtTradeDate.DateValue
                lstViewOblig.ListItems(n).SubItems(3) = txtTradeDate.DateValue
            Else 'срочные сделки
                If dDatePost < txtTradeDate.DateValue Then
                    MsgBox "Дата поставки не может быть меньше даты сделки.", vbOKOnly + vbCritical, "Проверка свойств"
                    If SSTabs.Tabs(3).Selected And SSTabs1.Tabs(1).Selected Then
                        txtDatePost.SetFocus
                    End If
                    CheckDatesOblig = False
                    Exit Function
                End If

                If dDateOpl < txtTradeDate.DateValue Then
                    MsgBox "Дата оплаты не может быть меньше даты сделки.", vbOKOnly + vbCritical, "Проверка свойств"
                    If SSTabs.Tabs(3).Selected And SSTabs1.Tabs(1).Selected Then
                        txtDateOpl.SetFocus
                    End If
                    CheckDatesOblig = False
                    Exit Function
                End If
            End If
        Next
    End If
    'определяем код ЦБ валюты оплаты по ее идентификатору
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    objParamIn.Parameter("IdCurrency") = cmbCurrencyOpl.ItemData(DDX.MemberData("Идентификатор валюты оплаты"))
    UbsChannel1.Run "DefineCodCurrency", objParamIn, objParamOut
        strCodCurrencyOpl = objParamOut.Parameter("CodCB")

    If SSActiveTabs1.Tabs(1).Visible And
           cmbContractType2.ItemData(cmbContractType2.ListIndex) <> 0 Then
        strCodCurrencyRS = Mid(txtRS(0).Text, 6, 3)
        If Trim(txtBIK(0).Text) = strOurBIK Then ' если наш БИК - проверяем
            If Not objTools.IsEqualNumCodeCurr(strCodCurrencyOpl, strCodCurrencyRS) Then
                MsgBox "Валюта расчетного счета инструкции оплаты покупателя должна соответствовать валюте оплаты.", vbOKOnly + vbCritical, "Проверка свойств"
                 CheckDatesOblig = False
                Exit Function
            End If
        Else
            If txtRS(0).Text <> "00000000000000000000" Then
                If Not objTools.IsEqualNumCodeCurr(strCodCurrencyOpl, strCodCurrencyRS) Then
                    MsgBox "Валюта расчетного счета инструкции оплаты покупателя должна соответствовать валюте оплаты.", vbOKOnly + vbCritical, "Проверка свойств"
                    CheckDatesOblig = False
                    Exit Function
                End If
            End If
        End If
    End If

    If SSActiveTabs1.Tabs(2).Visible And
           cmbContractType1.ItemData(cmbContractType1.ListIndex) <> 0 Then
        strCodCurrencyRS_1 = Mid(txtRS(1).Text, 6, 3)
        If Trim(txtBIK(1).Text) = strOurBIK Then ' если наш БИК - проверяем
            If Not objTools.IsEqualNumCodeCurr(strCodCurrencyOpl, strCodCurrencyRS_1) Then
                MsgBox "Валюта расчетного счета инструкции оплаты продавца должна соответствовать валюте оплаты.", vbOKOnly + vbCritical, "Проверка свойств"
                 CheckDatesOblig = False
                Exit Function
            End If
        Else
            If txtRS(1).Text <> "00000000000000000000" Then
                If Not objTools.IsEqualNumCodeCurr(strCodCurrencyOpl, strCodCurrencyRS_1) Then
                    MsgBox "Валюта расчетного счета инструкции оплаты продавца должна соответствовать валюте оплаты.", vbOKOnly + vbCritical, "Проверка свойств"
                    CheckDatesOblig = False
                    Exit Function
                End If
            End If
        End If
    End If
        '-----------------------------------
    Set objTools = Nothing
    Exit Function

ErrorCode:
    objError.UbsMsgRaise "CheckDatesOblig", "ошибка выполнения"

End Function
Sub GetRateCurOblig()
    If txtCostUnit.CurrencyValue > 0 Then
        txtRateCurOblig.VariantValue = objFormat.Round((CDbl(txtCostCurOpl.CurrencyValue) / CDbl(txtCostUnit.CurrencyValue)), 10)
    Else
        txtRateCurOblig.CurrencyValue = 0
    End If
End Sub
Sub GetSumOpl()
    If chkSumInCurValue.Value = 1 Then ' если руками вводим сумму за ед. в валюте оплаты, то "скачем" от нее
        txtSumOpl.CurrencyValue = objFormat.Round(txtCostCurOpl.CurrencyValue * txtMassa.CurrencyValue, 2)
    Else
        'txtSumOpl.CurrencyValue = objFormat.Round(txtSumOblig.CurrencyValue * txtRateCurOblig.CurrencyValue, 2)
        txtSumOpl.CurrencyValue = objFormat.Round(txtSumOblig.CurrencyValue * txtRateCurOblig.VariantValue, 2)
    End If
End Sub
Sub GetSumOblig()
    txtSumOblig.CurrencyValue = objFormat.Round(txtCostUnit.CurrencyValue * txtMassa.CurrencyValue, 2)
End Sub
Sub GetMassaGramm()
    If strCB = "A99" Then
        txtMassaGramm.CurrencyValue = objFormat.Round(txtMassa.CurrencyValue * IIf(cmbUnit.Text = "унция", 31.1035, 1), 0)
    Else
        txtMassaGramm.CurrencyValue = objFormat.Round(txtMassa.CurrencyValue * IIf(cmbUnit.Text = "унция", 31.1035, 1), 1)
    End If
End Sub
Sub GetMassaPrecision()
    If cmbUnit.Text = "грамм" Then
        txtMassa.Precision = IIf(strCB = "A99", 0, 1)
    End If
    If cmbUnit.Text = "унция" Then
        txtMassa.Precision = 3
    Else
        txtMassa.Precision = 2
    End If
End Sub

Sub FillControlStorage()
    ' получить данные хранилища
    objParamIn.ClearParameters
    objParamOut.ClearParameters

    objParamIn.Parameter("IsExternalStorage") = chkExternalStorage.Value

    objParamIn.Parameter("Id") = DDX.MemberData("Инструкция по поставке")
    UbsChannel1.Run "GetStorage", objParamIn, objParamOut
    txtStorageCode.Text = objParamOut.Parameter("Code")
    txtStorageName.Text = objParamOut.Parameter("Name")

End Sub


Sub FillControlContract(ByVal lngIdContract, ByRef ContractCode As Object, ByRef ClientName As Object, ByRef lngIdClient As Long)
    ' получить данные контракта
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    
    objParamIn.Parameter("ID_CONTRACT") = lngIdContract
    
    UbsChannel1.Run "GetContractPM", objParamIn, objParamOut
    ContractCode.Text = objParamOut.Parameter("CODE_CONTRACT")
    ClientName.Text = objParamOut.Parameter("LONG_NAME")
    lngIdClient = objParamOut.Parameter("ID_CLIENT")
        
End Sub

'--------------------------------
Function GetVarValue(Var)
    Dim strResult, strTN
    Dim i, j
    Dim k, n

    strResult = TypeName(Var) & vbCrLf
    Select Case TypeName(Var)
        Case "Variant()"
            i = UBound(Var)
            j = UBound(Var, 2)
            For k = 0 To j
                For n = 0 To i
                    If Not IsArray(Var(n, k)) Then
                        strResult = strResult & GetStrFromType(Var(n, k)) & " : "
                    Else
                        strResult = strResult & GetStrFromArray(Var(n, k)) & " : "
                    End If
                Next
                strResult = strResult & vbCrLf
            Next
        Case Else
            strResult = strResult & Var & vbCrLf
    End Select
    
    MsgBox strResult
End Function

Function GetStrFromType(Var)
    If IsDate(Var) Then
        GetStrFromType = CDate(Var)
    Else
        GetStrFromType = Var
    End If
End Function
Function GetStrFromArray(varArr)
    Dim i, j
    Dim k, n, strResult
    i = UBound(varArr)
    j = UBound(varArr, 2)
    strResult = "| "
    For k = 0 To j
        For n = 0 To i
            If Not IsArray(varArr(n, k)) Then
                strResult = strResult & varArr(n, k) & " | "
             Else
                 strResult = strResult & "Array" & " | "
             End If
          Next
          strResult = strResult & vbCrLf
       Next
       GetStrFromArray = strResult
End Function
