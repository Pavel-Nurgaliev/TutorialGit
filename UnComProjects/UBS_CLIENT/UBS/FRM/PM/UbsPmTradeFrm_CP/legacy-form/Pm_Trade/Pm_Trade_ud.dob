On Error GoTo ErrorCode

Dim SSTabs_Right As Long, SSTabsPanel1_Right As Long
Dim SSTabs1_Right As Long, SSTabs1Panel1_Right As Long
Dim lstViewOblig_Right As Long, lstViewObject_Right As Long

If RHS < UserDocument.MinWidth Then RHS = UserDocument.MinWidth
    
    SSTabs.Width = RHS - 165
ucpParam.Width = RHS - 1000 '345
cmdExit.Left = RHS - 1395
cmdSave.Left = RHS - 2655
'------------------------------------------------------------
SSTabs_Right = 105
SSTabsPanel1_Right = 30
SSTabs1_Right = 60
SSTabs1Panel1_Right = 30
lstViewOblig_Right = 1335
lstViewObject_Right = 1290
'------------------------------------------------------------
cmdAddOblig.Left = RHS - (SSTabs_Right + SSTabsPanel1_Right + 240 + cmdAddOblig.Width)
cmdEditOblig.Left = RHS - (SSTabs_Right + SSTabsPanel1_Right + 240 + cmdEditOblig.Width)
cmdDelOblig.Left = RHS - (SSTabs_Right + SSTabsPanel1_Right + 240 + cmdDelOblig.Width)
'------------------------------------------------------------
lstViewOblig.Width = RHS - (
    SSTabs.Left + SSTabsPanel1.Left + lstViewOblig.Left +
    SSTabs_Right + SSTabsPanel1_Right + lstViewOblig_Right)
'------------------------------------------------------------
SSTabs1.Width = RHS - (
    SSTabs.Left + SSTabsPanel1.Left + SSTabs1.Left +
    SSTabs_Right + SSTabsPanel1_Right + SSTabs1_Right)
'------------------------------------------------------------
cmdAddObject.Left = RHS - (
    SSTabs_Right + SSTabsPanel1_Right + SSTabs1_Right + SSTabs1Panel1_Right +
    cmdAddObject.Width + 450)
'------------------------------------------------------------
cmdDelObject.Left = RHS - (
    SSTabs_Right + SSTabsPanel1_Right + SSTabs1_Right + SSTabs1Panel1_Right +
    cmdDelObject.Width + 450)
'------------------------------------------------------------
lstViewObject.Width = RHS - (
    SSTabs.Left + SSTabsPanel1.Left + SSTabs1.Left + SSTabs1Panel1.Left +
    lstViewObject.Left +
    SSTabs_Right + SSTabsPanel1_Right + SSTabs1_Right + SSTabs1Panel1_Right +
    lstViewObject_Right)
'------------------------------------------------------------
cmdApplayOblig.Left = SSTabs1.Width - 300 - cmdApplayOblig.Width - cmdExitOblig.Width - 60
cmdExitOblig.Left = SSTabs1.Width - 300 - cmdExitOblig.Width

Exit Property

