Private Sub UBSChild_NotifyCloseWindow(ByVal NumWindow As Integer)
    On Error GoTo ErrorCode

    If NumParentWindow <> 0 And NumParentWindow = NumWindow Then
        bParentWindowClose = True
        cmdExit_Click()
    End If
    If NumWindow = NumChildWinContract1 Then
        NumChildWinContract1 = 0
    End If
    If NumWindow = NumChildWinContract2 Then
        NumChildWinContract2 = 0
    End If
    If NumWindow = NumChildWinStorage Then
        NumChildWinStorage = 0
    End If
    If NumWindow = NumChildWinInstr Then
        NumChildWinInstr = 0
    End If
    If NumWindow = NumChildWinObject Then
        NumChildWinObject = 0
    End If
    If NumWindow = NumChildWinAccount Then
        NumChildWinAccount = 0
    End If
    If NumWindow = NumChildWinAccountsByObligation Then
        NumChildWinAccountsByObligation = 0
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "UBSChild_NotifyCloseWindow", "ошибка выполнения"

End Sub

Private Sub UBSChild_NotifyFixWindow(ByVal NumWindow As Variant, ByVal FixState As Boolean)
    On Error GoTo ErrorCode

    If NumWindow = Numwin And FixState Then
        'Если пришпиливают наше окно
        NumParentWindow = 0
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "UBSChild_NotifyFixWindow", "ошибка выполнения"

End Sub

