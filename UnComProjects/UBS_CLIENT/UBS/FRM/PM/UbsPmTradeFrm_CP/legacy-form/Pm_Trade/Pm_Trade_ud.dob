Private Sub UserDocument_Hide()
    On Error GoTo ErrorCode

    DDX.ReleaseControlData
    objStub.ReleaseUbsChannel
    
    Set objError = Nothing
    Set objInterfaces = Nothing
    Set objFormParam = Nothing
    Set objParamIn = Nothing
    Set objParamOut = Nothing
    Set objFocusCtrl = Nothing
    Set objStub = Nothing
    Set objFormat = Nothing
    Set objArray = Nothing
    
    Set objParamOblig = Nothing
    Set objParamTrade = Nothing

    If Not bParentWindowClose And IParent.IsExistParam(NumParentWindow, "RefreshGrid") = True Then
        IParent.ParamInfo(NumParentWindow, "RefreshGrid") = blnNeedRefresh
    End If

    If Not bParentWindowClose And IParent.IsExistParam(NumParentWindow, "SelectItem") = True And blnNeedSelect Then
        IParent.ParamInfo(NumParentWindow, "SelectItem") = DDX.MemberData("ID_TRADE")
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "UserDocument_Hide", "ошибка выполнения"

End Sub

Private Sub UserDocument_Initialize()
    On Error GoTo ErrorCode

    Set objFormParam = CreateObject("ToolPubs.IUbsParam")
    Set objError = CreateObject("ToolPubs.IUbsError")
    Set objInterfaces = CreateObject("ToolPubs.Interfaces")
    Set objStub = CreateObject("UbsAddFiledsStub.IUbsAddFiledsStub")
    Set objFormat = CreateObject("Lib3.IUbsFormat")
    Set objArray = CreateObject("Lib1.IUbsArray")
    ArrayParam()

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "UserDocument_Initialize", "ошибка выполнения"

End Sub

Private Function CheckParamForClose(ByVal NameParam As String) As Boolean
    On Error GoTo ErrorCode

    CheckParamForClose = False
    If NameParam = "LoadFromMenu" Or
       NameParam = "InitParamForm" Or
       NameParam = "InitParamGrid" Then
        CheckParamForClose = True
    End If

    Exit Function

ErrorCode:
    objError.UbsErrMsg "CheckParamForClose", "ошибка выполнения"

End Function

Private Sub UserDocument_KeyPress(KeyAscii As Integer)
    On Error GoTo ErrorCode

    Select Case KeyAscii
        Case 13
            KeyAscii = 0
            Select Case UserDocument.ActiveControl.Name
                Case "cmbContractType2"
                    If cmdContract2.Enabled Then
                        cmdContract2.SetFocus
                    Else
                        If cmbComission.Enabled And cmbComission.Visible Then
                            cmbComission.SetFocus
                        Else
                            SSTabs.Tabs(2).Selected = True
                            If SSTabs.Tabs(2).Selected Then cmdAddOblig.SetFocus
                        End If
                    End If
                Case "cmbUnit"
                    txtCostUnit.SetFocus
                Case "cmbCurOblig"
                    If cmbUnit.Enabled Then
                        cmbUnit.SetFocus
                    Else
                        txtCostUnit.SetFocus
                    End If
                Case "cmbComission"
                    SSTabs.Tabs(2).Selected = True
                    cmdAddOblig.SetFocus
                Case "cmdAddOblig", "cmdEditOblig"
                    SSTabs.Tabs(3).Selected = True
                    SSTabs1.SetFocus
                    SSTabs1.Tabs(1).Selected = True
                    If cmbNaprTrade.Enabled Then
                        cmbNaprTrade.SetFocus
                    Else
                        cmbCurOblig.SetFocus
                    End If
                Case "txtRateCurOblig"
                    If txtDatePost.Enabled Then
                        txtDatePost.SetFocus
                    Else
                        If txtMassa.Enabled Then
                            txtMassa.SetFocus
                        Else
                            If SSTabs1.Tabs(2).Enabled And SSTabs1.Tabs(2).Visible Then
                                SSTabs1.Tabs(2).Selected = True
                                cmdAddObject.SetFocus
                            Else
                                cmdApplayOblig.SetFocus
                            End If
                        End If
                    End If
                '-------------------------------------------------------------
                Case "txtBIK"
                    If SSActiveTabs1.Tabs(2).Selected Then
                        FillKS(1)
                        objInterfaces.NextCtrl
                    End If
                    If SSActiveTabs1.Tabs(1).Selected Then
                        FillKS(0)
                        objInterfaces.NextCtrl
                    End If
                Case "txtRS"
                    If SSActiveTabs1.Tabs(2).Selected Then
                        If Not CheckKey(1) Then
                            If txtRS(1).Enabled Then
                                txtRS(1).SetFocus
                            Else
                                cmdAccount(1).SetFocus
                            End If
                        Else
                            txtClient(1).SetFocus
                        End If
                    End If
                    If SSActiveTabs1.Tabs(1).Selected Then
                        'проверяем ключ счета
                        If Not CheckKey(0) Then
                            If txtRS(0).Enabled Then
                                txtRS(0).SetFocus
                            Else
                                cmdAccount(0).SetFocus
                            End If
                        Else
                            txtClient(0).SetFocus
                        End If
                    End If

                Case "txtMassa"
                    If txtDateOpl.Enabled Then
                        txtDateOpl.SetFocus
                    Else
                        If SSTabs1.Tabs(2).Enabled And SSTabs1.Tabs(2).Visible Then
                            SSTabs1.Tabs(2).Selected = True
                            cmdAddObject.SetFocus
                        Else
                            cmdApplayOblig.SetFocus
                        End If
                    End If
                Case "txtDateOpl"
                    If SSTabs1.Tabs(2).Enabled And SSTabs1.Tabs(2).Visible Then
                        SSTabs1.Tabs(2).Selected = True
                        cmdAddObject.SetFocus
                    Else
                        cmdApplayOblig.SetFocus
                    End If

                Case "txtINN"
                    'objInterfaces.NextCtrl
                    'проверяем ИНН
                    If SSActiveTabs1.Tabs(2).Selected Then
                        If Not CheckINN(1) Then
                            txtINN(1).SetFocus
                        Else
                            cmdSave.SetFocus
                        End If
                    End If
                    If SSActiveTabs1.Tabs(1).Selected Then
                        If Not CheckINN(0) Then
                            txtINN(0).SetFocus
                        Else
                            If SSActiveTabs1.Tabs(2).Visible Then
                                SSActiveTabs1.Tabs(2).Selected = True
                                cmdListInstr(1).SetFocus
                            Else
                                cmdSave.SetFocus
                            End If
                        End If
                    End If

                Case Else
                    objInterfaces.NextCtrl
            End Select
        Case 27
            KeyAscii = 0
            objInterfaces.PrevCtrl
    End Select

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "UserDocument_KeyPress", "ошибка выполнения"

End Sub

Private Sub InitDoc()
    Dim varOpl, varOpl_1 As Variant
    On Error GoTo ErrorCode

    Dim ArrOut As Variant
    Dim strName As String, varValue As Variant
    Dim intContractType1 As Integer, intContractType2 As Integer
    Dim intChkNDS As Integer, intChkExport As Integer

    blnNeedSelect = False
    blnNeedRefresh = False
    blnCloseForm = False

    blnAddOblig = False
    blnEditOblig = False
    
    Set objStub.UbsChannel = UbsChannel1
    
    chkCash(0).Visible = False ' возможность расчета через кассу только для наличных сделок с клиентом (брокерский договор с клиентом)
    chkCash(1).Visible = False ' возможность расчета через кассу только для наличных сделок с клиентом (брокерский договор с клиентом)

    FillCombos()      'Заполнение комбо-боксов

    'значение нашего БИКа
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    UbsChannel1.Run "FillOurBIK", objParamIn, objParamOut
    strOurBIK = objParamOut.Parameter("Наш БИК")

    'Заполнение полей
    If strRunParam = "EDIT" Then
        blnClearContr1 = False
        blnClearContr2 = False
        blnClearOblig = False
        DDX.InitMemberData("ID_TRADE") = RSIdent(0)
        DDX.MemberData("ID_TRADE") = RSIdent(0)

        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("ID_TRADE") = DDX.MemberData("ID_TRADE")
        UbsChannel1.Run "GetOneTrade", objParamIn, objParamOut

        If objParamOut.ExistParameter("IsNDS") Then
            intChkNDS = Abs(objParamOut.Parameter("IsNDS"))
        End If

        If objParamOut.ExistParameter("IsExport") Then
            intChkExport = Abs(objParamOut.Parameter("IsExport"))
        End If

        '6060
        If objParamOut.ExistParameter("IsExternalStorage") Then
            chkExternalStorage.Value = Abs(objParamOut.Parameter("IsExternalStorage"))
        End If

        ArrOut = objParamOut.Parameters
        For n = LBound(ArrOut, 2) To UBound(ArrOut, 2)
            strName = ArrOut(0, n)
            varValue = ArrOut(1, n)
            If Not (strName = "Инструкция по оплате для покупателя" Or strName = "Инструкция по оплате для продавца") Then
                DDX.InitMemberData(strName) = varValue
                DDX.MemberData(strName) = varValue
            End If
        Next

        '0 наличные
        '1 срочные
        intVidTrade = DDX.MemberData("Вид сделки")

        If Not intVidTrade = 0 Then
            cmdAccounts.Visible = True
            lblAccounts.Visible = True
        End If

        If objParamOut.ExistParameter("Инструкция по оплате для покупателя") Then
            varOpl = objParamOut.Parameter("Инструкция по оплате для покупателя")
        End If
        If objParamOut.ExistParameter("Инструкция по оплате для продавца") Then
            varOpl_1 = objParamOut.Parameter("Инструкция по оплате для продавца")
        End If

        ' получить данные хранилища
        Call FillControlStorage()

        '-------------------------------------------------------------------------
        'инициализация DDX-переменных, связанных с combo-контролами
        '----------------------
        'тип сделки
        For n = 0 To cmbTradeType.ListCount - 1
            If cmbTradeType.ItemData(n) = DDX.MemberData("TYPE_TRADE") Then
                DDX.InitMemberData("TYPE_TRADE") = n
                DDX.MemberData("TYPE_TRADE") = n
            End If
        Next
        '----------------------
        'вид поставки по сделке
        For n = 0 To cmbKindSupplyTrade.ListCount - 1
            If cmbKindSupplyTrade.ItemData(n) = DDX.MemberData("Вид поставки по сделке") Then
                DDX.InitMemberData("Вид поставки по сделке") = n
                DDX.MemberData("Вид поставки по сделке") = n
            End If
        Next
        '----------------------

        'идентификатор базовой валюты
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        UbsChannel1.Run "FillBaseCurrency", objParamIn, objParamOut
        idBaseCurrency = objParamOut.Parameter("Идентификатор базовой валюты")

        'валюта обязательства
        For n = 0 To cmbCurOblig.ListCount - 1
            If cmbCurOblig.ItemData(n) = idBaseCurrency Then
                DDX.MemberData("Идентификатор валюты обязательства") = n
            End If
        Next
        '---------------------------------------------------------
        '--------------------------------
        'валюта оплаты
        For n = 0 To cmbCurrencyOpl.ListCount - 1
            If cmbCurrencyOpl.ItemData(n) = DDX.MemberData("Идентификатор валюты оплаты") Then
                DDX.InitMemberData("Идентификатор валюты оплаты") = n
                DDX.MemberData("Идентификатор валюты оплаты") = n
            End If
        Next
        '----------------------
        'драг.металл
        blnCurrencyPostClick = False

        For n = 0 To cmbCurrencyPost.ListCount - 1
            If cmbCurrencyPost.ItemData(n) = DDX.MemberData("Идентификатор драг.металла") Then
                DDX.InitMemberData("Идентификатор драг.металла") = n
                DDX.MemberData("Идентификатор драг.металла") = n
            End If
        Next

        strCurrencyPost = cmbCurrencyPost.Text
        '-------------------------------------------------------------------
        'стороны сделки

        'продавец
        Call FillControlContract(DDX.MemberData("Продавец"), txtContractCode1, txtClientName1, IdClient1)
        intContractType1 = objParamOut.Parameter("TYPE_CONTRACT")

        'покупатель
        Call FillControlContract(DDX.MemberData("Покупатель"), txtContractCode2, txtClientName2, IdClient2)
        intContractType2 = objParamOut.Parameter("TYPE_CONTRACT")

        For n = 0 To cmbContractType1.ListCount - 1
            If cmbContractType1.ItemData(n) = intContractType1 Then
                cmbContractType1.ListIndex = n
            End If
        Next
        For n = 0 To cmbContractType2.ListCount - 1
            If cmbContractType2.ItemData(n) = intContractType2 Then
                cmbContractType2.ListIndex = n
            End If
        Next
        '----------------------
        'идентификатор комиссии
        For n = 0 To cmbComission.ListCount - 1
            If cmbComission.ItemData(n) = DDX.MemberData("Идентификатор комиссии") Then
                DDX.InitMemberData("Идентификатор комиссии") = n
                DDX.MemberData("Идентификатор комиссии") = n
            End If
        Next
        '------------------------------------------------------------------
        'заполнить список обязательств
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("ID_TRADE") = DDX.MemberData("ID_TRADE")
        UbsChannel1.Run "FillObligPM", objParamIn, objParamOut
        FillListOblig objParamOut.Parameter("Обязательства сделки")
        ' при вынесении инструкций из обязательства, параметром обязательства остаются _
        одни объекты, которых при обезличенной сделке нет, следовательно параметра _
        "Обязательства сделки2" может и не быть
        If objParamOut.ExistParameter("Обязательства сделки2") Then
            objParamOblig.Parameters =
                objParamOut.Parameter("Обязательства сделки2").Parameters
        End If
        '------------------------------------------------------------------
        ' заполняем Инструкции по Оплате
        Call FillControlInstrOplata(0, varOpl)

        Call FillControlInstrOplata(1, varOpl_1)

        If intVidTrade = 0 Then
            If intContractType1 = 1 Then
                If CStr(txtBIK(1).Text) = CStr(strOurBIK) And CStr(Left(txtRS(1).Text, 5)) = "20202" Then
                    chkCash(1).Visible = True
                    chkCash(1).Value = 1
                    cmdListInstr(1).Visible = False
                    lblCheckInstr(1).Visible = False
                End If
            End If
            If intContractType2 = 1 Then
                If CStr(txtBIK(0).Text) = CStr(strOurBIK) And CStr(Left(txtRS(0).Text, 5)) = "20202" Then
                    chkCash(0).Visible = True
                    chkCash(0).Value = 1
                    cmdListInstr(0).Visible = False
                    lblCheckInstr(0).Visible = False
                End If
            End If
        End If
        '------------------------------------------------------------------

        ' НДС и Экспортная
        If Not IsEmpty(intChkExport) And intChkNDS = 1 Then
            chkNDS.Visible = True
            chkNDS.Value = 1
        Else
            UpdateDisplayNDS()
        End If

        If Not IsEmpty(intChkExport) And intChkExport = 1 Then
            chkExport.Visible = True
            chkExport.Value = 1
        Else
            UpdateDisplayExport()
        End If
        '------------------------------------------------------------------

        'Проверка, если были операции по сделке, то редактировать сделку нельзя
        objParamIn.Parameter("ID_TRADE") = DDX.MemberData("ID_TRADE")
        UbsChannel1.Run "PMCheckOperationByTrade", objParamIn, objParamOut
        blnWasOper = objParamOut.Parameter("Was_Operation")
        '------------------------------------------------------------------
    Else 'ADD
        DDX.InitMemberData("ID_TRADE") = Empty
        DDX.InitMemberData("DATE_TRADE") = #1/1/2222#
        DDX.InitMemberData("NUM_TRADE") = ""
        DDX.InitMemberData("IS_COMPOSIT") = Empty
        DDX.InitMemberData("TYPE_TRADE") = -1
        DDX.InitMemberData("Вид сделки") = -1
        DDX.InitMemberData("Вид поставки по сделке") = -1
        DDX.InitMemberData("Идентификатор валюты оплаты") = -1
        DDX.InitMemberData("Инструкция по поставке") = 0
        '----------------------------------------------------------
        DDX.InitMemberData("Идентификатор драг.металла") = -1
        DDX.InitMemberData("Идентификатор комиссии") = -1
        DDX.MemberData("DATE_TRADE") = Date
        DDX.MemberData("Вид поставки по сделке") = 1
        DDX.MemberData("Вид сделки") = intVidTrade
        '----------------------
        'драг.металл
        blnCurrencyPostClick = False

        For n = 0 To cmbCurrencyPost.ListCount - 1
            If cmbCurrencyPost.ItemData(n) = 1001 Then
                DDX.MemberData("Идентификатор драг.металла") = n
            End If
        Next

        strCurrencyPost = cmbCurrencyPost.Text
        '--------------------
        'идентификатор базовой валюты
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        UbsChannel1.Run "FillBaseCurrency", objParamIn, objParamOut
        idBaseCurrency = objParamOut.Parameter("Идентификатор базовой валюты")

        'валюта оплаты
        For n = 0 To cmbCurrencyOpl.ListCount - 1
            If cmbCurrencyOpl.ItemData(n) = idBaseCurrency Then
                DDX.MemberData("Идентификатор валюты оплаты") = n
            End If
        Next
        'валюта обязательства
        For n = 0 To cmbCurOblig.ListCount - 1
            If cmbCurOblig.ItemData(n) = idBaseCurrency Then
                DDX.MemberData("Идентификатор валюты обязательства") = n
            End If
        Next
        '------------------------------------------------------------

        '----------------------
        'стороны сделки
        DDX.InitMemberData("Продавец") = Empty 'id договора
        DDX.InitMemberData("Покупатель") = Empty 'id договора

        blnCheckType2 = False
        cmbContractType1.ListIndex = 0 '-1
        cmbContractType2.ListIndex = 0 '-1
        blnCheckType2 = True

        'номер в части
        DDX.InitMemberData("Макс.номер в части 1") = 0
        DDX.InitMemberData("Макс.номер в части 2") = 0
        DDX.MemberData("Макс.номер в части 1") = 0
        DDX.MemberData("Макс.номер в части 2") = 0
    End If

    '======================================================
    'видимость контролов
    '------------------------------------------------------
    'эти контролы включаться не будут

    'Основные
    'cmbCurrencyOpl.Enabled = False 'будем отрабатывать оплату в валюте
    txtContractCode1.Enabled = False
    txtClientName1.Enabled = False
    txtContractCode2.Enabled = False
    txtClientName2.Enabled = False

    'Данные, Обязательство
    txtSumOpl.Enabled = False

    'Данные, Инструкция по оплате
    txtKS(0).Enabled = False
    txtName(0).Enabled = False
    txtKS(1).Enabled = False
    txtName(1).Enabled = False

    'Данные, Инстукция по поставке
    txtStorageCode.Enabled = False
    txtStorageName.Enabled = False
    '------------------------------------------------------
    'эти контролы включаются в процессе работы

    chkIsComposit.Visible = CBool(intVidTrade <> 0)

    'Основные
    cmdContract1.Enabled = False
    cmdContract2.Enabled = False

    'Данные, Обязательство
    txtMassa.Enabled = False
    cmbNaprTrade.Text = "прямая"
    cmbNaprTrade.Enabled = False

    'Данные, Инструкция по оплате
    txtRS(0).Enabled = False
    cmdAccount(0).Enabled = False
    txtRS(1).Enabled = False
    cmdAccount(1).Enabled = False
    '======================================================
    'видимость вкладок
    SSTabs.Tabs(3).Enabled = CBool(IsExistOblig())

    DDX.UpdateData(False)
    ucpParam.UbsAddFields = objStub
    ucpParam.Refresh
    'получение Курса пересчета валюты обязательства и Цену за един. в валюте обязательства
    GetRate_CB()
    GetRateForPM()
    '----------------------------------
    If strRunParam = "EDIT" Then
        If blnWasOper Then
            'Call EnableWindow(SSTabsPanel2.hwnd, 0&) ' обязательства
            Call EnableWindow(SSTabsPanel4.hwnd, 0&) ' Поставка
            Call EnableWindow(SSActiveTabPanel1.hwnd, 0&) ' Оплата
            Call EnableWindow(SSActiveTabPanel2.hwnd, 0&) ' Дополнительные
            Call EnableWindow(SSTabs1Panel1.hwnd, 0&) ' обязательство
            cmdAddOblig.Enabled = False
            cmdEditOblig.Enabled = False
            cmdDelOblig.Enabled = False
            Call EnableWindow(SSTabs1Panel4.hwnd, 0&) ' объекты
            Call EnableWindow(SSTabsPanel1.hwnd, 0&)
            cmdSave.Enabled = False
        End If
    End If
    blnCurrencyPostClick = True

    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "InitDoc", "ошибка выполнения"

End Sub

Private Sub FillCombos()
    On Error GoTo ErrorCode

    Dim arrItem As Variant

    objParamIn.ClearParameters
    objParamOut.ClearParameters
    objParamIn.Parameter("ID_PATTERN") = 1
    UbsChannel1.Run "TradeCombo_FillPM", objParamIn, objParamOut

    'тип сделки
    cmbTradeType.AddItem "тип1", 0
    cmbTradeType.ItemData(0) = 1

    'направление сделки
    cmbNaprTrade.AddItem "прямая", 0
    cmbNaprTrade.ItemData(0) = 1

    cmbNaprTrade.AddItem "обратная", 1
    cmbNaprTrade.ItemData(1) = 2

    ' Единица измерения веса
    cmbUnit.List(0) = "грамм"
    cmbUnit.ItemData(0) = 1
    cmbUnit.List(1) = "унция"
    cmbUnit.ItemData(0) = 2
    cmbUnit.ListIndex = 0
    '==================================================================

    'типы договоров для поставщика
    If objParamOut.ExistParameter("Типы договоров") Then
        arrItem = objParamOut.Parameter("Типы договоров")
        For n = 0 To UBound(arrItem, 2)
            cmbContractType1.AddItem arrItem(1, n), n
            cmbContractType1.ItemData(n) = arrItem(0, n)
        Next
    Else
        cmbContractType1.AddItem "", 0
    End If

    'типы договоров для покупателя
    If objParamOut.ExistParameter("Типы договоров") Then
        arrItem = objParamOut.Parameter("Типы договоров")
        For n = 0 To UBound(arrItem, 2)
            cmbContractType2.AddItem arrItem(1, n), n
            cmbContractType2.ItemData(n) = arrItem(0, n)
        Next
    Else
        cmbContractType2.AddItem "", 0
    End If

    'валюты поставки
    If objParamOut.ExistParameter("Валюты поставки") Then
        arrItem = objParamOut.Parameter("Валюты поставки")
        For n = 0 To UBound(arrItem, 2)
            cmbCurrencyPost.AddItem arrItem(1, n), n
            cmbCurrencyPost.ItemData(n) = arrItem(0, n)
        Next
    Else
        cmbCurrencyPost.AddItem "", 0
    End If

    'валюты оплаты и обязательства
    If objParamOut.ExistParameter("Валюты оплаты") Then
        arrCurrency = objParamOut.Parameter("Валюты оплаты")
        For n = 0 To UBound(arrCurrency, 2)
            cmbCurrencyOpl.AddItem arrCurrency(1, n), n
            cmbCurrencyOpl.ItemData(n) = arrCurrency(0, n)
            ' заполнение комбобокса валюта обязательства
            cmbCurOblig.List(n) = arrCurrency(1, n)
            cmbCurOblig.ItemData(n) = arrCurrency(0, n)
            '------------------------------------------------------
        Next
    Else
        cmbCurrencyOpl.AddItem "", 0
    End If

    'вид поставки по сделке
    cmbKindSupplyTrade.AddItem "обезличенная", 0
    cmbKindSupplyTrade.ItemData(0) = 1

    cmbKindSupplyTrade.AddItem "физическая", 1
    cmbKindSupplyTrade.ItemData(1) = 2

    'список комиссий
    If objParamOut.ExistParameter("Список комиссий") Then
        arrItem = objParamOut.Parameter("Список комиссий")
        For n = 0 To UBound(arrItem, 2)
            cmbComission.AddItem arrItem(1, n), n
            cmbComission.ItemData(n) = arrItem(0, n)
        Next
    Else
        cmbComission.AddItem "", 0
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "FillCombos", "ошибка выполнения"

End Sub

Private Sub UserDocument_KeyDown(KeyCode As Integer, Shift As Integer)
    On Error GoTo ErrorCode
    If Shift = 2 And KeyCode = vbKeyTab Then
        Set objFocusCtrl = UserDocument.ActiveControl
        intFocusTab = SSTabs.SelectedTab.Index
        IParent.LoaderParamInfo(0, "NextWindow") = Numwin
    End If

    Exit Sub

ErrorCode:
    objError.UbsErrMsg "UserDocument_KeyDown", "ошибка выполнения"

End Sub

Private Sub InitChannel()
    On Error GoTo ErrorCode

    UbsChannel1.HostAddress = IParent.LoaderParamInfo(Numwin, "HostAddress")
    UbsChannel1.UserGUID = IParent.LoaderParamInfo(Numwin, "GuidSession")
    UbsChannel1.ParentHwnd = UserDocument.hwnd
    UbsChannel1.LoadResource = "VBS:UBS_VBD\PM\Pm_Trade.vbs"
 
    Set objParamIn = CreateObject("Lib2.IUbsParam")
    Set objParamOut = CreateObject("Lib2.IUbsParam")
    Set objParamOblig = CreateObject("Lib2.IUbsParam")
    Set objParamTrade = CreateObject("Lib2.IUbsParam")
    
    Exit Sub

ErrorCode:
    objError.UbsMsgRaise "InitChannel", "ошибка выполнения"

End Sub

Private Function CheckData() As Boolean
    On Error GoTo ErrorCode

    CheckData = True
    If cmbContractType1.ItemData(cmbContractType1.ListIndex) =
        cmbContractType2.ItemData(cmbContractType2.ListIndex) Then
        MsgBox "Тип договора покупателя и продавца не может совпадать", vbOKOnly + vbCritical, "Проверка свойств"
        CheckData = False
        Exit Function
    End If

    If cmbKindSupplyTrade.ListIndex = -1 Then
        MsgBox "Не указан вид поставки по сделке", vbExclamation + vbOKOnly, "Ошибка ввода"
        If SSTabs.Tabs(1).Selected Then cmbKindSupplyTrade.SetFocus
        CheckData = False
        Exit Function
    End If

    If txtTradeDate.DateValue = #1/1/2222# Or Not txtTradeDate.IsValid Then
        MsgBox "Не указана дата сделки", vbOKOnly + vbCritical, "Проверка свойств"
        If SSTabs.Tabs(1).Selected Then txtTradeDate.SetFocus
        CheckData = False
        Exit Function
    End If

    If Len(Trim(txtTradeNum.Text)) = 0 Then
        MsgBox "Не указан номер сделки", vbExclamation + vbOKOnly, "Ошибка ввода"
        SSTabs.Tabs(1).Selected = True
        txtTradeNum.SetFocus
        CheckData = False
        Exit Function
    End If

    If cmbCurrencyPost.ListIndex = -1 Then
        MsgBox "Не выбран драг.металл", vbExclamation + vbOKOnly, "Ошибка ввода"
        If SSTabs.Tabs(1).Selected Then cmbCurrencyPost.SetFocus
        CheckData = False
        Exit Function
    End If

    If cmbCurrencyOpl.ListIndex = -1 Then
        MsgBox "Не выбрана валюта оплаты", vbExclamation + vbOKOnly, "Ошибка ввода"
        If SSTabs.Tabs(1).Selected Then cmbCurrencyOpl.SetFocus
        CheckData = False
        Exit Function
    End If
    If cmbCurOblig.ListIndex = -1 Then
        MsgBox "Не выбрана валюта обязательства", vbExclamation + vbOKOnly, "Ошибка ввода"
        SSTabs.Tabs(3).Selected = True
        SSTabs1.Tabs(1).Selected = True
        cmbCurOblig.SetFocus
        CheckData = False
        Exit Function
    End If

    If cmbUnit.ListIndex = -1 Then
        MsgBox "Не указана единица измерения веса", vbExclamation + vbOKOnly, "Ошибка ввода"
        SSTabs.Tabs(3).Selected = True
        SSTabs1.Tabs(1).Selected = True
        cmbUnit.SetFocus
        CheckData = False
        Exit Function
    End If

    '------------------------------------------------------------------

    If Len(txtContractCode1.Text) = 0 Then
        MsgBox "Не выбран продавец", vbExclamation + vbOKOnly, "Ошибка ввода"
        If SSTabs.Tabs(1).Selected Then
            If cmdContract1.Enabled Then
                cmdContract1.SetFocus
            Else
                cmbContractType1.SetFocus
            End If
        End If
        CheckData = False
        Exit Function
    End If

    If Len(txtContractCode2.Text) = 0 Then
        MsgBox "Не выбран покупатель", vbExclamation + vbOKOnly, "Ошибка ввода"
        If SSTabs.Tabs(1).Selected Then
            If cmdContract2.Enabled Then
                cmdContract2.SetFocus
            Else
                cmbContractType2.SetFocus
            End If
        End If
        CheckData = False
        Exit Function
    End If

    If lstViewOblig.ListItems.Count = 0 Then
        MsgBox "Отсутствуют обязательства", vbExclamation + vbOKOnly, "Ошибка ввода"
        CheckData = False
        Exit Function
    End If

    If SSActiveTabs1.Tabs(1).Visible = True Then
        If Len(Trim(txtBIK(0).Text)) = 0 Or
          txtKS(0).Text = "0" Or
          txtRS(0).Text = "0" Then
            MsgBox "Отсутствует инструкция по оплате у покупателя", vbExclamation + vbOKOnly, "Ошибка ввода"
          SSTabs.Tabs(5).Selected = True
            SSActiveTabs1.Tabs(1).Selected = True
            cmdListInstr(0).SetFocus
            CheckData = False
            Exit Function
        End If
    End If

    If SSActiveTabs1.Tabs(2).Visible And SSActiveTabs1.Tabs(2).Enabled Then
        If Len(Trim(txtBIK(1).Text)) = 0 Or
          txtKS(1).Text = "0" Or
          txtRS(1).Text = "0" Then
            MsgBox "Отсутствует инструкция по оплате у продавца", vbExclamation + vbOKOnly, "Ошибка ввода"
          SSTabs.Tabs(5).Selected = True
            SSActiveTabs1.Tabs(2).Selected = True
            cmdListInstr(1).SetFocus
            CheckData = False
            Exit Function
        End If
    End If
    '-----------------------------------------------------
    'проверка наличия списка объектов по всем обязательствам (для физической сделки)
    If cmbKindSupplyTrade.Text = "физическая" Then
        For n = 1 To lstViewOblig.ListItems.Count
            If Not objParamOblig.ExistParameter("Object" & lstViewOblig.ListItems(n).SubItems(1)) Then
                MsgBox "Отсутствует список объектов по обязательству", vbExclamation + vbOKOnly, "Ошибка ввода"
                CheckData = False
                Exit Function
            End If
        Next
    End If

    ' проверка инструкции по поставке
    If SSTabs.Tabs(4).Visible Then
        If Len(Trim(txtStorageCode.Text)) = 0 Then
            MsgBox "Отсутствует инструкция по поставке", vbExclamation + vbOKOnly, "Ошибка ввода"
          SSTabs.Tabs(4).Selected = True
            cmdStorage.SetFocus
            CheckData = False
            Exit Function
        End If
    End If

    Exit Function

ErrorCode:
    objError.UbsMsgRaise "CheckData", "ошибка выполнения"

End Function

Private Sub cmdContract1_Click()
    On Error GoTo ErrorCode

    If Not CBool(chkCash(1).Value) Then ClearOpl(1)

    If NumChildWinContract1 <> 0 Then
        IParent.SetFocusToWindow NumChildWinContract1
        Exit Sub
    End If
    cmdContract1.Enabled = False
    DDX.UpdateData True

    'список в зависимости от выбранного типа договора
    Select Case cmbContractType1.ItemData(cmbContractType1.ListIndex)
        Case 1
            IParent.GetWindow "UBS_FLT\PM\BROKER.flt", NumChildWinContract1
        Case 2
            IParent.GetWindow "UBS_FLT\PM\CONTRACT.flt", NumChildWinContract1
    End Select

    If NumChildWinContract1 <> 0 Then
        Dim objGridF As Object
        Dim InitParamGrid As Variant
        ReDim InitParamGrid(5)
        Set objGridF = IParent.ParamInfo(NumChildWinContract1, "UbsGridList")
        If IParent.IsExistParam(NumChildWinContract1, "InitParamGrid") Then
            InitParamGrid(0) = Numwin
            InitParamGrid(2) = True
            InitParamGrid(5) = 1
            IParent.ParamInfo(NumChildWinContract1, "InitParamGrid") = InitParamGrid
            If IParent.IsExistParam(NumChildWinContract1, "SelectItem") Then
                IParent.ParamInfo(NumChildWinContract1, "SelectItem") = DDX.MemberData("Продавец")
            End If
            IParent.SetFocusToWindow NumChildWinContract1
        End If
    End If
    cmdContract1.Enabled = True
    Exit Sub

ErrorCode:
    objError.UbsErrMsg "cmdContract1_Click", "ошибка выполнения"

End Sub

