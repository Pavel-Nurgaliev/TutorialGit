        IParent.GetWindow "UBS_FLT\PM\PM_FOR_OPERATION_SALE.flt", NumChildWinObject
    Else
        IParent.GetWindow "UBS_FLT\PM\PM_FOR_OPERATION.flt", NumChildWinObject
    End If
    '-------------------------------------------------------------------------------------

    If NumChildWinObject <> 0 Then
        Dim objGridF As Object
        Dim InitParamGrid As Variant
        ReDim InitParamGrid(2)
   
        Set objGridF = IParent.ParamInfo(NumChildWinObject, "UbsGridList")
        objGridF.ClearWhereList
        objGridF.AddWhereItem "Наименование драгоценного металла", 4, cmbCurrencyPost.ItemData(cmbCurrencyPost.ListIndex)

        If IParent.IsExistParam(NumChildWinObject, "InitParamGrid") Then
            InitParamGrid(0) = Numwin
            InitParamGrid(2) = True
            IParent.ParamInfo(NumChildWinObject, "InitParamGrid") = InitParamGrid
            IParent.SetFocusToWindow NumChildWinObject
        End If
    End If
    cmdAddObject.Enabled = True
    blnAddObject = True
    Exit Sub

ErrorCode:
