Private Sub txtMonthBeg_LostFocus()

 On Error GoTo ErrorCode
    
    If Trim(txtMonthBeg.Text) = "" Then
        Exit Sub
    End If
    
    If CInt(txtMonthBeg.Text) < 1 Or CInt(txtMonthBeg.Text) > 12 Then
        MsgBox "Ошибка в дате!", vbCritical + vbOKOnly, m_strCaptionForm
        objInterfaces.GoToCtrl txtMonthBeg
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "txtMonthBeg_LostFocus", "ошибка выполнения"
End Sub

Private Sub txtMonthEnd_LostFocus()
    
 On Error GoTo ErrorCode
    
    If Trim(txtMonthEnd.Text) = "" Then
        Exit Sub
    End If
    
    If CInt(txtMonthEnd.Text) < 1 Or CInt(txtMonthEnd.Text) > 12 Then
        MsgBox "Ошибка в дате!", vbCritical + vbOKOnly, m_strCaptionForm
        objInterfaces.GoToCtrl txtMonthEnd
        Exit Sub
    End If
    
    If Trim(txtYearEnd.Text) <> "" Then
        txtDayEnd.Text = GetDayEnd(txtMonthEnd.Text, txtYearEnd.Text)
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "txtMonthEnd_LostFocus", "ошибка выполнения"
End Sub

Private Sub txtYearBeg_LostFocus()
    
 On Error GoTo ErrorCode
    
    If Trim(txtYearBeg.Text) = "" Then
        Exit Sub
    End If
    
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "txtYearBeg_LostFocus", "ошибка выполнения"
End Sub

Private Sub txtYearEnd_LostFocus()
    
On Error GoTo ErrorCode
    
    If Trim(txtYearEnd.Text) = "" Then
        Exit Sub
    End If
    
    If Trim(txtMonthEnd.Text) <> "" Then
        txtDayEnd.Text = GetDayEnd(txtMonthEnd.Text, txtYearEnd.Text)
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "txtYearEnd_LostFocus", "ошибка выполнения"
End Sub

