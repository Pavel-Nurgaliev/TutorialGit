   If RHS < 7080 Then RHS = 7995
   
    subPayment.Height = RHS - 850
    TabMain.Height = RHS - 850
    TabAdd.Height = RHS - 850
    SSActiveTabPanel1.Height = RHS - 850
    SSActiveTabPanel2.Height = RHS - 850
    SSActiveTabPanel3.Height = RHS - 850
    AddProperties.Height = SSActiveTabPanel2.Height - 600
    
    lblQttySubs.Top = RHS - 800
    txtQttySubs.Top = RHS - 800
    lblCommonSumma.Top = RHS - 800
    curCommonSumma.Top = RHS - 800
    curTotalSumma.Top = RHS - 800
    txtGRPId.Top = RHS - 800
    
    cmdCashSymb.Top = RHS - 450
    btnPattern.Top = RHS - 450
    btnSave.Top = RHS - 450
    btnCalc.Top = RHS - 450
    btnExit.Top = RHS - 450
    
    
    chkPrintForm.Top = RHS - 800

   
   'AddProperties.Height = SSActiveTabPanel2.Height - 600
   
   
End Property

Private Property Get UBSChild_ImageList(Key As String) As Object
    Key = "CARD"
End Property

Private Property Get UBSChild_IsExistParam(ByVal NameParam As String) As Boolean
    UBSChild_IsExistParam = objFormParam.ExistParameter(NameParam)
End Property

Private Sub UBSChild_NotifyCloseWindow(ByVal NumWindow As Integer)
    
    If NumWindow = NumChildWin Then
       NumChildWin = 0
    End If
    
    If NumWindow = NumChildWinThirdPerson Then
        NumChildWinThirdPerson = 0
    End If
    
    If NumWindow = NumChildWinContract Then
       NumChildWinContract = 0
    End If
    
    If NumWindow = NumChildWinAttributeRecip Then
       NumChildWinAttributeRecip = 0
    End If
    
    If NumWindow = NumChildWinPaymDic Then
       NumChildWinPaymDic = 0
    End If
       
    If NumWindow = NumChildWinPayments Then
       NumChildWinPayments = 0
    End If
           
    If NumWindow = NumChildWinTariff Then
        NumChildWinTariff = 0
    End If
       
    If NumParentWindow <> 0 And NumParentWindow = NumWindow Then
        bParentWindowClose = True
        'Если закрываемое окно - родительское и оно не пришпилено вызвать процедуру закрытия окна
        btnExit_Click
    End If
    
End Sub

Private Sub UBSChild_NotifyFixWindow(ByVal NumWindow As Variant, ByVal FixState As Boolean)
    If NumWindow = NumWin And FixState Then
        'Если пришпиливают наше окно
        NumParentWindow = 0
    End If
End Sub

Private Property Let UBSChild_NumWindow(ByVal RHS As Integer)
    NumWin = RHS
End Property

Private Property Let UBSChild_ParamInfo(ByVal NameParam As String, ByVal RHS As Variant)
    Dim ItemArray As Variant
    Dim Grid As Object
    Dim Filter As Object
    Dim n, nCount, iListItem
    'Dim strIP_Address As String, Prog_Id As String
    
On Error GoTo ErrorCode

    Dim version
    Set objInterfaces = CreateObject("ToolPubs.Interfaces")
    btnExit.ToolTipText = objInterfaces.GetVersion(App)

    m_strCaptionForm = "Платеж"
   
    If Not objFormParam.ExistParameter(NameParam) Then
        objErr.UbsErrRaise "Проверка поддержки параметров", "Параметер '" & NameParam & "' не поддерживается"
    End If
    
    Select Case NameParam
    
        Case "InitParamViewer"
            Initialize
            NumParentWindow = RHS(0)
            ItemArray = RHS(1)
            
            m_IdPayment = 0
            InitDoc
            m_IdPayment = ItemArray(0)
            fromFoAsClient = -1
            
        Case "InitParamForm"
            Initialize
            NumParentWindow = RHS(0)
            
            ItemArray = RHS(1)
            
            StrCommand = RHS(2)
            
            StrCommand_Source = StrCommand  ' исходное значение!

            m_IdContract = 0
            m_blnChangeContract = False
            blnGroup = False
            m_IdGroup = 0
            blnAddClient = False
            m_IdPayment = 0
            blnAddparam = False
            calledFromFrontOffice = False
            FoSettingValue = -1
                        
            Select Case StrCommand
            Case "ADD", "GROUP_ADD", "GROUP_PROCEED", "ADD_FROM_CLIENT":
                
                'Если форма в режиме добавления
                If StrCommand = "ADD_FROM_CLIENT" Then
                    If Not IsEmpty(ItemArray) Then
                        m_IdClient = ItemArray(0)
                        If UBound(ItemArray) >= 2 Then
                            calledFromFrontOffice = ItemArray(1)
                            FoSettingValue = ItemArray(1)
                            AccClientPay.Text = ItemArray(2)
                            If calledFromFrontOffice Then
                                lb_NumFolder.Visible = True
                                tb_NumFolder.Visible = True
                            End If
                            If (UBound(ItemArray) >= 3) Then fromFoAsClient = ItemArray(3) + 1
                        End If
                    Else
                        MsgBox "Не Клиент банка", vbCritical, m_strCaptionForm
                        btnExit_Click
                        Exit Property
                    End If
                    blnAddClient = True
                    StrCommand = "ADD"
                End If
                        
                'Проверяем, что при добавлении группового платежа есть платеж в который добавляется
                If StrCommand = "GROUP_PROCEED" Then
                    If Not IsEmpty(ItemArray) Then
                        m_IdPayment = ItemArray(0)
                    Else
                        MsgBox "Не выбран платеж для добавления", vbCritical, m_strCaptionForm
                        btnExit_Click
                        Exit Property
                    End If
                End If

                If (StrCommand = "GROUP_ADD") Or (StrCommand = "GROUP_PROCEED") Then   ' запуск формы из списка групповых платежей
                    blnGroup = True
                    If StrCommand = "GROUP_PROCEED" Then
                        Call GetGroupIDByPaymentID(ItemArray(0))
                        '----------------------------------
                        'Трубаков В   10.07.2007
                        If m_IdGroup = -1 Then
                            MsgBox "Данный платеж анулирован", vbCritical, m_strCaptionForm
                            btnExit_Click
                            Exit Property
                        End If
                        '----------------------------------
                    End If
                    StrCommand = "ADD"
                End If
                
                Call AddProcInit
                
                Call IsAutoPeriod
                
            Case "ADD_INCOMING":
            
                StrCommand = "ADD"
                
                'Идентификатор группового платежа
                IdGroupIncoming = CStr(RHS(3)(0))
                'Идентификатор основного платежа
                IdMainIncoming = CStr(RHS(3)(1))

                m_strCaptionForm = "Платеж в составе группового ID = " & IdGroupIncoming

                Call AddProcInit
                'Если флаг flase, значит какая-то ошибка и надо прерваться
                If blnCheckIncoming = False Then
                    Exit Property
                End If
                                     
                Call UpdateGroupInfo
                
                Call IsAutoPeriod
                                     
            Case "ADD_PARAM":
            
                Dim arrValue As Variant
                Dim Value As Variant
                Dim i As Integer
                Dim j As Integer
                
                outerSystemInfo = RHS(3)
                
                blnAddparam = True
                
                StrCommand = "ADD"
                
                Call AddProcInit
                
                j = 0
                For i = 0 To UBound(ItemArray, 1)
                    Value = ItemArray(i)
                    
                    If Value(0) = "ФИО" Then
                        txtFIOPay.Text = Value(1)
                        txtFIOPay.Enabled = Value(2)
                    ElseIf Value(0) = "Идентификатор клиента" Then
                        m_IdClient = Value(1)
                        blnGuest = Value(2)
                        Call FillPayer
                        CheckPayer (False)
                        'objParamOut.Parameter("IDCLIENT") = m_IdClient
                    ElseIf Value(0) = "Адрес" Then
                        txtAdressPay.Text = Value(1)
                        txtAdressPay.Enabled = Value(2)
                    ElseIf Value(0) = "Реквизиты плательщика" Then
                        txtInfoClient.Text = Value(1)
                    ElseIf Value(0) = "Код договора" Then
                        txtCode.Text = Value(1)
                        txtCode.Enabled = Value(2)
                        txtComment.Enabled = Value(2)
                        btnContract.Enabled = Value(2)
                        blnCodeEnter = True
                        Call FindContract
                    ElseIf Value(0) = "БИК" Then
                        txtBic.Text = Value(1)
                        txtBic.Enabled = Value(2)
                        Call GetBankNameACC
                    ElseIf Value(0) = "Р/с" Then
                        AccClient.Text = Value(1)
                        AccClient.Enabled = Value(2)
                    ElseIf Value(0) = "Корр. счет банка получателя" Then
                        AccKorr.Text = Value(1)
                        AccKorr.Enabled = Value(2)
                    ElseIf Value(0) = "Счет плательщика" Then
                        AccClientPay.Text = Value(1)
                        AccClientPay.Enabled = Value(2)
                    ElseIf Value(0) = "Назначение" Then
                        cmbPurpose.Text = Value(1)
                        cmbPurpose.Enabled = Value(2)
                    ElseIf Value(0) = "Наименование получателя" Then
                        txtRecip.Text = Value(1)
                        txtRecip.Enabled = Value(2)
                    ElseIf Value(0) = "Наименование банка получателя" Then
                           txtNameBank.Text = Value(1)
                           txtNameBank.Enabled = Value(2)
                    ElseIf Value(0) = "ИНН" Then
                        txtINN.Text = Value(1)
                        txtINN.Enabled = Value(2)
                    ElseIf Value(0) = "ИНН плательщика" Then
                        txtINNPay.Text = Value(1)
                        txtINNPay.Enabled = Value(2)
                    ElseIf Value(0) = "Сумма" Then
                        curSumma.CurrencyValue = Value(1)
                        curSumma.Enabled = Value(2)
                    ElseIf Value(0) = "Комиссия с плательщика" Then
                        curSummaRateSend.CurrencyValue = Value(1)
                        curSummaRateSend.Enabled = Value(2)
                        'Для расчета итоговой суммы
                        prefCalcRate = "_2 5"
                        Call CalcSumCommiss_2
                    ElseIf Value(0) = "Параметры поиска" Then
                        ContractFilterLimitations = True
                        searchTemplate = Value(1)
                        searchKBK = Value(2)
                        searchBIK = Value(3)
                    Else
                        If Not IsArray(arrValue) Then
                            ReDim arrValue(1, 0)
                        Else
                            ReDim Preserve arrValue(1, UBound(arrValue, 2) + 1)
                        End If
    
                         arrValue(0, j) = CStr(Value(0))
                         arrValue(1, j) = Value(1)
                         
                         j = j + 1
                         
                         If Value(0) = "КППУ" Then  'КППУ нужно в доп. поля и на форму
                            txtKppu.Text = Value(1)
                            txtKppu.Enabled = Value(2)
                        End If
                    End If
                Next
                

                'objParamIn.Parameter(CStr(Value(0))) = Value(1)
                objParamIn.Parameter("Доп. поля") = arrValue
                UbsChannel.Run "UtGetAddField", objParamIn, objParamOut
                AddProperties.Refresh
                btnContract.Enabled = True
                
                If outerSystemInfo = True Then
                    Call FillNalog(False, 0)
                    btnPattern.Visible = False
                End If
                                
                Call IsAutoPeriod
                
                               
            Case "VIEW", "GROUP_VIEW"
                If Not IsEmpty(ItemArray) Then
                    m_IdPayment = ItemArray(0)
                Else
                    MsgBox "Не выбран платеж для просмотра", vbCritical, m_strCaptionForm
                    btnExit_Click
                    Exit Property
                End If
                
                ' Потапов Д.А. - 14.05.2007г.
                If StrCommand = "GROUP_VIEW" Then   ' запуск формы из списка групповых платежей
                    blnGroup = True
                    StrCommand = "VIEW"
                End If
                
                Call InitDoc
                
            'Редактирование платежа
            Case "COPY"
                
                StrCommand = "ADD"
                Call AddProcInit
                
                If Not IsEmpty(ItemArray) Then
                    m_IdPayment = ItemArray(0)
                Else
                    MsgBox "Не выбран платеж для просмотра", vbCritical, m_strCaptionForm
                    btnExit_Click
                    Exit Property
                End If
                
                StrCommand = "COPY"
                Call InitDoc
                StrCommand = "ADD"
            
            'Редактирование платежа
            Case "CHANGE_PART", "GROUP_CHANGE", "CHANGE_PART_INCOMING"
                If Not IsEmpty(ItemArray) Then
                    m_IdPayment = ItemArray(0)
                Else
                    MsgBox "Не выбран платеж для просмотра", vbCritical, m_strCaptionForm
                    btnExit_Click
                    Exit Property
                End If
                
                If StrCommand = "GROUP_CHANGE" Then   ' запуск формы из списка групповых платежей
                    blnGroup = True
                    StrCommand = "CHANGE_PART"
                End If
                
                If StrCommand = "CHANGE_PART_INCOMING" Then
                    'Идентификатор группового платежа
                    IdGroupIncoming = CStr(RHS(3)(0))
                    'Идентификатор основного платежа
                    IdMainIncoming = CStr(RHS(3)(1))
                End If

                Call InitDoc
                
                If IdGroupIncoming > 0 Then
                    Call UpdateGroupInfo
                End If
            End Select

           
            lblCommonSumma.Visible = True
            curCommonSumma.Visible = True
            curTotalSumma.Visible = True
            Parent.WindowDraw(NumWin) = True
            objInterfaces.NextCtrl
            objInterfaces.PrevCtrl
        
            If txtFIOPay.Enabled Then
                txtFIOPay.SetFocus
            End If

        Case "SetFocus"
            If Not objFocusCtrl Is Nothing Then
                objFocusCtrl.SetFocus
            End If
        
        Case "RetFromGrid"
            If NumChildWinThirdPerson = RHS(0) Then
                ItemArray = RHS(1)
                Dim thirdPersonId
                If Not IsEmpty(ItemArray) Then
                    thirdPersonId = ItemArray(0)
                Else
                    objErr.UbsErrMsg "RetFromGrid", "Массив идентификаторов пуст"
                End If
                Parent.CloseWindow NumChildWinThirdPerson
                Parent.SetFocusToWindow NumWin
                
                objParamIn.ClearParameters
                
                objParamIn.Parameter("IDCLIENT") = thirdPersonId
                objParamIn.Parameter("IsGuest") = blnGuest
                '-----------------------------
                ' получить посетителя Опер. кассы
                UbsChannel.Run "ReadClientFromIdOC", objParamIn, objParamOut

                If Len(Trim(objParamOut.Parameter("StrError"))) Then
                    MsgBox objParamOut.Parameter("StrError"), 16, "ReadClientFromIdOC " & m_strCaptionForm
                    Exit Property
                End If
                    
                txt_ThirdPersonInn.Text = objParamOut.Parameter("INN")
                txt_ThirdPersonName.Text = objParamOut.Parameter("NAME")
                txt_ThirdPersonKpp.Text = objParamOut.Parameter("KPP")
                cmb_ThirdPersonKind.ListIndex = objParamOut.Parameter("CLIENT_KIND")
                If cmb_ThirdPersonKind.ListIndex = 2 And StrCommand <> "VIEW" Then txt_ThirdPersonKpp.Enabled = True
                ThirdPersonKindChanged
                
            End If
            
            If NumChildWin = RHS(0) Then
                ItemArray = RHS(1)
                If Not IsEmpty(ItemArray) Then
                    m_IdClient = ItemArray(0)
                Else
                    objErr.UbsErrMsg "RetFromGrid", "Массив идентификаторов пуст"
                End If
                Parent.CloseWindow NumChildWin
                Parent.SetFocusToWindow NumWin
                
                If m_SIDPattern = "UBS_UT_NALOG" And StrCommand = "ADD" And blnLast Then
                    'Если заполнен БИК и договор
                    If Len(Trim(txtBic.Text)) <> 0 And m_IdContract <> 0 Then
                        'Если заполнен р/с или клиент/посетитель
                        If AccClient.Text <> "00000000000000000000" Or m_IdClient <> 0 Then
                            Call FillNalog(True, m_IdClient)
                        End If
                    End If
                End If
                
                If m_IdClient > 0 Then
                    lblFindFilter.Visible = True
                    btnFindFilter.Visible = True
                End If
                
                '-----------------
                ' вызов
                objParamIn.ClearParameters
                
                objParamIn.Parameter("IDCLIENT") = m_IdClient
                '============ 23.03.2009 ============
                objParamIn.Parameter("IsGuest") = blnGuest
                '====================================
                '-----------------------------
                ' получить посетителя Опер. кассы
                UbsChannel.Run "ReadClientFromIdOC", objParamIn, objParamOut

                If Len(Trim(objParamOut.Parameter("StrError"))) Then
                    MsgBox objParamOut.Parameter("StrError"), 16, "ReadClientFromIdOC " & m_strCaptionForm
                    Exit Property
                End If
                    
                txtINNPay.Text = objParamOut.Parameter("INN")
                txtInfoClient.Text = objParamOut.Parameter("InfoClient")
                txtFIOPay.Text = objParamOut.Parameter("NAME")
                txtAdressPay.Text = objParamOut.Parameter("ADRESS")
                
                If CBool(objParamOut.Parameter("Benefits")) Then
                    CheckBenefits.Value = 1
                End If

                If AccClientPayVisible Then
                    AccClientPay.Text = "00000000000000000000"
                End If
                
                txtNomerCardPay.Text = ""

                Call CheckPayer(False)
                
                ' (69627)
                'Получить номер и серию документа
                m_strDocNumber = objParamOut.Parameter("NUMBER")
                m_strDocSeries = objParamOut.Parameter("SERIES")
                '

                '----------------------------- Новопашин В.М. 20.06.2006 ---
                'Проводим проверку на террориста и заблокированные паспорта
                'Если клиент террорист, то возращается False
                
                'If Not CheckTerror Then
                '   objInterfaces.GoToCtrl txtFIOPay
                '   Exit Property
                'End If
                '----------------------------------------------------------
                
                If StrCommand = "ADD" And txtCode.Enabled <> False Then objInterfaces.GoToCtrl txtCode
                
            End If
            
            'выбор договора
            If NumChildWinContract = RHS(0) Then
                txtCode.Text = ""
                ItemArray = RHS(1)
                If Not IsEmpty(ItemArray) Then
                   If m_IdContract <> ItemArray(0) Then
                       m_blnChangeContract = True
                   End If
                    m_IdContract = ItemArray(0)
                Else
                    objErr.UbsErrMsg "RetFromGrid", "Массив идентификаторов пуст"
                End If
                Parent.CloseWindow NumChildWinContract
                Parent.SetFocusToWindow NumWin

                '-----------------
                ' вызов
                Call FindContractbyId
                '==========7 сентября 2009==========
                If m_IdContract > 0 Then
                    prefCalcRate = "_2 6"
                    Call CalcSumCommiss_2
                End If
                '====================================

            End If
            
            'выбор платежа из списка
            If NumChildWinPayments = RHS(0) Then
                ItemArray = RHS(1)
                If Not IsEmpty(ItemArray) Then
                    IdPaymentCopy = ItemArray(0)
                Else
                    'objErr.UbsErrMsg "RetFromGrid", "Платеж не выбран"
                    MsgBox "Платеж не выбран", vbInformation, "Копирование платежа"
                End If
                Parent.CloseWindow NumChildWinPayments
                Parent.SetFocusToWindow NumWin
                
                If IdPaymentCopy > 0 Then
                
                    Dim curSumTemp As Currency
                    curSumTemp = curSumma.CurrencyValue

                    StrCommand = "ADD"
                    m_IdPayment = IdPaymentCopy
                    StrCommand = "COPY"
                    Call InitDoc
                    StrCommand = "ADD"
                
                    curSumma.CurrencyValue = curSumTemp
                    prefCalcRate = "_2 7"
                    Call CalcSumCommiss_2

                End If
                
            End If
            
            'Выбор атрибутов получателя
            If NumChildWinAttributeRecip = RHS(0) Then
                ItemArray = RHS(1)
                If Not IsEmpty(ItemArray) Then
                    '==========
                    m_IdAttributeRecip = ItemArray(0) 'Left(ItemArray(0), InStr(ItemArray(0), "@") - 1)
                    '==========
                    If m_IdAttributeRecip > 0 Then
                        objParamIn.ClearParameters
                        'objParamIn.Parameter("IdContract") = m_IdContract
                        objParamIn.Parameter("IdAttributeRecip") = m_IdAttributeRecip
                        
                        UbsChannel.Run "ReadRecipFromId", objParamIn, objParamOut
                        txtRecip.Text = objParamOut.Parameter("Наименование получателя в плат. документах")
                        txtBic.Text = objParamOut.Parameter("BIC")
                        AccKorr.Text = objParamOut.Parameter("CORRACC")
                        txtNameBank.Text = objParamOut.Parameter("Наименование банка")
                        AccClient.Text = objParamOut.Parameter("ACC")
                        txtINN.Text = objParamOut.Parameter("INN")
                        cmbPurpose.Text = objParamOut.Parameter("PURPOSE")
                        If m_SIDPattern = "UBS_UT_NALOG" Then
                            txtOKATONalog.Text = objParamOut.Parameter("OKATO")
                        End If
                        
                        AddProperties.Refresh
                    End If
                'Если идентификатора нет, это нормально, значит просто не
                'заполнены атрибуты получателя для данного договора
                'Else
                '    objErr.UbsErrMsg "RetFromGrid", "Массив идентификаторов пуст"
                End If
                Parent.CloseWindow NumChildWinAttributeRecip
                Parent.SetFocusToWindow NumWin
            
                'If m_IdAttributeRecip > 0 Then
                '    objParamIn.ClearParameters
                '    objParamIn.Parameter("IdAttributeRecip") = m_IdAttributeRecip
                '    UbsChannel.Run "ReadRecipFromId", objParamIn, objParamOut
                    'Call FillRecipFromId
                'End If

            End If
            
            
            If NumChildWinPaymDic = RHS(0) Then
                ItemArray = RHS(1)
                If Not IsEmpty(ItemArray) Then
                    m_IdPaymentDic = ItemArray(0)
                    FillDataPayment ("FILTER")
                    objInterfaces.NextCtrl
                End If
                Parent.CloseWindow NumChildWinPaymDic
                Parent.SetFocusToWindow NumWin
            End If
                        
        End Select

    Set Filter = Nothing
    Set Grid = Nothing
    
    Exit Property
ErrorCode:
    objErr.UbsErrMsg "UBSChild_ParamInfo", "ошибка выполнения"
    If CheckParamForClose(NameParam) Then
        btnExit_Click
    End If
End Property

'----------------------------------------------------- Новопашин В.М. 14.08.2006 г.
'Процедура инициализации добавления
Sub AddProcInit(Optional blnMsgIsVisible As Boolean = True)

On Error GoTo ErrorCode
    
    blnCheckIncoming = False
    
    UbsChannel.HostAddress = Parent.LoaderParamInfo(NumWin, "HostAddress")
    UbsChannel.UserGUID = Parent.LoaderParamInfo(NumWin, "GuidSession")
    UbsChannel.ParentHwnd = UserDocument.hWnd
    
    'Получаем признак вызова печатных форм
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    UbsChannel.LoadResource = "VBS:UBS_VBS\PS\PsCheckPrintForm.vbs"
    objParamIn.Parameter("NameSection") = "Оплата услуг"
    UbsChannel.Run "Ps_CheckPrintForm", objParamIn, objParamOut
    m_blnIsFrmPrn = objParamOut.Parameter("IsFrmPrn")
    If objParamOut.Parameter("bRetVal") = False Then
        MsgBox objParamOut.Parameter("StrError"), 16, "ПФ. " & m_strCaptionForm
        btnExit_Click
        Exit Sub
    End If

    cmbPurpose.Clear
    cmbPurpose.Text = ""
    cmbPurpose.Refresh
    m_IdContract = 0
    m_IdPayment = 0
    
    'для доп .полей
    Set objStub.UbsChannel = UbsChannel
    Set objScript = CreateObject("URunScr.IUbsRunScript")
    objScript.UbsChannel = UbsChannel
    objParamIn.ClearParameters
    objParamOut.ClearParameters

    UbsChannel.LoadResource = "VBS:UBS_VBD\PS\UT\UtPaymentF.vbs"
    UbsChannel.Run "InitForm", objParamIn, objParamOut

    If objParamOut.Parameter("bRetVal") = False And objParamOut.Parameter("bMsgBoxYesNo") = True And blnMsgIsVisible Then
        If MsgBox(objParamOut.Parameter("StrError"), vbYesNo + vbExclamation + vbDefaultButton2, m_strCaptionForm) = vbNo Then
           btnExit_Click
           Exit Sub
        End If
    End If
    
    '-------------------------------------------------------------------------
    Call InitDoc

    ' (89918) Запретим сохранение если есть документы
    If objParamOut.Parameter("DocumentsExists") = 1 Then
        StrCommand = "VIEW"
        Info.Caption = "По платежу сформированы документы. Форма открыта в режиме просмотра"
        Info.ShowMode = Constantly
        Info.Show
    End If

    If IdGroupIncoming = 0 Then
        ' вызов клиентского сценария для инициализации ФР
        '-----------------------------
        Set objScript = CreateObject("URunScr.IUbsRunScript")
        objScript.UbsChannel = UbsChannel
        objParamIn.ClearParameters
        objParamOut.ClearParameters
    
        objParamIn.Parameter("blnGroup") = blnGroup
        objParamIn.Parameter("strBusinessName") = "Оплата услуг"
        objScript.LoadFiles "UBS_VBS\PS\PsDevice.vbs"
    
        objScript.Run "FormInitDevice", objParamIn, objParamOut
    
        If Not (objParamOut.Parameter("bRetVal")) Then
            MsgBox objParamOut.Parameter("StrError"), 16, "ФР и сканер. " & m_strCaptionForm
            btnExit_Click
            Exit Sub
        End If
    
        m_blnIsFR = objParamOut.Parameter("bIsFR")
        lblFR.Caption = objParamOut.Parameter("strRegName")
        m_RegNumber = objParamOut.Parameter("strRegNumber")
        If CBool(m_blnIsFR) Then
            Set objDevice = objParamOut.Parameter("objDevice")
        End If
    
        If objParamOut.ExistParameter("objScan") Then
            m_blnIsScan = objParamOut.Parameter("bIsScan")
            Set objScaner = objParamOut.Parameter("objScan")
            If objScaner.Command("READ", Null) = False Then
                MsgBox objParamOut.Parameter("StrError"), 16, "ФР и сканер. " & m_strCaptionForm
                btnExit_Click
                Exit Sub
            End If
        End If
    End If

    blnCheckIncoming = True

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "AddProcInit", "ошибка выполнения"
End Sub
'----------------------------------------------------------------------------------

Private Property Get UBSChild_ParamInfo(ByVal NameParam As String) As Variant
    If NameParam = "WaitShow" Then
        UBSChild_ParamInfo = True
    End If
    If NameParam = "SelectedKeys" Then
        Dim varKeys As Variant
        varKeys = 0&
        UBSChild_ParamInfo = varKeys
    End If
    
End Property

Private Property Let UBSChild_Parrent(ByVal RHS As Object)
    Set Parent = RHS
End Property

Private Property Let UBSChild_RunParameter(ByVal RHS As String)

End Property

Private Function CheckParamForClose(ByVal NameParam As String) As Boolean
    CheckParamForClose = False
    If NameParam = "LoadFromMenu" Or NameParam = "InitParamForm" Or NameParam = "RetFromGrid" Or NameParam = "InitParamGrid" Then
        CheckParamForClose = True
    End If
End Function

Private Function CheckKeyInn(inn As String) As Boolean
    If Len(inn) = 10 Then

        If LCase(Left(inn, 2)) = "00" Then
            CheckKeyInn = True ' для Крыма
            Exit Function
        End If

        Dim k As Integer
        k = 2 * CInt(Mid(inn, 1, 1)) + _
            4 * CInt(Mid(inn, 2, 1)) + _
           10 * CInt(Mid(inn, 3, 1)) + _
            3 * CInt(Mid(inn, 4, 1)) + _
            5 * CInt(Mid(inn, 5, 1)) + _
            9 * CInt(Mid(inn, 6, 1)) + _
            4 * CInt(Mid(inn, 7, 1)) + _
            6 * CInt(Mid(inn, 8, 1)) + _
            8 * CInt(Mid(inn, 9, 1))

        k = (k Mod 11) Mod 10
        CheckKeyInn = (k = CInt(Mid(inn, 10, 1)))
        Exit Function

    ElseIf Len(inn) = 12 Then

        If LCase(Left(inn, 2)) = "00" Then
            CheckKeyInn = True ' для Крыма
            Exit Function
        End If

        Dim l As Integer
        l = 7 * CInt(Mid(inn, 1, 1)) + _
            2 * CInt(Mid(inn, 2, 1)) + _
            4 * CInt(Mid(inn, 3, 1)) + _
           10 * CInt(Mid(inn, 4, 1)) + _
            3 * CInt(Mid(inn, 5, 1)) + _
            5 * CInt(Mid(inn, 6, 1)) + _
            9 * CInt(Mid(inn, 7, 1)) + _
            4 * CInt(Mid(inn, 8, 1)) + _
            6 * CInt(Mid(inn, 9, 1)) + _
            8 * CInt(Mid(inn, 10, 1))

        l = (l Mod 11) Mod 10
        If l <> CInt(Mid(inn, 11, 1)) Then
            CheckKeyInn = False
            Exit Function
        End If

        l = 3 * CInt(Mid(inn, 1, 1)) + _
            7 * CInt(Mid(inn, 2, 1)) + _
            2 * CInt(Mid(inn, 3, 1)) + _
            4 * CInt(Mid(inn, 4, 1)) + _
           10 * CInt(Mid(inn, 5, 1)) + _
            3 * CInt(Mid(inn, 6, 1)) + _
            5 * CInt(Mid(inn, 7, 1)) + _
            9 * CInt(Mid(inn, 8, 1)) + _
            4 * CInt(Mid(inn, 9, 1)) + _
            6 * CInt(Mid(inn, 10, 1)) + _
            8 * CInt(Mid(inn, 11, 1))

        l = (l Mod 11) Mod 10
        CheckKeyInn = (l = CInt(Mid(inn, 12, 1)))
        Exit Function

    ElseIf Len(inn) = 5 Then
        CheckKeyInn = True ' для КИО проверка не выполняется
        Exit Function
    End If

    CheckKeyInn = False
End Function

Private Property Get UBSChild_Sizable() As Boolean
    UBSChild_Sizable = False
End Property

Private Property Get UBSChild_TitleWindow() As String
    UBSChild_TitleWindow = "Платеж"
End Property

Private Property Get UBSChild_Width() As Integer
    UBSChild_Width = 8550
End Property

Private Property Let UBSChild_WidthBrowser(ByVal RHS As Variant)

    If RHS < 8445 Then RHS = 8550
    
    AddProperties.Width = RHS - 200
    
    'subPayment.Width = RHS
    TabMain.Width = RHS - 200
    TabAdd.Width = RHS - 200
    SSActiveTabPanel1.Width = RHS - 200
    SSActiveTabPanel2.Width = RHS - 200
    SSActiveTabPanel3.Width = RHS - 200

    cmdCashSymb.Left = RHS - 8100
    btnPattern.Left = RHS - 6500
    btnSave.Left = RHS - 4300
    btnCalc.Left = RHS - 2900
    btnExit.Left = RHS - 1500
    
    chkPrintForm.Left = RHS - 1100
    
End Property


Private Sub UserDocument_Hide()

On Error GoTo ErrorCode

    DoEvents
  
    Set Wait = Nothing
    Set objErr = Nothing
    Set objInterfaces = Nothing
    Set objFocusCtrl = Nothing
    Set objParamIn = Nothing
    Set objParamOut = Nothing
    Set objFormat = Nothing
    Set objUbsCheck = Nothing
    
    DoEvents

    If Not bParentWindowClose And Parent.IsExistParam(NumParentWindow, "NeedRefreshGrid") = True Then
        Parent.ParamInfo(NumParentWindow, "NeedRefreshGrid") = bNeedRefreshGrid
    End If
    
    DoEvents

    objStub.ReleaseUbsChannel
    Set objStub = Nothing
    
    DoEvents
    
    UbsDDX.ReleaseControlData
    Set Parent = Nothing
    
    DoEvents
    If IdGroupIncoming = 0 Then
        If StrCommand = "ADD" Then
            objScript.ReleaseUbsChannel
            Set objScript = Nothing
            Set objDevice = Nothing
            Set objScaner = Nothing
        End If
    End If
    
    UbsChannel.UnLoadResource
    
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "UserDocument_Hide", "ошибка выполнения"
End Sub

Private Sub UserDocument_Initialize()


    lblFR.Caption = ""
    Info.Caption = ""
    Set objFormParam = CreateObject("ToolPubs.IUbsParam")
    Set objParamIn = CreateObject("ToolPubs.IUbsParam")
    Set objParamOut = CreateObject("ToolPubs.IUbsParam")
    Set objFormat = CreateObject("Lib3.IUbsFormat")
    
    Set objUbsCheck = CreateObject("UbsCheck.UbsCheckAction")

    objFormParam.Parameter("WaitShow") = True
    objFormParam.Parameter("InitParamForm") = True
    objFormParam.Parameter("SetFocus") = True
    objFormParam.Parameter("LostFocus") = True
    objFormParam.Parameter("RetFromGrid") = True
    objFormParam.Parameter("InitParamViewer") = True
    objFormParam.Parameter("SelectedKeys") = True
End Sub

Private Sub Initialize()
    Set Wait = CreateObject("UbsWait.UbsWaitBox")
    Set objErr = CreateObject("ToolPubs.IUbsError")
    Set objInterfaces = CreateObject("ToolPubs.Interfaces")
    Set objStub = CreateObject("UbsAddFiledsStub.IUbsAddFiledsStub")
End Sub


Private Sub InitDoc()
   
On Error GoTo ErrorCode

    Dim varState As Variant
    Dim i As Integer
    Dim lngIndex As Long
    Dim ressql As Variant, t As Variant
    Dim dDateBeg As Date, dDateEnd As Date
    Dim varCashSymbol As Variant
    Dim var
    
    m_IdContractOld = 0

    btnSaveAttribute.Visible = False
    btnListAttributeRecip.Visible = False

    m_blnLic = False
    
    lblNalog.Visible = False
    
    UbsChannel.HostAddress = Parent.LoaderParamInfo(NumWin, "HostAddress")
    UbsChannel.UserGUID = Parent.LoaderParamInfo(NumWin, "GuidSession")
    UbsChannel.ParentHwnd = UserDocument.hWnd
    'для доп .полей
    Set objStub.UbsChannel = UbsChannel
    UbsChannel.LoadResource = "VBS:UBS_VBD\PS\UT\UtPaymentF.vbs"
    Dim objParamIn:  Set objParamIn = CreateObject("ToolPubs.IUbsParam")
    Dim objParamOut: Set objParamOut = CreateObject("ToolPubs.IUbsParam")
    
    If StrCommand = "ADD" Or StrCommand = "ADD_FROM_CLIENT" Or StrCommand = "ADD_PARAM" Then
        
        If FoSettingValue > -1 Then objParamIn.Parameter("FROMFO") = FoSettingValue
            
        ' ???
        UbsChannel.Run "PS_UserIsCashier", objParamIn, objParamOut
        
        If objParamOut.Parameter("StrError") <> "" Then
            m_blnSave = False: btnExit.Enabled = True
            MsgBox objParamOut.Parameter("StrError"), vbCritical, "Приём платежа"
            Exit Sub
        End If

        If objParamOut.Parameter("NotCashier") Then
            m_blnSave = False: btnExit.Enabled = True
            MsgBox "Текущий пользователь не является кассиром !!!", vbCritical, "Приём платежа"
            btnExit_Click
            Exit Sub
            
        End If
        
        blnCashier = True
        If objParamOut.Parameter("bRet") Then
            blnCashier = False
        End If
    End If
    
    If blnAddClient Then
        txtNomerCardPay.Visible = False
        lblNomerCardPay.Visible = False
    Else
        txtNomerCardPay.Visible = True
        lblNomerCardPay.Visible = True
    End If
    
    txtCodePayment.Visible = False
    lblCodePayment.Visible = False
    txtRecip.Enabled = False
    lblRecip.Enabled = False
    blnAlready = False
    cb_ThirdPerson.Enabled = False
    cb_ThirdPerson.Value = 0
    subPayment.Tabs(TAB_ADDFL).Enabled = False
    cmdCashSymb.Visible = False
    AccPay.Visible = False
    If StrCommand = "ADD" Then
        lblFindFilter.Visible = False
        btnFindFilter.Visible = False
    End If
    btnPaymDic.Visible = False
    lblAcc.Visible = False
    txtCheckSum.Visible = False
    cboCityCode.Visible = False
    cboCityCode.Enabled = False
    subPayment.Tabs(TAB_TARIFF).Visible = False
    subPayment.Tabs(TAB_TELEPHONE).Visible = False
    subPayment.Tabs(TAB_TAX).Visible = False
    subPayment.Tabs(TAB_THIRDPERSON).Visible = False
    m_nNumTabAddFl = 5
    
    m_blnSave = False
    m_blnClickSave = False
    UbsDDX.InitControlData
    
    objParamIn.Parameter("StrCommand") = StrCommand
    objParamIn.Parameter("IdPayment") = m_IdPayment
    objParamIn.Parameter("IdMainIncoming") = IdMainIncoming
        
    UbsChannel.Run "InitForm", objParamIn, objParamOut
    '''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''
    '''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''
    '''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''
    stgCheckPayer = objParamOut.Parameter("Клиент.Проверки по справочникам")
    
    If objParamOut.ExistParameter("ChangeCommand") Then
        MsgBox objParamOut.Parameter("StrErrorCh")
        StrCommand = "VIEW"
    End If

    If objParamOut.ExistParameter("CloseForm") Then
        Dim strError
        strError = objParamOut.Parameter("StrError")
        
        MsgBox IIf(strError = "", "Платеж заблокирован, редактирование запрещено", strError), 16, IIf(strError = "", "Проверка блокировки", "Проверка")
        btnExit_Click
        Exit Sub
    End If
    
    If StrCommand = "CHANGE_PART_INCOMING" Then
        blnEndGroup = objParamOut.Parameter("EndGroup")
        If blnEndGroup Then
            StrCommand = "VIEW"
        Else
            StrCommand = "CHANGE_PART"
        End If
    End If

    ' Условие XOR - истина XOR ложь   - Истина
    '               ложь   XOR истина - истина
    If objParamOut.Parameter("bRetVal") Xor objParamOut.Parameter("bMsgBoxYesNo") Then
        ' заполним список кодов городов
        FillCityCode objParamOut.Parameter("arrCityCode")
        dDateBeg = objParamOut.Parameter("DateBeg")
        dDateEnd = objParamOut.Parameter("DateEnd")
                
        m_blnIsErrorKey = objParamOut.Parameter("blnIsErrorKey")
    Else
        If Not objParamOut.Parameter("bMsgBoxYesNo") Then
            MsgBox objParamOut.Parameter("StrError"), 16, "Инициализация формы. " & m_strCaptionForm
        End If
    End If
    
    If objParamOut.ExistParameter("Льготный клиент") Then
        If CBool(objParamOut.Parameter("Льготный клиент")) Then
            CheckBenefits.Value = 1
        End If
    End If
    
    If objParamOut.ExistParameter("Обоснование") Then
        TextReason.Text = objParamOut.Parameter("Обоснование")
    End If

    AddProperties.UbsAddFields = objStub
    AddProperties.Refresh

    chkPrintForm.Value = 0
    chkPrintForm.Visible = False
    If StrCommand = "ADD" Then
        If objParamOut.Parameter("ViewPrintForm") Then
            chkPrintForm.Visible = True
            If m_blnIsFrmPrn Then
                chkPrintForm.Value = 1
            End If
        End If
    End If
       
    ' (89918) Запретим сохранение если есть документы
    If objParamOut.Parameter("DocumentsExists") = 1 Then
        StrCommand = "VIEW"
        Info.Caption = "По платежу сформированы документы. Форма открыта в режиме просмотра"
        Info.ShowMode = Constantly
        Info.Show
    End If
       
    UbsChannel.Run "UtReadSettingEnterCashSymbol", objParamIn, objParamOut
    If Not objParamOut.Parameter("bRetVal") And objParamOut.Parameter("strError") <> "" Then
        MsgBox objParamOut.Parameter("strError"), 16, "Инициализация формы"
    Else
        lngCheckKSSymb = objParamOut.Parameter("UtEnterCashSymbol")
        lblKSPayment.Visible = lngCheckKSSymb
        lblKSRate.Visible = lngCheckKSSymb
        lblKSNDS.Visible = lngCheckKSSymb
        txtKSPayment.Visible = lngCheckKSSymb
        txtKSRate.Visible = lngCheckKSSymb
        txtKSNDS.Visible = lngCheckKSSymb
        
        m_blnRegimCashSymb = lngCheckKSSymb
    End If

    If blnAddClient Then
        blnGuest = False
    Else
        UbsChannel.Run "UtReadSettingChoiceClient", objParamIn, objParamOut
        If Not objParamOut.Parameter("bRetVal") And objParamOut.Parameter("strError") <> "" Then
            MsgBox objParamOut.Parameter("strError"), 16, "Инициализация формы"
        Else
            If objParamOut.Parameter("ChoiceClient") = 0 Then
                blnGuest = True
            Else
                blnGuest = False
            End If
        End If
    End If

    UbsChannel.Run "UtReadSettingSourceMeans", objParamIn, objParamOut

    If Not objParamOut.Parameter("bRetVal") And objParamOut.Parameter("strError") <> "" Then
        MsgBox objParamOut.Parameter("strError"), 16, "Инициализация формы"
    Else
        'Источник средств = 1 и клиент банка
        'If objParamOut.Parameter("UtEnterSourceMeans") = 1 And blnGuest = False Then
        'Доработали по заявке - 6635
        If objParamOut.Parameter("UtEnterSourceMeans") = 1 Or calledFromFrontOffice Then
            AccClientPayVisible = True
            AccClientPay.Visible = True
            lblAccClientPay.Visible = True
            If Not calledFromFrontOffice Then AccClientPay.Text = "00000000000000000000"
            txtInfoClient.Width = 4125
            blnSourceMeans = True
        Else
            AccClientPayVisible = False
            AccClientPay.Visible = False
            lblAccClientPay.Visible = False
            txtInfoClient.Width = 7185
            blnSourceMeans = False
        End If
    End If

    If StrCommand = "VIEW" Then
        cmdCashSymb.Enabled = False

        Call ReadContract

        DisableAllFields
        UbsDDX.UpdateData False
        AddProperties.Refresh
        
     ElseIf StrCommand = "COPY" Then
       Call EnableAllFields
       Call ReadContract
       UbsDDX.UpdateData False
       AddProperties.Refresh

    ElseIf StrCommand = "CHANGE_PART" Then
    
       If objParamOut.ExistParameter("ListSymbols") Then
            arrCashSymb = objParamOut.Parameter("ListSymbols")
            arrDataTypeCashSymbol = objParamOut.Parameter("arrTypeCashSymbol")
       End If
        
        Call ReadContract
        
        btnContract.Enabled = False
        txtCode.Enabled = False
        
        curSumma.Enabled = False
        curPeny.Enabled = False
        
        If txtKSPayment.Text <> "" Then
          txtKSPayment.Enabled = True
        Else
          txtKSPayment.Visible = False
          lblKSPayment.Visible = False
          m_blnRegimCashSymb = False
        End If
        
        If txtKSRate.Text <> "" Then
           txtKSRate.Enabled = True
        Else
           txtKSRate.Visible = False
           lblKSRate.Visible = False
        End If
        
        If txtKSNDS.Text <> "" Then
           txtKSNDS.Enabled = True
        Else
           txtKSNDS.Visible = False
           lblKSNDS.Visible = False
        End If
        
        UbsDDX.UpdateData False
        AddProperties.Refresh
        txtDayBeg.Enabled = True
        txtDayEnd.Enabled = True
    
    ElseIf StrCommand = "ADD" Then
    
        If IdGroupIncoming > 0 Then
            Call GetIdClientFromGroupPayment
        End If

'Если клиент банка задан (в режиме добавления), то значит вызов требует заполнить клиента
If blnAddClient Or IdGroupIncoming > 0 Then
        objParamIn.ClearParameters
        objParamIn.Parameter("IDCLIENT") = m_IdClient
        'всегда клиент банка
        objParamIn.Parameter("IsGuest") = False 'blnGuest
        'либо клиент банка, либо посетитель
        If IdGroupIncoming > 0 Then
            objParamIn.Parameter("IsGuest") = blnGuest
        End If
        
        ' получить посетителя Опер. кассы
        UbsChannel.Run "ReadClientFromIdOC", objParamIn, objParamOut
                
        If Len(Trim(objParamOut.Parameter("StrError"))) Then
           MsgBox objParamOut.Parameter("StrError"), 16, "ReadClientFromIdOC " & m_strCaptionForm
           Exit Sub
        End If

        UbsDDX.InitMemberData("PayerFIO") = objParamOut.Parameter("NAME")
        UbsDDX.InitMemberData("PayerAdress") = objParamOut.Parameter("ADRESS")
        UbsDDX.InitMemberData("PayerINN1") = objParamOut.Parameter("INN")
        txtInfoClient.Text = objParamOut.Parameter("InfoClient")
Else
        UbsDDX.InitMemberData("PayerFIO") = ""
        UbsDDX.InitMemberData("PayerAdress") = ""
        UbsDDX.InitMemberData("PayerINN1") = "" '0
        txtInfoClient.Text = ""
End If
        UbsDDX.InitMemberData("Code") = ""
        UbsDDX.InitMemberData("CodePayment") = "" 'Данилова, 28.10.2005
        UbsDDX.InitMemberData("Comment") = ""
        UbsDDX.InitMemberData("BIC") = ""
        UbsDDX.InitMemberData("INN1") = "" '0
        UbsDDX.InitMemberData("CorrAcc") = 0
        UbsDDX.InitMemberData("NameBank") = ""
        UbsDDX.InitMemberData("Acc") = 0
        UbsDDX.InitMemberData("Purpose") = ""
        UbsDDX.InitMemberData("AccCode") = ""
        UbsDDX.InitMemberData("CheckSum") = ""
        UbsDDX.InitMemberData("Summa") = 0
        UbsDDX.InitMemberData("SummaRateSend") = 0
        UbsDDX.InitMemberData("SummaTotal") = 0
        'UbsDDX.InitMemberData("Purpose2") = ""
        
        cmbPurpose.Clear
        cmbPurpose.Text = ""
        UbsDDX.UpdateData False
        
        Call EnableAllFields
        
    End If
    
    If IdGroupIncoming > 0 Then
        txtFIOPay.Enabled = False
        btnClient.Enabled = False
        txtINNPay.Enabled = False
        txtAdressPay.Enabled = False
        AccClientPay.Enabled = False
        txtNomerCardPay.Enabled = False
    End If

    txtDayBeg.Text = Day(dDateBeg)
    txtMonthBeg.Text = Month(dDateBeg)
    txtYearBeg.Text = Right(CStr(Year(dDateBeg)), 2)
    txtDayEnd.Text = Day(dDateEnd)
    txtMonthEnd.Text = Month(dDateEnd)
    txtYearEnd.Text = Right(CStr(Year(dDateEnd)), 2)
    
    Call CheckPeni
    
    Call CheckPayer(False)
    
    Call DefineRunUserForm(False)
    
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "InitDoc", "ошибка выполнения"
End Sub

'----------------------------------------------- Новопашин В.М. 14.08.2006 г.
'Считывание данных контракта
Sub ReadContract()

On Error GoTo ErrorCode

    Dim dDateBeg As Date, dDateEnd As Date, strAccCode As String
    Dim StrNameRecip As String

    objParamOut.ClearParameters
    objParamIn.Parameter("StrCommand") = "READ"
    objParamIn.Parameter("IdPaym") = m_IdPayment
    
    If blnGroup Then
        objParamIn.Parameter("PAYMENTGROUP") = True
    End If
    
    If StrCommand = "COPY" Then
        objParamIn.Parameter("ClearPayment") = True
    Else
        txtKSPayment.Enabled = False
        txtKSRate.Enabled = False
        txtKSNDS.Enabled = False
    End If
    
    UbsChannel.Run "Payment", objParamIn, objParamOut
    
    Dim varCashSymbol As Variant

    varCashSymbol = objParamOut.Parameter("CashSymbol")
    If IsArray(varCashSymbol) Then
        txtKSPayment.Text = varCashSymbol(0, 0)
        txtKSRate.Text = varCashSymbol(1, 0)
        txtKSNDS.Text = varCashSymbol(2, 0)
    End If
    
    Dim ArrayCashSymbols As Variant
    ArrayCashSymbols = objParamOut.Parameter("ArrayCashSymbols")
    If IsArray(ArrayCashSymbols) Then
        lblKSPayment.Visible = False
        txtKSPayment.Visible = False
        m_blnRegimCashSymb = False
    End If

    blnPenyPresent = objParamOut.Parameter("PeniPresent")
    
    'На всякий случай, хотя она и не вызывается... Но продублировать надо...
    m_blnComissPeniPayer = objParamOut.Parameter("PeniComissPayer")

    Call CheckPeni(objParamOut.Parameter("SUMMAPENI"))


    ' Потапов Д.А. - 14.05.2007г.
    If blnGroup Then
        m_IdGroup = objParamOut.Parameter("PAYMENTGROUPID")
        Call UpdateGroupInfo
    End If

    '---------------------------------------------------------------
    UbsDDX.InitMemberData("PayerFIO") = objParamOut.Parameter("FIOSend")
    UbsDDX.InitMemberData("PayerINN1") = objParamOut.Parameter("PayerINN1")
    UbsDDX.InitMemberData("PayerAdress") = objParamOut.Parameter("AdressSend")
    UbsDDX.InitMemberData("Code") = objParamOut.Parameter("Code")
    UbsDDX.InitMemberData("CodePayment") = objParamOut.Parameter("CodePayment")  'Данилова, 28.10.2005
    UbsDDX.InitMemberData("Comment") = objParamOut.Parameter("Comment")
    UbsDDX.InitMemberData("BIC") = objParamOut.Parameter("BIC")
    UbsDDX.InitMemberData("CorrAcc") = objParamOut.Parameter("AccCorr")
    UbsDDX.InitMemberData("NameBank") = objParamOut.Parameter("NameBank")
    UbsDDX.InitMemberData("INN1") = objParamOut.Parameter("INNRec1")
    UbsDDX.InitMemberData("Acc") = objParamOut.Parameter("AccRec")
    txtKppu.Text = objParamOut.Parameter("КППУ")
    
    If objParamOut.ExistParameter("THIRDPERSON_NAME") Then
        cb_ThirdPerson.Value = 1
        txt_ThirdPersonName.Text = objParamOut.Parameter("THIRDPERSON_NAME")
        If objParamOut.ExistParameter("THIRDPERSON_KIND") Then
            cmb_ThirdPersonKind.ListIndex = objParamOut.Parameter("THIRDPERSON_KIND")
            If StrCommand <> "VIEW" Then
                If cmb_ThirdPersonKind.ListIndex = 2 Then txt_ThirdPersonKpp.Enabled = True
            End If
        End If
        If objParamOut.ExistParameter("THIRDPERSON_INN") Then
            txt_ThirdPersonInn.Text = objParamOut.Parameter("THIRDPERSON_INN")
        End If
        If objParamOut.ExistParameter("THIRDPERSON_KPP") Then
            txt_ThirdPersonKpp.Text = objParamOut.Parameter("THIRDPERSON_KPP")
        End If
                Call cb_ThirdPerson_Click
    End If
    
    If StrCommand_Source = "ADD_PARAM" Then
        If Len(cmbPurpose.Text) = 0 Then cmbPurpose.Text = objParamOut.Parameter("Note")
        If AccClientPayVisible Then
            If Len(AccClientPay.Text) = 0 Then AccClientPay.Text = objParamOut.Parameter("AccSend")
        End If
        
        If Len(txtInfoClient.Text) = 0 Then txtInfoClient.Text = objParamOut.Parameter("InfoClient")
        If Len(txtRecip.Text) = 0 Then
            txtRecip.Text = objParamOut.Parameter("RecipientName")
            StrNameRecip = objParamOut.Parameter("RecipientName")
        End If
    ElseIf StrCommand_Source <> "ADD_PARAM" Then
        cmbPurpose.Text = objParamOut.Parameter("Note")
        If AccClientPayVisible Then
            AccClientPay.Text = objParamOut.Parameter("AccSend")
        End If
        txtInfoClient.Text = objParamOut.Parameter("InfoClient")
        txtRecip.Text = objParamOut.Parameter("RecipientName")
        StrNameRecip = objParamOut.Parameter("RecipientName")
    End If
    
    If objParamOut.Parameter("VisibleCodePayment") = "присутствует" Then
        txtCodePayment.Visible = True
        lblCodePayment.Visible = True
    Else
        txtCodePayment.Visible = False
        lblCodePayment.Visible = False
    End If
    
    strAccCode = CStr(objParamOut.Parameter("AccCode"))
    If Len(Trim(objParamOut.Parameter("AccCode"))) <> 0 Then
       If CStr(objParamOut.Parameter("IncludeKey")) = "входит в счет" Then
            'AccPay.MaxLength = AccPay.MaxLength + m_nLenKey
           UbsDDX.InitMemberData("AccCode") = objParamOut.Parameter("AccCode") & objParamOut.Parameter("CheckSum")
       Else
            '------------------------------------------------------------------
            'Трубаков В.Ю  10.07.2007
           'UbsDDX.InitMemberData("AccCode") = Mid(objParamOut.Parameter("AccCode"), 4, Len(objParamOut.Parameter("AccCode")) - 3)
            UbsDDX.InitMemberData("AccCode") = objParamOut.Parameter("AccCode")
            '------------------------------------------------------------------
            'Новопашин В.М. 02.11.2006 г.
            Dim lngI As Long
            For lngI = 0 To cboCityCode.ListCount
               If cboCityCode.List(lngI) = objParamOut.Parameter("CityCode") Then
                  cboCityCode.ListIndex = lngI
                  Exit For
               End If
            Next
            '-----------------------------------------------------------------
            
       End If
    End If

    UbsDDX.InitMemberData("CheckSum") = objParamOut.Parameter("CheckSum")
    UbsDDX.InitMemberData("Summa") = objParamOut.Parameter("SummaPaym")
    UbsDDX.InitMemberData("SummaRateSend") = objParamOut.Parameter("SummaRateSend")
    
    If (Trim(txtKppu.Text) = "") Then txtKppu.Text = objParamOut.Parameter("КППУ")
    
    m_curSumRec = objParamOut.Parameter("SummaRec")
    m_curSumRateRec = objParamOut.Parameter("SummaRateRec")
    'Мост
    'MsgBox "05: " & objParamOut.Parameter("SummaRateSend")
    UbsDDX.InitMemberData("SummaTotal") = objParamOut.Parameter("Summa")
    dDateBeg = objParamOut.Parameter("DateBeg")
    dDateEnd = objParamOut.Parameter("DateEnd")
    m_IdContract = objParamOut.Parameter("IdContract")
    m_IdTariff = objParamOut.Parameter("IdTariff")
    m_IdClient = objParamOut.Parameter("IdClient")
    
    m_IdPhone = objParamOut.Parameter("IdPhone")
    
    m_SIDPattern = objParamOut.Parameter("IdPattern")

    Call FindContractbyId
    '===============================
    txtRecip.Text = StrNameRecip
    '===============================
    cb_ThirdPerson.Enabled = False
    Select Case m_SIDPattern
    
    Case "UBS_UT_ENERGY"
        UbsDDX.InitMemberData("AccCode") = strAccCode
        subPayment.Tabs(TAB_TAX).Visible = True
        cb_ThirdPerson.Enabled = True
        If cb_ThirdPerson.Value = 1 Then subPayment.Tabs(TAB_THIRDPERSON).Visible = True
    Case "UBS_UT_PHONE"
        cboCityCode.Visible = True
        cboCityCode.Enabled = True
        AccPay.Width = 1275
        AccPay.Left = 5580
        subPayment.Tabs(TAB_TELEPHONE).Visible = True
    Case "UBS_UT_NALOG"
        subPayment.Tabs(TAB_TAX).Visible = True
        cb_ThirdPerson.Enabled = True
        If cb_ThirdPerson.Value = 1 Then subPayment.Tabs(TAB_THIRDPERSON).Visible = True
    Case "UBS_UT_PHONE_ACC"
        subPayment.Tabs(TAB_TELEPHONE).Visible = True
    Case Else
        'Новопашин В.М. 08.11.2006 г. ---------------------------------
        'UbsDDX.InitMemberData("AccCode") = strAccCode
        '--------------------------------------------------------------
    End Select

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "ReadContract", "ошибка выполнения"

End Sub

Private Sub UserDocument_KeyDown(KeyCode As Integer, Shift As Integer)
    
    If Shift = 2 And KeyCode = vbKeyTab Then
        Set objFocusCtrl = UserDocument.ActiveControl
        Parent.LoaderParamInfo(0, "NextWindow") = NumWin
    End If
    
    '------------------------------------Новопашин В.М. 22.05.2006 г.-----------------
    If KeyCode = vbKeyF7 And Shift = 0 Then
       btnCalc_Click
    End If
    '---------------------------------------------------------------------------------
    
End Sub


Private Sub UserDocument_KeyPress(KeyAscii As Integer)

    Dim bRet1 As Boolean
    
    bRet1 = True
    
    Select Case (KeyAscii)
        '------------------------------------Новопашин В.М. 22.05.2006 г.-----------------
        
        Case vbKeyF7  'F7
            btnCalc_Click
        '---------------------------------------------------------------------------------
        Case 13                       'Enter
            KeyAscii = 0
            blnForward = True
            If UserDocument.ActiveControl.name = "txtCode" Then
                If Not blnCodeEnter Then
                    blnCodeEnter = False
                    GotoNextControlForEnter
                End If
            Else
                GotoNextControlForEnter
            End If
            
        
        Case vbKeyTab
            blnForward = True
            GotoNextControlForEnter
            
        Case 27                              'Esc
            KeyAscii = 0
            blnForward = False
            Select Case (UserDocument.ActiveControl.name)
                Case "txtINNPay"
                    If txtFIOPay.Enabled Then
                        txtFIOPay.SetFocus
                    Else
                        objInterfaces.PrevCtrl
                    End If
                '---------------------изменено Кирсанова Е.В. 17.10.2005
                Case "cmbPurpose"
                     If txtINN.Enabled Then
                        txtINN.SetFocus
                     ElseIf AccClient.Enabled Then
                        AccClient.SetFocus
                     '-------------------------- Новопашин В.М. 02.06.2006
                     ElseIf txtBic.Enabled Then
                        txtBic.SetFocus
                     ElseIf txtCode.Enabled Then
                        txtCode.SetFocus
                     '----------------------------------------------------
                     End If
                '------------------- Новопашин В.М. 05.06.2006 ------------
                Case "txtCode"
                     If btnFindFilter.Visible And btnFindFilter.Enabled Then
                         btnFindFilter.SetFocus
                     ElseIf txtNomerCardPay.Visible And txtNomerCardPay.Enabled Then
                        txtNomerCardPay.SetFocus
                     ElseIf AccClientPay.Visible And AccClientPay.Enabled Then
                        AccClientPay.SetFocus
                     ElseIf txtInfoClient.Visible And txtInfoClient.Enabled Then
                        txtInfoClient.SetFocus
                     Else
                        btnClient.SetFocus
                     End If
                     'txtAdressPay.SetFocus
                Case "txtNomerCardPay"
                     AccClientPay.SetFocus
                Case "AccClientPay"
                     txtAdressPay.SetFocus
                Case "txtAdressPay"
                     txtINNPay.SetFocus
                Case "txtINNPay"
                     txtFIOPay.SetFocus
                Case "txtFIOPay"
                     btnExit.SetFocus
                '----------------------------------------------------------
                Case "txtINN"
                
                    '----------------------------- Новопашин В.М. 10.08.2006 г.
                     If AccClient.Enabled Then
                        AccClient.SetFocus
                     End If
                     '----------------------------------------------------------
                     
                Case "AccClient"
                
                     '----------------------------- Новопашин В.М. 10.08.2006 г.
                     If txtBic.Enabled Then
                        txtBic.SetFocus
                     End If
                     '----------------------------------------------------------
                        
                Case "'btnTariff", "btnPhone"
                    subPayment.Tabs(TAB_GENERAL).Selected = True
                    If txtCheckSum.Visible Then
                        txtCheckSum.SetFocus
                    Else
                        AccPay.SetFocus
                    End If
                
                Case "txt_ThirdPersonName"
                       subPayment.Tabs(TAB_GENERAL).Selected = True
                       If txtCheckSum.Visible Then
                            txtCheckSum.SetFocus
                        ElseIf curSumma.Enabled Then curSumma.SetFocus
                        Else
                            txtKSPayment.SetFocus
                        End If
                
                Case "txtKBKNalog"
                   If txtStatusNalog.Enabled Then
                        txtStatusNalog.SetFocus
                   ElseIf subPayment.Tabs(TAB_THIRDPERSON).Visible Then
                        subPayment.Tabs(TAB_THIRDPERSON).Selected = True
                        If txt_ThirdPersonKpp.Enabled Then
                            txt_ThirdPersonKpp.SetFocus
                        Else
                            txt_ThirdPersonInn.SetFocus
                        End If
                   Else
                       subPayment.Tabs(TAB_GENERAL).Selected = True
                       If txtCheckSum.Visible Then
                            txtCheckSum.SetFocus
                        ElseIf curSumma.Enabled Then curSumma.SetFocus
                        Else
                            txtKSPayment.SetFocus
                        End If
                    End If
                   
                Case "txtStatusNalog"
                    If subPayment.Tabs(TAB_THIRDPERSON).Visible Then
                        subPayment.Tabs(TAB_THIRDPERSON).Selected = True
                        If txt_ThirdPersonKpp.Enabled Then
                            txt_ThirdPersonKpp.SetFocus
                        Else
                            txt_ThirdPersonInn.SetFocus
                        End If
                    Else
                        subPayment.Tabs(TAB_GENERAL).Selected = True
                        If txtCheckSum.Visible Then
                            txtCheckSum.SetFocus
                        ElseIf curSumma.Enabled Then
                            curSumma.SetFocus
                        Else
                            txtKSPayment.SetFocus
                        End If
                    End If
                ' ------------------------------------
                ' добавила Бровкова Н.Ю. от 07.04.2005
                Case Else
                    
                    If subPayment.Tabs(TAB_ADDFL).Selected Then
                        If subPayment.Tabs(TAB_TARIFF).Visible Then
                            subPayment.Tabs(TAB_TARIFF).Selected = True
                            'btnTariff.SetFocus
                        Else
                            If subPayment.Tabs(TAB_TELEPHONE).Visible Then
                                subPayment.Tabs(TAB_TELEPHONE).Selected = True
                                'btnPhone.SetFocus
                            Else
                                If subPayment.Tabs(TAB_TAX).Visible Then
                                    subPayment.Tabs(TAB_TAX).Selected = True
                                Else
                                    subPayment.Tabs(TAB_GENERAL).Selected = True
                                    '------------------------- Новопашин В.М. 24.08.2006 г. -------
                                    If txtCheckSum.Enabled And txtCheckSum.Visible Then
                                        txtCheckSum.SetFocus
                                    Else
                                        If AccPay.Enabled And AccPay.Visible Then
                                            AccPay.SetFocus
                                        Else
                                            If txtYearEnd.Enabled And txtYearEnd.Visible Then
                                                txtYearEnd.SetFocus
                                            Else
                                                If curPeny.Visible And curPeny.Enabled Then
                                                    curPeny.SetFocus
                                                ElseIf curSumma.Enabled Then
                                                    curSumma.SetFocus
                                                Else
                                                    txtAdressPay.SetFocus
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                                '---------------------------------------------------------------
                                
                            End If
                        End If
                    
                    Else
                        objInterfaces.PrevCtrl
                    End If
                ' ------------------------------------
                End Select
    End Select
  End Sub

Private Function CheckPayment()

On Error GoTo ErrorCode

    CheckPayment = True

    ' (69627)
    ' проверка заблокированного паспорта клиента
    'If CheckLockPassport = False Then
    '   CheckPayment = False
    '   Exit Function
    'End If
    
    ' [16595]
    If Not CheckClientByDictionary() Then
       CheckPayment = False
       Exit Function
    End If

    If intState = 1 Then
       CheckPayment = False
       MsgBox "Не выбран договор с получателем!", 16, m_strCaptionForm
       subPayment.Tabs(TAB_GENERAL).Selected = True
        
       If subPayment.SelectedTab.Index = 1 Then
          objInterfaces.GoToCtrl btnContract
       End If
        
       Exit Function
    End If

    If CLng(m_IdContract) = CLng(0) Then
        CheckPayment = False
        MsgBox "Не выбран договор с получателем!", 16, m_strCaptionForm
        subPayment.Tabs(TAB_GENERAL).Selected = True
        
        If subPayment.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl btnContract
        End If
        
        Exit Function
    End If

    'проверка на террориста
    If CheckTerror = False Then

       CheckPayment = False
       Exit Function
    End If

   '----------------------------------- Новопашин В.М. 30.01.2006 г. -------------
   'В связи с введением устновки "Выбор плательщика" в "Оплата услуг",
   'изменения сделанные ниже Кирсановой Е.В. я закомментарил, т.к. эта установка
   'более универсальная, чем ниже условие.
   'Смысл установки следующий - если стоит 1, то плательщик вводится ВСЕГДА,
   '0 - на усмотрение пользователя.
    
    Dim intIsFIOPay As Integer
    
    Set objParamIn = CreateObject("ToolPubs.IUbsParam")
    Set objParamOut = CreateObject("ToolPubs.IUbsParam")
   
    objParamIn.ClearParameters
    objParamOut.ClearParameters
     
    'Во входных параметрах ставим считываемую установку
     
    UbsChannel.Run "UTReadSettingChechkClient", objParamIn, objParamOut
    
    'Если ошибки нет, то проверяем пустое ли значение установки или нет
    'Если пустое, то по умолчанию ставим 0, иначе 1
    If Not IsEmpty(objParamOut.Parameter("Result")) Then
       intIsFIOPay = CInt(objParamOut.Parameter("Result"))
    Else
       intIsFIOPay = 0
    End If
    
    'Если установка установлена в 1, то проверяем плательщика
    If intIsFIOPay = 1 And Len(txtFIOPay.Text) = 0 Then
       CheckPayment = False
       MsgBox "Введите ФИО плательщика.", vbCritical, m_strCaptionForm
       subPayment.Tabs(TAB_GENERAL).Selected = True
       txtFIOPay.SetFocus
       Exit Function
    End If
    
    ' (112807) =========================
    'If GetBankNameACC = False Then
    '    CheckPayment = False
    '    subPayment.Tabs(TAB_GENERAL).Selected = True
    '    If subPayment.SelectedTab.Index = 1 Then
    '        If txtBic.Enabled Then txtBic.SetFocus
    '    End If
    '    Exit Function
    'End If
    
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    objParamIn.Parameter("BicExtBank") = txtBic.Text
    objParamIn.Parameter("AccountExtBank") = AccKorr.Text
    objParamIn.Parameter("NameExtBank") = txtNameBank.Text
    
    UbsChannel.Run "UTCheckBankRecipient", objParamIn, objParamOut
    If objParamOut.Parameter("StrError") <> "" Then
    
        MsgBox objParamOut.Parameter("StrError"), vbCritical, m_strCaptionForm
    
        If objParamOut.Parameter("StrControlName") <> "" Then
            Dim ctl As Control
            Dim c As Control
            For Each c In UserDocument.Controls
                If c.name = objParamOut.Parameter("StrControlName") Then _
                    Set ctl = c: Exit For
            Next c
            
            If Not ctl Is Nothing Then
                subPayment.Tabs(TAB_GENERAL).Selected = True
                If subPayment.SelectedTab.Index = 1 Then
                    If ctl.Enabled Then ctl.SetFocus
                End If
            End If
        End If
        
        CheckPayment = False
        Exit Function
    End If
    ' (112807) =========================
       
    objParamIn.ClearParameters
    objParamOut.ClearParameters
 '=====================09.04.2008======================
    'Доработка по приему произвольных договоров
    objParamIn.Parameter("BIC") = Trim(txtBic.Text)
    objParamIn.Parameter("ACC") = AccClient.Text
    objParamIn.Parameter("IdContract") = m_IdContract

    UbsChannel.Run "UtCheckAccFromBic", objParamIn, objParamOut

    If objParamOut.Parameter("bRetVal") = False Then
       CheckPayment = False
       MsgBox objParamOut.Parameter("strError"), 16, m_strCaptionForm
       subPayment.Tabs(TAB_GENERAL).Selected = True
       If subPayment.SelectedTab.Index = 1 Then
          If AccClient.Enabled Then
              objInterfaces.GoToCtrl AccClient
          Else
              objInterfaces.GoToCtrl txtCode
          End If
       End If
       Exit Function
    End If
 
         If txtYearBeg.Text <> "" And txtMonthBeg.Text <> "" And txtDayBeg.Text <> "" And txtYearEnd.Text <> "" And txtMonthEnd.Text <> "" And txtDayEnd.Text <> "" Then
                'дата начала должна быть меньше даты окончания
                If CInt(txtMonthBeg.Text) > CInt(txtMonthEnd.Text) Then
                    If CInt(txtYearBeg.Text) >= CInt(txtYearEnd.Text) Then
                        MsgBox "Ошибка в дате!", 16, m_strCaptionForm
                        objInterfaces.GoToCtrl txtMonthBeg
                        CheckPayment = False
                        Exit Function
                    End If
                Else
                    If CInt(txtYearBeg.Text) > CInt(txtYearEnd.Text) Then
                        MsgBox "Ошибка в дате!", 16, m_strCaptionForm
                        objInterfaces.GoToCtrl txtMonthBeg
                        CheckPayment = False
                        Exit Function
                    End If
                End If
          End If

      objParamIn.Parameter("STRACC") = AccClient.Text
      objParamIn.Parameter("BIC") = txtBic.Text
      UbsChannel.Run "UtCheckCloseAccout", objParamIn, objParamOut
      If objParamOut.Parameter("RETVAL") = False Then
          CheckPayment = False
          MsgBox "Счет получателя обнаружен в списке закрытых счетов!", 16, m_strCaptionForm
          Exit Function
      End If
      
      objParamIn.Parameter("STRACC") = AccClient.Text
      objParamIn.Parameter("BIC") = txtBic.Text
      UbsChannel.Run "PsCheckTofkAcc", objParamIn, objParamOut
      If objParamOut.Parameter("RETVAL") = False Then
          CheckPayment = False
          MsgBox "Счет получателя не найден в справочнике ТОФК!", 16, m_strCaptionForm
          Exit Function
      End If
      
      
        ' проверка ключа расчетного счета счета
        objParamIn.Parameter("STRACC") = AccClient.Text
        objParamIn.Parameter("BIC") = txtBic.Text
        objParamIn.Parameter("CORRACC") = AccKorr.Text
        If Mid(AccClient.Text, 1, 2) <> "03" And Mid(AccClient.Text, 6, 3) <> "643" Then
            UbsChannel.Run "CheckKey", objParamIn, objParamOut
            If objParamOut.Parameter("RETVAL") = False Then
                CheckPayment = False
                MsgBox "Некорректный ключ счета!", 16, m_strCaptionForm
                subPayment.Tabs(TAB_GENERAL).Selected = True
                If subPayment.SelectedTab.Index = 1 Then
                    objInterfaces.GoToCtrl AccClient
                    Exit Function
                End If
            End If
        Else
            If (Mid(AccClient.Text, 1, 2) = "03" And Mid(AccClient.Text, 6, 3) <> "643") Or _
               (Mid(AccClient.Text, 1, 2) <> "03" And Mid(AccClient.Text, 6, 3) = "643") Then
                    CheckPayment = False
                    Call MsgBox("Введён недопустимый код валюты!", 16, m_strCaptionForm)
                    subPayment.Tabs(TAB_GENERAL).Selected = True
                    If subPayment.SelectedTab.Index = 1 Then
                        objInterfaces.GoToCtrl AccClient
                    End If
                    Exit Function
            End If
        End If
        
    '------------------------------------------ Новопашин В.М. 06-02-2006 г.
    ' Добавил в условие and AccPay.Visible =True
    If (AccPay.Enabled = True And AccPay.Visible = True) Or subPayment.Tabs(TAB_ADDFL).Selected = True Then
        If AccPay.Enabled And AccPay.Visible Then
    '------------------------------------------------------------------------
            If CInt(Len(Trim(AccPay.Text))) = CInt(0) Or CInt(Len(Trim(AccPay.Text))) < CInt(AccPay.MaxLength) Then
                CheckPayment = False
                MsgBox "Некорректная длина лицевого счета плательщика!(" & AccPay.MaxLength & ")", 16, m_strCaptionForm
                subPayment.Tabs(TAB_GENERAL).Selected = True
                If subPayment.SelectedTab.Index = 1 Then
                    objInterfaces.GoToCtrl AccPay
                End If
                Exit Function
            End If
        End If
    End If
 
    If AccPay.Enabled = True Or subPayment.Tabs(TAB_ADDFL).Selected = True Then
        If txtCheckSum.Enabled And txtCheckSum.Visible Then
            If CInt(Len(Trim(txtCheckSum.Text))) = CInt(0) Or CInt(Len(Trim(txtCheckSum.Text))) < CInt(txtCheckSum.Tag) Then
                CheckPayment = False
                MsgBox "Некорректная длина ключа лицевого счета плательщика!(" & txtCheckSum.Tag & ")", 16, m_strCaptionForm
                subPayment.Tabs(TAB_GENERAL).Selected = True
                If subPayment.SelectedTab.Index = 1 Then
                    objInterfaces.GoToCtrl txtCheckSum
                End If
                Exit Function
            End If
        End If
    End If

    If curSumma.CurrencyValue = CCur(0) Then
        CheckPayment = False
        MsgBox "Некорректная сумма платежа!", 16, m_strCaptionForm
        subPayment.Tabs(TAB_GENERAL).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl curSumma
        End If
        Exit Function
    End If
 
    If curSummaTotal.CurrencyValue < 0 Then
        CheckPayment = False
        MsgBox "Некорректная общая сумма платежа!", 16, m_strCaptionForm
        subPayment.Tabs(TAB_GENERAL).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl curSumma
        End If
        Exit Function
    End If
    
    '---------------------------------- Новопашин В.М. 11.01.2007 г. --------
    'Проверка суммы для контроля кассовых операций
    Dim curSumForCashControl As Currency
    UbsChannel.Run "UtReadSumForCashControl", objParamIn, objParamOut
    curSumForCashControl = CCur(objParamOut.Parameter("curSumForCashControl"))

    If curSumForCashControl < curSummaTotal.CurrencyValue And m_IdClient = 0 Then
       subPayment.Tabs(TAB_GENERAL).Selected = True
       btnClient.SetFocus
       CheckPayment = False
       MsgBox "Введите клиента из справочника, так как общая сумма платежа превышает сумму для контроля кассовых операций.", 16, m_strCaptionForm
       btnClient_Click
       Exit Function
    End If
    '------------------------------------------------------------------------
    
    
    ' если видна закладка Тариф, то тариф должен быть установлен
    If subPayment.Tabs(TAB_TARIFF).Visible = True Then
        If cmbTariff.ListCount = 0 Then
            CheckPayment = False
            MsgBox "Не задан тариф!", 16, m_strCaptionForm
            subPayment.Tabs(TAB_TARIFF).Selected = True
            'objInterfaces.GoToCtrl btnTariff
            Exit Function
        End If
    End If
    
    ' если видна закладка Телефонный узел, то ТУ должен быть установлен
    If subPayment.Tabs(TAB_TELEPHONE).Visible = True Then
        If cmbPhone.ListCount = 0 Then
            CheckPayment = False
            MsgBox "Не задан телефонный узел!", 16, m_strCaptionForm
            subPayment.Tabs(TAB_TELEPHONE).Selected = True
            'objInterfaces.GoToCtrl btnPhone
            Exit Function
        End If
    End If
    
    ' проверим в сценарии доп.поля объекта
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    UbsChannel.Run "CheckAddFields", objParamIn, objParamOut
    If objParamOut.Parameter("bRetVal") = False Then
        CheckPayment = False
        MsgBox objParamOut.Parameter("StrError"), 16, "Проверка доп. полей. " & m_strCaptionForm
        subPayment.Tabs(TAB_ADDFL).Selected = True
        Exit Function
    End If
    
    '---------изменено Кирсанова Е.В. 04.10.2005----------------------
    If m_SIDPattern = "UBS_UT_ENERGY" Then
        ' проверим в сценарии для платежа за электричество сумму, введенную оператором
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("curSumPaym") = curSumma.CurrencyValue
        objParamIn.Parameter("IdPattern") = m_SIDPattern
        objParamIn.Parameter("curRate") = CCur(varTariff(2, cmbTariff.ListIndex))
        UbsChannel.Run "CheckSumPayment", objParamIn, objParamOut
        If objParamOut.Parameter("bRetVal") = False Then
            If MsgBox(objParamOut.Parameter("StrError"), vbYesNo + vbQuestion, m_strCaptionForm) = vbYes Then
                ' сохраняем введенную сумму
            Else
                subPayment.Tabs(TAB_TAX).Selected = True
                'btnTariff.SetFocus
                CheckPayment = False
                Exit Function
            End If
        End If
    End If
    
    '------------------------------------ Новопашин В.М. 07.06.2006 г.
    'Проверка корректности введения кассовых символов

    If lngCheckKSSymb Then

'=============================31.03.2008=======================================
      'If txtKSPayment.Visible Then
      If m_blnRegimCashSymb Then
        Dim varCashSym As Variant
        ReDim varCashSym(2, 0) As Variant
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        
        varCashSym(0, 0) = txtKSPayment.Text
        varCashSym(1, 0) = txtKSRate.Text
        varCashSym(2, 0) = txtKSNDS.Text
        
        objParamIn.Parameter("varCashSym") = varCashSym
        objParamIn.Parameter("IdContract") = m_IdContract
        UbsChannel.Run "UtCheckCashSymbol", objParamIn, objParamOut
        
        If Not objParamOut.Parameter("bRetValCheck") And objParamOut.Parameter("strError") <> "" Then
           MsgBox objParamOut.Parameter("strError"), 16, "Проверка кассовых символов"
            subPayment.Tabs(TAB_GENERAL).Selected = True
           If objParamOut.Parameter("txtKSPayment") Then
              If txtKSPayment.Visible Then
                  txtKSPayment.SetFocus
              End If
           ElseIf objParamOut.Parameter("txtKSRate") Then
              txtKSRate.SetFocus
           Else
              txtKSNDS.SetFocus
           End If
           CheckPayment = False
           Exit Function
        End If
      End If

End If

If cmdCashSymb.Visible Then

'================================
      Dim i, sumCash
      If IsArray(arrCashSymb) Then
          sumCash = 0
          For i = 0 To UBound(arrCashSymb, 2)
              sumCash = sumCash + CCur(arrCashSymb(2, i))
          Next

          If (curSumma.CurrencyValue + curPeny.CurrencyValue) <> sumCash Then
              MsgBox "Сумма разбивки платежа по кассовым символам, не совпадает с суммой платежа!", 16, m_strCaptionForm
              CheckPayment = False
              Exit Function
          End If
      End If
'================================

   
        
   If lngCheckKSSymb Then
   
     If txtKSRate.Visible Then
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        
        objParamIn.Parameter("CashSymComiss") = txtKSRate.Text
        objParamIn.Parameter("IdContract") = m_IdContract
        
        UbsChannel.Run "UtCheckCashSymbolComiss", objParamIn, objParamOut
        
        If Not objParamOut.Parameter("bRetValCheck") And objParamOut.Parameter("strError") <> "" Then
            MsgBox objParamOut.Parameter("strError"), 16, "Проверка кассовых символов"
            subPayment.Tabs(TAB_GENERAL).Selected = True
            txtKSRate.SetFocus
            CheckPayment = False
           Exit Function
        End If
     End If
     
     If txtKSNDS.Visible Then
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        
        objParamIn.Parameter("CashSymNDS") = txtKSNDS.Text
        objParamIn.Parameter("IdContract") = m_IdContract
        
        UbsChannel.Run "UtCheckCashSymbolNDS", objParamIn, objParamOut
        
        If Not objParamOut.Parameter("bRetValCheck") And objParamOut.Parameter("strError") <> "" Then
            MsgBox objParamOut.Parameter("strError"), 16, "Проверка кассовых символов"
            subPayment.Tabs(TAB_GENERAL).Selected = True
            txtKSNDS.SetFocus
            CheckPayment = False
           Exit Function
        End If
     End If
     
   End If

    If IsEmpty(arrCashSymb) Then
        MsgBox "Некорректное заполнение массива кассовых символов", 16, "Проверка кассовых символов"
        subPayment.Tabs(TAB_GENERAL).Selected = True
        cmdCashSymb.Enabled = True
        cmdCashSymb.SetFocus
        CheckPayment = False
        Exit Function
    End If
'====================================================================
    End If
    '-----------------------------------------------------------------

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CheckPayment", "ошибка выполнения"
End Function
 
' (69627)
'Проверка заблокированности паспорта
Function CheckLockPassport() As Boolean
    CheckLockPassport = True
    
    Dim ret As Boolean, objComCheck As Object
    
    If Len(Trim(m_strDocNumber)) <> 0 Or Len(Trim(m_strDocSeries)) <> 0 Then
        Set objComCheck = CreateObject("UbsCheck.UbsComCheck")
    
        ret = objComCheck.CommonCheckPassport(UbsChannel, Trim(m_strDocSeries), Trim(m_strDocNumber), txtFIOPay.Text)
           
        CheckLockPassport = ret
    End If
    
End Function

' [16595]
' Проверка клиента по словарям
Function CheckClientByDictionary() As Boolean
    Dim objPrm
    Dim objCheck

    On Error GoTo ErrorCode
    
    Set objCheck = CreateObject("UbsCheck.UbsCheckClientByDictionary")
    Set objPrm = CreateObject("ToolPubs.IUbsParam")
    
    If m_IdClient > 0 Then
        If blnGuest Then
            objPrm.Parameter("Идентификатор посетителя") = m_IdClient
        Else
            objPrm.Parameter("Идентификатор клиента") = m_IdClient
        End If
    Else
        If Trim(txtFIOPay.Text) <> "" Then
            objPrm.Parameter("ФИО") = txtFIOPay.Text
        Else
            CheckClientByDictionary = True
            Exit Function
        End If
        If Trim(txtAdressPay.Text) <> "" Then _
            objPrm.Parameter("Адрес") = txtAdressPay.Text
        If Trim(txtINNPay.Text) <> "" Then _
            objPrm.Parameter("ИНН") = txtINNPay.Text
    End If
    
    CheckClientByDictionary = CBool(objCheck.SystemCheckClientByDictionary(UbsChannel, objPrm, stgCheckPayer, SidAction, "Прием платежа"))
    
    Exit Function

ErrorCode:
    objErr.UbsErrMsg "CheckClientByDictionary", "ошибка выполнения"
End Function
 
Private Function CheckAccPayment()

On Error GoTo ErrorCode

    CheckAccPayment = True

    If AccPay.Enabled Then
        ' CheckAndSplitAccount()

        If Not CheckAndSplitAccount() Then

            CheckAccPayment = False
            Exit Function
        Else

            ' PrepareAccount()
            ' (если ключ = входит в счет (для газа))
            If m_bIncludeKey Then
                If Not PrepareAccount() Then
                    CheckAccPayment = False
                    Exit Function
                End If
            End If
        End If

        If txtCheckSum.Enabled Then
            'МЕНЯТЬ СТРОКУ ВЫШЕ И НИЖЕ НЕЛЬЗЯ!!! ЗАСАДА!!!
            If Not m_bIncludeKey Then
                Dim strChkType
                strChkType = m_strCheckType
                ' PrepareAccount()
                If Not PrepareAccount() Then
                    CheckAccPayment = False
                    Exit Function
                End If
                If strChkType = "ключ сформирован автоматически" Then
                    m_strCheckType = strChkType
                End If
            End If
        End If
    End If
    
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CheckAccPayment", "ошибка выполнения"
End Function
 
' расчет суммы комиссии
Function CalcSumCommiss_2()
    Dim intTypeSend As Integer
    Dim curSumRateSend As Currency, curSumTotal As Currency
    Dim curSumPaym As Currency, curPerSend As Currency
    Dim curMinSumSend As Currency, curMaxSumSend As Currency

'MsgBox "[" + prefCalcRate + "] CalcSumCommiss_2() - begin"

btnSave.Enabled = False  ' (70410)

On Error GoTo ErrorCode
    ' данные для расчета комиссии с плательщика
    intTypeSend = m_arrRateSend(0)   ' RateTypeSend
    curPerSend = m_arrRateSend(1)    ' RatePercentSend
    curMinSumSend = m_arrRateSend(2) ' MinSumSend
    curMaxSumSend = m_arrRateSend(3) ' MaxSumSend

    curSumPaym = curSumma.CurrencyValue
    
   Dim arrStavka As Variant
   Dim strTarif As String
   Dim i As Integer
   Dim blnFind As Boolean

   arrStavka = m_arrRateSend(5)
   strTarif = m_arrRateSend(4)

   If IsArray(arrStavka) Then
       Select Case strTarif
           Case "ставка, %"
               intTypeSend = 1
           Case "фиксированная сумма"
               intTypeSend = 2
           Case Else
               Exit Function
       End Select

       If IsEmpty(arrStavka) Then
           Exit Function
       End If
       
       curPerSend = 0
       i = UBound(arrStavka, 2)
       blnFind = False
       Do
           If CCur(arrStavka(0, i)) <= CCur(curSumPaym) Then
               curPerSend = CCur(arrStavka(1, i))
               blnFind = True
           End If
           If i = 0 Then
               blnFind = True
           End If
           
           i = i - 1
         
       Loop While blnFind = False

   End If

   If subPayment.Tabs(TAB_TAX).Visible And blnSecondPayment = 2 Then
       intTypeSend = 0
   End If

Dim pr As String
pr = "Ком с плат: тип=" + CStr(intTypeSend) + ", ставка=" + CStr(curPerSend) + ", мин=" + CStr(curMinSumSend) + ", макс=" + CStr(curMaxSumSend) + ", от суммы=" + CStr(curSumPaym) + ", польз форма=" + CStr(blnAddparam) + ", ком на польз форме=" + CStr(curSummaRateSend.CurrencyValue)
curSumma.ToolTipText = pr

'=================================================================================
    Select Case intTypeSend
       Case 0
          curSumRateSend = CCur(0)
       Case 1 ' % от суммы платежа
           If m_blnComissPeniPayer Then 'Включаем пени в расчет комиссии
               'Если включить, что пени входит в комиссию, а признак пени не установить, то будет ошибочная сумма, но так делать нельзя
               curSumRateSend = objFormat.Round(CCur(curSumPaym) + CCur(curPeny.CurrencyValue) * CCur(curPerSend) / 100, 2) 'Round((CCur(Round(curSumPaym, 2)) + Round(CCur(curPeny.CurrencyValue), 2)) * CCur(Round(curPerSend, 2)) / 100, 2)
           Else 'Не включаем пени в расчет комиссии
               curSumRateSend = objFormat.Round(CCur(curSumPaym) * CCur(curPerSend) / 100, 2) 'Round(CCur(Round(curSumPaym, 2)) * CCur(Round(curPerSend, 2)) / 100, 2)
           End If
       Case 2 ' фиксированная сумма
          curSumRateSend = objFormat.Round(curPerSend, 2) 'CCur(Round(curPerSend, 2))
    End Select

    If intTypeSend > 0 Then
       If curSumRateSend < curMinSumSend And curMinSumSend > 0 Then
          curSumRateSend = Round(curMinSumSend, 2)
       End If
       If curSumRateSend > curMaxSumSend And curMaxSumSend > 0 Then
          curSumRateSend = Round(curMaxSumSend, 2)
       End If
    End If
    
    'Если вызов с пользовательской формы и комиссия заполнена
    If blnAddparam And curSummaRateSend.CurrencyValue > 0 Then
        curSumRateSend = curSummaRateSend.CurrencyValue
    End If
    
    curSumTotal = objFormat.Round(curSumPaym + curSumRateSend, 2) 'Round(curSumPaym, 2) + Round(curSumRateSend, 2)
    
    If blnPenyPresent Then
        curSumTotal = curSumTotal + curPeny.CurrencyValue
    End If
       
    curSummaRateSend.Text = curSumRateSend
    curSummaTotal.Text = curSumTotal

btnSave.Enabled = True  ' (70410)
'MsgBox "True"

'MsgBox "CalcSumCommiss_2() - end"

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CalcSumCommiss_2", "ошибка выполнения"
End Function

' расчет суммы комиссии
Function CalcSumCommiss()

'MsgBox "[" + prefCalcRate + "] CalcSumCommiss - begin"

On Error GoTo ErrorCode
    If curSumma.Text = "" Then curSumma.Text = "0"
    CalcSumCommiss = False
    
    'вызовем функцию , которая для договора посчитает суммы
    objParamIn.ClearParameters
    objParamIn.Parameter("IdContract") = m_IdContract
    objParamIn.Parameter("SumPaym") = curSumma.CurrencyValue
    objParamIn.Parameter("SUMMAPENI") = curPeny.CurrencyValue
    objParamIn.Parameter("blnComissPeniPayer") = m_blnComissPeniPayer
    objParamIn.Parameter("AccClientPay") = AccClientPay.Text
    objParamIn.Parameter("IdClient") = m_IdClient
    objParamIn.Parameter("INN") = txtINN.Text
    objParamIn.Parameter("Kppu") = txtKppu.Text
    objParamIn.Parameter("AccClient") = AccClient.Text
    
    objParamIn.Parameter("blnSecondPayment") = True  ' по умолчанию считать ком с плательщика
    ' для Налогов:
    If subPayment.Tabs(TAB_TAX).Visible Then
        objParamIn.Parameter("blnSecondPayment") = IIf(blnSecondPayment = 1, True, False)
    End If
    
    'Если вызов с пользовательской формы и комиссия заполнена
    If blnAddparam And curSummaRateSend.CurrencyValue > 0 Then
        objParamIn.Parameter("Комиссия задана") = curSummaRateSend.CurrencyValue
        'MsgBox "08: Комиссия задана " & curSummaRateSend.Text
    End If
    
    objParamIn.Parameter("IdGroupIncoming") = IdGroupIncoming
    objParamIn.Parameter("IsGuest") = blnGuest
    objParamIn.Parameter("Benefits") = CheckBenefits.Value
   'MsgBox "1"
    UbsChannel.Run "UtCalcSumCommiss", objParamIn, objParamOut
    If objParamOut.Parameter("bRetVal") = True Then
        m_curSumRateRec = objParamOut.Parameter("SummaRateRec")
        m_curSumRec = objParamOut.Parameter("SummaRec")
        curSummaRateSend.Text = objParamOut.Parameter("SummaRateSend")
        'MsgBox "09: Calc() " & curSummaRateSend.Text
        curSummaTotal.Text = objParamOut.Parameter("SummaTotal")

        CalcSumCommiss = True
    Else
        If CBool(m_blnClickSave) Then
            MsgBox objParamOut.Parameter("StrError"), 16, "Расчет комиссий. " & m_strCaptionForm
        End If
    End If

'MsgBox "CalcSumCommiss - end"

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "Проверка корректности данных", "ошибка выполнения"
End Function

' расчет суммы НДС
'
Function CalcSumNDS() As Boolean

 On Error GoTo ErrorCode

    CalcSumNDS = False
    
    objParamIn.ClearParameters
    '===============================
    'Параметры для НДС с суммы платежа
    objParamIn.Parameter("IDCONTRACT") = m_IdContract
    objParamIn.Parameter("SUMMA") = CCur(curSumma.CurrencyValue)
    '===============================
    objParamIn.Parameter("IDKINDPAYMENT") = m_IdKindPaym
    objParamIn.Parameter("SUMMARATESEND") = curSummaRateSend.CurrencyValue
    objParamIn.Parameter("SUMMARATEREC") = m_curSumRateRec

    UbsChannel.Run "UtCalcSumNDS", objParamIn, objParamOut

    'If Len(Trim(objParamOut.Parameter("StrError"))) = 0 Then
    If objParamOut.Parameter("bRetVal") = True Then
    'ошибок нет
        m_curSumNDSSend = objParamOut.Parameter("SumNDSSend")
        m_curSumNDSPaym = objParamOut.Parameter("SumNDSPaym")
        m_curSumNDSRec = objParamOut.Parameter("SumNDSRec")
    Else
        MsgBox objParamOut.Parameter("StrError"), 16, "Расчет НДС. " & m_strCaptionForm
        Exit Function
    End If

    CalcSumNDS = True
    
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CalcSumNDS", "ошибка выполнения"
End Function

