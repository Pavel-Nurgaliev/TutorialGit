' очищать ли поля плательщика
'
Sub clearRecFieldsSend()

 On Error GoTo ErrorCode
    
    Dim IsClear As Boolean
    
    UbsChannel.Run "UtGetStateClearFieldSend", objParamIn, objParamOut
    IsClear = False
    
    If objParamOut.Parameter("bRetVal") = True Then
    'ошибок нет
        IsClear = objParamOut.Parameter("IsClearSend")
    Else
        MsgBox objParamOut.Parameter("StrError"), 16, "Очищать данные клиента. " & m_strCaptionForm
        Exit Sub
    End If
 
    If CBool(IsClear) Then
        txtINNPay.Text = ""
        txtFIOPay.Text = ""
        txtInfoClient.Text = ""
        txtAdressPay.Text = ""
        If AccClientPay.Visible Then
            AccClientPay.Text = "00000000000000000000"
        End If
        
        '------------------------------ Новопашин В.М. 17.07.2006 г.
        m_IdClient = 0
        lblFindFilter.Visible = False
        btnFindFilter.Visible = False
        '-----------------------------------------------------------
    Else
        txtFIOPay.Text = m_OldtxtFIOPay
        txtInfoClient.Text = m_OldtxtInfoClient
        txtINNPay.Text = m_OldtxtINNPay
        txtAdressPay.Text = m_OldtxtAdressPay
    End If
 
    Call CheckPayer(False)  ' 26.03.1007 - Потапов Д.А.
    
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "clearRecFieldsSend", "ошибка выполнения"
End Sub

Sub IsAutoPeriod()

 On Error GoTo ErrorCode
    
    Dim IsPeriod As Boolean
    
    UbsChannel.Run "UtGetAutoFillPeriod", objParamIn, objParamOut
    IsPeriod = False
    IsAutoPeriodFlag = False
    
    If objParamOut.Parameter("bRetVal") = True Then
        IsPeriod = objParamOut.Parameter("IsPeriod")
        IsAutoPeriodFlag = objParamOut.Parameter("IsPeriod")
    Else
        MsgBox objParamOut.Parameter("StrError"), 16, "Автозаполнение периода. " & m_strCaptionForm
        Exit Sub
    End If
 
    If CBool(IsPeriod) Then
        txtYearBeg.Text = ""
        txtMonthBeg.Text = ""
        txtDayBeg.Text = ""
        
        txtYearEnd.Text = ""
        txtMonthEnd.Text = ""
        txtDayEnd.Text = ""
    End If
    
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "clearRecFieldsSend", "ошибка выполнения"
End Sub

Sub setParamAccCodeKey(idKind)

    objParamIn.ClearParameters
    objParamIn.Parameter("IDKINDPAYMENT") = idKind
    UbsChannel.Run "GetPropAccCode", objParamIn, objParamOut

    m_bIncludeKey = objParamOut.Parameter("INCLUDEKEY")
    m_strSignAccCode = objParamOut.Parameter("SIGNACCCODE")
    m_strSignKey = objParamOut.Parameter("SIGNKEY")
    m_nLenKey = objParamOut.Parameter("LENKEY")
    m_strNameProcAcc = objParamOut.Parameter("PROCCHECKACCCODE")
    m_strNameProcKey = objParamOut.Parameter("PROCCHECKKEY")
       
    AccPay.Enabled = objParamOut.Parameter("ISACCENABLE")
    If AccPay.Enabled Then
        AccPay.Tag = objParamOut.Parameter("TOTALLENACC")
        AccPay.MaxLength = objParamOut.Parameter("LENACC")
    Else
        AccPay.Text = ""
        '------------------------------------ Новопашин 09.06.2006
        txtCheckSum.Text = ""
        '---------------------------------------------------------
    End If

    AccPay.Visible = objParamOut.Parameter("ISACCENABLE")
    If objParamOut.Parameter("ISACCENABLE") And objParamOut.Parameter("ISBTNENABLE") Then
        btnPaymDic.Visible = objParamOut.Parameter("ISBTNENABLE")
    End If
    
    '----------------------------- Новопашин В.М. 15-02-2006 г.
    AccPay.Enabled = objParamOut.Parameter("ISACCENABLE")
    '----------------------------------------------------------
    
    lblAcc.Visible = objParamOut.Parameter("ISACCENABLE")
    
    ' ------- Бровкова Н.Ю. 03.05.05 ------------------------
    m_bIsPeriodEnable = objParamOut.Parameter("IsPeriodEnable")
    txtDayBeg.Visible = objParamOut.Parameter("IsPeriodEnable")
    txtMonthBeg.Visible = objParamOut.Parameter("IsPeriodEnable")
    txtYearBeg.Visible = objParamOut.Parameter("IsPeriodEnable")
    txtDayEnd.Visible = objParamOut.Parameter("IsPeriodEnable")
    txtMonthEnd.Visible = objParamOut.Parameter("IsPeriodEnable")
    txtYearEnd.Visible = objParamOut.Parameter("IsPeriodEnable")
    lblPeriod1.Visible = objParamOut.Parameter("IsPeriodEnable")
    lblPeriod2.Visible = objParamOut.Parameter("IsPeriodEnable")
    ' -------------------------------------------------------
    
    '------------------------------- Новопашин В.М. 27.09.2006 г.
    'Исправлена ошибка - в режиме изменения платежа в л/с вводилось любое кол-во символов
    If Not AccPay.Visible And Not AccPay.Enabled Then
    '------------------------------------------------------------
        AccPay.Text = ""
        txtCheckSum.Text = ""
        AccPay.Tag = 0 'objParamOut.Parameter("TOTALLENACC")
        AccPay.MaxLength = 0 ' objParamOut.Parameter("LENACC")
    End If
    
    If objParamOut.Parameter("ISKEYENABLE") = True Then
        txtCheckSum.Visible = True
        
        '----------------------------- Новопашин В.М. 15-02-2006 г.
        txtCheckSum.Enabled = True
        '----------------------------------------------------------
        
        If (objParamOut.Parameter("INCLUDEKEY")) = True Then
            txtCheckSum.Visible = False
            
            '----------------------------- Новопашин В.М. 15-02-2006 г.
            txtCheckSum.Enabled = False
            '----------------------------------------------------------
        End If
    Else
    
        '----------------------------- Новопашин В.М. 15-02-2006 г.
        txtCheckSum.Enabled = False
        '----------------------------------------------------------
        
        txtCheckSum.Visible = False
    End If

    If txtCheckSum.Visible Then
        txtCheckSum.MaxLength = objParamOut.Parameter("LENKEY")
        txtCheckSum.Tag = objParamOut.Parameter("LENKEY")
        txtCheckSum.Locked = False
    Else
        txtCheckSum.Text = ""
        txtCheckSum.MaxLength = 0
        txtCheckSum.Tag = 0
    End If

End Sub


Function GetBankNameACC()
    GetBankNameACC = False
    
    Dim ressql As Variant
    Dim i As Integer

 On Error GoTo ErrorCode
       
    '-------------------------- Новопашин В.М. 06-02-2006 г.---------
    '
    'If txtBic.Text = "" Then
    '   Exit Function
    'End If
    '----------------------------------------------------------------

    '----------------------------  Новопашин В.М. 28.06.2006 г. --
    'Комплексная проверка по БИК
    objParamIn.Parameter("BIC") = txtBic.Text

    UbsChannel.Run "UtCheckBIKBank", objParamIn, objParamOut
    If Not objParamOut.Parameter("bRetVal") Then
       'Проверяем выводить сообщение или нет 07.07.2006
       If m_blnNoMessage Then
          MsgBox objParamOut.Parameter("strError"), 16, m_strCaptionForm
       End If
       '---------------------------------------------------------------
       
       Exit Function
    End If
    '-----------------------------------------------------------------

    'Проверка на признаки ограничения участия в расчетах
    objParamIn.Parameter("BIC") = txtBic.Text
    UbsChannel.Run "UtCheckBIKLimitSharing", objParamIn, objParamOut
    If Not objParamOut.Parameter("bRetVal") Then
        If Not MsgBox(objParamOut.Parameter("strError") & vbCrLf & "Продолжить ввод платежа?", vbYesNo + vbQuestion, "Проверка корректности данных") = vbYes Then
            txtCode.Text = ""
            txtComment.Text = ""
            txtBic.Text = ""
            txtBic.Enabled = True
            txtBic.Visible = True
            AccKorr.Text = "00000000000000000000"
            txtNameBank.Text = ""
            txtINN.Text = ""
            txtINN.Enabled = True
            AccClient.Text = "00000000000000000000"
            AccClient.Enabled = True
            
            cmbPurpose.Clear
            cmbPurpose.Text = ""
            txtRecip.Text = ""
            Exit Function
        End If
    End If

    
    objParamIn.Parameter("BIC") = txtBic.Text
 
    UbsChannel.Run "ReadBankBIK", objParamIn, objParamOut

    ressql = objParamOut.Parameters
    
    Dim ActiveControlName As String
    If Not UserDocument.ActiveControl Is Nothing Then
        ActiveControlName = UserDocument.ActiveControl.name
    End If
    
    If objParamOut.Parameter("NUM") > 0 Then
        For i = 0 To objParamOut.CountParameters - 1
       
            Select Case ressql(0, i)
                Case "BANKNAME"
                    If Trim(txtNameBank.Text) = "" Or (ActiveControlName = "txtBic" And txtBic.Text <> BicOld) Then
                        txtNameBank.Text = ressql(1, i)
                    End If
                Case "CORRACC"
                    If Trim(AccKorr.Text) = "" Or AccKorr.Text = "00000000000000000000" Or (ActiveControlName = "txtBic" And txtBic.Text <> BicOld) Then
                        AccKorr.Text = ressql(1, i)
                    End If
            End Select
        Next
       
        GetBankNameACC = True
    End If
 
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "GetBankNameACC", "ошибка выполнения"
End Function

Function SetPropBank(blnSepDoc As Boolean)

    txtINN.Enabled = blnSepDoc
   ' AccClient.Enabled = blnSepDoc
   
End Function


Private Sub FindContract()
 On Error GoTo ErrorCode
    If Len(Trim(txtCode.Text)) > 0 Then
        '-------------------------- Новопашин В.М. 07.06.2006 г. ---------
        If blnAlready Then
            Exit Sub
        End If
        blnAlready = True
        '-----------------------------------------------------------------
        ' вызов
        objParamIn.ClearParameters
        objParamIn.Parameter("CODECONTRACT") = txtCode.Text
        '-----------------------------
        ' получить контракт
        objParamIn.Parameter("FROMFO") = calledFromFrontOffice
        UbsChannel.Run "ReadContractbyCode", objParamIn, objParamOut
        If objParamOut.Parameter("error") <> "" Then
            MsgBox objParamOut.Parameter("error"), 16, "Ошибка получения данных контракта"
        Else
            m_IdContract = objParamOut.Parameter("IDCONTRACT")
            If m_IdContract > 0 Then
                Call FindContractbyId
            End If
        End If
        
        '-------------------------- Новопашин В.М. 07.06.2006 г. ---------
        blnAlready = False
        '-----------------------------------------------------------------
    End If
    
    Exit Sub
ErrorCode:

    '-------------------------- Новопашин В.М. 07.06.2006 г. ---------
    blnAlready = False
    '-----------------------------------------------------------------
    
    objErr.UbsErrMsg "Поиск информации о договоре", "ошибка выполнения"
End Sub

Private Sub FindContractbyId()

    If m_IdContract <= 0 Then Exit Sub

    Dim blnSepDoc As Boolean

    ' при выборе к.-л. другого договора, массив, содержащий в себе данные
    ' с доп.поля "Субдоговоры" - очищаем....в любом случае...
    varSubContracts = Empty
    
    arrCashSymb = Empty 'Очищать массив кассовых символов

On Error GoTo ErrorCode

    blnArbitrary = False
    blnEditRecip = False
    If m_blnChangeContract = True Then
        AccPay.Text = ""
        txtCheckSum.Text = ""
        m_strAccCode = Empty
        m_strCheckSum = Empty
        m_strCheckType = Empty
        m_blnChangeContract = False
    End If
    cb_ThirdPerson.Enabled = False
    subPayment.Tabs(TAB_TARIFF).Visible = False
    subPayment.Tabs(TAB_TELEPHONE).Visible = False
    subPayment.Tabs(TAB_TAX).Visible = False
    subPayment.Tabs(TAB_THIRDPERSON).Visible = False
    cboCityCode.Visible = False
    cboCityCode.Enabled = False
    btnPaymDic.Visible = False
    AccPay.Left = 4800
    AccPay.Width = 2055

    If StrCommand_Source <> "ADD_PARAM" Then
        '--------------------
        txtRecip = ""
        '--------------------
        txtComment.Text = ""
        txtBic.Text = ""
        AccKorr.Text = ""
        txtINN.Text = ""
        AccClient.Text = ""
        'txtNote.Text = ""
    
        If StrCommand <> "CHANGE_PART" And StrCommand <> "VIEW" And StrCommand <> "COPY" Then
            cmbPurpose.Text = ""
        End If

        m_IdKindPaym = 0
        txtNameBank.Text = ""
    End If
    '==========7 сентября 2009==========
    'curPeny.CurrencyValue = 0
    '====================================
    If StrCommand = "ADD" Then
        curPeny.CurrencyValue = 0
        m_IdTariff = 0
        m_IdPhone = 0
    End If

    If m_IdContract > 0 Then
        '------------------------------- Новопашин В.М. 14-02-2006 г.
        'Принудительно переносим фокус на txtBic
        'If strCommand <> "VIEW" And Not txtBic.Locked And txtBic.Enabled Then txtBic.SetFocus
        '-----------------------------------------------------------
        
        objParamIn.ClearParameters
        objParamIn.Parameter("IdContract") = m_IdContract
        '-----------------------------
        ' получить контракт
        
        '===============31.03.2008==============================
        UbsChannel.Run "UtReadTypePayment", objParamIn, objParamOut
        If objParamOut.Parameter("bRetVal") = False Then
            MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
            m_IdContract = 0
            Exit Sub
        End If
        'Если платеж групповой, то разбивка по кассовым символам недоступна
        If Not blnGroup Then
            arrDataTypeCashSymbol = objParamOut.Parameter("arrTypeCashSymbol")
        End If
        '=========10 июля 2008 подстановка кассовых символов по умолчанию======
        'Если режим добавления, подставляем кассовые символа по умолчанию,
        'если режим редактирования или просмотра, то не подставляем
        If StrCommand = "ADD" Then
            'Если в установке сказано отображать касс символа
            If lngCheckKSSymb Then
                txtKSPayment.Text = ""
                txtKSRate.Text = ""
                txtKSNDS.Text = ""
                txtKSPayment.Text = objParamOut.Parameter("CASHSYM")
                txtKSRate.Text = objParamOut.Parameter("CASHSYMRATESEND")
                txtKSNDS.Text = objParamOut.Parameter("CASHSYMNDS")
            End If
        End If
        '=======================================================================

        If IsArray(arrDataTypeCashSymbol) Then
            cmdCashSymb.Visible = True
            lblKSPayment.Visible = False
            txtKSPayment.Visible = False
            m_blnRegimCashSymb = False
        Else
            cmdCashSymb.Visible = False
            txtKSPayment.Visible = lngCheckKSSymb 'True
            lblKSPayment.Visible = lngCheckKSSymb 'True
            m_blnRegimCashSymb = lngCheckKSSymb
        End If

       
        UbsChannel.Run "UtReadContract", objParamIn, objParamOut
               
        'Режим создания дополнительного платежа (для налоговых)
        '========================================================
        
        If objParamOut.ExistParameter("Формирование реестра к сводным документам") Then
            FormReestToDocs = objParamOut.Parameter("Формирование реестра к сводным документам")
        Else
            FormReestToDocs = False
        End If
        
        If objParamOut.Parameter("bRetVal") = False And objParamOut.Parameter("StrError") <> "" Then
            Call MsgBox(objParamOut.Parameter("StrError"), vbCritical + vbDefaultButton1 + vbOKOnly, m_strCaptionForm)
            m_IdContract = 0 'Надо обнулить идентификатор договора, т.к Call после этой
            'функции вызывается функция и валится CalcSumCommiss_2
            Exit Sub
        End If
        
        blnLast = False
        If objParamOut.ExistParameter("Данные из предыдущего платежа") Then
            If objParamOut.Parameter("Данные из предыдущего платежа") Then
                blnLast = True
            End If
        End If
        
        
        
        If objParamOut.ExistParameter("Комментарий") Then
            MsgBox CStr(objParamOut.Parameter("Комментарий")), vbInformation, m_strCaptionForm
        End If
        
        m_SIDFiletr = objParamOut.Parameter("Словарь платежей (SID)")
        
        arrKbkForCheck = objParamOut.Parameter("Символы КБК для контроля")
        arrKbkForCheckY = objParamOut.Parameter("Символы КБК для контроля (разрешение)")
        
        ' устанавливаем, только если еще не установлено (иначе после вопроса Вернуться к редакт платежа? будет неверно пересчитана ком с плат)
        If blnSecondPayment = 0 Then blnSecondPayment = 1  ' True  ' 83151
        
        If objParamOut.ExistParameter("Идентификатор договора (дополнительный платеж)") Then
            lblNalog.Visible = True
            m_IdContractSecond = objParamOut.Parameter("Идентификатор договора (дополнительный платеж)")
            arrCashSymbSecond = objParamOut.Parameter("Кассовые символа дополнительный платеж")
        Else
            lblNalog.Visible = False
            m_IdContractSecond = 0
        End If
        
        
         blnLetter = objParamOut.Parameter("blnLetter")
        '========================================================

        ' Потапов Д.А. 18.05.2007
        ' запомнить знечения в доп.поле "Субдоговоры" для дальнейщей проверки
        ' возможности последующего сохранения платежа...
        ' надо проверить, заполнены ли поля БИК банка получателя и счета получателя
        If blnGroup Then
            varSubContracts = objParamOut.Parameter("Субдоговоры")
            If Not CheckSubContracts(objParamOut) Then
                Call MsgBox(objParamOut.Parameter("StrError"), vbCritical + vbDefaultButton1 + vbOKOnly, m_strCaptionForm)
                m_IdContract = 0
                Exit Sub
            End If
        End If
         
        '--------------------------------------- Новопашин В.М. 06.06.2006 г.
        If objParamOut.Parameter("RateTypeSend") = 0 Then
           lblKSRate.Visible = False
           txtKSRate.Visible = False
        Else
           lblKSRate.Visible = lngCheckKSSymb
           txtKSRate.Visible = lngCheckKSSymb
        End If
        
        If objParamOut.Parameter("ShowNDS") = False Then
           lblKSNDS.Visible = False
           txtKSNDS.Visible = False
        Else
           lblKSNDS.Visible = lngCheckKSSymb
           txtKSNDS.Visible = lngCheckKSSymb
        End If
        
        If objParamOut.Parameter("bRetVal") = False And objParamOut.Parameter("StrError") <> "" Then
        '----------------------------------------------------------------------
            MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
            m_IdContract = 0
            Exit Sub
        End If

        '-------- добавила Бровкова Н.Ю. 05.12.05
        ReDim m_arrRateSend(5)
        ' данные для расчета комиссии с плательщика
        m_arrRateSend(0) = objParamOut.Parameter("RateTypeSend")
        m_arrRateSend(1) = objParamOut.Parameter("RatePercentSend")
        m_arrRateSend(2) = objParamOut.Parameter("MinSumSend")
        m_arrRateSend(3) = objParamOut.Parameter("MaxSumSend")
        
        m_arrRateSend(4) = objParamOut.Parameter("Комиссии с плательщика-признак ставки")
        m_arrRateSend(5) = objParamOut.Parameter("Комиссии с плательщика-тарифная сетка")
        '----------------------------------------
            
        'begin - Данилова, 28.10.2005
        If objParamOut.Parameter("VisibleCodePayment") = "присутствует" Then
            txtCodePayment.Visible = True
            
            '---------------------------- Новопашин В.М. 15-02-2006 г.
            'Помимо свойства Visible мне нужно и Enabled для проверки
            'состояния контрола, чтобы не выводить невидимые контролы
            'в проверку перед сохранением.
            'Но тут возникает проблема - если договор содержит несколько
            'закладок и активная закладка не основная, то свойство Visible
            'для контролов не активной закладки (даже если они видимы)
            'равно False.
            txtCodePayment.Enabled = True
            '--------------------------------------------------------
            
            lblCodePayment.Visible = True
        Else
            txtCodePayment.Visible = False
            
            '---------------------------- Новопашин В.М. 15-02-2006 г.
            'Помимо свойства Visible мне нужно и Enabled для проверки
            'состояния контрола, чтобы не выводить невидимые контролы
            'в проверку перед сохранением.
            'Но тут возникает проблема - если договор содержит несколько
            'закладок и активная закладка не основная, то свойство Visible
            'для контролов не активной закладки (даже если они видимы)
            'равно False.
            txtCodePayment.Enabled = False
            '--------------------------------------------------------
            
            lblCodePayment.Visible = False
        End If
        'end - Данилова, 28.10.2005
            
        ' Потапов Д.А. - 02.03.2007г.
        blnPenyPresent = objParamOut.Parameter("PeniPresent")
        
        m_blnComissPeniPayer = objParamOut.Parameter("PeniComissPayer")

        Call CheckPeni

        'If InStr(1, objParamOut.Parameter("IdPattern"), "_UT", 1) > 0 Then
        If StrCommand_Source = "ADD_PARAM" And Len(txtCode.Text) = 0 And Len(objParamOut.Parameter("Code")) > 0 Then
            txtCode.Text = objParamOut.Parameter("Code")
        ElseIf StrCommand_Source <> "ADD_PARAM" Then
            txtCode.Text = objParamOut.Parameter("Code")
        End If
        
        If StrCommand_Source = "ADD_PARAM" And Len(txtComment.Text) = 0 And Len(objParamOut.Parameter("Comment")) > 0 Then
            txtComment.Text = objParamOut.Parameter("Comment")
        ElseIf StrCommand_Source <> "ADD_PARAM" Then
            txtComment.Text = objParamOut.Parameter("Comment")
        End If
        
        If StrCommand_Source = "ADD_PARAM" And Len(txtBic.Text) = 0 And Len(objParamOut.Parameter("BIC")) > 0 Then
            txtBic.Text = objParamOut.Parameter("BIC")
        ElseIf StrCommand_Source <> "ADD_PARAM" Then
            txtBic.Text = objParamOut.Parameter("BIC")
        End If
        
        If StrCommand_Source = "ADD_PARAM" And Len(AccKorr.Text) = 0 And Len(objParamOut.Parameter("CorrAcc")) > 0 Then
            AccKorr.Text = objParamOut.Parameter("CorrAcc")
        ElseIf StrCommand_Source <> "ADD_PARAM" Then
            AccKorr.Text = objParamOut.Parameter("CorrAcc")
        End If
        
        If StrCommand_Source = "ADD_PARAM" And Len(txtINN.Text) = 0 And Len(objParamOut.Parameter("INN")) > 0 Then
            txtINN.Text = objParamOut.Parameter("INN")
        ElseIf StrCommand_Source <> "ADD_PARAM" Then
            txtINN.Text = objParamOut.Parameter("INN")
        End If

        If objParamOut.Parameter("КППУ") <> "" Then txtKppu.Text = objParamOut.Parameter("КППУ")
        If StrCommand_Source = "ADD_PARAM" And (Len(AccClient.Text) = 0 Or AccClient.Text = "00000000000000000000") And Len(objParamOut.Parameter("Acc")) > 0 Then
            AccClient.Text = objParamOut.Parameter("Acc")
            strAccFromContract = objParamOut.Parameter("Acc")
        ElseIf StrCommand_Source <> "ADD_PARAM" Then
            AccClient.Text = objParamOut.Parameter("Acc")
            strAccFromContract = objParamOut.Parameter("Acc")
        End If

            'txtNote.Text = txtComment.Text
            blnSepDoc = objParamOut.Parameter("IsSeparateDoc")
            m_SIDPattern = objParamOut.Parameter("IdPattern")
            m_strAddress = objParamOut.Parameter("Adress") ' поле Адрес орг-и нужно для сохранения в Платеж
            
            '=========================
            'If objParamOut.ExistParameter("Атрибуты получателя") Then
            If m_IdContract <> 0 And objParamOut.Parameter("BIC") = "" And objParamOut.Parameter("Acc") = "00000000000000000000" Then
                btnListAttributeRecip.Visible = True
                btnSaveAttribute.Visible = True
            Else
                btnListAttributeRecip.Visible = False
                btnSaveAttribute.Visible = False
            End If
            '=========================

            If Trim(txtBic.Text) = "" Then
                blnArbitrary = True
            End If
            
            'задан БИК и ИНН, но не задад р/с и получатель
            If AccClient.Text = "00000000000000000000" And objParamOut.Parameter("IdClient") = 0 And Len(Trim(txtBic.Text)) <> 0 And Len(Trim(txtINN.Text)) <> 0 Then
                blnEditRecip = True
            End If

            '-------------- добавлено Кирсанова Е.В. 11.10.2005
            If objParamOut.Parameter("State") = 1 Then
               MsgBox "Внимание!!! Договор закрыт.", vbOKOnly, "Платёж"
            End If
            intState = objParamOut.Parameter("State")
            '-------------------------------------------------
            
            Call SetPropBank(blnSepDoc)
            '-------------- добавлено Кирсанова Е.В. 07.10.2005
              If strAccFromContract = "00000000000000000000" Then
                 txtINN.Enabled = True
              End If
            '--------------------------------------------------
            m_IdKindPaym = objParamOut.Parameter("IdKindPayment")

            ' ----------- Бровкова Н.Ю. 04.05.05 ---------
            ' заполнить Назначение платежа данными из одноименного доп. поля Договора
            If StrCommand = "ADD" Then
                Dim blnPurposeLock As Boolean
                
                If StrCommand_Source = "ADD_PARAM" And Len(cmbPurpose.Text) = 0 Then
                    FillPurpose objParamOut.Parameter("arrPurpose")
                ElseIf StrCommand_Source <> "ADD_PARAM" Then
                    FillPurpose objParamOut.Parameter("arrPurpose")
                End If
                '------------------------- Новопашин В.М. 11.04.06 ------------
                UbsChannel.Run "UtReadSetupLockPurpose", objParamIn, objParamOut
                blnPurposeLock = objParamOut.Parameter("blnPurposeLock")
                If Not objParamOut.Parameter("bRetVal") And objParamOut.Parameter("StrError") <> "" Then
                   MsgBox objParamOut.Parameter("strError"), vbOKOnly, "Платёж"
                Else
                   cmbPurpose.Enabled = blnPurposeLock
                   'cmbPurpose.Visible = blnPurposeLock
                End If
                '---------------------------------------------------------------
            End If
            ' --------------------------------------------

            '----------------------------------------- Новопашин 18.04.2006 г.------
            'заполняем наименование банка
            objParamIn.Parameter("BIC") = objParamOut.Parameter("BIC")
            UbsChannel.Run "ReadBankBIK", objParamIn, objParamOut
            Call GetBankNameACC
            
            If m_IdKindPaym <> 0 Then
                Call setParamAccCodeKey(m_IdKindPaym)
            End If
                      
            subPayment.Tabs(TAB_GENERAL).Selected = True

            If subPayment.SelectedTab.Index = 1 Then
                If blnForward Then
                    If txtINN.Visible And txtINN.Enabled And Not (blnArbitrary Or blnEditRecip) Then
                        objInterfaces.GoToCtrl txtINN
                    ElseIf txtBic.Visible And txtBic.Enabled And (blnArbitrary Or blnEditRecip) Then
                        objInterfaces.GoToCtrl txtBic
                    Else
                        'If txtNote.Visible And txtNote.Enabled Then objInterfaces.GoToCtrl txtNote
                        If cmbPurpose.Visible And cmbPurpose.Enabled Then objInterfaces.GoToCtrl cmbPurpose
                    End If
                End If
            End If
            
            objParamIn.Parameter("AccClientPay") = AccClientPay.Text
            objParamIn.Parameter("IdClient") = m_IdClient
            objParamIn.Parameter("INN") = txtINN.Text
            objParamIn.Parameter("Kppu") = txtKppu.Text
            objParamIn.Parameter("AccClient") = AccClient.Text
            objParamIn.Parameter("IsGuest") = blnGuest
            
            If (CBool(CheckBenefits.Value)) Then
                
                If (AccClientPay.Text = "00000000000000000000") Then
                    objParamIn.Parameter("AccClientPay") = "20200"
                End If
                
                UbsChannel.Run "UtCheckPaymentBenefits", objParamIn, objParamOut
                
                If CBool(objParamOut.Parameter("isBenefits")) Then
                    m_arrRateSend(0) = 0
                    
                    If curSummaTotal.CurrencyValue > 0 Then
                        curSummaTotal.CurrencyValue = curSumma.CurrencyValue + curPeny.CurrencyValue
                    End If
                    
                    curSummaRateSend.CurrencyValue = 0
                Else
                    Call CalcSumCommiss_2
                End If
                
            Else
                Call CalcSumCommiss_2
            End If
            
            objParamIn.Parameter("IdContract") = m_IdContract
            objParamIn.Parameter("StrCommand") = "CHANGECONTRACT"

            '--------------------------------- Новопашин В.М. 05-06-2006 г.
            'Защита от скростного ввода клавишей Enter
            If m_IdContract <> 0 Then
               objParamIn.Parameter("Test") = ""
'MsgBox "FindContractbyId"
               UbsChannel.Run "Payment", objParamIn, objParamOut
                Call CheckPeni(objParamOut.Parameter("SUMMAPENI"))
            End If
            '--------------------------------------------------------------

            AddProperties.Refresh
            If AddProperties.PropertyCount = 0 Then
                subPayment.Tabs(TAB_ADDFL).Enabled = False
            Else
                subPayment.Tabs(TAB_ADDFL).Enabled = True
            End If
            cb_ThirdPerson.Enabled = False
            subPayment.Tabs(TAB_TARIFF).Visible = False
            subPayment.Tabs(TAB_TELEPHONE).Visible = False
            subPayment.Tabs(TAB_TAX).Visible = False
            subPayment.Tabs(TAB_THIRDPERSON).Visible = False
            cboCityCode.Visible = False
            cboCityCode.Enabled = False
            AccPay.Left = 4800
            AccPay.Width = 2055

            Select Case m_SIDPattern
            Case "UBS_UT_ENERGY"
                subPayment.Tabs(TAB_TARIFF).Visible = True
                
                Call FillTariff(m_IdTariff)
                   If subPayment.Tabs(TAB_ADDFL).Enabled = True Then
                      If CodeEnergy = 0 Then
                         AddProperties.PropertyByIndex(1) = 1
                      Else
                         AddProperties.PropertyByIndex(1) = CodeEnergy
                      End If
                   End If
            
            Case "UBS_UT_PHONE"
                cboCityCode.Visible = True
                cboCityCode.Enabled = True
                AccPay.Width = 1275
                AccPay.Left = 5580
                subPayment.Tabs(TAB_TELEPHONE).Visible = True
                '---------изменено Кирсанова Е.В. 05.10.2005 ----------------------
                'If strCommand = "ADD" Then
                
                '------------------------------------------------------------------
                '18.09.2006 г. Новопашин В.М.
                 Call FillPhone(m_IdPhone)
                '------------------------------------------------------------------
                
                'Else
                '   '-----------------------------
                '    objParamIn.Parameter("IdPhone") = m_IdPhone
                '   ' получить значение ТУ
                '    UbsChannel.Run "ReadPhoneById", objParamIn, objParamOut
                '    cmbPhone.List(0) = objParamOut.Parameter("CodePhone") & ", " & objParamOut.Parameter("NamePhone")
                '    cmbPhone.ListIndex = 0
                'End If
                '-------------------------------------------------------------------
                'txtCodePhone.Text = ""
                'txtPhone.Text = ""
            Case "UBS_UT_PHONE_ACC"
                subPayment.Tabs(TAB_TELEPHONE).Visible = True
                '---------изменено Кирсанова Е.В. 05.10.2005 ----------------------
                'If strCommand = "ADD" Then
                '------------------------------------------------------------------
                '18.09.2006 г. Новопашин В.М.
                 Call FillPhone(m_IdPhone)
                '    objParamIn.Parameter("IdPhone") = m_IdPhone
                '------------------------------------------------------------------
                'Else
                '    '-----------------------------
                '   ' получить значение ТУ
                '    UbsChannel.Run "ReadPhoneById", objParamIn, objParamOut
                '    cmbPhone.List(0) = objParamOut.Parameter("CodePhone") & ", " & objParamOut.Parameter("NamePhone")
                '    cmbPhone.ListIndex = 0
                'End If
                '-------------------------------------------------------------------
                'txtCodePhone.Text = ""
                'txtPhone.Text = ""
            Case "UBS_UT_NALOG"
                subPayment.Tabs(TAB_TAX).Visible = True
                cb_ThirdPerson.Enabled = True
                Call FillNalog(False, 0)
            End Select
        'End If
    '-------------------------------------- Новопашин В.М. 14-02-2006 г.
    'Сделано, чтобы не фокус не перескакивал на кнопку выбора договоров

    Else
        btnListAttributeRecip.Visible = False
        btnSaveAttribute.Visible = False
        'If strCommand <> "VIEW" And Not txtBic.Locked And txtBic.Enabled Then
        '    txtBic.SetFocus
        'End If
    '--------------------------------------------------------------------
    End If
    
    '-------------------------------------- Новопашин В.М. 04-07-2006 г.
    If blnArbitrary Or blnEditRecip Then
        'frmRec.Height = 3015
        'txtRecip.Top = 2580
        'lblRecip.Top = 2550
        'txtRecip.Visible = True
        'lblRecip.Visible = True
        txtRecip.Enabled = True
        lblRecip.Enabled = True
    Else
        'frmRec.Height = 2595
        'txtRecip.Visible = False
        'lblRecip.Visible = False
        txtRecip.Enabled = False
        lblRecip.Enabled = False
    End If
    '--------------------------------------------------------------------
        
    '--------------------------------------- Новопашин В.М. 23-03-2006 г.
    'strCommand = "ADD" And
    If m_IdContract <> 0 And StrCommand <> "VIEW" Then
        If txtBic.Text <> "" Then
           txtBic.Enabled = False
        Else
           txtBic.Enabled = True
        End If
        
        If txtINN.Text <> "" Then
           txtINN.Enabled = False
        Else
           txtINN.Enabled = True
        End If
        
        If AccClient.Text <> "00000000000000000000" Then
           AccClient.Enabled = False
        Else
           AccClient.Enabled = True
        End If

        If blnForward Then
            If txtBic.Enabled Then
               txtBic.SetFocus
            ElseIf AccClient.Enabled Then
               AccClient.SetFocus
            ElseIf txtINN.Enabled Then
               txtINN.SetFocus
            ElseIf cmbPurpose.Enabled Then
               cmbPurpose.SetFocus
            ElseIf txtCodePayment.Enabled Then
               txtCodePayment.SetFocus
            Else
               curSumma.SetFocus
            End If
        End If
        
        '----------------------------------- Новопашин В.М. 09.08.2006 г. ---
        'Подстановка значения поля КППУ из договора
        If StrCommand = "ADD" Then
           objParamIn.Parameter("IdContract") = m_IdContract
           UbsChannel.Run "UtGetKPPU", objParamIn, objParamOut
           AddProperties.Refresh
        End If
        
        'Если указан плательщик и БИК
        If m_IdClient <> 0 And Len(Trim(txtBic.Text)) <> 0 Then
        
           If m_SIDPattern = "UBS_UT_NALOG" And StrCommand = "ADD" And blnLast Then
               'Если заполнен БИК и договор
               If Len(Trim(txtBic.Text)) <> 0 And m_IdContract <> 0 Then
                   'Если заполнен р/с или клиент/посетитель
                   If AccClient.Text <> "00000000000000000000" Or m_IdClient <> 0 Then
                       Call FillNalog(True, m_IdClient)
                   End If
               End If
           End If

           objParamIn.ClearParameters
           objParamIn.Parameter("IdContract") = m_IdContract
           objParamIn.Parameter("IdClient") = m_IdClient
           objParamIn.Parameter("BIC") = txtBic.Text
           UbsChannel.Run "UtGetAccINNFromLastPayment", objParamIn, objParamOut
            'С предыдущего платежа при введеном плательщике, БИК и коде договора вносим
            'ИНН, расчетный счет и назначение платежа
             
             'Переносим данные ИНН
             If txtINN.Enabled = True Then
                txtINN.Text = objParamOut.Parameter("INN")
             End If
             
             'Переносим данные р/с
             If AccClient.Enabled = True Then
                AccClient.Text = objParamOut.Parameter("ACC")
             End If
             
             'Заносятся данные назначение платежа из последнего платежа
             If cmbPurpose.Enabled And StrCommand = "ADD" Then
                If Not IsComboBoxItemExists(objParamOut.Parameter("PURPOSE")) And Len(Trim(CStr(objParamOut.Parameter("PURPOSE")))) <> 0 Then
                   cmbPurpose.AddItem objParamOut.Parameter("PURPOSE"), cmbPurpose.ListCount '- 1
                   cmbPurpose.ListIndex = cmbPurpose.NewIndex
                End If
           End If
           
        End If
        '--------------------------------------------------------------------
    End If
        
        '-----------Трубаков--------------
        'В случае если видно поле "Пени", на него устанавливался фокус,
        'поэтому вручную переставим фокус куда надо
        Dim blnFocus As Boolean
        blnFocus = True
        
        If curPeny.Visible And txtBic.Visible And txtBic.Enabled And blnFocus Then
            blnFocus = False
            txtBic.SetFocus
        End If
        
        If curPeny.Visible And AccClient.Visible And AccClient.Enabled And blnFocus Then
            blnFocus = False
            AccClient.SetFocus
        End If
        
        If curPeny.Visible And txtINN.Visible And txtINN.Enabled And blnFocus Then
            blnFocus = False
            txtINN.SetFocus
        End If
        
        If curPeny.Visible And cmbPurpose.Visible And cmbPurpose.Enabled And blnFocus Then
            blnFocus = False
            cmbPurpose.SetFocus
        End If
        '--------------------------
           
    '--------------------------------------------------------------------
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Поиск информации о договоре с использованием идентификатора", "ошибка выполнения"
End Sub

'----------------------------------------------- Новопашин В.М. 10.08.2006 г. ----
'Проверяем есть ли в комбобоксе значение

Function IsComboBoxItemExists(Item As String) As Boolean
    Dim lngI As Long
    
    IsComboBoxItemExists = False
    For lngI = 0 To cmbPurpose.ListCount
        If cmbPurpose.List(lngI) = Item Then
           IsComboBoxItemExists = True
           Exit For
        End If
    Next lngI
    
End Function

'---------------------------------------------------------------------------------

Private Sub CreateCashOrd()
    
    Dim intReq As Integer, intRegim As Integer, intRegimRate As Integer
    Dim varPaym As Variant, VarContr As Variant, bRet As Boolean
    Dim varPaymArray1 As Variant, varContrArray1 As Variant, m_IdPaymentArray1 As Variant
    Dim blnPlatDoc As Boolean, lngIdUser As Long, IdDivision As Long
    
On Error GoTo ErrorCode
    
    blnPlatDoc = False
    intReq = 0
    intRegim = 0

    If blnGroup Then
        'Сформируем массив для подготовки кассовых ордеров при групповых платежах
        UbsChannel.Run "Ps_GetArrayPrepareCashOrd", objParamIn, objParamOut
        
        varPaymArray1 = objParamOut.Parameter("VARPAYMENTS")
        varContrArray1 = objParamOut.Parameter("VARCONTRACT")
        m_IdPaymentArray1 = objParamOut.Parameter("VARIDPAYMENTS")
    End If
    
    'Режим создания дополнительного платежа (для налоговых)
    'Этот режим не совместим с групповыми платежами
    If m_IdContractSecond <> 0 Then
        UbsChannel.Run "Ps_GetArrayPrepareCashOrdSecond", objParamIn, objParamOut
        varPaymArray1 = objParamOut.Parameter("VARPAYMENTS")
        varContrArray1 = objParamOut.Parameter("VARCONTRACT")
        m_IdPaymentArray1 = objParamOut.Parameter("VARIDPAYMENTS")
    End If
    
    ' Если в договоре установлен признак, что подготовка платежных документов = при приеме платежа,
    ' то кассовый ордер и кассовый ордер на комиссию готовим в любом случае,
    ' даже если в установках прописано, что готовим в отдельном режиме
    objParamIn.Parameter("IdContract") = m_IdContract
    UbsChannel.Run "Ps_PreparePlatDoc", objParamIn, objParamOut
    If objParamOut.Parameter("blnPeparePlatDoc") = True Then
        blnPlatDoc = True
    End If
        
    ' --------
    'получим режим подготовки приходных касс. ордеров
    UbsChannel.Run "Ps_GetStatePrepareCashOrd2", objParamIn, objParamOut
    
    intRegim = objParamOut.Parameter("StateCashOrd")      ' уст-ка "Подготовка приходных кассовых ордеров"
    intRegimRate = objParamOut.Parameter("StateCashRate") ' уст-ка "Подготовка прих. касс. ордеров (комиссия)"
    ' --------

    Set objParamIn = CreateObject("ToolPubs.IUbsParam")
    Set objParamOut = CreateObject("ToolPubs.IUbsParam")
   
    UbsChannel.Run "UtGetGlobalUserData", objParamIn, objParamOut
    
    lngIdUser = objParamOut.Parameter("IDUSER")
    IdDivision = objParamOut.Parameter("Division")

   If intRegim <> 0 Or intRegimRate <> 0 Or blnPlatDoc Then 'подготовки кассовых ордеров при приеме платежа
        'получим признак "Запрашивать форму подготовки КО"
        objParamIn.Parameter("NameSection") = "Оплата услуг"
        UbsChannel.Run "Ps_GetStateRequestFormCashOrd", objParamIn, objParamOut

        If Len(Trim(objParamOut.Parameter("StrError"))) = 0 Then
            intReq = objParamOut.Parameter("ISFRMPREVIEW")
        Else
            MsgBox objParamOut.Parameter("StrError"), 16, "Чтение установки"
        End If

       ' Если режим не групповой и не создание дополнительного платежа,
       ' то стандартная подготовка кассовых ордеров
       If blnGroup = False And m_IdContractSecond = 0 Then
           If Not IsArray(arrCashSymb) Then
               ReDim varPaym(13, 0)
               Dim varCashSymbol1 As Variant
               ReDim varCashSymbol1(2, 0)
               varCashSymbol1(0, 0) = txtKSPayment.Text
               varCashSymbol1(1, 0) = txtKSRate.Text
               varCashSymbol1(2, 0) = txtKSNDS.Text
               varPaym(6, 0) = varCashSymbol1
               varPaym(7, 0) = IdDivision
               If blnCashier Then
                   varPaym(8, 0) = lngIdUser
               End If
           Else
               ReDim varPaym(11, 0)
          
               'Заполняем массив кассовых символов, который заполняем при разделении по кассовым символам
               If IsArray(arrCashSymb) Then
                   Dim varCashSymbol2 As Variant
                   ReDim varCashSymbol2(2, 0)
                   varCashSymbol2(0, 0) = arrCashSymb 'txtKSPayment.Text
                   varCashSymbol2(1, 0) = txtKSRate.Text
                   varCashSymbol2(2, 0) = txtKSNDS.Text
                   varPaym(6, 0) = varCashSymbol2
               End If
           End If

           varPaym(0, 0) = m_IdPayment
           varPaym(1, 0) = m_IdContract
           varPaym(2, 0) = curSummaTotal.CurrencyValue
           varPaym(3, 0) = curSummaRateSend.CurrencyValue
           varPaym(4, 0) = m_curSumNDSSend
           varPaym(5, 0) = txtFIOPay.Text
           varPaym(7, 0) = IdDivision
           If blnCashier Then
               varPaym(8, 0) = lngIdUser
           End If
        
           'Для подготовки док-та НДС с платежа
           varPaym(9, 0) = m_curSumNDSPaym
           varPaym(10, 0) = CCur(curSumma.CurrencyValue)
           varPaym(11, 0) = AccClientPay.Text
           varPaym(12, 0) = m_curSumRateRec
           varPaym(13, 0) = m_curSumNDSRec
        
           ReDim VarContr(1, 0)
           VarContr(0, 0) = m_IdContract
           VarContr(1, 0) = txtCode.Text

           Set frmCashOrd.UbsChannel = UbsChannel
           frmCashOrd.varPaymIn = varPaym
           frmCashOrd.varContractIn = VarContr
           frmCashOrd.m_nIdPayment = m_IdPayment
       Else
           Set frmCashOrd.UbsChannel = UbsChannel
           frmCashOrd.m_nIdPaymentArray = m_IdPaymentArray1
           frmCashOrd.m_nIdPayment = m_IdPayment
           frmCashOrd.varPaymIn = varPaymArray1
           frmCashOrd.varContractIn = varContrArray1
       End If
      
       If intReq = 1 Then
           If frmCashOrd.lstDoc.ListItems.Count <> 0 Then
               frmCashOrd.Show vbModal
           End If
          
           Select Case frmCashOrd.TypeExit
               Case 0
                  'ничего не делаем
                   Unload frmCashOrd
                   Exit Sub
               Case 1
                   'получаем массив выбранных шаблонов
                   Unload frmCashOrd
           End Select
       Else
           Call frmCashOrd.Form_Load
          
           If frmCashOrd.m_bIsLoadOK = True Then
              Call frmCashOrd.btnMove_Click
           End If
          
           Unload frmCashOrd
        End If
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "CreateCashOrd", "ошибка выполнения"
End Sub


