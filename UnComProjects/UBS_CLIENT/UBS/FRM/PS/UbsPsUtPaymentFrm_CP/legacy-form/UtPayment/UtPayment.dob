Private Sub txtNomerCardPay_KeyDown(KeyCode As Integer, Shift As Integer)
    If KeyCode = 13 And Shift = 0 Then
        If Len(Trim(txtNomerCardPay.Text)) > 0 Then
           
            objParamIn.ClearParameters
            objParamIn.Parameter("NomerCard") = txtNomerCardPay.Text
            objParamIn.Parameter("IsGuest") = blnGuest
           'Вызвать переходник, который по номеру карты получит посетителя
            UbsChannel.Run "ReadClientFromNomerCard", objParamIn, objParamOut
            objParamIn.Parameter("IDCLIENT") = objParamOut.Parameter("IDCLIENT")
            If Len(Trim(objParamOut.Parameter("StrError"))) Then
                MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
                txtNomerCardPay.SetFocus
                Exit Sub
            End If

            ' получить посетителя Опер. кассы
            UbsChannel.Run "ReadClientFromIdOC", objParamIn, objParamOut
            If Len(Trim(objParamOut.Parameter("StrError"))) Then
                MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
                Exit Sub
            End If
            
            m_IdClient = objParamIn.Parameter("IDCLIENT")
            txtINNPay.Text = objParamOut.Parameter("INN")
            txtInfoClient.Text = objParamOut.Parameter("InfoClient")
            txtFIOPay.Text = objParamOut.Parameter("NAME")
            txtAdressPay.Text = objParamOut.Parameter("ADRESS")
             
            'If AccClientPay.Visible Then
            If AccClientPayVisible Then
                AccClientPay.Text = "00000000000000000000"
            End If
            
            Call CheckPayer(False)
                        
            ' (69627)
            'Получить номер и серию документа
            m_strDocNumber = objParamOut.Parameter("NUMBER")
            m_strDocSeries = objParamOut.Parameter("SERIES")
            '
   
            GotoNextControlForEnter
            
            If m_IdClient > 0 Then
                lblFindFilter.Visible = True
                btnFindFilter.Visible = True
            End If
        End If
    End If
End Sub


Private Sub txtRecip_Change()
    Dim tbLen As Integer
    tbLen = 160 - Len(txtRecip.Text)
    If tbLen < 0 Then
        lblNameCnt.ForeColor = vbRed
    Else
        lblNameCnt.ForeColor = vbBlack
    End If
    lblNameCnt.Caption = tbLen
End Sub

