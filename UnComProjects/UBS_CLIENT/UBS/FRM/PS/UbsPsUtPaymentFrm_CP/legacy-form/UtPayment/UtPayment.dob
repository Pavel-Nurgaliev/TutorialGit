Private Sub btnFindFilter_Click()

    Dim nIdSelectedRecord As Variant
    Dim j As Integer
    Dim intKeyCond As Integer
    
On Error GoTo ErrorCode
     
    If m_IdClient > 0 Then
    'If Len(txtCode.Text) > 0 And m_IdContract > 0 Then
     
    If NumChildWinPayments <> 0 Then
        Parent.SetFocusToWindow NumChildWinPayments
        Exit Sub
    End If
       
    Parent.GetWindow "UBS_LIST_PS\UT_UT_LIST_PAYMENT", NumChildWinPayments

    
    If NumChildWinPayments <> 0 Then
        Dim InitParamGrid As Variant
        Dim gridF As Object
        Dim varCond As Variant
        ReDim InitParamGrid(5)
        
        Set gridF = Parent.ParamInfo(NumChildWinPayments, "UbsGridList")

           Dim RetVal1 As Long, i As Integer
       
           gridF.GetWhereRS 1, varCond
           RetVal1 = 0
           
           Dim strNameField As String
           If blnGuest Then
               strNameField = "ID Посетитель"
           Else
               strNameField = "ID Клиент банка"
           End If
           
           'GridF.CheckSelectItem strNameField, True
           
           If Not IsEmpty(varCond) Then
               For i = 0 To UBound(varCond, 2)
                   If varCond(0, i) = strNameField Then
                       RetVal1 = varCond(4, i)
                   End If
               Next
           End If
           'Установка условий фильтра
           If RetVal1 = 0 Then
               RetVal1 = gridF.AddWhereItem(strNameField, 4, m_IdClient)
           Else
               gridF.DelWhereItem RetVal1
               RetVal1 = gridF.AddWhereItem(strNameField, 4, m_IdClient)
           End If
           gridF.WhereItemFlags(RetVal1) = 0

           If m_IdContract > 0 Then
               RetVal1 = 0
               If Not IsEmpty(varCond) Then
                   For i = 0 To UBound(varCond, 2)
                       If varCond(0, i) = "ID Договора" Then
                           RetVal1 = varCond(4, i)
                       End If
                   Next
               End If

               'Установка условий фильтра
               If RetVal1 = 0 Then
                   RetVal1 = gridF.AddWhereItem("ID Договора", 4, m_IdContract)
               Else
                   gridF.DelWhereItem RetVal1
                   RetVal1 = gridF.AddWhereItem("ID Договора", 4, m_IdContract)
               End If
               gridF.WhereItemFlags(RetVal1) = 0
           End If

           If Not IsEmpty(varCond) Then
               For i = 0 To UBound(varCond, 2)
                   If varCond(0, i) = "Дата платежа" Then
                       RetVal1 = varCond(4, i)
                   End If
               Next
           End If
           'Установка условий фильтра
           If RetVal1 > 0 Then
               gridF.DelWhereItem RetVal1
           End If
           
           'Сортировка
           gridF.CheckOrderItem "Идентификатор платежа", False, True
                    

'=======================================
        
        If Parent.IsExistParam(NumChildWinPayments, "InitParamGrid") Then
            nIdSelectedRecord = Empty
            InitParamGrid(0) = NumWin
            InitParamGrid(2) = True
            InitParamGrid(5) = 1
            Parent.ParamInfo(NumChildWinPayments, "InitParamGrid") = InitParamGrid
            If Parent.IsExistParam(NumChildWinPayments, "SelectItem") Then
                Parent.ParamInfo(NumChildWinPayments, "SelectItem") = nIdSelectedRecord
            End If
            Parent.SetFocusToWindow NumChildWinPayments
        End If
        Set gridF = Nothing
    End If
    '===========================================
    End If
   
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Выбор платежа", "ошибка выполнения"
End Sub

