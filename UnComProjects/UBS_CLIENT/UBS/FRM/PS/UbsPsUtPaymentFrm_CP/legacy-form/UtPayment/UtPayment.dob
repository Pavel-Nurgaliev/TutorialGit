    txtCodePayment.SelStart = 0
    txtCodePayment.SelLength = Len(txtCodePayment.Text)

    Exit Sub
        
ErrorCode:
    objErr.UbsErrMsg "txtCodePayment_GotFocus", "ошибка выполнения"

End Sub

Sub FillDataPayment(TypeCall As String)
'Данилова, 28.10.2005
'заполнение данных платежа по данным штрих-кода

 On Error GoTo ErrorCode
    Dim prm1 As Object
    Dim strAccPay As String, blnFind As Boolean, n As Integer
    Dim strPeriod As String, strMonth As String, strYear As String, strTitleError As String
    
    'Возможно два вызова: При вводе кода платежа или при выборе из списка л/с по клиенту
    'Если из поля код платежа
    If TypeCall = "CODE" Then
        '----------------------------------- Новопашин В.М. 13-02-2006 г.
        If txtCodePayment.Text = "" Then
           'objInterfaces.NextCtrl
           Exit Sub
        End If
        '----------------------------------------------------------------
        objParamIn.Parameter("CodePayment") = txtCodePayment.Text
        objParamIn.Parameter("IdContract") = m_IdContract
        objParamIn.Parameter("IDKINDPAYMENT") = m_IdKindPaym
        
        UbsChannel.Run "Ut_CheckSidPayment", objParamIn, objParamOut
        
    'Если из списка по клиенту
    ElseIf TypeCall = "FILTER" Then
    
        objParamIn.Parameter("IdPaymentDic") = m_IdPaymentDic
        objParamIn.Parameter("IdContract") = m_IdContract
        objParamIn.Parameter("IDKINDPAYMENT") = m_IdKindPaym
        
        UbsChannel.Run "Ut_GetDataLic", objParamIn, objParamOut
        
        txtCodePayment.Text = objParamOut.Parameter("CodePayment")
    End If
    
    If objParamOut.ExistParameter("strError") Then
        MsgBox objParamOut.Parameter("strError"), 16, "Проверка корректности данных"
        Exit Sub
    End If
    
    If objParamOut.ExistParameter("strMessage") Then
        If Not MsgBox(objParamOut.Parameter("strMessage") & vbCrLf & "Вы хотите продолжить работу?", vbYesNo + vbQuestion, "Проверка корректности данных") = vbYes Then
            Exit Sub
        End If
    End If
    
    'Если есть данные, то заполняем поля формы
    If objParamOut.ExistParameter("arrDataPayment") Then
    
        AddProperties.Refresh

        Set prm1 = objParamOut.Parameter("arrDataPayment")
        
        If subPayment.Tabs(TAB_TAX).Visible Then
            If prm1.ExistParameter("Код бюджетной классификации") Then
                If Len(Trim(prm1.Parameter("Код бюджетной классификации"))) > 0 Then
                    txtKBKNalog.Text = prm1.Parameter("Код бюджетной классификации")
                    
                    If prm1.ExistParameter("Расшифровка КБК") Then
                        If Len(Trim(prm1.Parameter("Расшифровка КБК"))) > 0 Then
                            txtKBKNoteNalog.Text = prm1.Parameter("Расшифровка КБК")
                        End If
                    End If
                End If
            End If
        End If

        'заполняем control-ы переданными значениями
        If prm1.ExistParameter("ACCCODE") Then
            If Len(Trim(prm1.Parameter("ACCCODE"))) > 0 Then
                AccPay.Text = prm1.Parameter("ACCCODE")
                m_strAccCode = prm1.Parameter("ACCCODE")
            End If
        End If
        
        If prm1.ExistParameter("SUMMA") And StrCommand = "ADD" Then
            curSumma.Text = prm1.Parameter("SUMMA")
            prefCalcRate = "_2 3"
            Call CalcSumCommiss_2
        End If
        
        If prm1.ExistParameter("THIRDPERSON_NAME") Then
            cb_ThirdPerson.Value = 1
            subPayment.Tabs(TAB_THIRDPERSON).Visible = True
            txt_ThirdPersonName.Text = prm1.Parameter("THIRDPERSON_NAME")
            If prm1.ExistParameter("THIRDPERSON_KIND") Then
                cmb_ThirdPersonKind.ListIndex = prm1.Parameter("THIRDPERSON_KIND")
                If StrCommand <> "VIEW" Then
                    If cmb_ThirdPersonKind.ListIndex = 2 Then txt_ThirdPersonKpp.Enabled = True
                End If
            End If
            If prm1.ExistParameter("THIRDPERSON_INN") Then
                txt_ThirdPersonInn.Text = prm1.Parameter("THIRDPERSON_INN")
            End If
            If prm1.ExistParameter("THIRDPERSON_KPP") Then
                txt_ThirdPersonKpp.Text = prm1.Parameter("THIRDPERSON_KPP")
            End If
        End If
               
        If prm1.ExistParameter("КППУ") Then
            txtKppu.Text = prm1.Parameter("КППУ")
        End If
                      
        If prm1.ExistParameter("SUMMARATESEND") And StrCommand = "ADD" Then
            curSummaRateSend.Text = prm1.Parameter("SUMMARATESEND")
'MsgBox "01: curSummaRateSend.Text = " & curSummaRateSend.Text
        End If
            
        If prm1.ExistParameter("SUMMATOTAL") And StrCommand = "ADD" Then
            curSummaTotal.Text = prm1.Parameter("SUMMATOTAL")
        End If
        
       ' If prm1.ExistParameter("SUMMAREC") Then
        '    m_curSumRec = prm1.Parameter("SUMMAREC")
        'End If
        
        '(89592)
        If prm1.ExistParameter("SUMMARATEREC") And StrCommand = "ADD" Then
            m_curSumRateRec = prm1.Parameter("SUMMARATEREC")
        End If
        
        If prm1.ExistParameter("Наименование получателя в плат. документах") Then
            If Len(Trim(prm1.Parameter("Наименование получателя в плат. документах"))) > 0 Then
                txtRecip.Text = prm1.Parameter("Наименование получателя в плат. документах")
            End If
        End If
            
        If prm1.ExistParameter("CORRACC") Then
            If Len(Trim(prm1.Parameter("CORRACC"))) > 0 Then
                AccKorr.Text = prm1.Parameter("CORRACC")
            End If
        End If

        'Соответсвия полям объекта нет
        If prm1.ExistParameter("Наименование банка") Then
            If Len(Trim(prm1.Parameter("Наименование банка"))) > 0 Then
                txtNameBank.Text = prm1.Parameter("Наименование банка")
            End If
        End If
            
        If prm1.ExistParameter("ACC") Then
            If Len(Trim(prm1.Parameter("ACC"))) > 0 Then
                AccClient.Text = prm1.Parameter("ACC")
            End If
        End If
            
        If prm1.ExistParameter("INN") Then
            If Len(Trim(prm1.Parameter("INN"))) > 0 Then
                txtINN.Text = prm1.Parameter("INN")
            End If
        End If
            
        If prm1.ExistParameter("PURPOSE") Then
            If Len(Trim(prm1.Parameter("PURPOSE"))) > 0 Then
                cmbPurpose.Text = prm1.Parameter("PURPOSE")
            End If
        End If
        
        If prm1.ExistParameter("PAYERFIO") Then
            If Len(Trim(prm1.Parameter("PAYERFIO"))) > 0 Then
                txtFIOPay.Text = prm1.Parameter("PAYERFIO")
            End If
        End If
        
        If prm1.ExistParameter("PAYERINN") Then
            If Len(Trim(prm1.Parameter("PAYERINN"))) > 0 Then
                txtINNPay.Text = prm1.Parameter("PAYERINN")
            End If
        End If
            
        If prm1.ExistParameter("PAYERADDRESS") Then
            If Len(Trim(prm1.Parameter("PAYERADDRESS"))) > 0 Then
                txtAdressPay.Text = prm1.Parameter("PAYERADDRESS")
            End If
        End If
        
        If subPayment.Tabs(TAB_TAX).Visible Then
            If prm1.ExistParameter("Код ОКАТО") Then
                If Len(Trim(prm1.Parameter("Код ОКАТО"))) > 0 Then
                    txtOKATONalog.Text = prm1.Parameter("Код ОКАТО")
                End If
            End If
        End If

        If prm1.ExistParameter("BIC") Then
            If Len(Trim(prm1.Parameter("BIC"))) > 0 Then
                txtBic.Text = prm1.Parameter("BIC")
                Call GetBankNameACC
            End If
        End If

        objParamIn.ClearParameters
        objParamOut.ClearParameters
    
    End If
    
    'Если вызов из списка, то выходим и делаем недоступным лицевой счет
    If TypeCall = "FILTER" Then
        AccPay.Enabled = False
        Exit Sub
    End If
    '------------------------------

    strTitleError = "Ошибка пользовательского сценария:" & vbCrLf
    
    objParamIn.Parameter("CodeContract") = txtCode.Text
    objParamIn.Parameter("CodePayment") = txtCodePayment.Text
    objParamIn.Parameter("NameSection") = "Оплата услуг"
    
    If Not objParamIn.ExistParameter("BIC") Then
        objParamIn.Parameter("BIC") = Trim(txtBic.Text)
    End If
    
    If Not objParamIn.ExistParameter("ACC") Then
        objParamIn.Parameter("ACC") = AccClient.Text
    End If
    '-----------------------------
    
    ' получить данные платежа по данным штрих-кода
    UbsChannel.Run "Ut_GetUserPaymentData", objParamIn, objParamOut
    
    If objParamOut.Parameter("bRetVal") = False Then
        If objParamOut.ExistParameter("StrError") Then
            If Len(Trim(objParamOut.Parameter("StrError"))) > 0 Then
                MsgBox strTitleError & objParamOut.Parameter("StrError"), 16, m_strCaptionForm
                txtCodePayment.SetFocus 'вызов события txtCodePayment_GotFocus
            End If
        End If
        Exit Sub
    End If
    If objParamOut.ExistParameter("StrQuestion") Then
        If vbCancel = MsgBox(CStr(objParamOut.Parameter("StrQuestion")), vbExclamation + vbOKCancel, "Внимание!") Then
            Exit Sub
        End If
    End If
    
    'Доустановим доп поля в случае утвердительного ответа
    Call UbsChannel.Run("UT_AplyUserPaymentData", objParamOut, objParamOut)

    If Not objParamOut.ExistParameter("arrDataPayment") Then
        If curSumma.Enabled Then
             objInterfaces.GoToCtrl curSumma
        Else
            If subPayment.Tabs(TAB_THIRDPERSON).Visible Then
                subPayment.Tabs(TAB_THIRDPERSON).Selected = True
                txt_ThirdPersonName.SetFocus
            ElseIf subPayment.Tabs(TAB_TAX).Visible Then
                subPayment.Tabs(TAB_TAX).Selected = True
                If txtStatusNalog.Enabled Then
                    txtStatusNalog.SetFocus
                Else
                    txtKBKNalog.SetFocus
                End If
            End If
        End If
        Exit Sub
    End If
    
    ' обновить доп. поля
    AddProperties.Refresh
           
    Set prm1 = objParamOut.Parameter("arrDataPayment")
            
    'заполняем переданными значениями закладку "Налог"
    '  если закладка "Налог" видимая
    If subPayment.Tabs(TAB_TAX).Visible Then
        If prm1.ExistParameter("Статус составителя") Then
            txtStatusNalog.Text = prm1.Parameter("Статус составителя")
        End If
        If prm1.ExistParameter("Код бюджетной классификации") Then
            txtKBKNalog.Text = prm1.Parameter("Код бюджетной классификации")
        End If
        If prm1.ExistParameter("Расшифровка КБК") Then
            txtKBKNoteNalog.Text = prm1.Parameter("Расшифровка КБК")
        End If
        If prm1.ExistParameter("Код ОКАТО") Then
            txtOKATONalog.Text = prm1.Parameter("Код ОКАТО")
        End If
        If prm1.ExistParameter("Основание налогового платежа") Then
            txtReasonNalog.Text = prm1.Parameter("Основание налогового платежа")
        End If
        If prm1.ExistParameter("Налоговый период") Then
            txtPeriodNalog.Text = prm1.Parameter("Налоговый период")
        End If
        If prm1.ExistParameter("Номер налогового документа") Then
            txtNomerNalog.Text = prm1.Parameter("Номер налогового документа")
        End If
        If prm1.ExistParameter("Дата налогового документа") Then
            txtDateNalog.Text = prm1.Parameter("Дата налогового документа")
        End If
        If prm1.ExistParameter("Тип налогового платежа") Then
            txTypeNalog.Text = prm1.Parameter("Тип налогового платежа")
        End If
        If prm1.ExistParameter("ИМНС") Then
            txtIMNSNalog.Text = prm1.Parameter("ИМНС")
        End If
    End If
            
    If prm1.ExistParameter("КППУ") Then
       txtKppu.Text = prm1.Parameter("КППУ")
    End If
            
    'заполняем control-ы переданными значениями
    If curSumma.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("Summa") And StrCommand = "ADD" Then
            curSumma.Text = objParamOut.Parameter("arrDataPayment").Parameter("Summa")
        End If
    End If
    
    If curSummaRateSend.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("SummaRateSend") And StrCommand = "ADD" Then
            ' (69038)
            ' Иначе при Сохранении комиссия пересчитается и перетрет это значение
            blnAddparam = True
            '
            curSummaRateSend.Text = objParamOut.Parameter("arrDataPayment").Parameter("SummaRateSend")
'MsgBox "02: " & curSummaRateSend.Text
        End If
    End If
    
    If curSummaTotal.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("SummaTotal") And StrCommand = "ADD" Then
            curSummaTotal.Text = objParamOut.Parameter("arrDataPayment").Parameter("SummaTotal")
        End If
    End If
    
    If txtCheckSum.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("CheckSum") Then
            If Len(Trim(objParamOut.Parameter("arrDataPayment").Parameter("CheckSum"))) > 0 Then
                txtCheckSum.Text = objParamOut.Parameter("arrDataPayment").Parameter("CheckSum")
            End If
        End If
    End If
    
    If AccPay.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("AccCode") Then
            strAccPay = Trim(objParamOut.Parameter("arrDataPayment").Parameter("AccCode"))
        Else
            strAccPay = ""
        End If
        
        If Len(strAccPay) > 0 Then
            If cboCityCode.Enabled Then
                'проверяем первые три символа в л/с на наличие в списке кодов
                blnFind = False
                For n = 0 To cboCityCode.ListCount - 1
                    If cboCityCode.List(n) = Left(strAccPay, 3) Then
                        blnFind = True
                        Exit For
                    End If
                Next
                
                'есть такое значение в списке кодов
                If blnFind Then
                    cboCityCode.ListIndex = n
                    AccPay.Text = Mid(strAccPay, 4, Len(strAccPay))
                Else
                    MsgBox strTitleError & "Код города " & Left(strAccPay, 3) & " отсутствует в списке кодов городов", 16, m_strCaptionForm
                    txtCodePayment.SetFocus 'вызов события txtCodePayment_GotFocus
                    Exit Sub
                End If
            Else
                AccPay.Text = strAccPay
            End If
        End If
    End If
    
    If txtDayBeg.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("Period") Then
            strPeriod = Trim(objParamOut.Parameter("arrDataPayment").Parameter("Period"))
        Else
            strPeriod = ""
        End If
        
        If Len(strPeriod) > 0 Then
            If Len(strPeriod) <> 4 Then
                MsgBox strTitleError & "Длина строки периода не равна 4", 16, m_strCaptionForm
                txtCodePayment.SetFocus 'вызов события txtCodePayment_GotFocus
                Exit Sub
            End If
            
            If Not IsNumeric(strPeriod) Then
                MsgBox strTitleError & "Строка периода содержит символы, отличные от цифр", 16, m_strCaptionForm
                txtCodePayment.SetFocus 'вызов события txtCodePayment_GotFocus
                Exit Sub
            End If
            
            strMonth = Right(strPeriod, 2)
            strYear = Left(strPeriod, 2)
            
            If CInt(strMonth) < 1 Or CInt(strMonth) > 12 Then
                MsgBox strTitleError & "Последние две цифры строки периода - месяц (от 1 до 12)", 16, m_strCaptionForm
                txtCodePayment.SetFocus 'вызов события txtCodePayment_GotFocus
                Exit Sub
            End If
            
            txtDayBeg.Text = 1
            txtMonthBeg.Text = strMonth
            txtYearBeg.Text = strYear
            
            txtDayEnd.Text = GetDayEnd(strMonth, strYear)
            txtMonthEnd.Text = strMonth
            txtYearEnd.Text = strYear
       End If
    End If
    '----------------------
    If txtDayBeg.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("DateBegin") Then
            If Len(Trim(objParamOut.Parameter("arrDataPayment").Parameter("DateBegin"))) > 0 Then
                If IsDate(objParamOut.Parameter("arrDataPayment").Parameter("DateBegin")) Then
            
                   Dim DateBegin As Date
            
                   DateBegin = objParamOut.Parameter("arrDataPayment").Parameter("DateBegin")
            
                   txtDayBeg.Text = Day(DateBegin)
                   txtMonthBeg.Text = Month(DateBegin)
                   txtYearBeg.Text = Right(Year(DateBegin), 2)
                End If
            End If
        End If
    End If
    
    If txtDayEnd.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("DateEnd") Then
            If Len(Trim(objParamOut.Parameter("arrDataPayment").Parameter("DateEnd"))) > 0 Then
                If IsDate(objParamOut.Parameter("arrDataPayment").Parameter("DateEnd")) Then
            
                   Dim DateEnd As Date
            
                   DateEnd = objParamOut.Parameter("arrDataPayment").Parameter("DateEnd")
            
                   txtDayEnd.Text = Day(DateEnd)
                   txtMonthEnd.Text = Month(DateEnd)
                   txtYearEnd.Text = Right(Year(DateEnd), 2)
                End If
            End If
        End If
    End If

    If AccClient.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("AccClient") Then
            If Len(Trim(objParamOut.Parameter("arrDataPayment").Parameter("AccClient"))) > 0 Then
                AccClient.Text = objParamOut.Parameter("arrDataPayment").Parameter("AccClient")
            End If
        End If
    End If
    '-------------------------
    '=========================================
    If txtFIOPay.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("PAYERFIO") Then
            txtFIOPay.Text = objParamOut.Parameter("arrDataPayment").Parameter("PAYERFIO")
        End If
    End If
    
    If txtINNPay.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("PAYERINN") Then
            txtINNPay.Text = objParamOut.Parameter("arrDataPayment").Parameter("PAYERINN")
        End If
    End If
    
    If txtAdressPay.Visible Then
        If objParamOut.Parameter("arrDataPayment").ExistParameter("PAYERADDRESS") Then
            txtAdressPay.Text = objParamOut.Parameter("arrDataPayment").Parameter("PAYERADDRESS")
        End If
    End If
    '============================================
    'objInterfaces.NextCtrl
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "FillDataPayment", "ошибка выполнения"

End Sub

Private Sub txtKBKNalog_Change()

    Dim strKbk As String, strKbkSymbol As String, i As Integer
    
    'MsgBox "txtKBKNalog_Change()..."
    'Режим создания дополнительного платежа (для налоговых)
    'If m_IdContractSecond > 0 And IsArray(arrKbkForCheck) And Len(Trim(txtKBKNalog.Text)) > 0 Then
    If IsArray(arrKbkForCheck) And Len(Trim(txtKBKNalog.Text)) > 0 Then
        'По умолчанию режим создания дополнительного платежа
        blnSecondPayment = 1  ' true
        'MsgBox "blnSecondPayment = True 1"
        If m_IdContractSecond > 0 Then
            lblNalog.Visible = True
        End If
        'Проводим проверку, требуется ли создавать дополнительный платеж
        strKbk = txtKBKNalog.Text
        For i = 0 To UBound(arrKbkForCheck, 1)
            'Если код в массиве больше чем на форме, то сравнивать не надо
            If Len(arrKbkForCheck(i)) <= Len(strKbk) And Len(arrKbkForCheck(i)) > 0 Then
                'Определяем часть КБК, введенный на форме
                strKbkSymbol = Left(strKbk, Len(arrKbkForCheck(i)))
                'Если часть КБК на форме совпадает с кодом из массива, то дополнительный платеж не создается
                If CStr(strKbkSymbol) = CStr(arrKbkForCheck(i)) Then
                    If m_IdContractSecond > 0 Then
                        lblNalog.Visible = False
                    End If
                    blnSecondPayment = 2  ' False
                    'MsgBox "blnSecondPayment = False 2"
                    Exit For
                End If
            End If
        Next
        If blnSecondPayment = 2 Then
            If IsArray(arrKbkForCheckY) Then
                For i = 0 To UBound(arrKbkForCheckY, 1)
                    'Если код в массиве больше чем на форме, то сравнивать не надо
                    If Len(arrKbkForCheckY(i)) <= Len(strKbk) And Len(arrKbkForCheckY(i)) > 0 Then
                        'Определяем часть КБК, введенный на форме
                        strKbkSymbol = Left(strKbk, Len(arrKbkForCheckY(i)))
                        'Если часть КБК на форме совпадает с кодом из массива, то дополнительный платеж создается
                        If CStr(strKbkSymbol) = CStr(arrKbkForCheckY(i)) Then
                            If m_IdContractSecond > 0 Then
                                lblNalog.Visible = True
                            End If
                            blnSecondPayment = 1  ' True
                            'MsgBox "blnSecondPayment = True 3"
                            Exit For
                        End If
                    End If
                Next
            End If
        End If
        'зависала форма. зачем тут вызов расчета комиссии?
        prefCalcRate = "_2 4"
        Call CalcSumCommiss_2
    End If
End Sub

