'---------------------------------------------------------------------------
'18.09.2006 г.   Новопашин В.М.
Sub FillTariff(lngIdTariff As Long)
'---------------------------------------------------------------------------

 Dim i, IdTarDefault As Integer
 On Error GoTo ErrorCode

'-----------------------------
' получить значения тарифов

 '------------------------- Новопашин В.М. 23.01.2007 г. ----------
 objParamIn.Parameter("IdPaym") = m_IdPayment
 '-----------------------------------------------------------------

 UbsChannel.Run "ReadTariff", objParamIn, objParamOut
    
varTariff = objParamOut.Parameter("Tarif_Name_Rate")
IdTarDefault = objParamOut.Parameter("Tarif_Name_Rate_Default")
CodeEnergy = objParamOut.Parameter("Code_Energy")
'---------------------------------------------------------------------------
'18.09.2006 г.   Новопашин В.М.
If lngIdTariff <> 0 Then IdTarDefault = lngIdTariff
'---------------------------------------------------------------------------

For i = 0 To UBound(varTariff, 2)
   cmbTariff.List(i) = varTariff(1, i) & ", " & varTariff(2, i)
   cmbTariff.ItemData(i) = varTariff(0, i)
   If IdTarDefault <> 0 Then
      If cmbTariff.ItemData(i) = IdTarDefault Then
         cmbTariff.ListIndex = i
      End If
   End If
Next

If IdTarDefault = 0 Then
   cmbTariff.ListIndex = 0
End If

Exit Sub
ErrorCode:
     objErr.UbsErrMsg "Чтение тарифа", "ошибка выполнения"
End Sub
Sub FillPayer()
On Error GoTo ErrorCode

    objParamIn.ClearParameters
    
    objParamIn.Parameter("IDCLIENT") = m_IdClient
    objParamIn.Parameter("IsGuest") = blnGuest
    
    ' получить посетителя Опер. кассы
    UbsChannel.Run "ReadClientFromIdOC", objParamIn, objParamOut

    If Len(Trim(objParamOut.Parameter("StrError"))) Then
        MsgBox objParamOut.Parameter("StrError"), 16, "ReadClientFromIdOC " & m_strCaptionForm
        Exit Sub
    End If
                    
    txtINNPay.Text = objParamOut.Parameter("INN")
    txtInfoClient.Text = objParamOut.Parameter("InfoClient")
    txtFIOPay.Text = objParamOut.Parameter("NAME")
    txtAdressPay.Text = objParamOut.Parameter("ADRESS")
    
    If CBool(objParamOut.Parameter("Benefits")) Then
        CheckBenefits.Value = 1
    End If
    
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "FillClient", "ошибка выполнения"
End Sub

'Command - добавление, или редактирование
'param - использовать последний платеж, или нет (только для добавления)
'Client - идентификатор клиента/посетителя(только для последнего платежа)
Sub FillNalog(param, Client)
    
    objParamIn.Parameter("LAST") = param
    
    If outerSystemInfo = True Then
        objParamIn.Parameter("StrCommand") = ""
    Else
        objParamIn.Parameter("StrCommand") = StrCommand
    End If
    
    objParamIn.Parameter("IdContract") = m_IdContract
    objParamIn.Parameter("IdClient") = Client
    objParamIn.Parameter("blnGuest") = blnGuest

    UbsChannel.Run "ReadNalog", objParamIn, objParamOut
        
    txtStatusNalog.Text = objParamOut.Parameter("Статус составителя")
        forbidTaxStatusChanges = objParamOut.Parameter("Запрет изменения статуса составителя")
    If forbidTaxStatusChanges Then
        txtStatusNalog.Enabled = False
        savedTaxStatusValue = objParamOut.Parameter("Статус составителя из договора")
    End If
    txtOKATONalog.Text = objParamOut.Parameter("Код ОКАТО")
    txtReasonNalog.Text = objParamOut.Parameter("Основание налогового платежа")
    txtPeriodNalog.Text = objParamOut.Parameter("Налоговый период")
    txtNomerNalog.Text = objParamOut.Parameter("Номер налогового документа")
    txtDateNalog.Text = objParamOut.Parameter("Дата налогового документа")
    txTypeNalog.Text = objParamOut.Parameter("Тип налогового платежа")
    txtIMNSNalog.Text = objParamOut.Parameter("ИМНС")
    txtKppu.Text = objParamOut.Parameter("КППУ")
    txtKBKNoteNalog.Text = objParamOut.Parameter("Расшифровка КБК")
    txtKBKNalog.Text = objParamOut.Parameter("Код бюджетной классификации")
    
    '(97887) Для приема платежей это поле не указывается
    If StrCommand = "ADD" Or StrCommand = "COPY" Or txTypeNalog.Text = "" Then
        txTypeNalog.Text = ""
        txTypeNalog.Enabled = False
    End If
    
    AddProperties.Refresh

End Sub

'----------------------------------------------------------------------
' Новопашин В.М. 18.09.2006 г.
Sub FillPhone(lngIdPhone As Long)
'---------------------------------------------------------------------
Dim varPhone As Variant
Dim i, intIdPhone As Integer
On Error GoTo ErrorCode

    ' вызов
    '-----------------------------
    ' получить значение тарифа по идентификатору
    UbsChannel.Run "ReadPhone", objParamIn, objParamOut
    varPhone = objParamOut.Parameter("Phone_Code_Name")
    intIdPhone = objParamOut.Parameter("Phone_Code_Name_Default")
    
    '----------------------------------------------------------------------
    ' Новопашин В.М. 18.09.2006 г.
    If lngIdPhone <> 0 Then
       intIdPhone = lngIdPhone
    End If
    '-----------------------------------------------------------------------
    
    For i = 0 To UBound(varPhone, 2)
        cmbPhone.List(i) = varPhone(1, i) & ", " & varPhone(2, i)
        cmbPhone.ItemData(i) = varPhone(0, i)
        If intIdPhone <> 0 Then
           If cmbPhone.ItemData(i) = intIdPhone Then
              cmbPhone.ListIndex = i
           End If
        End If
    Next
    
    If intIdPhone = 0 Then
       cmbPhone.ListIndex = 0
    End If
        
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "FillPhone", "ошибка выполнения"
End Sub


' заполнение списка кодов городов (для телефона)
Private Function FillCityCode(ArrayCityCode As Variant)
    Dim n As Integer, intIndex As Integer

 On Error GoTo ErrorCode

    cboCityCode.Clear
    intIndex = 0
    
    If IsArray(ArrayCityCode) Then
        
        For n = 0 To UBound(ArrayCityCode)
            cboCityCode.AddItem ArrayCityCode(n), n
        Next
        
        cboCityCode.ListIndex = 0
    End If
    
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "FillCityCode", "ошибка выполнения"
End Function

Private Function GetDayEnd(strMonth As String, strYear As String)

 On Error GoTo ErrorCode

    GetDayEnd = 1
    
    Dim dDate As Date
    
    ' первое число месяца
    'dDate = (CDate("01." & strMonth & "." & strYear))
    dDate = DateSerial(CInt(strYear), CInt(strMonth), 1)
    ' первое число следующего месяца
    dDate = DateAdd("m", 1, dDate)
    ' последнее число месяца
    dDate = DateAdd("d", -1, dDate)

    GetDayEnd = Day(dDate)
    
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "GetDayEnd", "ошибка выполнения"
End Function

' проверяем ввод в текстовое поле только цифр
Private Sub CheckInt(Control As TextBox, KeyCode As Integer)

 On Error GoTo ErrorCode

    Control.Locked = False
        
    If (KeyCode >= 48 And KeyCode <= 57) Or (KeyCode >= 96 And KeyCode <= 105) Or KeyCode = 8 Or KeyCode = 46 Then
        Control.Locked = False
    Else
        Control.Locked = True
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "CheckInt", "ошибка выполнения"
End Sub

