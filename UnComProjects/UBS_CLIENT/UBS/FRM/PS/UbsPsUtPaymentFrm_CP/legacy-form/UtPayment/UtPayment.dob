Private Sub CheckPaymDic()

      If Len(Trim(AccPay.Text)) > 0 Then

          objParamIn.Parameter("IdKindPayment") = m_IdKindPaym
          objParamIn.Parameter("accLic") = AccPay.Text
            
          UbsChannel.Run "CheckPaymDic", objParamIn, objParamOut
        'UbsChannel.LoadResource = "VBS:UBS_VBS\PS\Lib\PsLibTools.vbs"
        'UbsChannel.Run "CheckPaymDic", objParamIn, objParamOut
          m_IdOneRecord = objParamOut.Parameter("OneRecord")
        'Если в справочнике только одна запись
          If m_IdOneRecord <> 0 Then
               m_IdPaymentDic = m_IdOneRecord
               FillDataPayment ("FILTER")
               
          End If
      End If
End Sub

Private Sub RunEcOperation(ByVal DbOrCr As String, ByVal Oborot As Currency, ByVal IdCurrency As Long)
    On Error GoTo ErrorCode

    Dim objChildWnd As Object
    'Dim IdClient As Variant
    Dim intResult As Integer
    Dim outParam As Variant
    
    'IdClient = CLng(Client.Id)
        
    Parent.GetWindow "Action:UBS_OC_FRM_EC_OPERATION", objChildWnd
    If Not (objChildWnd Is Nothing) Then
        Set objChildWnd.MdiParent = Nothing
        objChildWnd.Run "SetOperation", Array(DbOrCr, Oborot, IdCurrency), outParam
        If CLng(outParam) = 0 Then intResult = objChildWnd.ShowDialog
    End If
    Set objChildWnd = Nothing
    
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "RunEcOperation", "ошибка выполнения"
End Sub

Private Sub AddProperties_ValueChange(ByVal id As Long, ByVal NameField As String, ByVal Value As Variant, ByVal newValue As Variant)

    objParamIn.Parameter("NameField") = NameField
    objParamIn.Parameter("Value") = Value
    objParamIn.Parameter("NewValue") = newValue

    UbsChannel.Run "UserAddField", objParamIn, objParamOut
    If objParamOut.Parameter("bRetVal") = False Then
        MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
         Exit Sub
     End If
    
    'Если есть ошибки с обновлением, надо поставить таймер, но проверка показала, что обновление работает нормально
     AddProperties.Refresh

End Sub

Private Function gotoPreviousTab()
    gotoPreviousTab = False
    Dim i, tabSelected
    Dim tabCount: tabCount = subPayment.Tabs.Count
    tabSelected = 1
    For i = 1 To tabCount
        If subPayment.Tabs(i).Selected Then tabSelected = i
    Next
    If tabSelected = 1 Then Exit Function

    For i = tabSelected To 1 Step -1
        If subPayment.Tabs(i).Enabled And subPayment.Tabs(i).Visible Then
            subPayment.Tabs(i).Selected = True
            gotoPreviousTab = True
            Exit Function
            End If
    Next
End Function


Private Sub UserDocument_Terminate()
     Set objFormParam = Nothing
End Sub

Property Get SidAction()
        If StrCommand = "ADD" Then
            SidAction = "UBS_PS_UT_PAYMENT_RECEPTION"
        ElseIf StrCommand = "CHANGE_PART" Then
            SidAction = "UBS_PS_PAYMENT_CHANGE_PART"
        Else
            SidAction = ""
        End If
End Property
