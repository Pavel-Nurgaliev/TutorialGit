' получить л/счет и ключ л/с
' --------------------------
'
Function CheckAndSplitAccount()
    CheckAndSplitAccount = False
    
On Error GoTo ErrorCode

    ' m_strSignAccCode = Признак ввода лицевого счета плательщика
    If m_strSignAccCode = "отсутствует" Then
        CheckAndSplitAccount = True
        Exit Function
    End If

    'проверка л/с на длину
    If CInt(Len(Trim(AccPay.Text))) = CInt(0) Or CInt(Len(Trim(AccPay.Text))) < CInt(AccPay.MaxLength) Then
        subPayment.Tabs(TAB_GENERAL).Selected = True
        MsgBox "Некорректная длина лицевого счета плательщика! (" & AccPay.MaxLength & ")", 16, m_strCaptionForm
        'вызов события AccPay_GotFocus
        AccPay.SetFocus
        Exit Function
    End If

    'вызов функции CheckAndSplitAccount
    objParamIn.ClearParameters
    ' /IN/
    objParamIn.Parameter("mSumma") = curSumma.CurrencyValue
    If cboCityCode.Enabled Then
        objParamIn.Parameter("AccCode") = cboCityCode.Text & Trim(AccPay.Text)
    Else
        objParamIn.Parameter("AccCode") = Trim(AccPay.Text)
    End If
    objParamIn.Parameter("nLenKey") = m_nLenKey
    objParamIn.Parameter("strSignKey") = m_strSignKey
    objParamIn.Parameter("strNameProcAcc") = m_strNameProcAcc
    '------------------------------------ Новопашин В.М. 05.06.2006 г.

    objParamIn.Parameter("IDKINDPAYMENT") = m_IdKindPaym
    
    objParamOut.ClearParameters
    'вызов
    UbsChannel.Run "UtCheckAndSplitAccount", objParamIn, objParamOut

    If Not CBool(objParamOut.Parameter("bRetVal")) Then
        If CLng(objParamOut.Parameter("ErrNum")) <> CLng(0) Then
            SetToWait objParamOut.Parameter("StrError")
            ' т.к. если нет, наприм., файла, то нельзя нажимать ничего, кроме Выхода
            ''btnSave.Enabled = False
        Else
            subPayment.Tabs(TAB_GENERAL).Selected = True
            
            MsgBox objParamOut.Parameter("StrError"), vbCritical, m_strCaptionForm
            'вызов события AccPay_GotFocus
            AccPay.SetFocus
            ''btnSave.Enabled = False
        End If
        '----------------------------------- Новопашин В.М.  16.06.2006
        m_strAccCode = objParamOut.Parameter("AccCode")
        m_strCheckSum = objParamOut.Parameter("CheckSum")
        '--------------------------------------------------------------
        
        Exit Function
    End If
    
    If objParamOut.ExistParameter("StrQuestion") Then
        If vbCancel = MsgBox(CStr(objParamOut.Parameter("StrQuestion")), vbExclamation + vbOKCancel, "Внимание!") Then
            Exit Function
        End If
    End If

    ' /OUT/
    'получаем: л/с и ключ л/с
    
    m_strAccCode = objParamOut.Parameter("AccCode")
    m_strCheckSum = objParamOut.Parameter("CheckSum")
    
    If IdGroupIncoming = 0 Then
        Call GetDataClietFromLic
    End If

    CheckAndSplitAccount = True

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CheckAndSplitAccount", "ошибка выполнения"
End Function

' получить ключ л/с и ChkType
' ---------------------------
'
Function PrepareAccount()
    PrepareAccount = False
    
    Dim strCityCode As String, strKey As String
    
On Error GoTo ErrorCode

    ' *pstrKey = txtCheckSum.Text
    ' base_types = m_SIDPattern
    ' strAccount = AccCode
    ' bAllowBadCheckSum = m_blnIsErrorKey
    ' [out] *pnChkType = objParamOut.Parameter("CheckType")
    ' mSumma = curSumma.CurrencyValue

    If m_strSignKey = "отсутствует" Then
        m_strCheckSum = Empty
        m_strCheckType = Empty
    ElseIf m_strSignKey = "отдельно от счета" And Trim(txtCheckSum.Text) = "" Then
        ' рассчитать ключ
        If Not CalcKey(strKey) Then Exit Function
        ' сохранить данные в глобальные переменные
        m_strCheckSum = strKey
        m_strCheckType = "ключ сформирован автоматически"
        txtCheckSum.Text = strKey
    Else    '("входит в счет") ИЛИ ("отдельно от счета" И ключ не пустой)
        If Not CalcKey(strKey) Then Exit Function
        
        ' если ключ проверять не надо (т.е. если процедура расчета ключа в Виде платежа не указана)
        If Not m_bIsCheckKey Then
            PrepareAccount = True
            m_strCheckSum = txtCheckSum.Text
            Exit Function
        End If
        
        ' (если ключ = входит в счет (для газа))
        If m_bIncludeKey Then
            ' рассчитанный ключ strKey нужно сравнить с
            ' рассчитанным ранее в функции CheckAndSplitAccount
            ' ключом m_strCheckSum
            If CStr(m_strCheckSum) = CStr(strKey) Then
                m_strCheckType = "ключ набран операционистом и совпадает с расч. ключом"
                btnSave.Enabled = True
            Else
                ' если не разрешен ввод ошибочных ключей
                If Not m_blnIsErrorKey Then
                    subPayment.Tabs(TAB_GENERAL).Selected = True
                    MsgBox "Ошибка в ключе! Правильный ключ '" & strKey & "'.", vbCritical, m_strCaptionForm
                    'вызов события AccPay_GotFocus
                    AccPay.SetFocus
                    ''btnSave.Enabled = False
                    Exit Function
                Else
                    ' если нажато No
                    If MsgBox("Ошибка в ключе! Правильный ключ '" & strKey & "'. Сохранить ошибочный ключ?", vbYesNo + vbQuestion, m_strCaptionForm) <> vbYes Then
                        subPayment.Tabs(TAB_GENERAL).Selected = True
                        'вызов события AccPay_GotFocus
                        AccPay.SetFocus
                        ''btnSave.Enabled = False
                        Exit Function
                    End If
                End If
                ' сохранить данные в глобальные переменные
                m_strCheckType = "ключ набран операционистом и не совпад. с расч. ключом"
                btnSave.Enabled = True
            End If
        Else
            ' рассчитанный ключ strKey нужно сравнить с
            ' введенным ключом txtCheckSum.Text
            If CStr(txtCheckSum.Text) = CStr(strKey) Then
                ' сохранить данные в глобальные переменные
                m_strCheckSum = strKey
                m_strCheckType = "ключ набран операционистом и совпадает с расч. ключом"
                btnSave.Enabled = True
            Else
                ' если не разрешен ввод ошибочных ключей
                If Not m_blnIsErrorKey Then
                    subPayment.Tabs(TAB_GENERAL).Selected = True
                    MsgBox "Ошибка в ключе! Правильный ключ '" & strKey & "'.", vbCritical, m_strCaptionForm
                    'вызов события txtCheckSum_GotFocus
                    txtCheckSum.SetFocus
                    ''btnSave.Enabled = False
                    Exit Function
                Else
                    ' если нажато No
                    If MsgBox("Ошибка в ключе! Правильный ключ '" & strKey & "'. Сохранить ошибочный ключ?", vbYesNo + vbQuestion, m_strCaptionForm) <> vbYes Then
                        subPayment.Tabs(TAB_GENERAL).Selected = True
                        'вызов события txtCheckSum_GotFocus
                        txtCheckSum.SetFocus
                        'btnSave.Enabled = False
                        Exit Function
                    End If
                End If
                ' сохранить данные в глобальные переменные
                m_strCheckSum = txtCheckSum.Text
                m_strCheckType = "ключ набран операционистом и не совпад. с расч. ключом"
                btnSave.Enabled = True
            End If
        End If
    End If

    PrepareAccount = True
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "PrepareAccount", "ошибка выполнения"
End Function

' получить ключ л/с и ChkType
' ---------------------------
'
Function CalcKey(strKey As String)
    CalcKey = False

    Dim strCityCode As String
    
On Error GoTo ErrorCode

    'вызов функции UtCalcKey
    objParamIn.ClearParameters
    ' /IN/
    If m_SIDPattern = "UBS_UT_PHONE_ROSTEL" Then
        objParamIn.Parameter("mSumma") = CCur(curSumma.CurrencyValue)
    End If
    objParamIn.Parameter("strNameProcKey") = m_strNameProcKey
    
    strCityCode = cboCityCode.Text 'cboCityCode.ItemData(cboCityCode.ListIndex)
    ' m_strAccCode - уже рассчитанный л/с в функции CheckAndSplitAccount
    If m_SIDPattern = "UBS_UT_PHONE" And Len(Trim(strCityCode)) > 0 Then
        'If CStr(Trim(Left(m_strAccCode, 3))) <> CStr(strCityCode) Then
        If CStr(Trim(Left(m_strAccCode, Len(CStr(strCityCode))))) <> CStr(strCityCode) Then
            ' для телефона - прибавляем впереди Код города
            m_strAccCode = strCityCode + m_strAccCode
        End If
    End If
    objParamIn.Parameter("AccCode") = m_strAccCode
    
    objParamOut.ClearParameters
    
    'вызов
    UbsChannel.Run "UtCalcKey", objParamIn, objParamOut
    
    If Not CBool(objParamOut.Parameter("bRetVal")) Then
        If CLng(objParamOut.Parameter("ErrNum")) <> CLng(0) Then
            SetToWait objParamOut.Parameter("StrError")
            ' т.к. если нет, наприм., файла, то нельзя нажимать ничего, кроме Выхода
            ''btnSave.Enabled = False
            btnCalc.Enabled = False
        Else
            MsgBox objParamOut.Parameter("StrError"), vbCritical, m_strCaptionForm
            'подсветить ключ txtCheckSum
            txtCheckSum_GotFocus
        End If
        Exit Function
    End If
    
    ' /OUT/
    'получаем: рассчитанный ключ л/с
    strKey = objParamOut.Parameter("CheckSum")
    m_bIsCheckKey = objParamOut.Parameter("bIsCheckKey")

    CalcKey = True
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CalcKey", "ошибка выполнения"
End Function


Sub SetToWait(strReport)
        
 On Error GoTo ErrorCode

    Wait.TextVisible = False
    Wait.ClearFile
    Wait.WriteLine = strReport
    Wait.ViewFile

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "SetToWait", "ошибка выполнения"
End Sub

Sub FormKeyPress(KeyAscii As Integer)
    ' KeyAscii с 48 до 57 = коды цифр с 0 до 9
    ' (Debug.Print и Ctrl+G)
    ' KeyAscii - 13 = код клавиши Enter
    ' KeyAscii -  8 = код клавиши Backspace
    If ((KeyAscii < 48 And KeyAscii <> 8 And KeyAscii <> 13) Or (KeyAscii > 57)) Then
        KeyAscii = 0
    End If
End Sub


' ----------- Бровкова Н.Ю. 04.05.05 ---------
' заполнение списка Назначение платежа
' --------------------------------------------
Private Function FillPurpose(arrPurpose As Variant)
    Dim i As Integer, intIndex As Integer

 On Error GoTo ErrorCode

    cmbPurpose.Clear
    intIndex = 0
    
    If IsArray(arrPurpose) Then
        
        For i = 0 To UBound(arrPurpose, 2)
            cmbPurpose.AddItem arrPurpose(0, i), i
        Next
        
        cmbPurpose.ListIndex = 0
    End If
    
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "FillPurpose", "ошибка выполнения"
End Function

' проверка на террориста
'
Function CheckTerror()
   CheckTerror = True
   
   'Проверка плательщика, если заполнен
   'If Len(Trim(txtFIOPay.Text)) > 0 Then
      '--------------------------------- Novopashin V.M. 09-02-2006 г.
      objParamIn.ClearParameters
      objParamOut.ClearParameters

      '---------------------------------------------------------------
      objParamIn.Parameter("NAME") = txtFIOPay.Text
      objParamIn.Parameter("IDCONTRACT") = m_IdContract
      objParamIn.Parameter("PURPOSE") = cmbPurpose.Text
      objParamIn.Parameter("RECIPIENTNAME") = txtRecip.Text
      'Для новой проверки в справочнике террористов
      objParamIn.Parameter("IDCLIENT") = m_IdClient
      objParamIn.Parameter("IsGuest") = blnGuest

      UbsChannel.Run "CheckTerror", objParamIn, objParamOut
      
      '--------------------------------- Novopashin V.M. 09-02-2006 г.
      If Not objParamOut.ExistParameter("RETVAL") Then Exit Function
      '---------------------------------------------------------------
      
      blnTerror = False
      If Not objParamOut.Parameter("RETVAL") Then

              'If MsgBox(objParamOut.Parameter("StrError"), vbOKCancel + vbQuestion, "Проверка корректности данных") = vbOK Then
              'Да - добавить террориста в справочник
              Dim Reply As Integer
              
              If objParamOut.Parameter("TypeTerror") = 0 Then
                  Reply = (MsgBox(objParamOut.Parameter("StrError"), vbOKCancel + vbQuestion, "Проверка корректности данных"))
              Else
                  Reply = (MsgBox(objParamOut.Parameter("StrError"), vbYesNoCancel + vbQuestion + vbDefaultButton2, "Проверка корректности данных"))
              End If
              
              If Reply = 6 Or Reply = 7 Or Reply = 1 Then 'vbYes or vbNo or vbOk
                  If m_IdClient = 0 And objParamOut.ExistParameter("blnErrorPayer") Then
                      subPayment.Tabs(TAB_GENERAL).Selected = True
                      btnClient.SetFocus
                      CheckTerror = False
                      MsgBox "Клиента подозреваемого в террористической деятельности надо выбрать из справочника!!!", vbOKOnly + vbInformation, "Проверка корректности данных"
                      btnClient_Click
                  End If
                  'ок - работа без занесения в справочник
                  If Reply = 1 Then 'vbOk
                      blnTerror = False
                  'да - это террорист
                  ElseIf Reply = 6 Then 'vbYes
                      blnTerror = True
                  'Нет - не добавлять (это не террорист)
                  ElseIf Reply = 7 Then ' vbNo
                      blnTerror = False
                  End If
              'Прервать работу
              Else ' vbCancel
                 CheckTerror = False
                 Exit Function
              End If
          End If
      'End If
   'End If
      
End Function

Function CheckRS()
'Данилова, 28.10.2005

On Error GoTo ErrorCode

    CheckRS = True
    '-------------------------------------------- Новопашин В.М. 24.05.06 ----
    Dim strOurBankBic As String
    UbsChannel.Run "UtReadOurBankBik", objParamIn, objParamOut
    strOurBankBic = CStr(objParamOut.Parameter("strOurBankBic"))
    If AccClient.Text = "00000000000000000000" And Trim(strOurBankBic) = Trim(txtBic.Text) Then
    '-------------------------------------------------------------------------
        CheckRS = False
        MsgBox "Некорректный расчетный счет!", 16, m_strCaptionForm
        subPayment.Tabs(TAB_GENERAL).Selected = True
        
        If subPayment.SelectedTab.Index = 1 Then
            If AccClient.Enabled Then
                objInterfaces.GoToCtrl AccClient
            Else
                objInterfaces.GoToCtrl txtCode
            End If
        End If
        
        Exit Function
    End If
    
   ' проверка ключа расчетного счета счета
    If AccClient.Text <> "00000000000000000000" And AccClient.Text <> "" Then
        objParamIn.Parameter("STRACC") = AccClient.Text
        objParamIn.Parameter("BIC") = txtBic.Text
        objParamIn.Parameter("CORRACC") = AccKorr.Text
        
        If Mid(AccClient.Text, 1, 2) <> "03" And Mid(AccClient.Text, 6, 3) <> "643" Then
            UbsChannel.Run "CheckKey", objParamIn, objParamOut
            
            If objParamOut.Parameter("RETVAL") = False Then
                CheckRS = False
                MsgBox "Некорректный ключ счета!", 16, m_strCaptionForm
                subPayment.Tabs(TAB_GENERAL).Selected = True
                If subPayment.SelectedTab.Index = 1 Then
                    objInterfaces.GoToCtrl AccClient
                End If
                Exit Function
            End If
        Else
            If (Mid(AccClient.Text, 1, 2) = "03" And Mid(AccClient.Text, 6, 3) <> "643") Or _
               (Mid(AccClient.Text, 1, 2) <> "03" And Mid(AccClient.Text, 6, 3) = "643") Then
                    CheckRS = False
                    Call MsgBox("Введён недопустимый код валюты!", 16, m_strCaptionForm)
                    subPayment.Tabs(TAB_GENERAL).Selected = True
                    If subPayment.SelectedTab.Index = 1 Then
                        objInterfaces.GoToCtrl AccClient
                    End If
                    Exit Function
            End If
            
            UbsChannel.Run "PsCheckTofkAcc", objParamIn, objParamOut
            If objParamOut.Parameter("RETVAL") = False Then
                CheckRS = False
                MsgBox "Счет получателя не найден в справочнике ТОФК!", 16, m_strCaptionForm
                subPayment.Tabs(TAB_GENERAL).Selected = True
                If subPayment.SelectedTab.Index = 1 Then
                    objInterfaces.GoToCtrl AccClient
                End If
                Exit Function
            End If
        End If
    End If
    
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CheckRS", "ошибка выполнения"
End Function


'----------------------------------- Новопашин В.М. 09-02-2007 г. ------
'Запуск дополнительной проверки определяемой пользователем
Function Ut_CheckUserBeforeSave()
Dim blnRes As Boolean
On Error GoTo Err_Proc
     
     Dim objParamUserIn As Object, objParamUserOut As Object
     Dim varAddFields As Variant, strError As String
     Dim lngI As Long
     
     Ut_CheckUserBeforeSave = True
     
     Set objParamUserIn = CreateObject("ToolPubs.IUbsParam")
     Set objParamUserOut = CreateObject("ToolPubs.IUbsParam")
     
     objParamUserIn.ClearParameters
     objParamUserOut.ClearParameters
              
     objParamUserIn.Parameter("КППУ") = Trim(txtKppu.Text)
      
     'Для проверки налоговых данных (если эти поля сделаны невидимыми)
     If m_SIDPattern = "UBS_UT_NALOG" Or subPayment.Tabs(TAB_TAX).Visible Then
         objParamUserIn.Parameter("SIDPATTERN") = m_SIDPattern
         objParamUserIn.Parameter("Статус составителя") = txtStatusNalog.Text
         objParamUserIn.Parameter("Код бюджетной классификации") = txtKBKNalog.Text
         objParamUserIn.Parameter("Код ОКАТО") = txtOKATONalog.Text
         objParamUserIn.Parameter("Основание налогового платежа") = txtReasonNalog.Text
         objParamUserIn.Parameter("Налоговый период") = txtPeriodNalog.Text
         objParamUserIn.Parameter("Номер налогового документа") = txtNomerNalog.Text
         objParamUserIn.Parameter("Дата налогового документа") = txtDateNalog.Text
         objParamUserIn.Parameter("Тип налогового платежа") = txTypeNalog.Text
         objParamUserIn.Parameter("ИМНС") = txtIMNSNalog.Text
     End If
     
     'Считываем значение доп. полей
     UbsChannel.Run "UTListAddRead", objParamUserIn, objParamUserOut

    'При редактировании передавать в пользовательский сценарий проверки идентификатор платежа
    If StrCommand = "CHANGE_PART" Then
        objParamUserIn.Parameter("IDPAYMENT") = m_IdPayment
    End If
     
     objParamUserIn.Parameter("IDCONTRACT") = m_IdContract  '  идентификатор контракта
     objParamUserIn.Parameter("CODE") = txtCode.Text   '  идентификатор контракта
     
     If txtCodePayment.Enabled Then
        objParamUserIn.Parameter("CODEPAYMENT") = txtCodePayment.Text   '  Код платежа
     End If
     
     objParamUserIn.Parameter("INN") = txtINN.Text  '  ИНН получателя платежа
     objParamUserIn.Parameter("BIC") = txtBic.Text  ' БИК банка
     objParamUserIn.Parameter("CORRACC") = AccKorr.Text   '  к/с получателя платежа
     objParamUserIn.Parameter("ACC") = AccClient.Text   '  р/с получатела платежа
     
     objParamUserIn.Parameter("IDCLIENT") = m_IdClient   '  id клиента
     objParamUserIn.Parameter("PAYERFIO") = txtFIOPay.Text  '  ФИО плательщика
     objParamUserIn.Parameter("PAYERINN") = txtINNPay.Text  '  ИНН плательщика
     objParamUserIn.Parameter("PAYERADDRESS") = txtAdressPay.Text  '  адрес плательщика
     
     objParamUserIn.Parameter("RECIPIENTNAME") = txtRecip.Text 'Наименование получателя
     
     'If AccPay.Enabled Then
     If AccPay.Enabled Or btnPaymDic.Visible Then
        objParamUserIn.Parameter("ACCCODE") = AccPay.Text  '  л/с плательщика
     End If
     
     If txtCheckSum.Enabled Then
        objParamUserIn.Parameter("CHECKSUM") = txtCheckSum.Text  '  контрольная сумма к л/с плательщика
     End If
     
     objParamUserIn.Parameter("PURPOSE") = cmbPurpose.Text  '  назначение платежа
      
     objParamUserIn.Parameter("SUMMAPENY") = curPeny.CurrencyValue  'сумма пени
      
     objParamUserIn.Parameter("SUMMA") = curSumma.CurrencyValue     '  сумма
     objParamUserIn.Parameter("SUMMARATESEND") = curSummaRateSend.CurrencyValue  '  комиссия с плательщика
     objParamUserIn.Parameter("SUMMARATEREC") = m_curSumRateRec  '  комиссия с получателя платежа
     objParamUserIn.Parameter("SUMMANDSSEND") = m_curSumNDSSend   '  сумма НДС с плательщика платежа
     objParamUserIn.Parameter("SUMMANDSREC") = m_curSumNDSRec   '  сумма НДС получателя
     objParamUserIn.Parameter("SUMMAREC") = m_curSumRec   '  сумма получателя
     objParamUserIn.Parameter("SUMMATOTAL") = curSummaTotal.CurrencyValue '  Итого к оплате
     
     objParamUserIn.Parameter("<БИК банка получателя>,<Счет получателя>") = Trim(txtBic.Text) & "," & Trim(AccClient.Text)
     
     If AccClientPay.Visible Then
         objParamUserIn.Parameter("ACCCLIENTPAY") = AccClientPay.Text  '  Источник средств
     End If
     
     
        If txtYearBeg.Text <> "" And txtMonthBeg.Text <> "" And txtDayBeg.Text <> "" And txtYearEnd.Text <> "" And txtMonthEnd.Text <> "" And txtDayEnd.Text <> "" Then
                '---------------------------------------- Новопашин 14-02-2006 г.
                If m_bIsPeriodEnable Then
                   objParamUserIn.Parameter("DATEBEGIN") = DateSerial(CInt(txtYearBeg.Text), CInt(txtMonthBeg.Text), CInt(txtDayBeg.Text))   '  дата начала периода
                   objParamUserIn.Parameter("DATEEND") = DateSerial(CInt(txtYearEnd.Text), CInt(txtMonthEnd.Text), CInt(txtDayEnd.Text))  '  дата конца периода
                End If
                '---------------------------------------------------------------
     End If
     
    
    Select Case m_SIDPattern
    Case "UBS_UT_ENERGY"
        objParamUserIn.Parameter("Идентификатор тарифа электроэнергии") = cmbTariff.ItemData(cmbTariff.ListIndex)
        'm_IdTariff
    Case "UBS_UT_PHONE", "UBS_UT_PHONE_ACC"
        objParamUserIn.Parameter("Идентификатор телефонного узла") = cmbPhone.ItemData(cmbPhone.ListIndex)
        'm_IdPhone
    End Select
    
    'Если доп. поля есть на форме, то передаём их в виде входных параметров
    If objParamUserOut.ExistParameter("AddFields") Then
      varAddFields = objParamUserOut.Parameter("AddFields")
      For lngI = 0 To UBound(varAddFields, 2)
         objParamUserIn.Parameter(varAddFields(1, lngI)) = varAddFields(7, lngI)
      Next lngI
    End If
     
     
    UbsChannel.Run "Ut_CheckBeforeSave", objParamUserIn, objParamUserOut
     
    '-------------------------------------- Новопашин В.М. 14-02-2006 г.
    'Вызываем функцию Ut_CheckBeforeSave.
    'Входные параметры содержимое основных и доп. полей
    '
    'Выходные параметры - код возрата bRet и Error
    '
    'Если код возврата равен False, то отображаем ошибку
    
    '-------------------------------------------------------------------
    ' 16.02.2007 - Потапов Д.А.
    'btnSave.Enabled = True

    btnExit.Enabled = True
    strError = objParamUserOut.Parameter("Error")
    blnRes = CBool(objParamUserOut.Parameter("bRet"))
    If Len(strError) > 0 And blnRes Then
        If MsgBox(strError, vbInformation + vbYesNo, m_strCaptionForm) = vbNo Then
            Ut_CheckUserBeforeSave = False
        End If
    ElseIf Not blnRes Then
        MsgBox strError, vbCritical, m_strCaptionForm & "(Пользовательская проверка)"
        btnSave.Enabled = False
        Ut_CheckUserBeforeSave = False
    End If
    '--------------------------------
    Exit Function
    
Err_Proc:
    Ut_CheckUserBeforeSave = False
    m_blnSave = False
    objErr.UbsErrMsg "Ut_CheckUserBeforeSave", "ошибка выполнения"
    
End Function

Function tryGotoOnNextControl()
    On Error GoTo errNext
    objInterfaces.NextCtrl
    tryGotoOnNextControl = True
    Exit Function
errNext:
    tryGotoOnNextControl = False
End Function

Sub MoveToAnotherTab()
    Dim i, tabSelected
    Dim tabCount: tabCount = subPayment.Tabs.Count
    tabSelected = 1
    For i = 1 To tabCount
        If subPayment.Tabs(i).Selected Then tabSelected = i
    Next
    For i = tabSelected To subPayment.Tabs.Count
        If subPayment.Tabs(i).Enabled And subPayment.Tabs(i).Visible Then
            subPayment.Tabs(i).Selected = True
            Exit Sub
            End If
    Next
End Sub

Sub GotoNextControlForEnter()

Dim bRet1 As Boolean

   On Error GoTo ErrorCode

     bRet1 = True
     Select Case (UserDocument.ActiveControl.name)

        'begin - Данилова, 28.10.2005
         Case "txtCodePayment"
             FillDataPayment ("CODE") 'заполнение данных платежа по данным штрих-кода
             If curSumma.Enabled Then
                curSumma.SetFocus
             ElseIf Not tryGotoOnNextControl Then MoveToAnotherTab
             End If
         'end - Данилова, 28.10.2005
         
         Case "txtFIOPay"
             If txtINNPay.Enabled Then
                 txtINNPay.SetFocus
             Else
                 objInterfaces.NextCtrl
             End If
         
         Case "AccPay"
             Call CheckPaymDic
             ' CheckAndSplitAccount()
             If Not CheckAndSplitAccount() Then
                 'AccPay.SetFocus
             Else
                 ' PrepareAccount()
                 ' (если ключ = входит в счет (для газа))
                 If m_bIncludeKey Then
                     If Not PrepareAccount() Then
                         bRet1 = False
                         AccPay.SetFocus
                     End If
                 End If
                 
                 If bRet1 Then
                     If txtCheckSum.Visible Then
                         txtCheckSum.SetFocus
                     ElseIf btnPaymDic.Visible Then
                          btnPaymDic.SetFocus
                     Else
                         If subPayment.Tabs(TAB_TELEPHONE).Visible Then
                            subPayment.Tabs(TAB_TELEPHONE).Selected = True
                            cmbPhone.SetFocus
                         Else
                            GoToNextControl
                         End If
                     End If
                 End If
             End If
             
           Case "txtCheckSum"
             ' PrepareAccount()
             If Not PrepareAccount() Then
                 txtCheckSum.SetFocus
             Else
               If btnPaymDic.Visible Then
                  btnPaymDic.SetFocus
               ElseIf subPayment.Tabs(TAB_TAX).Visible Then
                subPayment.Tabs(TAB_TAX).Selected = True
                If txtStatusNalog.Enabled Then
                    txtStatusNalog.SetFocus
                Else
                    txtKBKNalog.SetFocus
                End If
               ElseIf subPayment.Tabs(TAB_TELEPHONE).Visible Then
                  subPayment.Tabs(TAB_TELEPHONE).Selected = True
                  cmbPhone.SetFocus
               ElseIf subPayment.Tabs(TAB_TARIFF).Visible Then
                  subPayment.Tabs(TAB_TARIFF).Selected = True
                  cmbTariff.SetFocus
               Else
                  GoToNextControl
               End If
             End If
                             
         Case "txtBic"
             '------------------------------------- Новопашин В.М. 07.07.2006 г.
             m_blnNoMessage = True

             If GetBankNameACC = False Then
             
                 subPayment.Tabs(TAB_GENERAL).Selected = True
                 If subPayment.SelectedTab.Index = 1 Then
                     If txtBic.Enabled Then txtBic.SetFocus
                 End If
             Else
                 subPayment.Tabs(TAB_GENERAL).Selected = True
                 If subPayment.SelectedTab.Index = 1 Then
                     
                     '------------------------------ Новопашин В.М. 10.08.2006 г.
                     'Изменился порядок движения по полям
                     If AccClient.Enabled Then
                         AccClient.SetFocus
                     Else
                         If txtINN.Enabled Then txtINN.SetFocus
                     End If
                     '------------------------------------------------------------
                     
                 End If
             End If
             
             If m_SIDPattern = "UBS_UT_NALOG" And StrCommand = "ADD" And blnLast Then
                 'Если заполнен БИК и договор
                 If Len(Trim(txtBic.Text)) <> 0 And m_IdContract <> 0 Then
                     'Если заполнен р/с или клиент/посетитель
                     If AccClient.Text <> "00000000000000000000" Or m_IdClient <> 0 Then
                         Call FillNalog(True, m_IdClient)
                     End If
                 End If
             End If
         '----------испорчено Кирсанова Е.В.----------
         Case "cmbPhone", "cmbTariff"
              If subPayment.Tabs(TAB_ADDFL).Enabled Then
                 subPayment.Tabs(TAB_ADDFL).Selected = True
                 AddProperties.SetFocus
              End If
         
           Case "AccClient"

              'begin - Данилова, 28.10.2005
              If CheckRS Then
                 '----------------------------- Новопашин В.М. 10.08.2006 г.--------
                 If m_IdContract <> 0 Then
                     
                    If m_SIDPattern = "UBS_UT_NALOG" And StrCommand = "ADD" And blnLast Then
                        'Если заполнен БИК и договор
                        If Len(Trim(txtBic.Text)) <> 0 And m_IdContract <> 0 Then
                            'Если заполнен р/с или клиент/посетитель
                            If AccClient.Text <> "00000000000000000000" Or m_IdClient <> 0 Then
                                Call FillNalog(True, m_IdClient)
                            End If
                        End If
                    End If
                    
                    objParamIn.ClearParameters
                    objParamIn.Parameter("ACC") = AccClient.Text
                    objParamIn.Parameter("BIC") = txtBic.Text
                    objParamIn.Parameter("IdContract") = m_IdContract
                    
                    UbsChannel.Run "UtGetINNFromLastPayment", objParamIn, objParamOut
                    
                    'Переносим данные ИНН
                    If txtINN.Enabled = True Then
                       txtINN.Text = objParamOut.Parameter("INN")
                    End If
                    
                    If cmbPurpose.Enabled Then
                       If Not IsComboBoxItemExists(objParamOut.Parameter("PURPOSE")) And Len(Trim(CStr(objParamOut.Parameter("PURPOSE")))) = 0 Then
                          cmbPurpose.AddItem objParamOut.Parameter("PURPOSE"), cmbPurpose.ListCount - 1
                          cmbPurpose.ListIndex = cmbPurpose.NewIndex
                       End If
                    End If
                    
                    
                    If objParamOut.Parameter("IDPAYMENT") <> "" Then
                       objParamIn.ClearParameters
                       objParamIn.Parameter("IDPAYMENT") = objParamOut.Parameter("IDPAYMENT")
                       UbsChannel.Run "UtGetKPPUPayerLastPayment", objParamIn, objParamOut
                       txtRecip.Text = objParamOut.Parameter("Recip")
                       AddProperties.Refresh
                    End If
                 End If
                 '------------------------------------------------------------------
                 
                 objParamIn.Parameter("ACC") = AccClient.Text
                 If blnForward Then
                    objInterfaces.NextCtrl
                 End If
                 
              End If
                 
         Case "curSumma"
             If m_IdContract > 0 Then
                prefCalcRate = "_2 8"
                Call CalcSumCommiss_2
             End If
             If curPeny.Visible And curPeny.Enabled Then
                curPeny.SetFocus
                 ' если хоть один из этих контролов Enabled, то переход будет по первой закладке
             ElseIf (txtMonthBeg.Visible Or AccPay.Visible Or txtCheckSum.Visible) Then
                subPayment.Tabs(TAB_GENERAL).Selected = True
                objInterfaces.NextCtrl
             Else
                If subPayment.Tabs(TAB_THIRDPERSON).Visible Then
                    subPayment.Tabs(TAB_THIRDPERSON).Selected = True
                    txt_ThirdPersonName.SetFocus
                ElseIf subPayment.Tabs(TAB_TAX).Visible Then
                    subPayment.Tabs(TAB_TAX).Selected = True
                    If txtStatusNalog.Enabled Then
                        txtStatusNalog.SetFocus
                    Else
                        txtKBKNalog.SetFocus
                    End If
                Else
                    GoToNextControl
                End If
             
                'GoToNextControl
             End If
             
         Case "txtIMNSNalog"
            subPayment.Tabs(TAB_ADDFL).Selected = True
            AddProperties.SetFocus
            
         Case "curPeny"
             If m_IdContract > 0 Then
                prefCalcRate = "_2 9"
                Call CalcSumCommiss_2
             End If
             ' если хоть один из этих контролов Enabled, то переход будет по первой закладке
             If (txtMonthBeg.Visible Or AccPay.Visible Or txtCheckSum.Visible) Then
                subPayment.Tabs(TAB_GENERAL).Selected = True
                objInterfaces.NextCtrl
             Else
                If subPayment.Tabs(TAB_THIRDPERSON).Visible Then
                    subPayment.Tabs(TAB_THIRDPERSON).Selected = True
                    txt_ThirdPersonName.SetFocus
                ElseIf subPayment.Tabs(TAB_TAX).Visible Then
                    subPayment.Tabs(TAB_TAX).Selected = True
                    If txtStatusNalog.Enabled Then
                        txtStatusNalog.SetFocus
                    Else
                        txtKBKNalog.SetFocus
                    End If
                Else
                    GoToNextControl
                End If
                'GoToNextControl
             End If
             
         ' ------------------------------------
         ' добавила Бровкова Н.Ю. от 07.04.2005
           Case "txtYearEnd"
         '-------------------------- Novopashin V.M. 04-04-2006 г. --
             If cboCityCode.Visible And cboCityCode.Enabled Then
                  cboCityCode.SetFocus
         '------------------------------------------------------------
         '========================= изменено Кирсанова Е.В. 23.11.2005
             ElseIf AccPay.Visible And AccPay.Enabled Then ' = стало
             'If AccPay.Enabled Then ' = было
                 AccPay.SetFocus
         '===========================================================
             ElseIf subPayment.Tabs(TAB_THIRDPERSON).Visible Then
                subPayment.Tabs(TAB_THIRDPERSON).Selected = True
                txt_ThirdPersonName.SetFocus
             Else
                If subPayment.Tabs(TAB_ADDFL).Enabled Then
                   '======================= испорчено Кирсанова Е.В. 23.11.2005
                   ' ничего не упало пока, но так, на всякий случай
                   If AddProperties.PropertyCount <> 0 Then
                      subPayment.Tabs(TAB_ADDFL).Selected = True
                      AddProperties.SetFocus
                   Else
                      btnSave.SetFocus
                   End If
                   '============================================================
                ' -------испорчено Кирсанова Е.В. 05.10.2005 -----
                Else
                   btnSave.SetFocus
                ' ------------------------------------------------
                End If
             End If
      Case "txt_ThirdPersonInn"
            If subPayment.Tabs(TAB_TAX).Visible And Not txt_ThirdPersonKpp.Enabled Then
                subPayment.Tabs(TAB_TAX).Selected = True
                txtKBKNalog.SetFocus
            Else
                objInterfaces.NextCtrl
            End If
      Case "txt_ThirdPersonKpp"
            If subPayment.Tabs(TAB_TAX).Visible Then
                subPayment.Tabs(TAB_TAX).Selected = True
                txtKBKNalog.SetFocus
            Else
                GoToNextControl
            End If
      Case "txtKPPU" '"txtIMNSNalog"
          If subPayment.Tabs(TAB_ADDFL).Enabled Then
              subPayment.Tabs(TAB_ADDFL).Selected = True
              AddProperties.SetFocus
          End If
      Case "txtKBKNalog"
          ' переход не нужен, т.к. по Enter есть переход выше по событию txtKBKNalog_KeyPress(), где уже ставится .SetFocus по Enter
      Case Else
           objInterfaces.NextCtrl        'SendKeys "{TAB}"
     End Select
     
     Exit Sub
ErrorCode:
    objErr.UbsErrMsg "GotoNextControlForEnter", "ошибка выполнения"
    
End Sub


'-----------------------------------------------------------------------
' Проверка полей в субконтрактах на наличие
' обязательных данных
Function CheckSubContracts(out_Param As Variant) As Boolean
Dim cstrErr As String
Dim i As Long
Dim lngID As Long
Dim objPIn As Object, objPOut As Object

    CheckSubContracts = True
    cstrErr = "В выбранном субдоговоре отсутствуют данные в " & "обязательных полях (БИК банка получателя и/или счета получателя). " & vbCr & "Сохранить платеж на основе такого субдоговора будет невозможно."
    out_Param.Parameter("StrError") = ""
    If IsArray(varSubContracts) Then
    
        Set objPIn = CreateObject("ToolPubs.IUbsParam")
        Set objPOut = CreateObject("ToolPubs.IUbsParam")
    
        For i = 0 To UBound(varSubContracts, 2)
        
            objPIn.ClearParameters
            objPOut.ClearParameters
            
            objPIn.Parameter("CODECONTRACT") = varSubContracts(0, i)
            
            Call UbsChannel.Run("ReadContractbyCode", objPIn, objPOut)
            
            lngID = objPOut.Parameter("IDCONTRACT")
            If lngID > 0 Then
                
                objPIn.Parameter("IdContract") = lngID
                
                Call UbsChannel.Run("UtReadContract", objPIn, objPOut)
                
                If (Len(CStr(objPOut.Parameter("BIC"))) = 0) Or (Len(CStr(objPOut.Parameter("Acc"))) = 0) Or (Len(CStr(objPOut.Parameter("CorrAcc"))) = 0) Then
                    CheckSubContracts = False
                    Exit For
                End If
            End If
            
        Next i
    
        Set objPIn = Nothing
        Set objPOut = Nothing
    
    End If
    
    If Not CheckSubContracts Then
        out_Param.Parameter("StrError") = cstrErr
    End If
    
End Function


Private Sub UpdateGroupInfo()
Dim objPIn As Object, objPOut As Object

    txtGRPId.Text = m_IdGroup

    If m_IdGroup > 0 Or IdGroupIncoming > 0 Then
        Set objPIn = CreateObject("ToolPubs.IUbsParam")
        Set objPOut = CreateObject("ToolPubs.IUbsParam")
        
        objPIn.ClearParameters
        objPOut.ClearParameters
        
        If IdGroupIncoming > 0 Then
            objPIn.Parameter("PAYMENTGROUPID") = IdGroupIncoming
        Else
            objPIn.Parameter("PAYMENTGROUPID") = m_IdGroup
        End If
        
        'W:\SYSTEM\VBD\PS\UT\UtPaymentF.vbs
        Call UbsChannel.Run("UtReadGroupInfo", objPIn, objPOut)

        If Len(objPOut.Parameter("StrError")) Then
            objErr.UbsErrMsg "UpdateGroupInfo", "ошибка выполнения"
        Else
            If IdGroupIncoming > 0 Then
                objPOut.Parameter("QTTYSUBCONTRACTS") = objPOut.Parameter("QTTYSUBCONTRACTS") - 1
            End If
            txtQttySubs.Text = objPOut.Parameter("QTTYSUBCONTRACTS")
            curCommonSumma.CurrencyValue = CCur(objPOut.Parameter("CURCOMMONSUMMA"))
            curTotalSumma.CurrencyValue = CCur(objPOut.Parameter("CURTOTALSUMMA"))
        End If
        
        Set objPIn = Nothing
        Set objPOut = Nothing
    Else
        txtQttySubs.Text = "0"
        curCommonSumma.CurrencyValue = CCur(0)
        curTotalSumma.CurrencyValue = CCur(0)
    End If
    
End Sub

Sub GetGroupIDByPaymentID(ByVal in_PaymID As Long)

    If blnGroup And (in_PaymID > 0) Then
        
        objParamOut.ClearParameters
        objParamIn.Parameter("IdPaym") = in_PaymID
        
        UbsChannel.HostAddress = Parent.LoaderParamInfo(NumWin, "HostAddress")
        UbsChannel.UserGUID = Parent.LoaderParamInfo(NumWin, "GuidSession")
        UbsChannel.ParentHwnd = UserDocument.hWnd
        UbsChannel.LoadResource = "VBS:UBS_VBD\PS\UT\UtPaymentF.vbs"
        
        UbsChannel.Run "GetGroupIDByPayment", objParamIn, objParamOut

        m_IdGroup = objParamOut.Parameter("PAYMENTGROUPID")
        
        objParamOut.ClearParameters

        Call UpdateGroupInfo
     End If

End Sub

'Проверка на разрыв связи
Private Function CheckStateFR()
On Error GoTo ErrorCode

    CheckStateFR = False

    objParamIn.Parameter("objDevice") = objDevice
    
    CheckStateFR = True
    
    Exit Function
ErrorCode:
    'objErr.UbsErrMsg "CheckStateFR", "ошибка выполнения"
End Function

Function CheckIPDL()
    CheckIPDL = True
   
    Dim ret As Integer, objComCheck As Object
    
    Set objComCheck = CreateObject("UbsCheck.UbsComCheck")
    
    ret = objComCheck.CommonCheckIPDL(UbsChannel)
        
    If ret = 0 Then      ' не является ИПДЛ
        blnIPDL = False
    ElseIf ret = 1 Then  ' является ИПДЛ, разрешено
        blnIPDL = True
    Else                 ' является ИПДЛ, не разрешено
        blnIPDL = True
        CheckIPDL = False
    End If
    
End Function


Private Sub GetDataClietFromLic()
            objParamIn.Parameter("blnGuest") = blnGuest
            objParamIn.Parameter("IdContract") = m_IdContract
            objParamIn.Parameter("л/с") = AccPay.Text
            
            UbsChannel.LoadResource = "VBS:UBS_VBD\PS\UT\UtPaymentF.vbs"
            UbsChannel.Run "UtReadLic", objParamIn, objParamOut
            
            If objParamOut.ExistParameter("ID_CLIENT") Then
                m_blnLic = True
            Else
                m_blnLic = False
            End If

            If m_blnLic Then
                m_IdClient = objParamOut.Parameter("ID_CLIENT")
                AccPay.Text = objParamOut.Parameter("ACCCODE")
        
                objParamIn.Parameter("IDCLIENT") = m_IdClient
                objParamIn.Parameter("IsGuest") = blnGuest
                'получить посетителя Опер. кассы
                UbsChannel.Run "ReadClientFromIdOC", objParamIn, objParamOut
                If Len(Trim(objParamOut.Parameter("StrError"))) Then
                    MsgBox objParamOut.Parameter("StrError"), 16, "ReadClientFromIdOC " & m_strCaptionForm
                    Exit Sub
                End If
                 txtINNPay.Text = objParamOut.Parameter("INN")
                 txtInfoClient.Text = objParamOut.Parameter("InfoClient")
                 txtFIOPay.Text = objParamOut.Parameter("NAME")
                 txtAdressPay.Text = objParamOut.Parameter("ADRESS")
                 If AccClientPay.Visible Then
                     AccClientPay.Text = "00000000000000000000"
                 End If
                 txtNomerCardPay.Text = ""

                 Call CheckPayer(False)
                 
                 ' (69627)
                 'Получить номер и серию документа
                 m_strDocNumber = objParamOut.Parameter("NUMBER")
                 m_strDocSeries = objParamOut.Parameter("SERIES")
                 '

               End If

            '========================================================
'ErrorCode:
'    objErr.UbsErrMsg "GetDataClietFromLic", "ошибка выполнения"
End Sub

