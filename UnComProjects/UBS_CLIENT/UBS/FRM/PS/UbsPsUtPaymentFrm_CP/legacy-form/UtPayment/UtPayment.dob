Private Sub btnSelectThirdPerson_Click()
    Dim nIdSelectedRecord As Variant
    Dim j As Integer
    Dim intKeyCond As Integer
    
On Error GoTo ErrorCode

    If NumChildWinThirdPerson <> 0 Then
        Parent.SetFocusToWindow NumChildWinThirdPerson
        Exit Sub
    End If
        
    If blnGuest Then
        Parent.GetWindow "UBS_LIST_OC_OC_CLIENTS", NumChildWinThirdPerson
    Else
        Parent.GetWindow "UBS_LIST_COMMON_CLIENT", NumChildWinThirdPerson
    End If
    '===================================
    
    If NumChildWinThirdPerson <> 0 Then
        Dim InitParamGrid As Variant
        Dim gridF As Object
        Dim varCond As Variant
        ReDim InitParamGrid(5)
        
        Set gridF = Parent.ParamInfo(NumChildWinThirdPerson, "UbsGridList")
            
        If Parent.IsExistParam(NumChildWinThirdPerson, "InitParamGrid") Then
            nIdSelectedRecord = Empty
            InitParamGrid(0) = NumWin
            InitParamGrid(2) = True
            InitParamGrid(5) = 1
            Parent.ParamInfo(NumChildWinThirdPerson, "InitParamGrid") = InitParamGrid
            If Parent.IsExistParam(NumChildWinThirdPerson, "SelectItem") Then
                Parent.ParamInfo(NumChildWinThirdPerson, "SelectItem") = nIdSelectedRecord
            End If
            Parent.SetFocusToWindow NumChildWinThirdPerson
        End If
        Set gridF = Nothing
    End If
    '===========================================
   
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Выбор клиента", "ошибка выполнения"
End Sub

Private Sub cb_ThirdPerson_Click()
    
    If (cb_ThirdPerson.Value = 1) Then
        subPayment.Tabs(TAB_THIRDPERSON).Visible = True
        
        '(100077)
        'txtStatusNalog.Enabled = False
        txtStatusNalog.Enabled = True
        
        If cmb_ThirdPersonKind.ListIndex >= 0 Then Call ThirdPersonKindChanged
    Else
       subPayment.Tabs(TAB_THIRDPERSON).Visible = False
       If forbidTaxStatusChanges Then
          txtStatusNalog.Text = savedTaxStatusValue
       Else
          txtStatusNalog.Enabled = True
       End If
    End If
End Sub



Private Sub CheckBenefits_Click()
    If CheckBenefits.Value = 1 Then
        'curSummaRateSend.CurrencyValue = 0
        'If curSummaTotal.CurrencyValue > 0 Then
        '    curSummaTotal.CurrencyValue = curSumma.CurrencyValue + curPeny.CurrencyValue
        'End If
    End If
End Sub

Private Sub cmb_ThirdPersonKind_LostFocus()
    ThirdPersonKindChanged
End Sub

'0000000000000000000000
Private Sub ThirdPersonKindChanged()
    If cmb_ThirdPersonKind.ListIndex = 2 Then
        txt_ThirdPersonKpp.Enabled = True
    Else
        txt_ThirdPersonKpp.Enabled = False
        txt_ThirdPersonKpp.Text = "0"
    End If
    
    Select Case cmb_ThirdPersonKind.ListIndex
        Case 0
            If FormReestToDocs Then
                txtStatusNalog.Text = "09"
            Else
                txtStatusNalog.Text = "20"
            End If
        Case 1
            If FormReestToDocs Then
                txtStatusNalog.Text = "13"
            Else
                txtStatusNalog.Text = "20"
            End If
        Case 2
            If FormReestToDocs Then
                txtStatusNalog.Text = "01"
            Else
                txtStatusNalog.Text = "20"
            End If
    End Select
End Sub

Private Sub cmbPurpose_Change()
    Dim tbLen As Integer
    tbLen = 210 - Len(cmbPurpose.Text)
    If tbLen < 0 Then
        lblNoteCnt.ForeColor = vbRed
    Else
        lblNoteCnt.ForeColor = vbBlack
    End If
    lblNoteCnt.Caption = tbLen
End Sub

Private Sub cmdCashSymb_Click()
 
On Error GoTo ErrorCode

    If curSumma.CurrencyValue = 0 Then
        MsgBox "Не заполнена сумма платежа!", vbCritical, "Ошибка"
        Exit Sub
    End If
    
    If Not IsArray(arrDataTypeCashSymbol) Then
        MsgBox "Не заполнено доп поле 'Разбивка платежа по символам'!", vbCritical, "Ошибка"
        Exit Sub
    End If
    
    UbsChannel.LoadResource = "VBS:UBS_VBD\PS\UT\UtPaymentF.vbs"
    Set frmCashSymb.UbsChannel = UbsChannel
    
    Dim arrData As Variant
    
    arrData = arrCashSymb
    
    frmCashSymb.ArrayData = arrData
    frmCashSymb.arrTypeCashSymbol = arrDataTypeCashSymbol

    frmCashSymb.curSummaTotal = curSumma.CurrencyValue + curPeny.CurrencyValue
    '========================================
    Load frmCashSymb
    frmCashSymb.Show vbModal
        
     Select Case frmCashSymb.TypeExit
         Case 0
             'Выход без сохранения
         Case 1
             'Выход с сохранением
             arrCashSymb = frmCashSymb.arrCashSymb
     End Select
    
     'arrCashSymb = frmCashSymb.arrCashSymb
       
    Unload frmCashSymb

    Exit Sub
ErrorCode:
  objErr.UbsErrMsg "cmdCashSymb_Click", "ошибка выполнения"
End Sub


Private Sub curPeny_TextChange()
    If m_IdContract > 0 Then
        prefCalcRate = "_2 1"
        Call CalcSumCommiss_2
    End If
End Sub


Private Sub Timer1_Timer()
    On Error GoTo Fatal
    
    Timer1.Enabled = False
    If m_IdContract > 0 Then
        prefCalcRate = "_2 2 Timer"
        Call CalcSumCommiss_2
    End If
    
    Exit Sub
Fatal:
    objErr.UbsErrMsg "Timer1_Timer", "ошибка выполнения"
End Sub

