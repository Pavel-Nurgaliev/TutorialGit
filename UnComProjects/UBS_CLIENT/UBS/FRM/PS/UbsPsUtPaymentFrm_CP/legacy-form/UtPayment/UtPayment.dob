' обработка нажатий клавиш на контроле Доп. полей
Private Sub AddProperties_KeyPress(ByVal nKeyCode As Integer)

On Error GoTo ErrorCode
  
    Select Case (nKeyCode)
        Case 13
           'objInterfaces.GoToCtrl btnSave
          nKeyCode = 0
          If AddProperties.PropertyCurrentIndex = AddProperties.PropertyCount - 1 Then
             objInterfaces.NextCtrl
          End If
        Case 27
            nKeyCode = Asc(Chr(0))  'Chr(0) - это пробел
            If subPayment.Tabs(TAB_TAX).Visible Then
                subPayment.Tabs(TAB_TAX).Selected = True
            ElseIf subPayment.Tabs(TAB_THIRDPERSON).Visible Then
                subPayment.Tabs(TAB_THIRDPERSON).Selected = True
            Else
                subPayment.Tabs(TAB_GENERAL).Selected = True
                If txtCheckSum.Visible Then
                   txtCheckSum.SetFocus
                ElseIf AccPay.Visible Then
                    AccPay.SetFocus
                ElseIf txtYearEnd.Visible Then
                    objInterfaces.GoToCtrl txtYearEnd
                Else
                    objInterfaces.GoToCtrl curSumma
                End If
            End If
    End Select
  
    Exit Sub
ErrorCode:
  objErr.UbsErrMsg "AddProperties_KeyPress", "ошибка выполнения"
End Sub

' НАЖАТИЕ КНОПКИ "РАСЧЕТ"
'
Private Sub btnCalc_Click()
Dim sumEc As Currency

btnCalc.Enabled = False

On Error GoTo ErrorCode

    ' проверим - надо ли показывать форму расчета
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    UbsChannel.Run "InitDialogCalc", objParamIn, objParamOut
    
    If CBool(objParamOut.Parameter("bRetVal")) Then
    
        If (txtINNPay.Text <> "") Then
            If (txtINNPay.Text <> "0") Then
                If Not CheckKeyInn(txtINNPay.Text) Then
                    MsgBox "Проверка контрольного числа в ИНН плательщика <" & txtINNPay.Text & "> не пройдена!", vbCritical, "Прием платежа"
                    Exit Sub
                End If
            End If
        End If
        
        If (txtINN.Text <> "") Then
            If Not CheckKeyInn(txtINN.Text) Then
                MsgBox "Проверка контрольного числа в ИНН получателя <" & txtINN.Text & "> не пройдена!", vbCritical, "Прием платежа"
                Exit Sub
            End If
        End If
    
        btnCalc.Enabled = True
        If CBool(objParamOut.Parameter("bInitDialog")) Then
            sumEc = objParamOut.Parameter("Summa")
            frmCalc.curSumPaym = objParamOut.Parameter("Summa")
            Load frmCalc 'Данилова, 12.09.2005
            frmCalc.Show vbModal

            If frmCalc.TypeExit = 1 Then
                ' нажали Расчет
                ' сохраняем платежам данного юзера доп.поле "Расчет с клиентом" = "произведен"
                objParamIn.ClearParameters
                objParamOut.ClearParameters
                
                '=============== электронный кассир =================
                Dim IdCurrency As Long
                UbsChannel.Run "GetGlobal_ParamBaseCurrency", objParamIn, objParamOut
                IdCurrency = objParamOut.Parameter("Идентификатор базовой валюты")

                Dim Ec As Object
                Set Ec = CreateObject("UbsOcRunEc.Ec")
                If Not Ec.RunEcOperation(Parent, "DB", CCur(sumEc), IdCurrency) Then
                    MsgBox "Расчет с клиентом не произведен! Возникли проблемы взаимодействия с электронным кассиром.", 16, m_strCaptionForm
                    Exit Sub
                End If

                '===================================================

                UbsChannel.Run "PutAddFlCalc", objParamIn, objParamOut
                
                If CBool(objParamOut.Parameter("bRetVal")) = True Then
                    '----------------------- Новопашин В.М. 31.05.2006 ----------
                    NewRecordCalc
                    '------------------------------------------------------------
                    
                    curCommonSumma.CurrencyValue = 0
                    curTotalSumma.CurrencyValue = 0
                    
                    '----------------------- Новопашин В.М. 24.07.2006 ----------
                    'При нажатии кнопки "Расчет" очищаются данные по клиенту
                    m_IdClient = 0
                    lblFindFilter.Visible = False
                    btnFindFilter.Visible = False
                    txtINNPay.Text = ""
                    txtFIOPay.Text = ""
                    txtAdressPay.Text = ""
                    'If AccClientPay.Visible Then
                    If AccClientPayVisible Then
                        AccClientPay.Text = "00000000000000000000"
                    End If
                    txtInfoClient.Text = "" '2009
                    '------------------------------------------------------------
                    MsgBox "Расчет с клиентом проведен", vbInformation, m_strCaptionForm
                Else
                    MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
                End If
            End If

            Unload frmCalc
        End If
    Else
        btnCalc.Enabled = True
        MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
        Exit Sub
    End If

    Exit Sub
ErrorCode:
  objErr.UbsErrMsg "btnCalc_Click", "ошибка выполнения"
End Sub

' НАЖАТИЕ КНОПКИ "ВЫБОР КЛИЕНТА"
'
Private Sub btnClient_Click()

    Dim nIdSelectedRecord As Variant
    Dim j As Integer
    Dim intKeyCond As Integer
    
On Error GoTo ErrorCode

    If NumChildWin <> 0 Then
        Parent.SetFocusToWindow NumChildWin
        Exit Sub
    End If

    '========================================
    'отобразить список по кнопке "..."
    '========================================
    'Parent.GetWindow "UBS_LIST_OC_OC_CLIENTS", NumChildWin
    
    
    '=========== 23.03.2009 ===========
    If blnGuest Then
        Parent.GetWindow "UBS_LIST_OC_OC_CLIENTS", NumChildWin
    Else
        Parent.GetWindow "UBS_LIST_COMMON_CLIENT", NumChildWin
    End If
    '===================================
    
    If NumChildWin <> 0 Then
        Dim InitParamGrid As Variant
        Dim gridF As Object
        Dim varCond As Variant
        ReDim InitParamGrid(5)
        
        Set gridF = Parent.ParamInfo(NumChildWin, "UbsGridList")
'        GridF.ClearAllLists
'
'        intKeyCond = GridF.AddWhereItem("Фамилия", 6, "")
'        GridF.WhereItemFlags(intKeyCond) = 1
'
'        GridF.CheckSelectItem "Фамилия", 1
'        GridF.CheckSelectItem "Имя", 1
'        GridF.CheckSelectItem "Отчество", 1
'        GridF.CheckSelectItem "Адрес", 1

'этот код запишет в условие фильтра тип 2 - физическое лицо и сделает повторный выбор не доступным
'============== 23.03.2009 ===============
       If Not blnGuest Then
           Dim RetVal1 As Long, i As Integer
       
           gridF.GetWhereRS 1, varCond
           RetVal1 = 0

           If Not IsEmpty(varCond) Then
               For i = 0 To UBound(varCond, 2)
                   If varCond(0, i) = "Тип" Then
                       RetVal1 = varCond(4, i)
                   End If
               Next
           End If
       
           'Установка условий фильтра
           If RetVal1 = 0 Then
               RetVal1 = gridF.AddWhereItem("Тип", 4, 2)
           Else
               gridF.DelWhereItem RetVal1
               RetVal1 = gridF.AddWhereItem("Тип", 4, 2)
           End If
        
           gridF.WhereItemFlags(RetVal1) = 0
       End If
'=======================================
        
        If Parent.IsExistParam(NumChildWin, "InitParamGrid") Then
            nIdSelectedRecord = Empty
            InitParamGrid(0) = NumWin
            InitParamGrid(2) = True
            InitParamGrid(5) = 1
            Parent.ParamInfo(NumChildWin, "InitParamGrid") = InitParamGrid
            If Parent.IsExistParam(NumChildWin, "SelectItem") Then
                Parent.ParamInfo(NumChildWin, "SelectItem") = nIdSelectedRecord
            End If
            Parent.SetFocusToWindow NumChildWin
        End If
        Set gridF = Nothing
    End If
    '===========================================
   
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Выбор клиента", "ошибка выполнения"
End Sub

' НАЖАТИЕ КНОПКИ "ВЫБОР ДОГОВОРА"
'
Private Sub btnContract_Click()
    Dim nIdSelectedRecord As Variant

On Error GoTo ErrorCode
    
    btnContract.Enabled = False
    
    If NumChildWinContract <> 0 Then
        Parent.SetFocusToWindow NumChildWinContract
        btnContract.Enabled = True
        Exit Sub
    End If
    '-----------------------добавлено Кирсанова Е.В. 11.10.2005
    '========================================
    'отобразить список по кнопке "..."
    '========================================
    
    Parent.GetWindow "UBS_LIST_PS\UT_UT_LIST_CONTRACT", NumChildWinContract
        
    If NumChildWinContract <> 0 Then
        Dim InitParamGrid As Variant
        Dim gridF As Object
        ReDim InitParamGrid(5)
        Dim rsWhere
        Dim i As Integer, fl As Boolean
        Set gridF = Parent.ParamInfo(NumChildWinContract, "UbsGridList")
        
        If calledFromFrontOffice Then 'Если форма вызвана из фронт офиса, то договоры должны быть доступны для оплаты с фронт офиса
            i = 0
            fl = False
            gridF.GetWhereRS 1, rsWhere
            
            If IsArray(rsWhere) Then
            For i = 0 To UBound(rsWhere, 2)
                If rsWhere(0, i) = "Доступен для единой формы обслуживания" Then
                    fl = True
                    Exit For
                End If
            Next
            End If
            If fl Then
               gridF.EditWhereItemValue rsWhere(4, i), 1
               gridF.WhereItemFlags(rsWhere(4, i)) = 0
            Else
               i = gridF.AddWhereItem("Доступен для единой формы обслуживания", 4, 1)
               gridF.WhereItemFlags(i) = 0
            End If
            fl = False
        End If
        
      ' ----------- Добавим в условия БИК и р/с Романова И. 08.07.05
        If (Trim(txtBic.Text) <> "" Or (Trim(AccClient.Text) <> "" And AccClient.Text <> "00000000000000000000")) And Not ContractFilterLimitations Then
            i = 0
            fl = False
            gridF.GetWhereRS 1, rsWhere
            
           If Trim(txtBic.Text) <> "" Then
             If IsArray(rsWhere) Then
             For i = 0 To UBound(rsWhere, 2)
              If rsWhere(0, i) = "БИК" Then
               fl = True
               Exit For
              End If
             Next
             End If
             If fl Then
              gridF.EditWhereItemValue rsWhere(4, i), Trim(txtBic.Text)
              gridF.WhereItemFlags(rsWhere(4, i)) = 0
              gridF.WhereItemFlags(rsWhere(4, i)) = 1
             Else
              i = gridF.AddWhereItem("БИК", 4, Trim(txtBic.Text))
              gridF.WhereItemFlags(i) = 0
              gridF.WhereItemFlags(i) = 1
             End If
              
           End If
             fl = False
             If Trim(AccClient.Text) <> "" And AccClient.Text <> "00000000000000000000" Then
             If IsArray(rsWhere) Then
             For i = 0 To UBound(rsWhere, 2)
              If rsWhere(0, i) = "Расчетный счет" Then
               fl = True
               Exit For
              End If
             Next
             End If
             If fl Then
               gridF.EditWhereItemValue rsWhere(4, i), Trim(AccClient.Text)
               gridF.WhereItemFlags(rsWhere(4, i)) = 0
               gridF.WhereItemFlags(rsWhere(4, i)) = 1
             Else
               i = gridF.AddWhereItem("Расчетный счет", 4, Trim(AccClient.Text))
               gridF.WhereItemFlags(i) = 0
               gridF.WhereItemFlags(i) = 1
             End If
           End If
           
           '-------------------------------------- Novopashin V.M. 19.05.2006
           'Задействуем ИНН в поиске договора
           If Trim(txtINN.Text) <> "" And Not ContractFilterLimitations Then
             If IsArray(rsWhere) Then
             For i = 0 To UBound(rsWhere, 2)
              If rsWhere(0, i) = "ИНН" Then
               fl = True
               Exit For
              End If
             Next
             End If
             If fl Then
              gridF.EditWhereItemValue rsWhere(4, i), Trim(txtINN.Text)
              gridF.WhereItemFlags(rsWhere(4, i)) = 0
              gridF.WhereItemFlags(rsWhere(4, i)) = 1
             Else
              i = gridF.AddWhereItem("ИНН", 4, Trim(txtINN.Text))
              gridF.WhereItemFlags(i) = 0
              gridF.WhereItemFlags(i) = 1
             End If
           End If
           '----------------------------------------------------------------
           
        End If
       ' ----------------------------------------------------------------------
       
        If ContractFilterLimitations And searchKBK = "Да" Then
            i = 0
            fl = False
            gridF.GetWhereRS 1, rsWhere
            
            If IsArray(rsWhere) Then
            For i = 0 To UBound(rsWhere, 2)
                If rsWhere(0, i) = "КБК" Then
                    fl = True
                    Exit For
                End If
            Next
            End If
            If fl Then
               gridF.EditWhereItemValue rsWhere(4, i), txtKBKNalog.Text
               gridF.WhereItemFlags(rsWhere(4, i)) = 0
            Else
               i = gridF.AddWhereItem("КБК", 4, txtKBKNalog.Text)
               gridF.WhereItemFlags(i) = 0
            End If
            fl = False
        End If
        
        If ContractFilterLimitations And searchTemplate <> "" And searchTemplate <> "*" Then
            i = 0
            fl = False
            gridF.GetWhereRS 1, rsWhere
            
            If IsArray(rsWhere) Then
            For i = 0 To UBound(rsWhere, 2)
                If rsWhere(0, i) = "Шаблон" Then
                    fl = True
                    Exit For
                End If
            Next
            End If
            If fl Then
               gridF.EditWhereItemValue rsWhere(4, i), searchTemplate
               gridF.WhereItemFlags(rsWhere(4, i)) = 0
            Else
               i = gridF.AddWhereItem("Шаблон", 4, searchTemplate)
               gridF.WhereItemFlags(i) = 0
            End If
            fl = False
        End If
        
        If ContractFilterLimitations Then
            i = 0
            fl = False
            gridF.GetWhereRS 1, rsWhere
            
            If IsArray(rsWhere) Then
            For i = 0 To UBound(rsWhere, 2)
                If rsWhere(0, i) = "БИК" Then
                    fl = True
                    Exit For
                End If
            Next
            End If
            
                    
            If fl Then
               If searchBIK = "Да" Then
                 gridF.EditWhereItemValue rsWhere(4, i), txtBic.Text
                 gridF.WhereItemFlags(rsWhere(4, i)) = 0
               ElseIf searchBIK = "" Then
                 gridF.EditWhereItemValue rsWhere(4, i), ""
                 gridF.WhereItemFlags(rsWhere(4, i)) = 0
               End If
            Else
               If searchBIK = "Да" Then
                 i = gridF.AddWhereItem("БИК", 4, txtBic.Text)
                 gridF.WhereItemFlags(i) = 0
               ElseIf searchBIK = "" Then
                 i = gridF.AddWhereItem("БИК", 4, "")
                 gridF.WhereItemFlags(i) = 0
               End If
            
            End If
            fl = False
        End If
       
        gridF.GetWhereRS 1, rsWhere
        gridF.ClearMenuList
        
        If Parent.IsExistParam(NumChildWinContract, "InitParamGrid") Then
            nIdSelectedRecord = Empty
            InitParamGrid(0) = NumWin
            InitParamGrid(2) = True
            If IsEmpty(rsWhere) Then
               InitParamGrid(5) = 2
            Else
               InitParamGrid(5) = 1
            End If
            
            Parent.ParamInfo(NumChildWinContract, "InitParamGrid") = InitParamGrid
            If Parent.IsExistParam(NumChildWinContract, "SelectItem") Then
                Parent.ParamInfo(NumChildWinContract, "SelectItem") = nIdSelectedRecord
            End If
            Parent.SetFocusToWindow NumChildWinContract
        End If
        Set gridF = Nothing
    End If
    '===========================================
    btnContract.Enabled = True
    
    'objInterfaces.GoToCtrl curPeny

    Exit Sub
ErrorCode:
    btnContract.Enabled = True
    objErr.UbsErrMsg "Выбор договора", "ошибка выполнения"
End Sub

' НАЖАТИЕ КНОПКИ "ВЫХОД"
'
Private Sub btnExit_Click()

    '========= завершение и проверка группового платежа   ==========
    If IdGroupIncoming > 0 Then
        objParamIn.Parameter("IdGroupIncoming") = IdGroupIncoming
        objParamIn.Parameter("IdPaym") = objParamOut.Parameter("IdPaym")
        objParamIn.Parameter("curCommonSumma") = curCommonSumma.CurrencyValue
            
        UbsChannel.Run "CheckOrEndGroup", objParamIn, objParamOut
        If objParamOut.Parameter("Type") = 3 Then
            If MsgBox("Сумма принятых платежей " & curCommonSumma.CurrencyValue & " меньше суммы группового платежа " & objParamOut.Parameter("PaymentGroupSum") & ". Продолжить ввод?", vbYesNo + vbQuestion + vbDefaultButton1, "Проверка суммы платежа") = vbYes Then
                Exit Sub
            End If
        End If
    End If
    '================================================================

    If Not CBool(m_blnSave) Then
        Parent.CloseWindow NumWin
    End If
End Sub

'------------испорчено Кирсанова Е.В. 06.10.2005 Вместо кнопки "Новая карточка"
'
Private Function NewRecord()
    btnSave.Enabled = True
    btnClient.Enabled = True
    btnContract.Enabled = True
    btnCalc.Enabled = True
    'btnNew.Enabled = False
    cb_ThirdPerson.Enabled = False
    cb_ThirdPerson.Value = 0
    cmdCashSymb.Enabled = True 'False
    objParamIn.Parameter("StrCommand") = "CLEAR"

'MsgBox "NewRecord"
    UbsChannel.Run "PAYMENT", objParamIn, objParamOut
    
    '---------------------------- Новопашин В.М. 14.08.2006 г. --------
    cmbPurpose.Clear
    cmbPurpose.Text = ""
    '------------------------------------------------------------------
    
    m_IdPayment = 0
    
    '----------------------- Новопашин В.М. 05.06.2006 ------------
    blnForward = True
    m_blnNoMessage = False
    '--------------------------------------------------------------

    Call InitDoc
    
    If IdGroupIncoming = 0 Then
        '01 февраля 2010 - клиента очищать не надо
        If Not blnAddClient Then
            Call clearRecFieldsSend
        End If
    End If
    Call clearRecFields

    If txtFIOPay.Enabled Then
       txtFIOPay.SetFocus
    End If
    
    arrCashSymb = Empty
    
    Call IsAutoPeriod
  
End Function

'Новопашин 02.06.2006
Private Function NewRecordCalc()
    btnSave.Enabled = True
    'btnSave.Enabled = False
    btnClient.Enabled = True
    btnContract.Enabled = True
    btnCalc.Enabled = True
    cmdCashSymb.Enabled = True 'False
    
    '---------------------------- Новопашин В.М. 17.07.2006 г. --------
    'm_IdClient = 0
    '------------------------------------------------------------------
    
    m_IdPayment = 0
    
    Call clearRecFields
    txtINNPay.Text = ""
    txtFIOPay.Text = ""
    txtAdressPay.Text = ""
    'If AccClientPay.Visible Then
    If AccClientPayVisible Then
        AccClientPay.Text = "00000000000000000000"
    End If
    txtInfoClient.Text = "" '2009

    If txtFIOPay.Enabled Then
       txtFIOPay.SetFocus
    End If
  
End Function



' НАЖАТИЕ КНОПКИ "СОХРАНИТЬ"
'
Private Sub btnSave_Click()
    Dim strGroupMess As String, strKbk As String, strKbkSymbol As String
    Dim IdCurrency As Long
    Dim blnIsAskEdit As Boolean
    Dim RSChange As Variant, i As Integer
    Dim dDateBeg As Date, dDateEnd As Date
    Dim isNalog As Boolean
 
 On Error GoTo ErrorCode
    
'MsgBox "00 "

    m_blnNoMessage = True
    isNalog = False

    UbsDDX.UpdateData True

    Dim objParamInTemp, objParamOutTemp, temploadRes
    Set objParamInTemp = CreateObject("ToolPubs.IUbsParam")
    Set objParamOutTemp = CreateObject("ToolPubs.IUbsParam")
    
    If (txtINNPay.Text <> "") Then
        If (txtINNPay.Text <> "0") Then
            If Not CheckKeyInn(txtINNPay.Text) Then
                MsgBox "Проверка контрольного числа в ИНН плательщика <" & txtINNPay.Text & "> не пройдена!", vbCritical, "Прием платежа"
                Exit Sub
            End If
        End If
    End If
    
    If (txtINN.Text <> "") Then
        If Not CheckKeyInn(txtINN.Text) Then
            MsgBox "Проверка контрольного числа в ИНН получателя <" & txtINN.Text & "> не пройдена!", vbCritical, "Прием платежа"
            Exit Sub
        End If
    End If

    If FoSettingValue > -1 Then objParamIn.Parameter("FROMFO") = FoSettingValue
            
    ' ???
    UbsChannel.Run "PS_UserIsCashier", objParamIn, objParamOut
    
    If objParamOut.Parameter("StrError") <> "" Then
        m_blnSave = False: btnExit.Enabled = True
        MsgBox objParamOut.Parameter("StrError"), vbCritical, "Прием платежа"
        Exit Sub
    End If

    If objParamOut.Parameter("NotCashier") Then
        m_blnSave = False: btnExit.Enabled = True
         MsgBox "Текущий пользователь не является кассиром !!!", vbCritical, "Приём платежа"
        btnExit_Click
        Exit Sub
    End If
    
    If (objParamOut.Parameter("bRet") = True) Then
        blnCashier = False
    Else
        blnCashier = True
    End If
    
    If (tb_NumFolder.Text = "") And calledFromFrontOffice Then
    
        MsgBox "Поле 'Номер пачки' должно быть заполнено!", vbCritical, "Прием платежа"
        Exit Sub
    
    End If
    
    ' (103623)
    If Trim(txt_ThirdPersonName.Text) <> "" Then
        If txt_ThirdPersonInn.Text = "" Or txt_ThirdPersonInn.Text = "0" Then
            MsgBox "Поле 'ИНН' третьего лица должно быть заполнено!", vbCritical, "Прием платежа"
            Exit Sub
        End If
    End If
                    
    If subPayment.Tabs(TAB_TAX).Visible Then
        If txtReasonNalog.Text = "ТП" Or txtReasonNalog.Text = "ЗД" Then
            txtNomerNalog.Text = "0"
        Else
            If m_IdClient <> 0 Then
                If Trim(txtINNPay.Text) = "" Or Trim(txtINNPay.Text) = "0" Then
                    If Trim(txtNomerNalog.Text) = "" Or Trim(txtNomerNalog.Text) = "0" Then
                        objParamInTemp.Parameter("idClient") = m_IdClient
                    
                        UbsChannel.Run "GetNalogNumber", objParamInTemp, objParamOutTemp
    
                        txtNomerNalog.Text = CStr(objParamOutTemp.Parameter("NalogNumber"))
                    End If
                End If
            End If
        End If
        
        ' (83321)
        If Len(Trim(txtKBKNalog.Text)) > 0 Then
            objParamInTemp.Parameter("КБК") = txtKBKNalog.Text
            UbsChannel.Run "CheckKBK", objParamInTemp, objParamOutTemp
            isNalog = CBool(objParamOutTemp.Parameter("isNalog"))
            If isNalog Then
                
                objParamInTemp.Parameter("Field108") = txtNomerNalog.Text
                objParamInTemp.Parameter("IdClient") = m_IdClient
                objParamInTemp.Parameter("Guest") = blnGuest
                UbsChannel.Run "CheckRegex108Field", objParamInTemp, objParamOutTemp
                
                If (Len(Trim(txtINNPay.Text)) = 0 Or Trim(txtINNPay.Text) = "0") And objParamOutTemp.Parameter("Result") = False Then
                    MsgBox "Для налоговых платежей обязателен ИНН плательщика!", vbCritical, "Приём платежа"
                    m_blnSave = False
                    Call ButtEnabled(True)
                    subPayment.Tabs(TAB_GENERAL).Selected = True
                    If txtINNPay.Visible And txtINNPay.Enabled Then txtINNPay.SetFocus
                    Exit Sub
                End If
            End If
        End If
    End If
    
    'Проверки реквизитов третьего лица
    If cb_ThirdPerson.Value = 1 Then
        If txt_ThirdPersonName.Text = "" Then
            MsgBox "Не заполнено поле 'Наименование третьего лица'!", vbCritical, "Приём платежа"
            m_blnSave = False
            Call ButtEnabled(True)
            Exit Sub
        End If
        Select Case cmb_ThirdPersonKind.ListIndex
            Case 0
                If txt_ThirdPersonInn.Text = "0" Or Len(txt_ThirdPersonInn.Text) <> 12 Then
                    MsgBox "Некорректно заполнено поле 'ИНН' (вкладка 'Сведения о третьем лице'): ИНН должен состоять из 12 символов!", vbCritical, "Приём платежа"
                    m_blnSave = False
                    Call ButtEnabled(True)
                    Exit Sub
                End If
            Case 1
                If txt_ThirdPersonInn.Text <> "0" And Len(txt_ThirdPersonInn.Text) <> 12 Then
                    MsgBox "Некорректно заполнено поле 'ИНН' (вкладка 'Сведения о третьем лице'): ИНН должен состоять из 12 символов или ИНН должен быть равен 0!", vbCritical, "Приём платежа"
                    m_blnSave = False
                    Call ButtEnabled(True)
                    Exit Sub
                End If
            Case 2
                If txt_ThirdPersonInn.Text = "0" Or Len(txt_ThirdPersonInn.Text) <> 10 Then
                    MsgBox "Некорректно заполнено поле 'ИНН' (вкладка 'Сведения о третьем лице'): ИНН юр. лица должен состоять из 10 символов!", vbCritical, "Приём платежа"
                    m_blnSave = False
                    Call ButtEnabled(True)
                    Exit Sub
                End If
                If txt_ThirdPersonKpp.Text = "0" Or Len(txt_ThirdPersonKpp.Text) <> 9 Then
                    MsgBox "Некорректно заполнено поле 'КПП' (вкладка 'Сведения о третьем лице'): КПП должен состоять из 9 символов!", vbCritical, "Приём платежа"
                    m_blnSave = False
                    Call ButtEnabled(True)
                    Exit Sub
                End If
        End Select
    End If

    ' сохраним старые значения
    m_OldtxtFIOPay = txtFIOPay.Text
    m_OldtxtINNPay = txtINNPay.Text
    m_OldtxtAdressPay = txtAdressPay.Text
    m_OldtxtInfoClient = txtInfoClient.Text

    m_blnSave = True
    Call ButtEnabled(False)
        
    '=========== Удалить документы и движение ценностей (если есть, для режима повторного редактирования) =========
    If blnStopPrint Then
        objParamIn.Parameter("IdPayment") = m_IdPayment
        UbsChannel.Run "DeleteDocForm", objParamIn, objParamOut
    End If
    '==============================================================================================================
    If Trim(cmbPurpose.Text) = "" Then
       MsgBox "Не заполнено назначение платежа!!!", vbCritical, "Приём платежа"
        m_blnSave = False
       Call ButtEnabled(True)
       Exit Sub
    End If
    If 210 - Len(cmbPurpose.Text) < 0 Then
       MsgBox "Назначение платежа не может содержать более 210 символов!", vbCritical, "Приём платежа"
        m_blnSave = False
       Call ButtEnabled(True)
       Exit Sub
    End If
    If 160 - Len(txtRecip.Text) < 0 Then
       MsgBox "Наименование получателя не может содержать более 160 символов!", vbCritical, "Приём платежа"
        m_blnSave = False
       Call ButtEnabled(True)
       Exit Sub
    End If
    If subPayment.Tabs(TAB_TAX).Visible Then
        If Trim(txtINN.Text) = "" Or Trim(txtINN.Text) = "0" Then
            MsgBox "Для налоговых платежей обязательно заполнение поля ИНН!!!", vbCritical, "Приём платежа"
            m_blnSave = False
            Call ButtEnabled(True)
            Exit Sub
        End If
        objParamIn.Parameter("Статус составителя") = txtStatusNalog.Text
        objParamIn.Parameter("Код бюджетной классификации") = txtKBKNalog.Text
        objParamIn.Parameter("Код ОКАТО") = txtOKATONalog.Text
        objParamIn.Parameter("Основание налогового платежа") = txtReasonNalog.Text
        objParamIn.Parameter("Налоговый период") = txtPeriodNalog.Text
        objParamIn.Parameter("Номер налогового документа") = txtNomerNalog.Text
        objParamIn.Parameter("Дата налогового документа") = txtDateNalog.Text
        objParamIn.Parameter("Тип налогового платежа") = txTypeNalog.Text
        objParamIn.Parameter("ИМНС") = txtIMNSNalog.Text
        objParamIn.Parameter("КППУ") = Trim(txtKppu.Text)
        'Сохранение налоговых полей в доп. полях
        UbsChannel.Run "NalogAddFieldSave", objParamIn, objParamOut
        AddProperties.Refresh
    End If
        
    'Если ФИО, ИНН и адрес плательщика пустые, то обнуляем ссылку на id клиента
    If (Len(Trim(txtFIOPay.Text)) = 0 And Len(Trim(txtINNPay.Text)) = 0 And Len(Trim(txtAdressPay)) = 0) Or (Not CheckPayer(True)) Then
       
        m_IdClient = 0
        lblFindFilter.Visible = False
        btnFindFilter.Visible = False
    End If

    If CBool(m_blnSave) Then
        ' проверки
        If Not CheckPayment Then
            m_blnSave = False
            Call ButtEnabled(True)
            Exit Sub
        End If

        If Not CheckAccPayment Then
            m_blnSave = False
            Call ButtEnabled(True)
            Exit Sub
        End If
           
        'При проверке в некоторых случаях кнопка сохранить раздизыйбливается, поэтому еще раз дизэйблим
        Call ButtEnabled(False)
       
        m_blnClickSave = True

        ' расчет комиссии
        prefCalcRate = "_1 0"
        'If curSumma.Enabled Then
                If StrCommand <> "CHANGE_PART" And StrCommand <> "GROUP_CHANGE" And StrCommand <> "CHANGE_PART_INCOMING" Then
            If Not CalcSumCommiss Then
               m_blnClickSave = False
               m_blnSave = False
               Call ButtEnabled(True)
               Exit Sub
            End If
        End If
        
        m_blnClickSave = False

        ' расчет НДС
       If Not CalcSumNDS Then
           m_blnClickSave = False
           m_blnSave = False
           Call ButtEnabled(True)
           Exit Sub
       End If

        Set objParamIn = CreateObject("ToolPubs.IUbsParam")
        Set objParamOut = CreateObject("ToolPubs.IUbsParam")
        
        objParamIn.Parameter("FROMFO") = calledFromFrontOffice
                
        ' ???
        blnControlSum = False
        objParamIn.ClearParameters
        objParamOut.ClearParameters
        objParamIn.Parameter("BicExtBank") = txtBic.Text
        objParamIn.Parameter("Account_R") = AccClient.Text
        UbsChannel.Run "PS_GetSummaControl", objParamIn, objParamOut
        If objParamOut.Parameter("Внутренний документ") Then
            objParamIn.Parameter("NeedControl") = False
            blnControlSum = False
        Else
            If objParamOut.Parameter("SumControl") = 0 Then
                objParamIn.Parameter("NeedControl") = False
                blnControlSum = False
            ElseIf curSumma.CurrencyValue > objParamOut.Parameter("SumControl") Then
                MsgBox "Сумма платежа превышает допустимую, требуется дополнительный контроль", vbInformation, "Приём платежа"
                objParamIn.Parameter("NeedControl") = True
                blnControlSum = True
            Else
                objParamIn.Parameter("NeedControl") = False
                blnControlSum = False
            End If
        End If
        
        ' состояние платежа
        '
        ' (64147) для Изменить состояние платежа останется прежним
        If StrCommand_Source <> "CHANGE_PART" Then
            objParamIn.Parameter("IsCashier") = blnCashier
            objParamIn.Parameter("IdContract") = m_IdContract
            UbsChannel.Run "PS_GetState", objParamIn, objParamOut
        
            objParamIn.Parameter("State") = objParamOut.Parameter("State")
        End If

        'Запуск пользовательской проверки перед сохранением
        If Not Ut_CheckUserBeforeSave Then
             m_blnSave = False
             Call ButtEnabled(True)
             Exit Sub
         End If
        m_blnClickSave = False
        m_blnCreateCashOrd = False
        UbsDDX.UpdateData True

        UbsDDX.MembersValue RSChange
        Dim ressql As Variant, name As String
        For i = 0 To UBound(RSChange, 2)
        
            Select Case RSChange(0, i)
                Case "IDCONTRACT"
                    objParamIn.Parameter(RSChange(0, i)) = m_IdContract
                Case Else
                    objParamIn.Parameter(RSChange(0, i)) = RSChange(1, i)
            End Select
        Next


        If txtYearBeg.Text <> "" And txtMonthBeg.Text <> "" And txtDayBeg.Text <> "" And txtYearEnd.Text <> "" And txtMonthEnd.Text <> "" And txtDayEnd.Text <> "" Then
           
            dDateBeg = DateSerial(CInt(txtYearBeg.Text), CInt(txtMonthBeg.Text), CInt(txtDayBeg.Text))
            dDateEnd = DateSerial(CInt(txtYearEnd.Text), CInt(txtMonthEnd.Text), CInt(txtDayEnd.Text))
            
            objParamIn.Parameter("DateBeg") = dDateBeg
            objParamIn.Parameter("DateEnd") = dDateEnd
        
        End If
        
        objParamIn.Parameter("IdContract") = m_IdContract
        objParamIn.Parameter("SummaRateRec") = m_curSumRateRec
        objParamIn.Parameter("SummaRec") = m_curSumRec
        objParamIn.Parameter("SummaNDSRec") = m_curSumNDSRec
        objParamIn.Parameter("SummaNDSSend") = m_curSumNDSSend
        objParamIn.Parameter("SummaNDSPaym") = m_curSumNDSPaym
        If CInt(Len(Trim(m_strCheckType))) = CInt(0) And CInt(Len(m_strCheckSum)) > CInt(0) Then
            m_strCheckType = "ключ сформирован автоматически"
        End If
        objParamIn.Parameter("SignCreateKey") = m_strCheckType

        objParamIn.Parameter("bIsPeriodEnable") = m_bIsPeriodEnable
        objParamIn.Parameter("RegNumber") = m_RegNumber
        objParamIn.Parameter("Address") = m_strAddress
        
        objParamIn.Parameter("AccCode") = m_strAccCode
        If m_IdPaymentDic <> 0 Then
            m_strCheckSum = txtCheckSum.Text
        End If
        objParamIn.Parameter("CheckSum") = m_strCheckSum
        
        objParamIn.Parameter("RecipientName") = txtRecip.Text
        If blnArbitrary Or blnEditRecip Then
            objParamIn.Parameter("RecipientName") = txtRecip.Text
        ElseIf txtRecip.Text = "" Then
            objParamIn.Parameter("RecipientName") = ""
        End If
        
        objParamIn.Parameter("Льготный клиент") = CheckBenefits.Value
        objParamIn.Parameter("Основание") = TextReason.Text
        
        'Передаём Id_Client во входных параметрах, для того чтобы можно было в отчете отобразить серия и номер паспорта клиента
        objParamIn.Parameter("blnGuest") = blnGuest
        objParamIn.Parameter("ID_CLIENT") = m_IdClient
        ' [16724] Нужно для подтверждения действий оператора
        ' Работаем только с клиентом, посетителя игнорим
        If Not blnGuest And m_IdClient > 0 Then _
            objParamIn.Parameter("Идентификатор клиента, инициирующего действие") = m_IdClient

        If lngCheckKSSymb Then
          Dim varCashSymbol As Variant
          
          If m_blnRegimCashSymb Then
            If txtKSPayment.Text <> "" Or txtKSRate.Text <> "" Or txtKSNDS.Text <> "" Then
               ReDim varCashSymbol(2, 0)
               varCashSymbol(0, 0) = txtKSPayment.Text
               varCashSymbol(1, 0) = txtKSRate.Text
               varCashSymbol(2, 0) = txtKSNDS.Text
               objParamIn.Parameter("Кассовые символа") = varCashSymbol
            End If
          End If
        End If

        If IsArray(arrCashSymb) Then
            objParamIn.Parameter("Массив кассовых символов") = arrCashSymb
            If txtKSRate.Text <> "" Or txtKSNDS.Text <> "" Then
               ReDim varCashSymbol(2, 0)
               varCashSymbol(0, 0) = ""
               varCashSymbol(1, 0) = txtKSRate.Text
               varCashSymbol(2, 0) = txtKSNDS.Text
               objParamIn.Parameter("Кассовые символа") = varCashSymbol
            End If
        End If
            
        If AccPay.Enabled And m_IdPaymentDic = 0 Then
            If Trim(m_strAccCode) = "" Then
                MsgBox "Лицевой счет плательщика не может быть пустым!", 16, m_strCaptionForm
                m_blnSave = False
                btnExit.Enabled = True
                Exit Sub
            End If
        End If
        If txtCheckSum.Visible Then
            If Trim(m_strCheckSum) = "" Then
                MsgBox "Ключ л/с плательщика не может быть пустым!", 16, m_strCaptionForm
                m_blnSave = False
                btnExit.Enabled = True
                Exit Sub
            End If
        End If
        
        Select Case m_SIDPattern
        Case "UBS_UT_ENERGY"
            objParamIn.Parameter("IdTariff") = cmbTariff.ItemData(cmbTariff.ListIndex)
        Case "UBS_UT_PHONE", "UBS_UT_PHONE_ACC"
            objParamIn.Parameter("IdPhone") = cmbPhone.ItemData(cmbPhone.ListIndex)
        End Select
        objParamIn.Parameter("Purpose") = cmbPurpose.Text
        
        'сохраняем
        objParamIn.Parameter("StrCommand") = "ADD"
       
        'Команда на входе
        objParamIn.Parameter("COMMANDIN") = StrCommand
        
        If blnPenyPresent Then
            objParamIn.Parameter("SUMMAPENI") = curPeny.CurrencyValue
        Else
            objParamIn.Parameter("SUMMAPENI") = 0
        End If
        
        If AccClientPayVisible Then
            objParamIn.Parameter("AccClientPay") = AccClientPay.Text
        End If
        
        If blnGroup Then
            If m_IdGroup = 0 Then
                Call UbsChannel.Run("UTGetNewPaymGroupID", objParamIn, objParamOut)
                m_IdGroup = objParamOut.Parameter("PAYMENTGROUPID")
            End If
            objParamIn.Parameter("PAYMENTGROUPID") = m_IdGroup
        End If
        
        'Если клиент задан, то выполняется проверка ИПДЛ
        If m_IdClient <> 0 Then
            If Not CheckIPDL() Then
                MsgBox "Проверка ИПДЛ, сохранение запрещено!", 16, m_strCaptionForm
                m_blnSave = False
                Call ButtEnabled(True)
                Exit Sub
            Else
                objParamIn.Parameter("blnIPDL") = blnIPDL
            End If
        End If
        
        
        If subPayment.Tabs(TAB_TAX).Visible And blnSecondPayment = 2 Then
            m_IdContractSecond = 0
            
            objParamIn.Parameter("SummaRateSend") = 0
            objParamIn.Parameter("SummaNDSSend") = 0
            curSummaRateSend.CurrencyValue = 0
            lblNalog.Visible = False
        End If

        If m_IdContractSecond > 0 Then
            objParamIn.Parameter("IdContractSecond") = m_IdContractSecond
            objParamIn.Parameter("Кассовые символа дополнительный платеж") = arrCashSymbSecond
        End If
        
        If m_IdPaymentDic <> 0 Then
             objParamIn.Parameter("IdPaymentDic") = True 'm_IdPaymentDic
        End If

        If IdGroupIncoming > 0 Then
            objParamIn.Parameter("IdGroupIncoming") = IdGroupIncoming
        End If

        objParamIn.Parameter("blnTerror") = blnTerror
        
        
        ' (1805)
        If cb_ThirdPerson.Value = 1 Then
            objParamIn.Parameter("ThirdPerson_Name") = txt_ThirdPersonName.Text
            objParamIn.Parameter("ThirdPerson_Kind") = cmb_ThirdPersonKind.ListIndex
            objParamIn.Parameter("ThirdPerson_INN") = txt_ThirdPersonInn.Text
            objParamIn.Parameter("ThirdPerson_KPP") = txt_ThirdPersonKpp.Text
        End If
        
        If subPayment.Tabs(TAB_TAX).Visible Then
            objParamIn.Parameter("Статус составителя") = txtStatusNalog.Text
            objParamIn.Parameter("Код бюджетной классификации") = txtKBKNalog.Text
            objParamIn.Parameter("Код ОКАТО") = txtOKATONalog.Text
            objParamIn.Parameter("Основание налогового платежа") = txtReasonNalog.Text
            objParamIn.Parameter("Налоговый период") = txtPeriodNalog.Text
            objParamIn.Parameter("Номер налогового документа") = txtNomerNalog.Text
            objParamIn.Parameter("Дата налогового документа") = txtDateNalog.Text
            objParamIn.Parameter("Тип налогового платежа") = txTypeNalog.Text
            objParamIn.Parameter("ИМНС") = txtIMNSNalog.Text
            objParamIn.Parameter("КППУ") = Trim(txtKppu.Text)
        End If
        
        
        '===================================
        
        ' проверка действий
        If Not objUbsCheck.SystemCheckAction(UbsChannel, objParamIn, "PS", SidAction, "Прием платежа") Then
            m_blnSave = False
            Call ButtEnabled(True)
            Exit Sub
        End If
        
        If (Len(Trim(txtKppu.Text)) > 0) Then objParamIn.Parameter("КППУ") = Trim(txtKppu.Text)
               
        ' (64147)
        objParamIn.Parameter("StrCommand_Source") = StrCommand_Source
               
        ' (84314)  для правильного формирования поля "Идентификатор плательщика" при первых символах КБК = "182"
        objParamIn.Parameter("txtINNPay") = txtINNPay.Text
        
        ' (1805) перенесено выше, чтобы попало в параметры проверки действия
        'If cb_ThirdPerson.Value = 1 Then
        '    objParamIn.Parameter("ThirdPerson_Name") = txt_ThirdPersonName.Text
        '    objParamIn.Parameter("ThirdPerson_Kind") = cmb_ThirdPersonKind.ListIndex
        '    objParamIn.Parameter("ThirdPerson_INN") = txt_ThirdPersonInn.Text
        '    objParamIn.Parameter("ThirdPerson_KPP") = txt_ThirdPersonKpp.Text
        'End If
        
        If calledFromFrontOffice Then
            objParamIn.Parameter("CalledFromFrontOffice") = 1
            objParamIn.Parameter("Номер пачки") = tb_NumFolder.Text
            If (tb_NumFolder.Text = "") Then MsgBox "Поле 'Номер пачки' должно быть заполнено!", vbOKOnly, "Прием платежа"
        End If
        
        If fromFoAsClient <> -1 Then objParamIn.Parameter("fromFoAsClient") = fromFoAsClient
        ' ***********************************************
        ' СОХРАНЕНИЕ ПЛАТЕЖА  (VBD\PS\UT\UtPaymentF.vbs)
        UbsChannel.Run "Payment_Save", objParamIn, objParamOut
        ' ***********************************************

        ' сохранение сумм платежа
        If Len(objParamOut.Parameter("StrError")) = 0 Then
            UbsDDX.SetInitMemberData
            bNeedRefreshGrid = True
            Info.Caption = "Платеж сохранен в БД"
            Info.Show
            
            If Not blnGroup Then
                If StrCommand <> "CHANGE_PART" Then
                    countPaper = countPaper + 1
                    txtQttySubs.Text = CStr(countPaper)
                    sumCommonSumma = curSumma.CurrencyValue
                    sumTotalSumma = curSummaTotal.CurrencyValue
                    curCommonSumma.CurrencyValue = curCommonSumma.CurrencyValue + sumCommonSumma
                    curTotalSumma.CurrencyValue = curTotalSumma.CurrencyValue + sumTotalSumma
                Else
                    txtQttySubs.Text = CStr(countPaper)
                    curCommonSumma.CurrencyValue = curCommonSumma.CurrencyValue
                    curTotalSumma.CurrencyValue = curTotalSumma.CurrencyValue
                End If
            End If
            
            ' blnStopPrint - был откат приходников и откат движения ценностей
            If (StrCommand = "ADD" Or blnStopPrint) And blnControlSum = False Then
                m_IdPayment = objParamOut.Parameter("IdPaym")
                
                If Not calledFromFrontOffice Then
                    'Режим двойного создания платежа
                    objParamIn.Parameter("ID_DOUBLE_PAYMENT") = objParamOut.Parameter("ID_DOUBLE_PAYMENT")
                    m_arrSecondPaym = objParamOut.Parameter("ID_DOUBLE_PAYMENT")
    
                    'Для групповых платежей, в режиме формирования кассовых ордеров при
                    'приеме платежа, производим формирование кассовых ордеров
                    'после сохранения всех платежей в БД
                    If Not blnGroup And ((AccClientPay.Text = "") Or (AccClientPay.Text = "00000000000000000000")) _
                    Then
                       ' ***********************
                       ' движение остатков по кассиру (если пользователь = кассир)
                       Call objParamIn.ClearParameters
                       Call objParamOut.ClearParameters
                       objParamIn.Parameter("Sum") = curSummaTotal.CurrencyValue
                       
                       UbsChannel.Run "UTIsMoveValByAccountA", objParamIn, objParamOut
                       
                       If objParamOut.Parameter("Error") <> "" Then
                           MsgBox objParamOut.Parameter("Error"), vbOKOnly, "Прием платежа"
                           Exit Sub
                       End If
                       ' ***********************
    
                        ' ***********************************************
                        ' СОЗДАНИЕ ПРИХ. КАСС. ОРДЕРОВ
                        Call CreateCashOrd
                        ' ***********************************************
                    End If
            
                    m_blnCreateCashOrd = frmCashOrd.blnCreate
    
                    If m_blnCreateCashOrd = True Then
                        frmCashOrd.blnCreate = False
                        m_blnCreateCashOrd = False
                    End If
                    
                    
                    If blnGroup Then
                        blnOldGroupID = m_IdGroup
                        Call UpdateGroupInfo
                     
                        strGroupMess = "Введено " & txtQttySubs.Text & " платежей на общую сумму " & curTotalSumma.CurrencyValue & " руб." & vbCr & "Вы хотите продолжить ввод платежей в группу?"
        
                        ' If = vbNo
                        If MsgBox(strGroupMess, vbDefaultButton1 + vbApplicationModal + vbQuestion + vbYesNo, "Ввод группы платежей") = vbNo Then
                            ' ***********************
                            ' движение остатков по кассиру (если пользователь = кассир)
                            Call objParamIn.ClearParameters
                            Call objParamOut.ClearParameters
                            objParamIn.Parameter("Sum") = curTotalSumma.CurrencyValue  ' (83505) - была не та сумма (не общая, а последнего платежа)
                            objParamIn.Parameter("IdGroup") = m_IdGroup  ' (83505)
                            
                            UbsChannel.Run "UTIsMoveValByAccountA", objParamIn, objParamOut
                            
                            If objParamOut.Parameter("Error") <> "" Then
                                MsgBox objParamOut.Parameter("Error"), vbOKOnly, "Прием платежа"
                                Exit Sub
                            End If
                            ' ***********************
                            
                            ' Для групповых платежей, в режиме формирования кассовых ордеров при
                            ' приеме платежа, производим формирование кассовых ордеров
                            ' после сохранения всех платежей в БД
                            objParamIn.Parameter("PAYMENTGROUPID") = m_IdGroup
                            ' ***********************************************
                            ' Групповой - СОЗДАНИЕ ПРИХ. КАСС. ОРДЕРОВ
                            Call CreateCashOrd  ' 111
                            ' ***********************************************
            
                            m_IdGroup = 0
                            Call UpdateGroupInfo
                        End If  ' If = vbNo
                    End If
    
                    If IdGroupIncoming > 0 Then
                        Call UpdateGroupInfo
                    End If
                    
                    objParamIn.ClearParameters
                    objParamOut.ClearParameters
                    
                    objParamIn.Parameter("blnTerror") = blnTerror
                    objParamIn.Parameter("IdPayment") = m_IdPayment
                    objParamIn.Parameter("IdContract") = m_IdContract
                    If m_IdContractSecond <> 0 Then
                        objParamIn.Parameter("arrSecondPaym") = m_arrSecondPaym
                        'Если режим создания двух платежей использовать другую функцию
                        UbsChannel.Run "UtGetDoublePaymentsPlatDocExt_Form", objParamIn, objParamOut
                    Else
                        UbsChannel.Run "UtGetPaymentsPlatDocExt_Form", objParamIn, objParamOut
                    End If
                                    
                    If objParamOut.Parameter("StrError") <> "" Then
                        MsgBox objParamOut.Parameter("StrError"), vbCritical, "Подготовка внешних документов"
                    End If
                     
                    blnIsAskEdit = False
                       
                    If chkPrintForm.Visible Then
                        If chkPrintForm.Value = 1 Then
                            m_blnIsFrmPrn = True
                        Else
                            m_blnIsFrmPrn = False
                        End If
                    End If
                End If
                '-------------------------------------------
                'Дизэйблим все кнопки при вызове печатной формы
                If m_blnIsFrmPrn And IdGroupIncoming = 0 Then
                    ' ============================================
                    ' вызов ПЕЧАТНЫХ ФОРМ (клиентский сценарий)
                    ' ============================================
                    Dim objScript1 As Object, varArr(0) As Variant
                    varArr(0) = m_IdPayment
                    Set objScript1 = CreateObject("URunScr.IUbsRunScript")
                    objScript1.UbsChannel = UbsChannel
                    objScript1.Parameter("Parent") = Parent
                    objScript1.Parameter("Key") = varArr
                    
                    objScript1.Parameter("NameSection") = "Оплата услуг"
                    
                    objScript1.LoadFiles "UBS_VBS\PS\PsPrintForm.vbs"
                    objScript1.ExecuteScript
                    objScript1.ReleaseUbsChannel
                    
                    blnIsAskEdit = objScript1.Parameter("IsAskEdit")
                    
                    Set objScript1 = Nothing

                    If blnIsAskEdit Then
                        objParamIn.ClearParameters
                        objParamOut.ClearParameters
                        UbsChannel.Run "IsAskEdit", objParamIn, objParamOut

                        If objParamOut.ExistParameter("EditPaym") Then
                            If Not MsgBox("Вернуться к редактированию?", vbYesNo + vbQuestion + vbDefaultButton2, "Проверка корректности данных") = vbNo Then
                        
                                m_blnSave = False
                                Call ButtEnabled(True)

                                StrCommand = "CHANGE_PART"
                                StrCommand_Source = "CHANGE_PART"
                                blnStopPrint = True
                                m_blnNoMessage = False
                                InitDoc
                                Exit Sub
                            End If
                        End If
                    End If
                End If

                If (blnCashier And IdGroupIncoming = 0) Then
                    ' печатаем платеж НА ФИСКАЛЬНОМ РЕГИСТРАТОРЕ!
                    ' ===========================================
                    If (CBool(m_blnIsFR) And (Not blnGroup)) Or (CBool(m_blnIsFR) And blnGroup And (m_IdGroup = 0) And (blnOldGroupID <> 0)) Then
                        objParamIn.ClearParameters
                        objParamOut.ClearParameters
                        'Проверяем, что фискальный регистратор доступен
                        If Not CheckStateFR() Then
                            m_blnSave = False: btnExit.Enabled = True
                            MsgBox "Разрыв связи с фискальным регистратором", vbCritical, "Приём платежа"
                            Exit Sub
                        End If
                        objParamIn.Parameter("objDevice") = objDevice
                        objParamIn.Parameter("nIdPayment") = m_IdPayment
                        objParamIn.Parameter("bIsFR") = m_blnIsFR
                        If blnGroup Then
                            objParamIn.Parameter("nPaymentGroupId") = blnOldGroupID
                            objParamIn.Parameter("nPaymentGroupQtty") = CLng(txtQttySubs.Text)
                            objParamIn.Parameter("nPaymentGroupSUMMA") = curCommonSumma.CurrencyValue
                            objParamIn.Parameter("nPaymentGroupTOTAL") = curTotalSumma.CurrencyValue
                        End If
                    
                        objParamIn.Parameter("curSUMMAPENI") = curPeny.CurrencyValue
                        If m_IdContractSecond <> 0 Then
                            objParamIn.Parameter("arrSecondPaym") = m_arrSecondPaym
                            'Если режим создания двух платежей использовать другую функцию
                            objScript.Run "FormDoublePrintPayment", objParamIn, objParamOut
                        Else
                            objScript.Run "FormPrintPayment", objParamIn, objParamOut
                        End If
                    
                        If Not CBool(objParamOut.Parameter("bRetVal")) Then
                            MsgBox objParamOut.Parameter("StrError"), 16, "Печать на ФР. " & m_strCaptionForm
                            m_blnSave = False
                            btnExit.Enabled = True
                            Exit Sub
                        End If
                    End If  ' If (CBool(m_blnIsFR)
                End If  ' If (blnCashier And IdGroupI
             
            End If  ' If (StrCommand = "ADD"
        Else
            MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
            Info.Caption = objParamOut.Parameter("StrError")
            Info.Show
            Call ButtEnabled(True)
            m_blnSave = False
            Exit Sub
        End If  ' If(Len(...))


        '=====================================================================
        'Пользовательский сценарий
        If (Not blnGroup) Or (blnGroup And m_IdGroup = 0 And blnOldGroupID <> 0) Then
            objParamIn.ClearParameters
            objParamOut.ClearParameters
             objParamIn.Parameter("IdPayment") = m_IdPayment
             If IdGroupIncoming > 0 Then
                 objParamIn.Parameter("blnGroup") = True
             Else
                 objParamIn.Parameter("blnGroup") = blnGroup
             End If
             UbsChannel.Run "RunScrFromSetting", objParamIn, objParamOut
             If Len(Trim(objParamOut.Parameter("StrError"))) > 0 Then
                 'm_blnSave = False: btnExit.Enabled = True
                 MsgBox objParamOut.Parameter("StrError"), vbCritical, "Приём платежа"
                 NewRecord
                 Exit Sub
             End If
        End If
        '=======================================================================
              
              
        '========= завершение и проверка группового платежа   ==========
        If IdGroupIncoming > 0 Then
            objParamIn.Parameter("IdGroupIncoming") = IdGroupIncoming
            objParamIn.Parameter("IdPaym") = objParamOut.Parameter("IdPaym")
            objParamIn.Parameter("curCommonSumma") = curCommonSumma.CurrencyValue

            UbsChannel.Run "CheckOrEndGroup", objParamIn, objParamOut
            If objParamOut.Parameter("Type") = 1 Then
                Dim objScriptGr As Object, varArrGr(0) As Variant
                varArrGr(0) = objParamOut.Parameter("IdPaymentGroup")
                Set objScriptGr = CreateObject("URunScr.IUbsRunScript")
                objScriptGr.UbsChannel = UbsChannel
                objScriptGr.Parameter("Parent") = Parent
                objScriptGr.Parameter("Key") = varArrGr
                objScriptGr.Parameter("IsReception") = True

                objScriptGr.Parameter("ViewPrintForm") = m_blnIsFrmPrn
                objScriptGr.LoadFiles "UBS_VBS\PS\PaymentGroupEnd.vbs"
                objScriptGr.ExecuteScript
                objScriptGr.ReleaseUbsChannel
                Set objScriptGr = Nothing
                m_blnSave = False
                btnExit.Enabled = True
                btnExit_Click
                Exit Sub
            ElseIf objParamOut.Parameter("Type") = 2 Then
                If MsgBox("Сумма принятых платежей " & curCommonSumma.CurrencyValue & " больше суммы группового платежа " & objParamOut.Parameter("PaymentGroupSum") & ". Выход?", vbYesNo + vbQuestion + vbDefaultButton1, "Проверка суммы платежа") = vbYes Then
                    m_blnSave = False
                    btnExit.Enabled = True
                    btnExit_Click
                    Exit Sub
                End If
            End If
            
        End If
               
        btnExit.Enabled = True
        btnCalc.Enabled = True
        btnPattern.Enabled = True
        cmdCashSymb.Enabled = True
        chkPrintForm.Enabled = True
        
        btnClient.Enabled = False
        btnContract.Enabled = False
        subPayment.Tabs(TAB_GENERAL).Selected = True
        m_blnSave = False
        
        If StrCommand = "CHANGE_PART" Then
            txtQttySubs.Text = "0"
            curCommonSumma.CurrencyValue = CCur(0)
            curTotalSumma.CurrencyValue = CCur(0)
            txtGRPId = "0"
        
            m_IdGroup = 0
        End If
        
        StrCommand = "ADD"


        If objScript Is Nothing Then
            m_IdPayment = 0
            
            objStub.ReleaseUbsChannel
            Set objStub = Nothing
            
            Initialize
            StrCommand = "ADD"
            m_IdClient = 0 '28 июля 2009г
            lblFindFilter.Visible = False
            btnFindFilter.Visible = False

            Call AddProcInit(False)
            
            curPeny.CurrencyValue = 0
        Else
            NewRecord
        End If
                
    End If
    
    If outerSystemInfo = True Then
        btnExit_Click
    End If
    
    Exit Sub
ErrorCode:
    m_blnSave = False
    Call ButtEnabled(True)
    objErr.UbsErrMsg "SaveBtn_Click", "ошибка выполнения"
End Sub

Sub ButtEnabled(p_Enabled As Boolean)
    btnExit.Enabled = p_Enabled
    btnSave.Enabled = p_Enabled
    btnCalc.Enabled = p_Enabled
    btnPattern.Enabled = p_Enabled
    cmdCashSymb.Enabled = p_Enabled
    chkPrintForm.Enabled = p_Enabled
End Sub

Private Sub curSumma_TextChange()
    Timer1.Enabled = False
    curSumma.ToolTipText = ""
    Timer1.Enabled = True
End Sub

' потеря фокуса с Кода договора
Private Sub txtCode_LostFocus()
    
   If txtComment.Text = "" Then Call FindContract
    
End Sub

