Private Sub CreateUserFormArray()
Dim lngI As Long
Dim lngJ As Long
Dim i As Long, j As Long
Dim lngQtty As Long, lngMode As Long, lngQ As Long
Dim objFieldList As Object
Dim arrArray As Variant
Dim varValue As Variant
Dim arrAddFields As Variant

On Error GoTo Err_

    ' сохранение значений контролов
    lngMode = 0
    
    ReDim arrArray(26) As Variant
    
    arrArray(0) = "txtFIOPay"
    arrArray(1) = "txtINNPay"
    arrArray(2) = "txtAdressPay"
    arrArray(3) = "txtCode"
    arrArray(4) = "txtBic"
    arrArray(5) = "AccClient"
    arrArray(6) = "txtINN"
    arrArray(7) = "cmbPurpose"
    arrArray(8) = "txtRecip"
    arrArray(9) = "txtKSPayment"
    arrArray(10) = "txtKSRate"
    arrArray(11) = "txtCodePayment"
    arrArray(12) = "curSumma"
    arrArray(13) = "txtDateBegin"
    arrArray(14) = "txtDateEnd"
    arrArray(15) = "AccPay"
    arrArray(16) = "txtCheckSum"
    arrArray(17) = "cmbTariff"
    arrArray(18) = "cmbPhone"
    arrArray(19) = "txtNote"
    arrArray(20) = "txtNameBank"
    arrArray(21) = "txtComment"
    arrArray(22) = "AccKorr"
    arrArray(23) = "curSummaRateSend"
    arrArray(24) = "curSummaTotal"
    arrArray(25) = "curPeny"
    arrArray(26) = "AccClientPay"

    lngQtty = UBound(arrArray)
    lngQ = 0
    For lngI = 0 To lngQtty
        
        varValue = Empty
        Select Case arrArray(lngI)
        
            Case "txtDateBegin":
            If txtYearBeg.Text <> "" Then
                varValue = DateSerial(CLng(txtYearBeg.Text), CLng(txtMonthBeg.Text), CLng(txtDayBeg.Text))
            End If
    
            Case "txtDateEnd":
            If txtYearEnd.Text <> "" Then
                varValue = DateSerial(CLng(txtYearEnd.Text), CLng(txtMonthEnd.Text), CLng(txtDayEnd.Text))
            End If
                
            Case Else
                Select Case TypeName(Controls(arrArray(lngI)))
                    Case "UbsControlMoney":
                        If Controls(arrArray(lngI)).CurrencyValue <> 0 Then
                            varValue = Controls(arrArray(lngI)).CurrencyValue
                        End If
                    Case "UbsControlDate":
                        If Controls(arrArray(lngI)).DateValue > DateSerial(1990, 1, 1) And Controls(arrArray(lngI)).DateValue < DateSerial(2222, 1, 1) Then
                            varValue = Controls(arrArray(lngI)).DateValue
                        End If
                        
                    Case Else:
                        If Len(Trim(Controls(arrArray(lngI)).Text)) > 0 Then
                            varValue = Controls(arrArray(lngI)).Text
                        End If
                End Select
        End Select

        If (VarType(varValue) <> vbEmpty) And (Len(arrArray(lngI)) > 0) Then
            If lngQ > 0 Then
                ReDim Preserve varUFArray(2, lngQ) As Variant
            Else
                ReDim varUFArray(2, lngQ) As Variant
            End If
            varUFArray(0, lngQ) = arrArray(lngI)
            varUFArray(1, lngQ) = varValue
            varUFArray(2, lngQ) = lngMode
            lngQ = lngQ + 1
        End If
        
    Next lngI
    
    ' сохранение переменных
    
    lngQtty = UBound(varUFArray, 2)
    
    If m_IdClient <> 0 Then
        
        lngMode = 1
        ReDim Preserve varUFArray(2, lngQtty + 1) As Variant
        lngQtty = lngQtty + 1
        varUFArray(0, lngQtty) = "IdClient"
        varUFArray(1, lngQtty) = m_IdClient
        varUFArray(2, lngQtty) = lngMode
    
    End If
    
    ' сохранение доп полей
    lngMode = 3
    lngQtty = UBound(varUFArray, 2)
    ReDim Preserve varUFArray(2, (lngQtty + AddProperties.PropertyCount)) As Variant
    lngQtty = lngQtty + 1
    If AddProperties.PropertyCount > 0 Then
        For lngI = 0 To AddProperties.PropertyCount - 1
            varUFArray(0, lngQtty + lngI) = AddProperties.PropertyByIndexName(lngI)
            varUFArray(1, lngQtty + lngI) = AddProperties.PropertyByIndex(lngI)
            varUFArray(2, lngQtty + lngI) = lngMode
        Next lngI
    End If
    
out_:
    Exit Sub
Err_:
    objErr.UbsErrMsg Err.Description, "CreateUserFormArray"
    Resume out_
End Sub



Private Sub CheckPeni(Optional in_Peni As Variant = Empty)
    lblPeny.Visible = blnPenyPresent
    curPeny.Visible = blnPenyPresent
    If Not IsEmpty(in_Peni) Then
        curPeny.CurrencyValue = in_Peni
    End If
End Sub

Private Function CheckPayer(in_Flag As Boolean)

    If in_Flag Then
        CheckPayer = False
        If (m_strFIOOld = txtFIOPay.Text) And (m_strAddressOld = txtAdressPay.Text) Then
            CheckPayer = True
        End If
    Else
        m_IdClientOld = m_IdClient
        m_strFIOOld = txtFIOPay.Text
        m_strAddressOld = txtAdressPay.Text
        m_strINNOld = txtINNPay.Text
        
        CheckPayer = True
    End If

End Function

Private Function IsCtrlEnabled(in_CtrlName As String)
On Error Resume Next
    IsCtrlEnabled = Controls(in_CtrlName).Enabled
    If Err <> 0 Then
        Err.Clear
    End If
On Error GoTo 0
End Function
'----------------------------------------------------
' 00.02.2007 - Потапов Д.А.
' заполняет контролы данными полученными с пользовательской формы инициализации
Private Sub FillControlsByPattern(arrRes As Variant)
Dim lngI As Long
Dim strName As String, strCode As String
Dim datDate As Date
Dim strCtrl As String
Dim varArr As Variant
Dim lngQtty As Long

    If IsArray(arrRes) Then

        ' часть, для определения служебных и первичных моментов на форме
        For lngI = 0 To UBound(arrRes, 2)
            Select Case arrRes(2, lngI)
                Case 0:
                    If arrRes(0, lngI) = "txtCode" Then
                        strName = "txtCode"
                        If IsCtrlEnabled(strName) Then
                            Controls(strName).Text = arrRes(1, lngI)
                            Call FindContract
                        End If
                        arrRes(0, lngI) = ""
                    End If
                Case 1:
                    If arrRes(0, lngI) = "IdClient" Then
                        m_IdClient = arrRes(1, lngI)
                    End If
                Case 2:
                    strCtrl = arrRes(1, lngI)
                Case 3:
                    If IsArray(varArr) Then
                        ReDim Preserve varArr(1, lngQtty + 1) As Variant
                    Else
                        ReDim varArr(1, 0) As Variant
                    End If
                    lngQtty = UBound(varArr, 2)
                    
                    varArr(0, lngQtty) = arrRes(0, lngI)
                    varArr(1, lngQtty) = arrRes(1, lngI)
                    
            End Select
        Next lngI
On Error Resume Next
        ' основная часть присвоения данных контролам
        For lngI = 0 To UBound(arrRes, 2)
            If arrRes(2, lngI) = 0 Then
                strName = arrRes(0, lngI)
                If Len(strName) > 0 Then
                    If IsCtrlEnabled(strName) Then
                        Select Case strName
                            Case "txtDateBegin":
                                datDate = arrRes(1, lngI)
                                txtDayBeg.Text = Day(datDate)
                                txtMonthBeg.Text = Month(datDate)
                                txtYearBeg.Text = Right(CStr(Year(datDate)), 2)
        
                            Case "txtDateEnd":
                                datDate = arrRes(1, lngI)
                                txtDayEnd.Text = CStr(Day(datDate))
                                txtMonthEnd.Text = CStr(Month(datDate))
                                txtYearEnd.Text = Right(CStr(Year(datDate)), 2)
                                
                            Case Else:
                                Select Case TypeName(Controls(strName))
                                    Case "UbsControlMoney":
                                        Controls(strName).CurrencyValue = arrRes(1, lngI)
                                    Case "UbsControlDate":
                                        Controls(strName).DateValue = arrRes(1, lngI)
                                    Case Else
                                        Controls(strName).Text = arrRes(1, lngI)
                                End Select
                        End Select
                        ' часть кода для отработки доп.кода, который надо вызвать сразу
                        ' после пристваения значения контролу
                        Select Case strName
                            Case "curSumma":
                                If m_IdContract > 0 Then
                                    prefCalcRate = "_2 0"
                                    Call CalcSumCommiss_2
                                End If
                        End Select
                    End If
                End If
            End If
        Next lngI
        
On Error GoTo 0
        If IsArray(varArr) Then
            objParamIn.ClearParameters
            objParamIn.Parameter("varAddFields") = varArr
            
            '=======================
            If m_SIDPattern = "UBS_UT_NALOG" Then
                'Если доп. поля невидимы
                Dim k As Integer
                For k = 0 To UBound(varArr, 2)
                    If varArr(0, k) = "Статус составителя" Then
                        txtStatusNalog.Text = varArr(1, k)
                    End If
                    If varArr(0, k) = "Код ОКАТО" Then
                        txtOKATONalog.Text = varArr(1, k)
                    End If
                    If varArr(0, k) = "Основание налогового платежа" Then
                        txtReasonNalog.Text = varArr(1, k)
                    End If
                    If varArr(0, k) = "Налоговый период" Then
                        txtPeriodNalog.Text = varArr(1, k)
                    End If
                    If varArr(0, k) = "Номер налогового документа" Then
                        txtNomerNalog.Text = varArr(1, k)
                    End If
                    If varArr(0, k) = "Дата налогового документа" Then
                        txtDateNalog.Text = varArr(1, k)
                    End If
                    If varArr(0, k) = "Тип налогового платежа" Then
                        txTypeNalog.Text = varArr(1, k)
                    End If
                    If varArr(0, k) = "ИМНС" Then
                        txtIMNSNalog.Text = varArr(1, k)
                    End If
                    'If varArr(0, k) = "Расшифровка КБК" Then
                    '    txtKBKNoteNalog.Text = varArr(1, k)
                    'End If
                    If varArr(0, k) = "Код бюджетной классификации" Then
                        txtKBKNalog.Text = varArr(1, k)
                    End If
                    If varArr(0, k) = "КППУ" Then
                        txtKppu.Text = varArr(1, k)
                    End If
                Next
            End If
            '=======================
            
            UbsChannel.Run "UtInitAddFields", objParamIn, objParamOut
            AddProperties.Refresh
        End If
        
        Call CheckPayer(False)
        
        If Not lngCheckKSSymb Then
            txtKSPayment.Text = ""
            txtKSRate.Text = ""
            txtKSNDS.Text = ""
        End If
        If Len(strCtrl) > 0 Then
            If IsCtrlEnabled(strCtrl) And Controls(strCtrl).Visible Then
                Controls(strCtrl).SetFocus
            End If
        End If
    End If

End Sub


' 00.02.2007 - Потапов Д.А.
' определяет или запускает пользовательскую форму инициализации
Private Sub DefineRunUserForm(in_Flag As Boolean)
Dim objScrRun As Object
Dim objPIn As Object, objPOut As Object
Dim arrRes As Variant
    

    Set objPIn = CreateObject("ToolPubs.IUbsParam")
    Set objPOut = CreateObject("ToolPubs.IUbsParam")
    Set objScrRun = CreateObject("URunScr.IUbsRunScript")
    
    objScrRun.UbsChannel = UbsChannel
     
    objScrRun.ParentWnd = UserDocument.hWnd
    objScrRun.Parameter("DocObj") = Parent
    objPIn.Parameter("DocHandle") = NumWin
    objPIn.Parameter("IdContract") = m_IdContract
    objPIn.Parameter("RunUserForm") = in_Flag
    objPIn.Parameter("InitArray") = varUFArray
    
    objScrRun.Read "UBS_VBD\PS\UT\UTPUFT.vbs"
    Call objScrRun.Run("CallingUserFormPattern", objPIn, objPOut)
    
    objScrRun.ReleaseUbsChannel
        
    btnPattern.Caption = objPOut.Parameter("ButtonCaption")
        
    If Not objPOut.Parameter("bRetVal") And Len(objPOut.Parameter("StrError")) > 0 Then
        MsgBox objPOut.Parameter("StrError"), vbCritical, "Ошибка"
    End If
    
    If StrCommand = "ADD" Then
        If in_Flag Then
            Call FillControlsByPattern(objPOut.Parameter("Results"))
        Else
            btnPattern.Visible = objPOut.Parameter("OptionOK")
        End If
    Else
        btnPattern.Visible = False
    End If
    
    Set objScrRun = Nothing
    Set objPIn = Nothing
    Set objPOut = Nothing
    
End Sub

Private Sub AccClient_LostFocus()
    
 On Error GoTo ErrorCode
   
 If Len(Trim(txtCode.Text)) = 0 And (Trim(txtBic.Text) <> "" Or (Trim(AccClient.Text) <> "" And AccClient.Text <> "00000000000000000000")) Then
 Dim recCount As Integer, idArr
 objParamIn.Parameter("BIC") = Trim(txtBic.Text)
 objParamIn.Parameter("ACC") = AccClient.Text
 
 '------------------------------------------------- Новопашин В.М. 19-05-2006 г.
 objParamIn.Parameter("INN") = txtINN.Text
 '------------------------------------------------------------------------------
 
 UbsChannel.Run "FindContrByBicAndAccount", objParamIn, objParamOut
 recCount = objParamOut.Parameter("RecCount")
 idArr = objParamOut.Parameter("IdArray")

 If recCount = 1 Then
    m_IdContract = idArr(0, 0)
    
    If m_IdContract > 0 Then
        FindContractbyId
    End If
    
    If blnForward Then
        If cmbPurpose.Enabled And cmbPurpose.Visible Then
           cmbPurpose.SetFocus
        ElseIf txtCodePayment.Enabled And txtCodePayment.Visible Then
           txtCodePayment.SetFocus
        ElseIf curSumma.Enabled And curSumma.Visible Then
           curSumma.SetFocus
        End If
    End If
    
 ElseIf recCount > 1 Then
    btnContract_Click
 ElseIf recCount = 0 Then
  m_IdContract = 0
  txtCode.Text = ""
 ' FindContractbyId
 End If
 
End If
   Exit Sub
ErrorCode:
    objErr.UbsErrMsg "AccClient_LostFocus", "ошибка выполнения"

End Sub

' при получении фокуса контролом подсветить (выделить) его данные
Private Sub AccPay_GotFocus()
    
 On Error GoTo ErrorCode
    
    AccPay.SelStart = 0
    AccPay.SelLength = Len(AccPay.Text)
    
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "AccPay_GotFocus", "ошибка выполнения"
End Sub

