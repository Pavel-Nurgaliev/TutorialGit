Private Sub UserDocument_Hide()
    On Error GoTo ErrorCode
  
    Set objErr = Nothing
    Set objInterfaces = Nothing
    Set objFormParam = Nothing
    Set objFocusCtrl = Nothing
    Set objArray = Nothing
    Set objParamIn = Nothing
   Set objParamOut = Nothing
    If Not bParentWindowClose And Parent.IsExistParam(NumParentWindow, "NeedRefreshGrid") = True Then
        Parent.ParamInfo(NumParentWindow, "NeedRefreshGrid") = bNeedRefreshGrid
    End If
    objStub.ReleaseUbsChannel
    Set objStub = Nothing
    UbsDDX.ReleaseControlData
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "UserDocument_Hide", "ошибка выполнения"
End Sub

Private Sub UserDocument_Initialize()
    Set objFormParam = CreateObject("ToolPubs.IUbsParam")
    Set objParamIn = CreateObject("ToolPubs.IUbsParam")
    Set objParamOut = CreateObject("ToolPubs.IUbsParam")
    ArrayParam()
End Sub

Private Sub Initialize()
    Set objErr = CreateObject("ToolPubs.IUbsError")
    Set objInterfaces = CreateObject("ToolPubs.Interfaces")
    Set objArray = CreateObject("Lib1.IUbsArray")
    Set objStub = CreateObject("UbsAddFiledsStub.IUbsAddFiledsStub")
End Sub


Private Sub InitDoc()
    Dim varState As Variant
    Dim i As Integer
    Dim lngIndex As Long
    Dim ressql As Variant, t As Variant
    Dim nIdOI As Integer, varExecutors As Variant

    'MsgBox "00"
    On Error GoTo ErrorCode

    idClient = 0
    idAcc = 0
    idKind = 0
    blnIsOurBik = False
    txtINN.Justify = 0
    txtBic.Justify = 0
    UbsDDX.InitControlData
    blnArbitrary = False

    UbsChannel.HostAddress = Parent.LoaderParamInfo(NumWin, "HostAddress")
    UbsChannel.UserGUID = Parent.LoaderParamInfo(NumWin, "GuidSession")
    UbsChannel.ParentHwnd = UserDocument.hWnd
    'для доп .полей
    Set objStub.UbsChannel = UbsChannel
        
    UbsDDX.InitMemberData(txtCode) = ""
    UbsDDX.InitMemberData(txtComment) = ""
    UbsDDX.InitMemberData(curPercentSend) = 0
    UbsDDX.InitMemberData(curPercentRec) = 0
    UbsDDX.InitMemberData(dateContract) = Now
    UbsChannel.LoadResource = "VBS:UBS_VBD\PS\Contract.vbs"

    'MsgBox "00-1"
    UbsChannel.Run "InitFormContract", objParamIn, objParamOut
    strOurBIK = objParamOut.Parameter("BIKBANK")
    ' ------------ Бровкова Н.Ю. 05.05.05 --------------
    m_nIdOI = objParamOut.Parameter("nIdOI")
    varExecutors = objParamOut.Parameter("varExecutors")
    ' --------------------------------------------------
    ' MsgBox "00-2"

    'заполняем типы комиссии
    cboTypeSend.Clear
    cboTypeRec.Clear
    varState = objParamOut.Parameter("VARSTATE")
    ' MsgBox "00-3"
    'If Not IsArray(varState) Then MsgBox "00 not isarr..."
    For i = 0 To UBound(varState, 2)
        cboTypeSend.AddItem(varState(1, i))
        cboTypeSend.ItemData(cboTypeSend.NewIndex) = varState(0, i)
        cboTypeRec.AddItem(varState(1, i))
        cboTypeRec.ItemData(cboTypeRec.NewIndex) = varState(0, i)
    Next
    cboTypeSend.ListIndex = 0
    cboTypeRec.ListIndex = 0
    UbsDDX.InitMemberData(cboTypeSend) = 0
    UbsDDX.InitMemberData(cboTypeRec) = 0
    'MsgBox "01"
    '---------------------------добавила Кирсанова Е.В. 11.10.2005
    'Dim objGridList
    'Set objGridList = Parent.ParamInfo(NumParentWindow, "UbsGridList")
    'If objGridList.FilterName = "UBS_FLT\PS\UT\UT_LIST_CONTRACT.flt" _
    '   Or objGridList.FilterName = "UBS_FLT\PS\UT\UT_LIST_CONTRACT_CLOSE.flt" Then
    blnIsPublicPayments = True
    lblState.Visible = True
    cmbStatus.Visible = True
    cmbStatus.List(0) = "открыт"
    cmbStatus.ItemData(0) = 0
    cmbStatus.List(1) = "закрыт"
    cmbStatus.ItemData(1) = 1
    cmbStatus.ListIndex = 0
    'Else
    '    blnIsPublicPayments = False
    'End If
    '----------------------------------------
    'MsgBox "02"
    If StrCommand = "EDIT" Then
        objParamIn.Parameter("IDCONTRACT") = idObject
        objParamIn.Parameter("STRCOMMAND") = "READ"

        UbsChannel.Run "Contract", objParamIn, objParamOut
        ' -----------------
        'ОИ из сохраненного Договора
        nIdOI = objParamOut.Parameter("nIdOI")
        ' -----------------
        ressql = objParamOut.Parameters
        For i = 0 To objParamOut.CountParameters - 1
            If ressql(0, i) <> "IDCONTRACT" Then
                Select Case ressql(0, i)
                    Case "INTIDCLIENT"
                        idClient = ressql(1, i)
                    Case "TXTKIND"
                        idKind = ressql(1, i)
                    Case "TXTCODE", "TXTCOMMENT", "CURPERCENTSEND", "CURPERCENTREC", "TXTACC", "TXTACCCORR", "DATECONTRACT", "TXTADRESS", "TXTBIC", "TXTCODE", "TXTINN", "TXTNAMEBANK", "TXTNUM"
                        UbsDDX.InitMemberData(ressql(0, i)) = ressql(1, i)
                    Case "INTTYPESEND"
                        objInterfaces.SetFocusCombo cboTypeSend, CInt(ressql(1, i))
                        ressql(1, i) = cboTypeSend.ListIndex
                        UbsDDX.InitMemberData(ressql(0, i)) = ressql(1, i)
                    Case "INTTYPEREC"
                        objInterfaces.SetFocusCombo cboTypeRec, CInt(ressql(1, i))
                        ressql(1, i) = cboTypeRec.ListIndex '(cboTypeRec.ListIndex)
                        UbsDDX.InitMemberData(ressql(0, i)) = ressql(1, i)
                End Select
            End If
        Next

        If objParamOut.Parameter("Метод расчета комиссии с получателя") = "Обратный" Then
            cb_comissType.Value = 1
        End If


        txtBic.Text = objParamOut.Parameter("TXTBIC")
        If Trim(txtBic.Text) = "" Then
            ' Если нету БИКа, значит это произвольный договор
            blnArbitrary = True
            lblArbitrary.Visible = True
            txtBic.Enabled = False
            AccClient.Enabled = False
            btnClient.Enabled = False
            btnDelClient.Enabled = False
        Else
            blnMayBeArbitrary = False
        End If
        txtINN.Text = objParamOut.Parameter("TXTINN")
        '   MsgBox "03"

        '----------------------------------добавила Кирсанова Е.В. 11.10.2005
        'If objGridList.FilterName = "UBS_FLT\PS\UT\UT_LIST_CONTRACT.flt" _
        '  Or objGridList.FilterName = "UBS_FLT\PS\UT\UT_LIST_CONTRACT_CLOSE.flt" Then
        cmbStatus.ListIndex = objParamOut.Parameter("STATE")
        'End If
        '----------------------------------

        '---------------------------------------- Новопашин В.М 11.08.2006 г. -----
        txtDateClose.Visible = False
        lblDateClose.Visible = False

        If cmbStatus.ItemData(cmbStatus.ListIndex) = 1 Then
            txtDateClose.Visible = True
            lblDateClose.Visible = True

            txtDateClose.DateValue = objParamOut.Parameter("DATECLOSE")
        End If
        '--------------------------------------------------------------------------

        objParamIn.Parameter("IDKINDPAYMENT") = idKind
        objParamIn.Parameter("STRCOMMAND") = "READ"
        UbsChannel.Run "ReadKind", objParamIn, objParamOut
        ressql = objParamOut.Parameters
        For i = 0 To objParamOut.CountParameters - 1
            If ressql(0, i) <> "IDKINDPAYMENT" Then
                Select Case ressql(0, i)
                    Case "TXTCODE"
                        UbsDDX.InitMemberData("TXTKIND") = ressql(1, i)
                    Case "TXTCOMMENT"
                        UbsDDX.InitMemberData("TXTCOMMENTKIND") = ressql(1, i) '= resSQL(1, i)
                End Select
            Else
                idKind = ressql(1, i)
            End If
        Next

        objParamIn.Parameter("IDCLIENT") = idClient
        objParamIn.Parameter("STRCOMMAND") = "READ"
        UbsChannel.Run "ReadClient", objParamIn, objParamOut
        UbsDDX.InitMemberData("INTIDCLIENT") = objParamOut.Parameter("NAME")
    End If
    'MsgBox "04"
    AddProperties.UbsAddFields = objStub
    AddProperties.Refresh
    UbsDDX.UpdateData False
 '   MsgBox "04-1"
    Call GetBankNameACC()
    '  MsgBox "04-2"
    Call EnableFieldsCl()
    ' MsgBox "04-3"

    ' ------------ Бровкова Н.Ю. 05.05.05 --------------
    If StrCommand = "ADD" Then
        Call ClearBankFields()
    End If


    'MsgBox "m_nIdOI=" & m_nIdOI & ", nIdOI=" & nIdOI & vbCrLf & _
    '   objGridList.FilterName & vbCrLf & StrCommand

    'If objGridList.FilterName = "UBS_FLT\PS\UT\UT_LIST_CONTRACT.flt" Then
    lblNameOI.Visible = True
    cmbNameOI.Visible = True
    If StrCommand = "ADD" Then
        'ОИ по тек. пользователю (по установке)
        nIdOI = m_nIdOI
    End If
    '    MsgBox "04-4"
    ' заполнить список ОИ по Договорам с получателем
    FillExecutors varExecutors, nIdOI
    'Else
    '    lblNameOI.Visible = False
    '    cmbNameOI.Visible = False
    'End If
    
    Set objGridList = Nothing
    
    '   If Not IsEmpty(varExecutors) Then
    '       For i = 0 To UBound(varExecutors, 2)
    '           If Trim(varExecutors(1, i)) = Trim(strOI) Then
    '               GetIdOI = varExecutors(0, i)
    '               Exit For
    '           End If
    '       Next
    '   End If
    ' ----------------------------------------------------
    
'MsgBox "05"
Exit Sub
ErrorCode:
    objErr.UbsErrMsg "InitDoc", "ошибка выполнения"
End Sub

Private Sub UserDocument_KeyDown(KeyCode As Integer, Shift As Integer)
    If Shift = 2 And KeyCode = vbKeyTab Then
                Set objFocusCtrl = UserDocument.ActiveControl
                Parent.LoaderParamInfo(0, "NextWindow") = NumWin
    End If
End Sub

Private Sub UserDocument_KeyPress(KeyAscii As Integer)
    Select Case (KeyAscii)
        Case 13                              'Enter
            KeyAscii = 0
            Select Case (UserDocument.ActiveControl.name)
                Case "txtBic"
                    If Not GetBankNameACC() And (Not blnIsPublicPayments Or Not blnArbitrary And StrCommand = "EDIT") Then

                        '--------------------------------- Новопашин В.М. 25.08.2006 г.
                        '
                        If txtBic.Text <> "" Or AccClient.Text <> "00000000000000000000" Then
                            If AccClient.Text <> "" Then
                                '-------------------------------------------------------------

                                Call MsgBox("БИК не найден ", 16, "Обработка данных БИКа")
                                subContract.Tabs(1).Selected = True
                                If subContract.SelectedTab.Index = 1 Then
                                    If txtBic.Enabled Then txtBic.SetFocus
                                End If
                            End If
                        End If
                    Else
                        subContract.Tabs(1).Selected = True
                        If subContract.SelectedTab.Index = 1 Then
                            If txtINN.Enabled Then
                                txtINN.SetFocus
                            Else
                                If AccClient.Enabled Then AccClient.SetFocus
                            End If
                        End If

                        If Not blnIsOurBik Then
                            AccClient.Text = "00000000000000000000"
                        Else
                            Call SearchOneAccClient()
                        End If

                    End If
                Case "cboTypeRec"
                    If Not curPercentRec.Enabled Then
                        subContract.Tabs(3).Selected = True
                        If subContract.SelectedTab.Index = 3 Then
                            objInterfaces.GoToCtrl AddProperties
                       Else
                            objInterfaces.NextCtrl
                        End If
                    Else
                        objInterfaces.NextCtrl
                    End If
                Case "curPercentRec"
                    subContract.Tabs(3).Selected = True
                    If subContract.SelectedTab.Index = 3 Then
                        objInterfaces.GoToCtrl AddProperties
                       Else
                        objInterfaces.NextCtrl
                    End If
                Case "txtComment"
                    subContract.Tabs(2).Selected = True
                    If subContract.SelectedTab.Index = 2 Then
                        objInterfaces.GoToCtrl cboTypeSend
                       Else
                        objInterfaces.NextCtrl
                    End If
                Case Else
                    objInterfaces.NextCtrl        'SendKeys "{TAB}"
            End Select

        Case 27                              'Esc
            KeyAscii = 0
            Select Case (UserDocument.ActiveControl.name)
                Case "AddProperties"
                    subContract.Tabs(2).Selected = True
                    If subContract.SelectedTab.Index = 2 Then
                        objInterfaces.GoToCtrl cboTypeRec
                    Else
                        objInterfaces.PrevCtrl
                    End If
                Case "cboTypeSend"
                    subContract.Tabs(1).Selected = True
                    If subContract.SelectedTab.Index = 1 Then
                        objInterfaces.GoToCtrl txtComment
                    Else
                        objInterfaces.PrevCtrl
                    End If
                Case Else
                    objInterfaces.PrevCtrl        'SendKeys "+{TAB}"
            End Select
    End Select
End Sub


Private Function Check()
    On Error GoTo ErrorCode
    Check = True
    If Len(txtCode.Text) = 0 Then
        Check = False
        Call MsgBox("Некорректный код договора!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl txtCode
    End If
        Exit Function
    End If

    If Len(txtCode.Text) > 20 Then
        Check = False
        Call MsgBox("Некорректная длина кода договора!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl txtCode
    End If
        Exit Function
    End If

    If Len(txtComment.Text) > 255 Then
        Check = False
        Call MsgBox("Некорректная длина комментария!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl txtComment
    End If
        Exit Function
    End If

    If Len(Trim(txtComment.Text)) = 0 Then
        Check = False
        Call MsgBox("Некорректный комментарий!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl txtComment
    End If
        Exit Function
    End If

    If Len(txtNum.Text) > 20 Then
        Check = False
        Call MsgBox("Некорректная длина номера договора!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl txtNum
    End If
        Exit Function
    End If

    If idKind = 0 Then
        Check = False
        Call MsgBox("Некорректный вид платежа !", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl btnKind
    End If
        Exit Function
    End If

    If Len(txtINN.Text) = 0 And idClient > 0 Then
        Check = False
        Call MsgBox("Не заполнен ИНН для клиента банка!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            If txtINN.Enabled Then objInterfaces.GoToCtrl txtINN
    End If
        Exit Function
    End If

    If Len(txtBic.Text) > 9 Then
        Check = False
        Call MsgBox("Некорректная длина БИКа!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            If txtBic.Enabled Then objInterfaces.GoToCtrl txtBic
    End If
        Exit Function
    End If

    If Len(txtINN.Text) > 12 Then
        Check = False
        Call MsgBox("Некорректная длина ИНН!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            If txtINN.Enabled Then objInterfaces.GoToCtrl txtINN
    End If
        Exit Function
    End If

    'If Len(AccKorr.Text) = 0 Or AccKorr.Text = "00000000000000000000" Then
    '  If Not (AccKorr.Text = "00000000000000000000" And blnRKC = True) Then
    '     Check = False
    '     Call MsgBox("Некорректный корр.счет !", 16, "Проверка корректности данных")
    '     subContract.Tabs(1).Selected = True
    '     If subContract.SelectedTab.Index = 1 And AccKorr.Enabled Then
    '       If AccKorr.Enabled Then objInterfaces.GoToCtrl AccKorr
    '     End If
    '  End If
    '  Exit Function
    ' End If

    If Len(txtAdress.Text) > 255 Then
        Check = False
        Call MsgBox("Некорректная длина адреса!", 16, "Проверка корректности данных")
        subContract.Tabs(1).Selected = True
        If subContract.SelectedTab.Index = 1 Then
            If txtAdress.Enabled Then objInterfaces.GoToCtrl txtAdress
    End If
        Exit Function
    End If



    If idClient > 0 Then
        If AccClient.Text = "00000000000000000000" Then
            Check = False
            Call MsgBox("Некорректный счет клиента!", 16, "Проверка корректности данных")
            subContract.Tabs(1).Selected = True
            If subContract.SelectedTab.Index = 1 Then
                objInterfaces.GoToCtrl AccClient
        End If
            Exit Function
        End If

        'проверка ключа счета
        objParamIn.Parameter("STRACC") = AccClient.Text
        objParamIn.Parameter("BIC") = txtBic.Text
        objParamIn.Parameter("CORRACC") = AccKorr.Text
        UbsChannel.Run "CheckKey", objParamIn, objParamOut
    If objParamOut.Parameter("RETVAL") = False Then
            Check = False
            Call MsgBox("Некорректный ключ счета!", 16, "Проверка корректности данных")
            subContract.Tabs(1).Selected = True
            If subContract.SelectedTab.Index = 1 Then
                If btnAcc.Enabled Then
                    objInterfaces.GoToCtrl btnAcc
         Else
                    objInterfaces.GoToCtrl AccClient
         End If
            End If
            Exit Function
        End If
        If blnIsOurBik = True Then

            ' проверим соответствует ли выбранный счет клиента
            'выбранному клиенту
            objParamIn.Parameter("IDCLIENT") = idClient
            objParamIn.Parameter("STRACC") = AccClient.Text
            UbsChannel.Run "CheckClientAcc", objParamIn, objParamOut
    If objParamOut.Parameter("IDCLIENT") <> idClient Then
                '    If objParamOut.Parameter("RETVAL") = False Then
                Check = False
                Call MsgBox("Выбранный счет не принадлежит выбранному клиенту!", 16, "Проверка корректности данных")
                subContract.Tabs(1).Selected = True
                If subContract.SelectedTab.Index = 1 Then
                    If btnAcc.Enabled Then
                        objInterfaces.GoToCtrl btnAcc
           Else
                        objInterfaces.GoToCtrl AccClient
           End If

                End If
                Exit Function
            End If
        End If
    Else 'клиент не выбран
        If AccClient.Text <> "00000000000000000000" Then
            '  проверка ключа счета
            objParamIn.Parameter("STRACC") = AccClient.Text
            objParamIn.Parameter("BIC") = txtBic.Text
            objParamIn.Parameter("CORRACC") = AccKorr.Text
            UbsChannel.Run "CheckKey", objParamIn, objParamOut
       If objParamOut.Parameter("RETVAL") = False Then
                Check = False
                Call MsgBox("Некорректный ключ счета!", 16, "Проверка корректности данных")
                subContract.Tabs(1).Selected = True
                If subContract.SelectedTab.Index = 1 Then
                    If btnAcc.Enabled Then
                        objInterfaces.GoToCtrl btnAcc
             Else
                        objInterfaces.GoToCtrl AccClient
            End If
                End If
                Exit Function
            End If
        End If
    End If

    If CheckAddField("Транзитные счета") Then
   'If AddProperties.PropertyByName("Транзитные счета") = "00000000000000000000" _
      Or AddProperties.PropertyByName("Транзитные счета") = "" Then
  '    Check = False
  '    Call MsgBox("Некорректный Транзитные счета!", 16, "Проверка корректности данных")
  '    subContract.Tabs(3).Selected = True
  '    If subContract.SelectedTab.Index = 3 Then
  '      objInterfaces.GoToCtrl AddProperties
  '    End If
  '    Exit Function
  ' End If
  
  If CheckAddField("Транзитные счета") = True Then
            'проверяем по переданной строке счета , существует ли такой счет
            objParamIn.Parameter("varAccounts") = AddProperties.PropertyByName("Транзитные счета")
            UbsChannel.Run "PSCheckAccounts", objParamIn, objParamOut
       If objParamOut.Parameter("RETVAL") = False Then
                Check = False
                Call MsgBox(objParamOut.Parameter("strError"), 16, "Проверка корректности данных")
                'Call MsgBox("Некорректный Транзитные счета " & AddProperties.PropertyByName("Транзитные счета") & " !", 16, "Проверка корректности данных")
                subContract.Tabs(3).Selected = True
                If subContract.SelectedTab.Index = 3 Then
                    objInterfaces.GoToCtrl AddProperties
          End If
                Exit Function
            End If
        End If
    End If

    Dim ArrProp As Variant
    If CheckAddField("Доп. параметры комиссии с плательщика") Then
        If IsArray(AddProperties.PropertyByName("Доп. параметры комиссии с плательщика")) Then
            ArrProp = AddProperties.PropertyByName("Доп. параметры комиссии с плательщика")
            If ArrProp(0, 0) > ArrProp(1, 0) Or IsEmpty(ArrProp(1, 0)) Or IsEmpty(ArrProp(0, 0)) Then
                Check = False
                If ArrProp(0, 0) > ArrProp(1, 0) And Not IsEmpty(ArrProp(1, 0)) Then _
              Call MsgBox("Некорректное заполнение доп.поля 'Доп.параметры комиссии с плательщика Минимальная сумма должна быть меньше максимальной'!", 16, "Проверка корректности данных")
                If IsEmpty(ArrProp(1, 0)) And Not IsEmpty(ArrProp(0, 0)) Then _
              Call MsgBox("Некорректное заполнение доп.поля 'Доп.параметры комиссии с плательщика' Максимальная сумма должна быть заполнена!", 16, "Проверка корректности данных")
                If IsEmpty(ArrProp(0, 0)) And Not IsEmpty(ArrProp(1, 0)) Then _
              Call MsgBox("Некорректное заполнение доп.поля 'Доп.параметры комиссии с плательщика' Минимальная сумма должна быть заполнена!", 16, "Проверка корректности данных")
                If IsEmpty(ArrProp(0, 0)) And IsEmpty(ArrProp(1, 0)) Then _
               Call MsgBox("Некорректное заполнение доп.поля 'Доп.параметры комиссии с плательщика' Минимальная и максимальныя суммы должны быть заполнены!", 16, "Проверка корректности данных")

                subContract.Tabs(3).Selected = True
                If subContract.SelectedTab.Index = 3 Then
                    objInterfaces.GoToCtrl AddProperties
           End If
                Exit Function
            End If
        End If
    End If

    If CheckAddField("Доп. параметры комиссии с получателя") Then
        If IsArray(AddProperties.PropertyByName("Доп. параметры комиссии с получателя")) Then
            ArrProp = AddProperties.PropertyByName("Доп. параметры комиссии с получателя")
            If ArrProp(0, 0) > ArrProp(1, 0) Or IsEmpty(ArrProp(1, 0)) Or IsEmpty(ArrProp(0, 0)) Then
                Check = False
                If ArrProp(0, 0) > ArrProp(1, 0) And Not IsEmpty(ArrProp(1, 0)) Then _
           Call MsgBox("Некорректное заполнение доп.поля 'Доп.параметры комиссии с получателя Минимальная сумма должна быть меньше максимальной'!", 16, "Проверка корректности данных")
                If IsEmpty(ArrProp(1, 0)) And Not IsEmpty(ArrProp(0, 0)) Then _
           Call MsgBox("Некорректное заполнение доп.поля 'Доп.параметры комиссии с получателя' Максимальная сумма должна быть заполнена!", 16, "Проверка корректности данных")
                If IsEmpty(ArrProp(0, 0)) And Not IsEmpty(ArrProp(1, 0)) Then _
           Call MsgBox("Некорректное заполнение доп.поля 'Доп.параметры комиссии с получателя' Минимальная сумма должна быть заполнена!", 16, "Проверка корректности данных")
                If IsEmpty(ArrProp(0, 0)) And IsEmpty(ArrProp(1, 0)) Then _
           Call MsgBox("Некорректное заполнение доп.поля 'Доп.параметры комиссии с получателя' Минимальная и максимальныя суммы должны быть заполнены!", 16, "Проверка корректности данных")

                subContract.Tabs(3).Selected = True
                If subContract.SelectedTab.Index = 3 Then
                    objInterfaces.GoToCtrl AddProperties
        End If
                Exit Function
            End If
        End If
    End If


    Exit Function
ErrorCode:
    objErr.UbsErrMsg "Проверка корректности данных", "ошибка выполнения"
 End Function

Sub EnableSum()

    If cboTypeSend.ListIndex = 0 Or cboTypeSend.ListIndex = 3 Then
        curPercentSend.Enabled = False
        curPercentSend.CurrencyValue = 0
    Else
        curPercentSend.Enabled = True
    End If

    curPercentRec.Enabled = CBool(cboTypeRec.ListIndex > 0)
    If cboTypeRec.ListIndex = 0 Or cboTypeRec.ListIndex = 3 Then
        curPercentRec.Enabled = False
        curPercentRec.CurrencyValue = 0
    Else
        curPercentRec.Enabled = True
    End If
    'curPercentSend.Enabled = CBool(cboTypeSend.ListIndex > 0)
    'If cboTypeSend.ListIndex = 0 Then curPercentSend.CurrencyValue = 0
    'curPercentRec.Enabled = CBool(cboTypeRec.ListIndex > 0)
    'If cboTypeRec.ListIndex = 0 Then curPercentRec.CurrencyValue = 0
End Sub

Sub EnableCode()
    txtCode.Enabled = CBool(StrCommand = "ADD")
    btnKind.Enabled = CBool(StrCommand = "ADD")
End Sub

Sub EnableFieldsCl()
    ' txtBic.Enabled = Not CBool(idClient > 0)
    txtINN.Enabled = Not CBool(idClient > 0)
    ' txtClient.Enabled = Not CBool(idClient > 0)
    txtAdress.Enabled = Not CBool(idClient > 0)

End Sub



Function GetBankNameACC()
    Dim ressql As Variant
    Dim i As Integer
    On Error GoTo ErrorCode
    GetBankNameACC = False
    If Len(Trim(txtBic.Text)) > 0 Then
        objParamIn.Parameter("BIC") = txtBic.Text

        UbsChannel.Run "ReadBankBIK", objParamIn, objParamOut

        ressql = objParamOut.Parameters
        If objParamOut.Parameter("NUM") > 0 Then
            For i = 0 To objParamOut.CountParameters - 1

                Select Case ressql(0, i)
                    Case "BANKNAME"
                        'If Trim(txtNameBank.Text) = "" Then
                        txtNameBank.Text = ressql(1, i)
                        'End If
                    Case "CORRACC"
                        If Trim(AccKorr.Text) = "" Or AccKorr.Text = "00000000000000000000" Then
                            AccKorr.Text = ressql(1, i)
                        End If
                        '               Case "BIKOURBANK"
                        '                   strOurBIK = objParamOut.Parameter("BIKBANK")
                End Select
            Next
            '       blnRKC = objParamOut.Parameter("BLNRKC")
            GetBankNameACC = True
        End If
    End If
    Call setSignOurBIK()
    Exit Function
ErrorCode:
    objErr.UbsErrMsg "Информация о банке", "ошибка выполнения"
End Function

Sub ClearBankFields()
    Dim ressql As Variant
    Dim i As Integer
    On Error GoTo ErrorCode
    txtClient.Text = ""
    txtBic.Text = ""
    AccKorr.Text = "00000000000000000000"
    txtNameBank.Text = ""
    AccClient.Text = "00000000000000000000"
    txtINN.Text = ""
    txtAdress.Text = ""

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Очистка полей клиента", "ошибка выполнения"
End Sub


Sub ClearCommissFields()
    cboTypeSend.ListIndex = 0
    cboTypeRec.ListIndex = 0
    curPercentSend.Text = "0"
    curPercentRec.Text = "0"
    Call EnableSum()
End Sub


Function FillKind()
    Dim ressql As Variant
    Dim i As Integer
    FillKind = True
    '-----------------
    ' вызов
    objParamIn.ClearParameters
    objParamIn.Parameter("STRCOMMAND") = "READ"
    objParamIn.Parameter("IDKINDPAYMENT") = idKind
    '-----------------------------
    ' получить вид платежа
    UbsChannel.Run "ReadKind", objParamIn, objParamOut

                If Len(Trim(objParamOut.Parameter("StrError"))) > 0 Then
        FillKind = False
        Exit Function
    End If
    '-----------------
    txtKind.Text = objParamOut.Parameter("TXTCODE")
    txtNoteKind.Text = objParamOut.Parameter("TXTCOMMENT")
    cboTypeSend.ListIndex = objParamOut.Parameter("INTTYPESEND")
    cboTypeRec.ListIndex = objParamOut.Parameter("INTTYPEREC")
    curPercentSend.Text = objParamOut.Parameter("CURPERCENTSEND")
    curPercentRec.Text = objParamOut.Parameter("CURPERCENTREC")
    ' может ли быть произвольным
    blnMayBeArbitrary = objParamOut.Parameter("MayBeArbitrary")

    If objParamOut.Parameter("INTTYPESEND") = 3 Then
        If CheckAddField("Комиссии с плательщика-тарифная сетка") Then
            AddProperties.PropertyByName("Комиссии с плательщика-тарифная сетка") = objParamOut.Parameter("Комиссии с плательщика-тарифная сетка")
            AddProperties.Refresh
        End If
        If CheckAddField("Комиссии с плательщика-признак ставки") Then
            AddProperties.PropertyByName("Комиссии с плательщика-признак ставки") = objParamOut.Parameter("Комиссии с плательщика-признак ставки")
            AddProperties.Refresh
        End If
    End If

    If objParamOut.Parameter("INTTYPEREC") = 3 Then
        If CheckAddField("Комиссии с получателя-тарифная сетка") Then
            AddProperties.PropertyByName("Комиссии с получателя-тарифная сетка") = objParamOut.Parameter("Комиссии с получателя-тарифная сетка")
            AddProperties.Refresh
        End If
        If CheckAddField("Комиссии с получателя-признак ставки") Then
            AddProperties.PropertyByName("Комиссии с получателя-признак ставки") = objParamOut.Parameter("Комиссии с получателя-признак ставки")
            AddProperties.Refresh
        End If
    End If

    If CheckAddField("Доп. параметры комиссии с получателя") Then
        AddProperties.PropertyByName("Доп. параметры комиссии с получателя") = objParamOut.Parameter("VARCOMMISREC")
        AddProperties.Refresh
    End If

    If CheckAddField("Доп. параметры комиссии с плательщика") Then
        AddProperties.PropertyByName("Доп. параметры комиссии с плательщика") = objParamOut.Parameter("VARCOMMISSEND")
        AddProperties.Refresh
    End If
End Function





Sub setSignOurBIK()

    If txtBic.Text = strOurBIK Then
        blnIsOurBik = True
        btnAcc.Enabled = True
    Else
        blnIsOurBik = False
        btnAcc.Enabled = False
    End If
End Sub


Function SearchOneAccClient()

    If idClient <= 0 Then Exit Function  ' (86000)

    objParamIn.Parameter("IDCLIENT") = idClient

    UbsChannel.Run "SearchAccClient", objParamIn, objParamOut
    If Len(Trim(objParamOut.Parameter("ACCCLIENT"))) > 0 Then
        AccClient.Text = objParamOut.Parameter("ACCCLIENT")
    End If

End Function



Sub FillDependFields()

    If CheckAddField("Доп. параметры комиссии с плательщика") = True Then
        If cboTypeSend.Text = "отсутствует" Then
            AddProperties.PropertyByName("Доп. параметры комиссии с плательщика") = Empty
        End If
    End If
    If CheckAddField("Доп. параметры комиссии с получателя") = True Then
        If cboTypeRec.Text = "отсутствует" Then
            AddProperties.PropertyByName("Доп. параметры комиссии с получателя") = Empty

        End If
    End If

    AddProperties.Refresh

End Sub

Function CheckAddField(NameAddField)
    Dim objParamIn As Object
    Dim objParamOut As Object

 Set objParamIn = CreateObject("ToolPubs.IUbsParam")
 Set objParamOut = CreateObject("ToolPubs.IUbsParam")
 
 CheckAddField = False
    objParamIn.Parameter("NAMEFIELD") = NameAddField
    UbsChannel.Run "CheckExistAddFieldContract", objParamIn, objParamOut
 CheckAddField = objParamOut.Parameter("BLNEXIST")
 
 Set objParamIn = Nothing
 Set objParamOut = Nothing
End Function

' ----------- Бровкова Н.Ю. 05.05.05 ---------
' заполнение списка ОИ по Договору
' --------------------------------------------
Private Function FillExecutors(varExecutors As Variant, nIdOI As Integer)
    Dim i As Integer, intIndex As Integer

    On Error GoTo ErrorCode

    cmbNameOI.Clear
    intIndex = 0

    If IsArray(varExecutors) Then
        For i = 0 To UBound(varExecutors, 2)
            'cmbNameOI.AddItem varExecutors(0, i), i
            cmbNameOI.AddItem varExecutors(1, i)
            cmbNameOI.ItemData(cmbNameOI.NewIndex) = varExecutors(0, i)
            If CInt(nIdOI) = CInt(varExecutors(0, i)) Then
                intIndex = i
            End If
        Next
        ' подсветить нужное значение в комбо-боксе
        cmbNameOI.ListIndex = intIndex
    End If

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "FillExecutors", "ошибка выполнения"
End Function

Sub CheckArbitraryAddFl()
    On Error GoTo ErrorCode

    If Not AddProperties.PropertyByName("Отдельный документ на каждый платеж") = "да" Then
        AddProperties.PropertyByName("Отдельный документ на каждый платеж") = "да"
    End If
    If AddProperties.PropertyByName("Подготовка платежных документов") = "Подготовка документов по спец. договорам" Then
        AddProperties.PropertyByName("Подготовка платежных документов") = ""
    End If
    If Not AddProperties.PropertyByName("Ссылка на спец. договор") = "" Then
        AddProperties.PropertyByName("Ссылка на спец. договор") = Empty
    End If
    If Not AddProperties.PropertyByName("Признак ввода кода платежа") = "отсутствует" Then
        AddProperties.PropertyByName("Признак ввода кода платежа") = "отсутствует"
    End If

    AddProperties.Refresh

    '    MsgBox "Отдельный документ на каждый платеж " & AddProperties.PropertyByName("Отдельный документ на каждый платеж")
    '    MsgBox "Подготовка платежных документов " & AddProperties.PropertyByName("Подготовка платежных документов")
    '    MsgBox "Ссылка на спец. договор " & AddProperties.PropertyByName("Ссылка на спец. договор")

    Exit Sub
ErrorCode:
    objErr.UbsMsgRaise "CheckArbitraryAddFl", "ошибка выполнения"
End Sub
