End Property

Private Sub UBSChild_NotifyCloseWindow(ByVal NumWindow As Integer)

    If NumWindow = NumChildWin Then
        NumChildWin = 0
    End If

    If NumWindow = NumChildWinAcc Then
        NumChildWinAcc = 0
    End If

    If NumWindow = NumChildWinKind Then
        NumChildWinKind = 0
    End If

    If NumParentWindow <> 0 And NumParentWindow = NumWindow Then
        bParentWindowClose = True
        'Если закрываемое окно - родительское и оно не пришпилено вызвать процедуру закрытия окна
        btnExit_Click()
    End If

End Sub

Private Sub UBSChild_NotifyFixWindow(ByVal NumWindow As Variant, ByVal FixState As Boolean)
    If NumWindow = NumWin And FixState Then
        'Если пришпиливают наше окно
        NumParentWindow = 0
    End If
End Sub

Private Property Let UBSChild_NumWindow(ByVal RHS As Integer)
    NumWin = RHS
End Property

Private Property Let UBSChild_ParamInfo(ByVal NameParam As String, ByVal RHS As Variant)
Dim ItemArray As Variant
Dim Grid As Object
Dim Filter As Object 'UbsFilter
Dim N, nCount, iListItem
On Error GoTo ErrorCode

If Not objFormParam.ExistParameter(NameParam) Then
objErr.UbsErrRaise "Проверка поддержки параметров", "Параметер '" & NameParam & "' не поддерживается"
    End If
Select Case NameParam
Case "InitParamForm"
Initialize
NumParentWindow = RHS(0)
ItemArray = RHS(1)
StrCommand = RHS(2)

If Not IsEmpty(ItemArray) And (StrCommand = "EDIT") Then
idObject = ItemArray(0)
Else
If StrCommand = "EDIT" Then
Call MsgBox("Не выбран договор", 16, "Изменение договора")
Call btnExit_Click
Exit Property
Else
idObject = 0
StrCommand = "ADD"
End If
End If

InitDoc
Parent.WindowDraw(NumWin) = True
objInterfaces.NextCtrl
objInterfaces.PrevCtrl
Call EnableCode
If txtCode.Enabled Then
txtCode.SetFocus
Else
txtNum.SetFocus
End If


Case "SetFocus"
If Not objFocusCtrl Is Nothing Then
objFocusCtrl.SetFocus
End If
   '=========================================================================
        'RetFromGrid - возврат из списков,
        'вызываемых кнопкой "..."
Case "RetFromGrid"
If NumChildWin = RHS(0) Then
ItemArray = RHS(1)
If Not IsEmpty(ItemArray) Then
idClient = ItemArray(0)
Else
objErr.UbsErrMsg "RetFromGrid", "Массив идентификаторов пуст"
                End If
Parent.CloseWindow NumChildWin
                Parent.SetFocusToWindow NumWin

                '-----------------
' вызов
objParamIn.ClearParameters
objParamIn.Parameter("IDCLIENT") = idClient
'-----------------------------
' получить наименование клиента
UbsChannel.Run "ReadClient", objParamIn, objParamOut

                If Len(Trim(objParamOut.Parameter("StrError"))) Then
                    MsgBox objParamOut.Parameter("StrError"), 16, "Карточка договора"
                    Exit Property
End If
'-----------------

txtClient.Text = objParamOut.Parameter("NAME")
txtBic.Text = objParamOut.Parameter("BIC")
txtAdress.Text = objParamOut.Parameter("ADRESS")
txtINN.Text = objParamOut.Parameter("INN")
Call setSignOurBIK
If CheckAddField("КППУ") = True Then
AddProperties.PropertyByName("КППУ") = objParamOut.Parameter("KPPU") ' strKPPU
End If
AddProperties.Refresh
Call GetBankNameACC
Call EnableFieldsCl
'если БИК нашего банка, то подставляем счет клиента в поле р/с
If blnIsOurBik Then
Call SearchOneAccClient
End If
objInterfaces.GoToCtrl btnClient

            End If

''выбор счета клиента
If NumChildWinAcc = RHS(0) Then
ItemArray = RHS(1)
If Not IsEmpty(ItemArray) Then
idAcc = ItemArray(0)
Else
objErr.UbsErrMsg "RetFromGrid", "Массив идентификаторов пуст"
                End If
Parent.CloseWindow NumChildWinAcc
                Parent.SetFocusToWindow NumWin

                '-----------------
' вызов
objParamIn.ClearParameters
objParamIn.Parameter("IDACC") = idAcc
'-----------------------------
' получить счет
UbsChannel.Run "ReadAcc", objParamIn, objParamOut

                If Len(Trim(objParamOut.Parameter("StrError"))) Then
                    MsgBox objParamOut.Parameter("StrError"), 16, "Карточка договора"
                    Exit Property
End If
'-----------------

AccClient.Text = objParamOut.Parameter("TXTACC")
' m_nIdAcc = nIdSelectedRecord

objInterfaces.GoToCtrl btnAcc
            End If


'выбор вида платежа
If NumChildWinKind = RHS(0) Then
ItemArray = RHS(1)
If Not IsEmpty(ItemArray) Then
idKind = ItemArray(0)
Else
objErr.UbsErrMsg "RetFromGrid", "Массив идентификаторов пуст"
                End If
Parent.CloseWindow NumChildWinKind
                Parent.SetFocusToWindow NumWin
                 'говорим объекту, что изменился вид платежа
objParamIn.Parameter("STRCOMMAND") = "CHANGEKIND"
objParamIn.Parameter("INTIDKIND") = idKind
UbsChannel.Run "Contract", objParamIn, objParamOut
                 AddProperties.Refresh

If Not FillKind Then
                     MsgBox objParamOut.Parameter("StrError"), 16, "Карточка договора"
                 Else
'------------------ добавила Кирсанова Е.В. 11.10.2005
If cmbStatus.Visible Then
objInterfaces.GoToCtrl cmbStatus
                    Else
If txtClient.Enabled Then
objInterfaces.GoToCtrl txtClient
                       Else
objInterfaces.GoToCtrl btnClient
                       End If
End If
End If
End If

End Select
'=========================================================================


Set Filter = Nothing
Set Grid = Nothing
    Exit Property

ErrorCode:
objErr.UbsErrMsg "UBSChild_ParamInfo", "ошибка выполнения"
    If CheckParamForClose(NameParam) Then
btnExit_Click
End If

End Property

