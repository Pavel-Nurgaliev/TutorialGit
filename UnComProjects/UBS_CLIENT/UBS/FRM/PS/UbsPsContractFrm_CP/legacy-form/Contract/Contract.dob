Attribute VB_Name = "Contract"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = True
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = True
Option Explicit On
Implements UBSChild
Dim NumWin As Integer, NumParentWindow As Integer
Dim NumChildWin As Integer
Dim NumChildWinKind As Integer
Dim NumChildWinAcc As Integer
Dim Parent As UBSParrent
Dim StrCommand As String
Dim objErr As Object, objInterfaces As Object
Dim objArray As Object
Dim idObject As String
Dim idClient As String
Dim idKind As String
Dim idAcc As String
Dim objStub As Object
Dim objFormParam As Object
Dim bNeedRefreshGrid As Boolean, bParentWindowClose As Boolean
Dim objFocusCtrl As Object
Dim objParamIn As Object, objParamOut As Object
Dim strOurBIK As String
Dim blnIsOurBik As Boolean
Dim objGridList As Object
Dim strFilterName As String
Dim m_nIdOI As Integer
Dim blnIsPublicPayments As Boolean
Dim blnArbitrary As Boolean
Dim blnMayBeArbitrary As Boolean
'Dim blnRKC As Boolean

' varPattern    - список активных шаблонов
Private varPattern As Variant

Private Sub AddProperties_KeyPress(ByVal nKeyCode As Integer)
    On Error GoTo ErrorCode
    Select Case (nKeyCode)
        Case 13
            objInterfaces.GoToCtrl btnSave
    Case 27
            nKeyCode = Asc(Chr(0))
            subContract.Tabs(2).Selected = True
            If subContract.SelectedTab.Index = 2 Then
                If curPercentRec.Enabled Then
                    objInterfaces.GoToCtrl curPercentRec
        Else
                    objInterfaces.GoToCtrl cboTypeRec
        End If
            End If
    End Select
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "AddProperties_KeyPress", "ошибка выполнения"
End Sub

Private Sub btnAcc_Click()
    Dim nIdSelectedRecord As Variant
    Dim l As Variant
    On Error GoTo ErrorCode

    If NumChildWinAcc <> 0 Then
        Parent.SetFocusToWindow NumChildWinAcc
        Exit Sub
    End If

    '========================================
    'отобразить список по кнопке "..."
    '========================================
    Parent.GetWindow "UBS_LIST_OD_ACCOUNT0", NumChildWinAcc

    If NumChildWinAcc <> 0 Then
        Dim InitParamGrid As Variant
        Dim GridF As Object
        ReDim InitParamGrid(5)
        
        Set GridF = Parent.ParamInfo(NumChildWinAcc, "UbsGridList")
        GridF.ClearWhereList
        If idClient > 0 Then
            GridF.AddWhereItem "Идентификатор клиента", 4, idClient
        End If
        l = GridF.AddWhereItem("Балансовый счет", 6, "")
        GridF.WhereItemFlags(l) = 1
        If Parent.IsExistParam(NumChildWinAcc, "InitParamGrid") Then
            nIdSelectedRecord = Empty
            InitParamGrid(0) = NumWin
            InitParamGrid(2) = True
            'InitParamGrid(5) = 2
            InitParamGrid(5) = 1
            Parent.ParamInfo(NumChildWinAcc, "InitParamGrid") = InitParamGrid
            If Parent.IsExistParam(NumChildWinAcc, "SelectItem") Then
                Parent.ParamInfo(NumChildWinAcc, "SelectItem") = nIdSelectedRecord
            End If
            Parent.SetFocusToWindow NumChildWinAcc
        End If
        Set GridF = Nothing
    End If
    '===========================================

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Выбор счета", "ошибка выполнения"

End Sub

Private Sub btnClient_Click()

    Dim nIdSelectedRecord As Variant
    Dim intKeyCond As Long
    Dim J As Integer
    Dim varCond As Variant

    On Error GoTo ErrorCode

    If NumChildWin <> 0 Then
        Parent.SetFocusToWindow NumChildWin
        Exit Sub
    End If

    '========================================
    'отобразить список по кнопке "..."
    '========================================
    Parent.GetWindow "UBS_LIST_COMMON_CLIENT", NumChildWin

    If NumChildWin <> 0 Then
        Dim InitParamGrid As Variant
        Dim GridF As Object
        ReDim InitParamGrid(5)
        
        Set GridF = Parent.ParamInfo(NumChildWin, "UbsGridList")
'        GridF.ClearWhereList
'        GridF.AddWhereItem "Тип", 4, 1
        GridF.GetWhereRS 1, varCond
        intKeyCond = 0
        If Not IsEmpty(varCond) Then
            For J = 0 To UBound(varCond, 2)
                If varCond(0, J) = "Тип" Then
                    intKeyCond = varCond(4, J)
                End If
            Next
        End If
        If intKeyCond = 0 Then
            intKeyCond = GridF.AddWhereItem("Тип", 4, 1)
        Else
            GridF.EditWhereItem intKeyCond, "Тип", 4, 1
        End If
        GridF.WhereItemFlags(intKeyCond) = 1

        If Parent.IsExistParam(NumChildWin, "InitParamGrid") Then
            nIdSelectedRecord = Empty
            InitParamGrid(0) = NumWin
            InitParamGrid(2) = True
            InitParamGrid(5) = 1
            Parent.ParamInfo(NumChildWin, "InitParamGrid") = InitParamGrid
            If Parent.IsExistParam(NumChildWin, "SelectItem") Then
                Parent.ParamInfo(NumChildWin, "SelectItem") = nIdSelectedRecord
            End If
            Parent.SetFocusToWindow NumChildWin
        End If
        Set GridF = Nothing
    End If
    '===========================================
    'Call ClearBankFields
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Выбор клиента", "ошибка выполнения"

End Sub

Private Sub btnDelClient_Click()
    If idClient > 0 Then
        txtClient.Text = ""
        idClient = 0
        Call ClearBankFields()
        Call EnableFieldsCl()
    End If
End Sub

Private Sub btnExit_Click()
    Parent.CloseWindow NumWin
End Sub




Private Sub btnKind_Click()
    Dim nIdSelectedRecord As Variant
    Dim varCond As Variant

    On Error GoTo ErrorCode

    If NumChildWinKind <> 0 Then
        Parent.SetFocusToWindow NumChildWinKind
        Exit Sub
    End If

    '========================================
    'отобразить список по кнопке "..."
    '========================================
    Set objGridList = Parent.ParamInfo(NumParentWindow, "UbsGridList")
    
    objParamIn.Parameter("FILTERCONTRACT") = objGridList.FilterName
    UbsChannel.Run "GetNameFilterKindPaym", objParamIn, objParamOut
    strFilterName = objParamOut.Parameter("FILTERKINDPAYM")
    
'    If objGridList.FilterName = "UBS_FLT\PS\LIST_CONTRACT.flt" Then 'оплата услуг
'     strFilterName = "UBS_FLT\PS\KIND_PAYMENT.flt"
'    Else
'     strFilterName = "UBS_FLT\PS\KIND_PAYM_ALL.flt"
'    End If
    
    Set objGridList = Nothing
    
    Parent.GetWindow strFilterName, NumChildWinKind

    If NumChildWinKind <> 0 Then
        Dim InitParamGrid As Variant
        Dim GridF As Object
        ReDim InitParamGrid(5)
        
        Set GridF = Parent.ParamInfo(NumChildWinKind, "UbsGridList")
'        GridF.ClearWhereList
'       ' GridF.AddWhereItem "Тип", 4, 1
        GridF.GetWhereRS 1, varCond
        If Parent.IsExistParam(NumChildWinKind, "InitParamGrid") Then
            nIdSelectedRecord = Empty
            InitParamGrid(0) = NumWin
            InitParamGrid(2) = True
            If IsEmpty(varCond) Then
                InitParamGrid(5) = 2
            Else
                InitParamGrid(5) = 1
            End If
            Parent.ParamInfo(NumChildWinKind, "InitParamGrid") = InitParamGrid
            If Parent.IsExistParam(NumChildWinKind, "SelectItem") Then
                Parent.ParamInfo(NumChildWinKind, "SelectItem") = nIdSelectedRecord
            End If
            Parent.SetFocusToWindow NumChildWinKind
        End If
        Set GridF = Nothing
    End If
    '===========================================

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Выбор вида платежа", "ошибка выполнения"

End Sub

Private Sub btnSave_Click()
    On Error GoTo ErrorCode
    UbsDDX.UpdateData True
    Dim RSChange As Variant, i As Integer
    If txtBic.Text = "" And blnIsPublicPayments And idClient = 0 And blnMayBeArbitrary Then
        blnArbitrary = True
        lblArbitrary.Visible = True
    End If

    '--------------------------------------------------------------
    'Новопашин В.М. 23.05.06
    'If Not (GetBankNameACC Or blnArbitrary) Then
    '    Call MsgBox("БИК не найден ", 16, "Обработка данных БИКа")
    '    subContract.Tabs(1).Selected = True
    '    If subContract.SelectedTab.Index = 1 Then
    '        If txtBic.Enabled Then txtBic.SetFocus
    '    End If
    '    Exit Sub
    'End If

    '-------------------------------------------------- Новопашин В.М. 25.08.2006 г.
    '
    If txtBic.Text <> "" Or AccClient.Text <> "00000000000000000000" Then
        If AccClient.Text <> "" Then
            '-------------------------------------------------------------------------------
            If Not GetBankNameACC() And (Not blnIsPublicPayments Or Not blnArbitrary And StrCommand = "EDIT") Then
                Call MsgBox("БИК не найден ", 16, "Обработка данных БИКа")
                subContract.Tabs(1).Selected = True
                If subContract.SelectedTab.Index = 1 Then
                    If txtBic.Enabled Then txtBic.SetFocus
                End If
                Exit Sub
            End If
        End If
    End If
    '------------------------------------------------------------------------------------

    '----------------------------------------------- Новопашин В.М. 11.08.2006 г. ----------
    If cmbStatus.ItemData(cmbStatus.ListIndex) = 1 And txtDateClose.DateValue = DateSerial(2222, 1, 1) Then
        MsgBox "Не заполнена дата закрытия договора", 16, "Обработка даты закрытия договора"
       txtDateClose.SetFocus
        Exit Sub
    End If
    '---------------------------------------------------------------------------------------


    If blnArbitrary Then CheckArbitraryAddFl()
    Call FillDependFields()


    If Not Check() Then Exit Sub

    UbsDDX.UpdateData True
    If 1 = 1 Then 'UbsDDX.IsChange Then
        '  If StrCommand = "EDIT" Then
        '   UbsDDX.ChangeMembersValue RSChange
        ' Else
        UbsDDX.MembersValue RSChange
        ' End If

        Dim ressql As Variant, name As String

        If StrCommand = "EDIT" Then
            objParamIn.Parameter("IDCONTRACT") = idObject
        End If

        '------------------------------------------------------ Новопашин В.М. 11.08.2006 г. ---
        objParamIn.Parameter("DATECLOSE") = txtDateClose.DateValue
        '----------------------------------------------------------------------------------------

        For i = 0 To UBound(RSChange, 2)
            Select Case RSChange(0, i)
                Case "TXTCODE", "TXTCOMMENT", "CURPERCENTSEND", "CURPERCENTREC", "TXTNUM", "TXTINN", "TXTADRESS", "TXTBIC", "TXTACCCORR", "TXTACC", "DATECONTRACT"
                    objParamIn.Parameter(RSChange(0, i)) = RSChange(1, i)
                Case "INTIDCLIENT"
                    objParamIn.Parameter(RSChange(0, i)) = idClient
                Case "TXTKIND"
                    objParamIn.Parameter(RSChange(0, i)) = idKind
                Case "INTTYPESEND"
                    objParamIn.Parameter(RSChange(0, i)) = cboTypeSend.ItemData(cboTypeSend.ListIndex)
                Case "INTTYPEREC"
                    objParamIn.Parameter(RSChange(0, i)) = cboTypeRec.ItemData(cboTypeRec.ListIndex)
            End Select
        Next
        'делаем проверку на уникальность кода

        If cb_comissType.Value = 0 Then
            objParamIn.Parameter("Метод расчета комиссии с получателя") = "Прямой"
        Else
            objParamIn.Parameter("Метод расчета комиссии с получателя") = "Обратный"
        End If

        objParamIn.Parameter("STRCOMMAND") = "READF"
        UbsChannel.Run "Contract", objParamIn, objParamOut
        'код уникален
        If objParamOut.Parameter("IDCONTRACT") = idObject Then
            'сохраняем
            objParamIn.Parameter("STRCOMMAND") = StrCommand

            ' ----------- Бровкова Н.Ю. 05.05.05 --------
            If cmbNameOI.Enabled = True Then
                '--------------- Новопашин В.М. 14.03.2007 г. -------
                If cmbNameOI.ListIndex <> -1 Then
                    objParamIn.Parameter("nIdOI") = cmbNameOI.ItemData(cmbNameOI.ListIndex)
                End If
                '----------------------------------------------------
            End If
            ' -------------------------------------------

            objParamIn.Parameter("TXTBIC") = txtBic.Text
            objParamIn.Parameter("TXTINN") = txtINN.Text
            '----------------------------------------добавлено Кирсанова Е.В. 10.10.2005
            '----------------Закоментировано Семененко Д.Е. 17.06.2016 в связи с обращением банка
            'Причина обращения: При сохранении закрытого договора с получателем со ВКЛАДКИ КОМИССИЯ, договор переходит в состояние открыт.
            'If cmbStatus.Visible = False Then
            '    objParamIn.Parameter("STATE") = 0
            'Else
            objParamIn.Parameter("STATE") = cmbStatus.ItemData(cmbStatus.ListIndex)
            'End If
            '----------------------------------------

            UbsChannel.Run "Contract", objParamIn, objParamOut

            If Len(objParamOut.Parameter("strError")) = 0 Then
                If StrCommand <> "EDIT" Then
                    StrCommand = "EDIT"
                    idObject = objParamOut.Parameter("IDCONTRACT")
                    AddProperties.Refresh
                End If
                UbsDDX.SetInitMemberData
                bNeedRefreshGrid = True
                Info.Caption = "Договор сохранен в БД"
                Info.Show
            Else
                Info.Caption = objParamOut.Parameter("strError")
                Info.Show
                objInterfaces.GoToCtrl txtCode
            End If
        Else
            Call MsgBox("Объект с таким кодом уже существует!", 16, "Проверка корректности данных")
            '       Info.Caption = "Объект с таким кодом уже существует"
            '       Info.Show
            subContract.Tabs(1).Selected = True
            If subContract.SelectedTab.Index = 1 Then
                objInterfaces.GoToCtrl txtCode
            End If
        End If

    End If
    Call EnableCode()
    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "SaveBtn_Click", "ошибка выполнения"
End Sub

Private Sub cboTypeRec_Click()
    Call EnableSum()
End Sub

Private Sub cboTypeSend_Click()
    Call EnableSum()
End Sub

'---------------------------------------------------- Новопашин В.М. 11.08.2006 г. ---
Private Sub cmbStatus_Click()

    On Error GoTo ErrorCode

    If cmbStatus.ItemData(cmbStatus.ListIndex) = "1" Then
        lblDateClose.Visible = True
        txtDateClose.Visible = True
    Else
        lblDateClose.Visible = False
        txtDateClose.Visible = False
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "cmbStatus_Click", "ошибка выполнения"

End Sub
