Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = True
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = True
Option Explicit On

Implements UBSChild
Public Parent As UBSParrent
Dim StrCommand As String
Dim NumWin As Integer, NumParentWindow As Integer, NumChildWin As Integer, NumChildWinContract As Integer
Dim NumChildWinAttributeRecip As Integer
