Private Sub UserDocument_Hide()
    On Error GoTo ErrorCode
    Set Wait = Nothing
    Set objErr = Nothing
    Set objFormParam = Nothing
    Set objFocusCtrl = Nothing
    Set objParamIn = Nothing
    Set objParamOut = Nothing
    Set objInterfaces = Nothing
    
    Set objFormat = Nothing
    
    objStub.ReleaseUbsChannel
    Set objStub = Nothing
    
    If Not blnParentWindowClose And Parent.IsExistParam(NumParentWindow, "NeedRefreshGrid") = True And blnNeedRefreshGrid = True Then
        Parent.ParamInfo(NumParentWindow, "NeedRefreshGrid") = True
    End If
    '-----
    Set Parent = Nothing
    '-----
    Exit Sub
ErrorCode:
    objErr.UbsMsgRaise "UserDocument_Hide", "ошибка выполнения"
End Sub

Private Sub UserDocument_Initialize()
    Set objStub = CreateObject("UbsAddFiledsStub.IUbsAddFiledsStub")
    Set objFormParam = CreateObject("ToolPubs.IUbsParam")
    Set objInterfaces = CreateObject("ToolPubs.Interfaces")
'=====
    Set objErr = CreateObject("ToolPubs.IUbsError")
    Set Wait = CreateObject("UbsWait.UbsWaitBox")
'====
    Set objFormat = CreateObject("Lib3.IUbsFormat")

    Set objParamIn = CreateObject("Lib2.IUbsParam")
    Set objParamOut = CreateObject("Lib2.IUbsParam")


    objFormParam.Parameter("WaitShow") = True
    objFormParam.Parameter("InitParamForm") = True
    objFormParam.Parameter("SetFocus") = True
    objFormParam.Parameter("LostFocus") = True
    objFormParam.Parameter("RetFromGrid") = True
    '======================
    objFormParam.Parameter("LoadFromMenu") = True
    '======================
End Sub

Private Function CheckParamForClose(ByVal NameParam As String) As Boolean
    CheckParamForClose = False
    If NameParam = "LoadFromMenu" Or
        NameParam = "InitParamForm" Or
        NameParam = "RetFromGrid" Or
        NameParam = "InitParamGrid" Then
        CheckParamForClose = True
    End If
End Function

Private Sub InitDoc()

    On Error GoTo ErrorCode

    Dim varState As Variant
    Dim i As Integer
    Dim lngIndex As Long
    Dim ressql As Variant, t As Variant
    Dim dDateBeg As Date, dDateEnd As Date

    btnSaveAttribute.Visible = False
    btnListAttributeRecip.Visible = False

    txtRecip.Enabled = False
    lblRecip.Enabled = False
    curPeny.Enabled = False

    blnAlready = False
    subPayment.Tabs(2).Enabled = False

    'm_nNumTabAddFl = 2

    m_blnSave = False
    m_blnClickSave = False

    'UbsChannel.HostAddress = Parent.LoaderParamInfo(NumWin, "HostAddress")
    'UbsChannel.UserGUID = Parent.LoaderParamInfo(NumWin, "GuidSession")
    'UbsChannel.ParentHwnd = UserDocument.hWnd
    'для доп .полей
    'Set objStub.UbsChannel = UbsChannel
    'UbsChannel.LoadResource = "VBS:UBS_VBD\PS\UT\UtPaymentF.vbs"

    objParamIn.Parameter("StrCommand") = StrCommand
    objParamIn.Parameter("IdPayment") = m_IdPayment

    UbsChannel.Run "InitFormGroup", objParamIn, objParamOut

    'UbsChannel.Run "UtReadSettingChoiceClient", objParamIn, objParamOut
    'If Not objParamOut.Parameter("bRetVal") And objParamOut.Parameter("strError") <> "" Then
    If objParamOut.Parameter("strError") <> "" Then
        MsgBox objParamOut.Parameter("strError"), 16, "Проверка"
        btnExit_Click()
        Exit Sub
    Else
        If objParamOut.Parameter("ChoiceClient") = 0 Then
            blnGuest = True
        Else
            blnGuest = False
        End If
        blnEndGroup = objParamOut.Parameter("EndGroup")
        GroupContract = objParamOut.Parameter("GroupContract")
        curPeny.CurrencyValue = objParamOut.Parameter("SummaPeni")
    End If

    AddProperties.Refresh

    cmbCode.Clear
    For i = 0 To UBound(GroupContract, 2)
        cmbCode.List(i) = GroupContract(1, i)
        cmbCode.ItemData(i) = GroupContract(0, i)
    Next
    '    cmbCode.ListIndex = 0


    If StrCommand = "GROUP_EDIT" Then
        Call ReadContract()

        If blnEndGroup Then
            DisableAllFields()
        End If
        AddProperties.Refresh
    ElseIf StrCommand = "GROUP_ADD" Then

        Call EnableAllFields()

    End If

    'Call CheckPayer(False)

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "InitDoc", "ошибка выполнения"
End Sub

Private Sub UserDocument_KeyDown(KeyCode As Integer, Shift As Integer)
    If Shift = 2 And KeyCode = vbKeyTab Then
        Set objFocusCtrl = UserDocument.ActiveControl
        Parent.LoaderParamInfo(0, "NextWindow") = NumWin
    End If
End Sub

Private Sub UserDocument_KeyPress(KeyAscii As Integer)
    On Error GoTo ErrorCode

    'If subPayment.Index = 2 Then
    '    AddProperties.SetFocus
    'End If

    Select Case KeyAscii
        Case 13
            KeyAscii = 0
            Select Case (UserDocument.ActiveControl.Name)
                Case "curSumma"
                    If subPayment.Tabs(2).Enabled Then
                        If AddProperties.PropertyCount <> 0 Then
                            subPayment.Tabs(2).Selected = True
                            AddProperties.SetFocus
                        Else
                            btnSave.SetFocus
                        End If
                    Else
                        btnSave.SetFocus
                    End If

                Case "AccClient"
                    If CheckRS() Then
                        If m_IdContract <> 0 Then
                            objParamIn.ClearParameters
                            objParamIn.Parameter("ACC") = AccClient.Text
                            objParamIn.Parameter("BIC") = txtBic.Text
                            objParamIn.Parameter("IdContract") = m_IdContract
                            UbsChannel.Run "UtGetINNFromLastPayment", objParamIn, objParamOut
                            'Переносим данные ИНН
                            If txtINN.Enabled = True Then
                                txtINN.Text = objParamOut.Parameter("INN")
                            End If
                            If cmbPurpose.Enabled Then
                                If Not IsComboBoxItemExists(objParamOut.Parameter("PURPOSE")) _
                                   And Len(Trim(CStr(objParamOut.Parameter("PURPOSE")))) = 0 Then
                                    cmbPurpose.AddItem objParamOut.Parameter("PURPOSE"), cmbPurpose.ListCount - 1
                                    cmbPurpose.ListIndex = cmbPurpose.NewIndex
                                End If
                            End If
                            If objParamOut.Parameter("IDPAYMENT") <> "" Then
                                objParamIn.ClearParameters
                                objParamIn.Parameter("IDPAYMENT") = objParamOut.Parameter("IDPAYMENT")
                                UbsChannel.Run "UtGetKPPUPayerLastPayment", objParamIn, objParamOut
                                txtRecip.Text = objParamOut.Parameter("Recip")
                                AddProperties.Refresh
                            End If
                            objParamIn.Parameter("ACC") = AccClient.Text
                            objInterfaces.NextCtrl
                        End If
                    End If
                Case Else
                    objInterfaces.NextCtrl
            End Select
            'objInterfaces.NextCtrl
        Case 27
            Select Case (UserDocument.ActiveControl.Name)
                Case "txtFIOPay"
                    btnExit.SetFocus
                Case Else
                    If subPayment.Tabs(2).Enabled And subPayment.Tabs(2).Selected Then
                        subPayment.Tabs(1).Selected = True
                        curSumma.SetFocus
                    Else
                        objInterfaces.PrevCtrl
                    End If
            End Select
            'objInterfaces.PrevCtrl
    End Select

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "UserDocument_KeyPress", "ошибка выполнения"
End Sub

' обработка нажатий клавиш на контроле Доп. полей
Private Sub AddProperties_KeyPress(ByVal nKeyCode As Integer)

    On Error GoTo ErrorCode

    Select Case (nKeyCode)
        Case 13
            nKeyCode = 0
            If AddProperties.PropertyCurrentIndex = AddProperties.PropertyCount - 1 Then
                objInterfaces.NextCtrl
            End If
        Case 27
            nKeyCode = Asc(Chr(0))  'Chr(0) - это пробел
            subPayment.Tabs(1).Selected = True
            objInterfaces.GoToCtrl curSumma
    End Select

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "AddProperties_KeyPress", "ошибка выполнения"
End Sub

' заполнение списка Назначение платежа
Private Function FillPurpose(arrPurpose As Variant)
    Dim i As Integer, intIndex As Integer

    On Error GoTo ErrorCode

    cmbPurpose.Clear
    intIndex = 0

    If IsArray(arrPurpose) Then

        For i = 0 To UBound(arrPurpose, 2)
            cmbPurpose.AddItem arrPurpose(0, i), i
        Next

        cmbPurpose.ListIndex = 0
    End If

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "FillPurpose", "ошибка выполнения"
End Function

Private Sub FindContractbyId()
    Dim blnSepDoc As Boolean

    On Error GoTo ErrorCode

    blnArbitrary = False
    'If m_blnChangeContract = True Then
    '    txtCheckSum.Text = ""
    '    m_strAccCode = Empty
    '    m_strCheckSum = Empty
    '    m_strCheckType = Empty
    '    m_blnChangeContract = False
    'End If


    txtRecip = ""
    txtComment.Text = ""
    txtBic.Text = ""
    AccKorr.Text = ""
    txtINN.Text = ""
    AccClient.Text = ""
    txtNameBank.Text = ""

    'If StrCommand <> "VIEW" Then
    If blnEndGroup = False Then
        cmbPurpose.Text = ""
    End If

    'm_IdKindPaym = 0

    If m_IdContract > 0 Then
        objParamIn.ClearParameters
        objParamIn.Parameter("IdContract") = m_IdContract
        'UbsChannel.Run "UtReadTypePayment", objParamIn, objParamOut
        'If objParamOut.Parameter("bRetVal") = False Then
        '    MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
        '    m_IdContract = 0
        '    Exit Sub
        'End If

        UbsChannel.Run "UtReadContract", objParamIn, objParamOut
        If objParamOut.Parameter("bRetVal") = False And objParamOut.Parameter("StrError") <> "" Then
            Call MsgBox(objParamOut.Parameter("StrError"), vbCritical + vbDefaultButton1 + vbOKOnly, m_strCaptionForm)
            m_IdContract = 0 'Надо обнулить идентификатор договора, т.к Call после этой
            'функции вызывается функция и валится CalcSumCommiss
            Exit Sub
        End If

        If objParamOut.ExistParameter("Комментарий") Then
            MsgBox CStr(objParamOut.Parameter("Комментарий")), vbInformation, m_strCaptionForm
        End If

        If objParamOut.Parameter("bRetVal") = False And objParamOut.Parameter("StrError") <> "" Then
            MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
            m_IdContract = 0
            Exit Sub
        End If

        If objParamOut.Parameter("State") = 1 Then
            MsgBox "Внимание!!! Договор закрыт.", vbOKOnly, m_strCaptionForm '"Платёж"
        End If

        ReDim m_arrRateSend(5)
        ' данные для расчета комиссии с плательщика
        m_arrRateSend(0) = objParamOut.Parameter("RateTypeSend")
        m_arrRateSend(1) = objParamOut.Parameter("RatePercentSend")
        m_arrRateSend(2) = objParamOut.Parameter("MinSumSend")
        m_arrRateSend(3) = objParamOut.Parameter("MaxSumSend")
        m_arrRateSend(4) = objParamOut.Parameter("Комиссии с плательщика-признак ставки")
        m_arrRateSend(5) = objParamOut.Parameter("Комиссии с плательщика-тарифная сетка")

        intState = objParamOut.Parameter("State")

        cmbCode.ItemData(cmbCode.ListIndex) = m_IdContract
        'txtCode.Text = objParamOut.Parameter("Code")
        txtComment.Text = objParamOut.Parameter("Comment")
        txtBic.Text = objParamOut.Parameter("BIC")
        AccKorr.Text = objParamOut.Parameter("CorrAcc")
        txtINN.Text = objParamOut.Parameter("INN")
        AccClient.Text = objParamOut.Parameter("Acc")

        '---------------------------
        If objParamOut.Parameter("Acc") = "00000000000000000000" Then
            txtINN.Enabled = True
        End If
        'm_SIDPattern = objParamOut.Parameter("IdPattern")
        m_strAddress = objParamOut.Parameter("Adress")
        '----------------------------

        If m_IdContract <> 0 And objParamOut.Parameter("BIC") = "" And objParamOut.Parameter("Acc") = "00000000000000000000" Then
            btnListAttributeRecip.Visible = True
            btnSaveAttribute.Visible = True
        Else
            btnListAttributeRecip.Visible = False
            btnSaveAttribute.Visible = False
        End If

        If Trim(txtBic.Text) = "" Then
            blnArbitrary = True
        End If

        txtINN.Enabled = objParamOut.Parameter("IsSeparateDoc")



        'm_IdKindPaym = objParamOut.Parameter("IdKindPayment")

        ' заполнить Назначение платежа данными из одноименного доп. поля Договора
        If StrCommand = "ADD" Then
            FillPurpose objParamOut.Parameter("arrPurpose")
            UbsChannel.Run "UtReadSetupLockPurpose", objParamIn, objParamOut
            If Not objParamOut.Parameter("bRetVal") And objParamOut.Parameter("StrError") <> "" Then
                MsgBox objParamOut.Parameter("strError"), vbOKOnly, "Платёж"
            Else
                cmbPurpose.Enabled = objParamOut.Parameter("blnPurposeLock")
            End If
        End If


        'заполняем наименование банка
        objParamIn.Parameter("BIC") = objParamOut.Parameter("BIC")
        UbsChannel.Run "ReadBankBIK", objParamIn, objParamOut
        Call GetBankNameACC()

        subPayment.Tabs(1).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            'If blnForward Then
            If txtINN.Visible And txtINN.Enabled And Not blnArbitrary Then
                objInterfaces.GoToCtrl txtINN
            ElseIf txtBic.Visible And txtBic.Enabled And blnArbitrary Then
                objInterfaces.GoToCtrl txtBic
            ElseIf cmbPurpose.Visible And cmbPurpose.Enabled Then
                objInterfaces.GoToCtrl cmbPurpose
            End If
            'End If
        End If

        objParamIn.Parameter("IdContract") = m_IdContract
        objParamIn.Parameter("StrCommand") = "CHANGECONTRACT"



        AddProperties.Refresh
        If AddProperties.PropertyCount = 0 Then
            subPayment.Tabs(2).Enabled = False
        Else
            subPayment.Tabs(2).Enabled = True
        End If

    Else
        btnListAttributeRecip.Visible = False
        btnSaveAttribute.Visible = False
    End If

    If blnArbitrary Then
        txtRecip.Enabled = True
        lblRecip.Enabled = True
    Else

        txtRecip.Enabled = False
        lblRecip.Enabled = False
    End If

    If m_IdContract <> 0 And blnEndGroup = False Then
        If txtBic.Text <> "" Then
            txtBic.Enabled = False
        Else
            txtBic.Enabled = True
        End If

        If txtINN.Text <> "" Then
            txtINN.Enabled = False
        Else
            txtINN.Enabled = True
        End If

        If AccClient.Text <> "00000000000000000000" Then
            AccClient.Enabled = False
        Else
            AccClient.Enabled = True
        End If

        'If blnForward Then
        '    If txtBic.Enabled Then
        '       txtBic.SetFocus
        '    ElseIf AccClient.Enabled Then
        '       AccClient.SetFocus
        '    ElseIf txtINN.Enabled Then
        '       txtINN.SetFocus
        '    ElseIf cmbPurpose.Enabled Then
        '       cmbPurpose.SetFocus
        '    Else
        '       curSumma.SetFocus
        '    End If
        'End If

        'Подстановка значения поля КППУ из договора
        If StrCommand = "ADD" Then
            objParamIn.Parameter("IdContract") = m_IdContract
            UbsChannel.Run "UtGetKPPU", objParamIn, objParamOut
           AddProperties.Refresh
        End If

        'Если указан плательщик и БИК
        If m_IdClient <> 0 And Len(Trim(txtBic.Text)) <> 0 Then
            objParamIn.ClearParameters
            objParamIn.Parameter("IdContract") = m_IdContract
            objParamIn.Parameter("IdClient") = m_IdClient
            objParamIn.Parameter("BIC") = txtBic.Text
            UbsChannel.Run "UtGetAccINNFromLastPayment", objParamIn, objParamOut
            'С предыдущего платежа при введеном плательщике, БИК и коде договора вносим
            'ИНН, расчетный счет и назначение платежа

            'Переносим данные ИНН
            If txtINN.Enabled = True Then
                txtINN.Text = objParamOut.Parameter("INN")
            End If

            'Переносим данные р/с
            If AccClient.Enabled = True Then
                AccClient.Text = objParamOut.Parameter("ACC")
            End If

            'Заносятся данные назначение платежа из последнего платежа
            If cmbPurpose.Enabled Then
                If Not IsComboBoxItemExists(objParamOut.Parameter("PURPOSE")) And Len(Trim(CStr(objParamOut.Parameter("PURPOSE")))) <> 0 Then
                    cmbPurpose.AddItem objParamOut.Parameter("PURPOSE"), cmbPurpose.ListCount '- 1
                    cmbPurpose.ListIndex = cmbPurpose.NewIndex
                End If
            End If
        End If
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Поиск информации о договоре с использованием идентификатора", "ошибка выполнения"
End Sub

