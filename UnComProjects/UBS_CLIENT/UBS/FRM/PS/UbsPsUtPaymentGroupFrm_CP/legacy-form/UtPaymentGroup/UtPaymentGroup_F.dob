Function IsComboBoxItemExists(Item As String) As Boolean
    Dim lngI As Long

    IsComboBoxItemExists = False
    For lngI = 0 To cmbPurpose.ListCount
        If cmbPurpose.List(lngI) = Item Then
            IsComboBoxItemExists = True
            Exit For
        End If
    Next lngI

End Function

Function GetBankNameACC()
    GetBankNameACC = False

    Dim ressql As Variant
    Dim i As Integer

    On Error GoTo ErrorCode

    'Комплексная проверка по БИК
    objParamIn.Parameter("BIC") = txtBic.Text
    UbsChannel.Run "UtCheckBIKBank", objParamIn, objParamOut
    If Not objParamOut.Parameter("bRetVal") Then
        If m_blnNoMessage Then
            MsgBox objParamOut.Parameter("strError"), 16, m_strCaptionForm
       End If
        Exit Function
    End If


    'Проверка на признаки ограничения участия в расчетах
    objParamIn.Parameter("BIC") = txtBic.Text
    UbsChannel.Run "UtCheckBIKLimitSharing", objParamIn, objParamOut
    If Not objParamOut.Parameter("bRetVal") Then
        If Not MsgBox(objParamOut.Parameter("strError") & vbCrLf & "Продолжить ввод платежа?", vbYesNo + vbQuestion, "Проверка корректности данных") = vbYes Then
            cmbCode.ListIndex = -1
            'txtCode.Text = ""
            txtComment.Text = ""
            txtBic.Text = ""
            txtBic.Enabled = True
            txtBic.Visible = True
            AccKorr.Text = "00000000000000000000"
            txtNameBank.Text = ""
            txtINN.Text = ""
            txtINN.Enabled = True
            AccClient.Text = "00000000000000000000"
            AccClient.Enabled = True
            cmbPurpose.Clear
            cmbPurpose.Text = ""
            txtRecip.Text = ""
            Exit Function
        End If
    End If

    objParamIn.Parameter("BIC") = txtBic.Text

    UbsChannel.Run "ReadBankBIK", objParamIn, objParamOut

    ressql = objParamOut.Parameters

    If objParamOut.Parameter("NUM") > 0 Then
        For i = 0 To objParamOut.CountParameters - 1

            Select Case ressql(0, i)
                Case "BANKNAME"
                    txtNameBank.Text = ressql(1, i)
                Case "CORRACC"
                    AccKorr.Text = ressql(1, i)
            End Select
        Next

        GetBankNameACC = True
    End If

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "GetBankNameACC", "ошибка выполнения"
End Function

Private Function CheckPayment()

    'Dim intIsFIOPay As Integer
    
    Set objParamIn = CreateObject("ToolPubs.IUbsParam")
    Set objParamOut = CreateObject("ToolPubs.IUbsParam")

On Error GoTo ErrorCode

    CheckPayment = True

    'Проверка заблокированных паспортов
    If CheckLockPassport() = False Then
        CheckPayment = False
        Exit Function
    End If

    If intState = 1 Then
        CheckPayment = False
        MsgBox "Не выбран договор с получателем!", 16, m_strCaptionForm
       subPayment.Tabs(1).Selected = True

        If subPayment.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl cmbCode
       End If
        Exit Function
    End If

    If CLng(m_IdContract) = CLng(0) Then
        CheckPayment = False
        MsgBox "Не выбран договор с получателем!", 16, m_strCaptionForm
        subPayment.Tabs(1).Selected = True

        If subPayment.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl cmbCode
        End If
        Exit Function
    End If

    'проверка на террориста
    If CheckTerror() = False Then
        CheckPayment = False
        Exit Function
    End If

    objParamIn.ClearParameters
    objParamOut.ClearParameters

    'Во входных параметрах ставим считываемую установку
    'UbsChannel.Run "UTReadSettingChechkClient", objParamIn, objParamOut
    'If Not IsEmpty(objParamOut.Parameter("Result")) Then
    '   intIsFIOPay = CInt(objParamOut.Parameter("Result"))
    'Else
    '   intIsFIOPay = 0
    'End If
    'Если установка установлена в 1, то проверяем плательщика
    'If intIsFIOPay = 1 And Len(txtFIOPay.Text) = 0 Then
    If Len(txtFIOPay.Text) = 0 Then
        CheckPayment = False
        MsgBox "Введите ФИО плательщика.", vbCritical, m_strCaptionForm
       subPayment.Tabs(1).Selected = True
        txtFIOPay.SetFocus
        Exit Function
    End If

    If GetBankNameACC() = False Then
        CheckPayment = False
        subPayment.Tabs(1).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            If txtBic.Enabled Then txtBic.SetFocus
        End If
        Exit Function
    End If

    objParamIn.ClearParameters
    objParamOut.ClearParameters
    'Доработка по приему произвольных договоров
    objParamIn.Parameter("BIC") = Trim(txtBic.Text)
    objParamIn.Parameter("ACC") = AccClient.Text
    objParamIn.Parameter("IdContract") = m_IdContract
    UbsChannel.Run "UtCheckAccFromBic", objParamIn, objParamOut
    If objParamOut.Parameter("bRetVal") = False Then
        CheckPayment = False
        MsgBox objParamOut.Parameter("strError"), 16, m_strCaptionForm
       subPayment.Tabs(1).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            If AccClient.Enabled Then
                objInterfaces.GoToCtrl AccClient
          Else
                objInterfaces.GoToCtrl cmbCode
          End If
        End If
        Exit Function
    End If

    'проверка ключа расчетного счета счета
    objParamIn.Parameter("STRACC") = AccClient.Text
    objParamIn.Parameter("BIC") = txtBic.Text
    objParamIn.Parameter("CORRACC") = AccKorr.Text

    If curSumma.CurrencyValue = CCur(0) Then
        CheckPayment = False
        MsgBox "Некорректная сумма платежа!", 16, m_strCaptionForm
        subPayment.Tabs(1).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl curSumma
        End If
        Exit Function
    End If

    If curSummaTotal.CurrencyValue < 0 Then
        CheckPayment = False
        MsgBox "Некорректная общая сумма платежа!", 16, m_strCaptionForm
        subPayment.Tabs(1).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl curSumma
        End If
        Exit Function
    End If

    ' проверим в сценарии доп.поля объекта
    objParamIn.ClearParameters
    objParamOut.ClearParameters
    UbsChannel.Run "CheckAddFields", objParamIn, objParamOut
    If objParamOut.Parameter("bRetVal") = False Then
        CheckPayment = False
        MsgBox objParamOut.Parameter("StrError"), 16, "Проверка доп. полей. " & m_strCaptionForm
        subPayment.Tabs(2).Selected = True
        Exit Function
    End If

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CheckPayment", "ошибка выполнения"
End Function

'проверка на террориста
Function CheckTerror()

    On Error GoTo ErrorCode

    CheckTerror = True

    objParamIn.ClearParameters
    objParamOut.ClearParameters

    objParamIn.Parameter("NAME") = txtFIOPay.Text
    objParamIn.Parameter("IDCONTRACT") = m_IdContract
    objParamIn.Parameter("PURPOSE") = cmbPurpose.Text
    objParamIn.Parameter("RECIPIENTNAME") = txtRecip.Text

    UbsChannel.Run "CheckTerror", objParamIn, objParamOut

   If Not objParamOut.ExistParameter("RETVAL") Then Exit Function

    If Not objParamOut.Parameter("RETVAL") Then
        If MsgBox(objParamOut.Parameter("StrError"), vbOKCancel + vbQuestion, "Проверка корректности данных") = vbOK Then
            blnTerror = True
            If m_IdClient = 0 And objParamOut.ExistParameter("blnErrorPayer") Then
                subPayment.Tabs(1).Selected = True
                btnClient.SetFocus
                CheckTerror = False
                MsgBox "Клиента подозреваемого в террористической деятельности надо выбрать из справочника!!!", vbOKOnly + vbInformation, "Проверка корректности данных"
               btnClient_Click()
            End If
        Else
            CheckTerror = False
            Exit Function
        End If
    End If

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CheckTerror", "ошибка выполнения"
End Function

Function CheckRS()

    On Error GoTo ErrorCode

    CheckRS = True

    Dim strOurBankBic As String
    UbsChannel.Run "UtReadOurBankBik", objParamIn, objParamOut
    strOurBankBic = CStr(objParamOut.Parameter("strOurBankBic"))
    If AccClient.Text = "00000000000000000000" _
        And Trim(strOurBankBic) = Trim(txtBic.Text) Then
        CheckRS = False
        MsgBox "Некорректный расчетный счет!", 16, m_strCaptionForm
        subPayment.Tabs(1).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            If AccClient.Enabled Then
                objInterfaces.GoToCtrl AccClient
            Else
                objInterfaces.GoToCtrl cmbCode
            End If
        End If
        Exit Function
    End If

    'проверка ключа расчетного счета счета
    objParamIn.Parameter("STRACC") = AccClient.Text
    objParamIn.Parameter("BIC") = txtBic.Text
    objParamIn.Parameter("CORRACC") = AccKorr.Text
    UbsChannel.Run "CheckKey", objParamIn, objParamOut
    If objParamOut.Parameter("RETVAL") = False Then
        CheckRS = False
        MsgBox "Некорректный ключ счета!", 16, m_strCaptionForm
        subPayment.Tabs(1).Selected = True
        If subPayment.SelectedTab.Index = 1 Then
            objInterfaces.GoToCtrl AccClient
        End If
        Exit Function
    End If

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CheckRS", "ошибка выполнения"
End Function

'Запуск дополнительной проверки определяемой пользователем
Function Ut_CheckUserBeforeSave()
    Dim blnRes As Boolean
    Dim objParamUserIn As Object, objParamUserOut As Object
    Dim varAddFields As Variant, strError As String
    Dim lngI As Long
    Set objParamUserIn = CreateObject("ToolPubs.IUbsParam")
    Set objParamUserOut = CreateObject("ToolPubs.IUbsParam")
     
On Error GoTo Err_Proc

    Ut_CheckUserBeforeSave = True

    objParamUserIn.ClearParameters
    objParamUserOut.ClearParameters

    'Считываем значение доп. полей
    UbsChannel.Run "UTListAddRead", objParamUserIn, objParamUserOut

    'При редактировании передавать в пользовательский сценарий проверки идентификатор платежа
    If StrCommand = "CHANGE_PART" Then
        objParamUserIn.Parameter("IDPAYMENT") = m_IdPayment
    End If

    objParamUserIn.Parameter("IDCONTRACT") = m_IdContract         '  идентификатор контракта
    objParamUserIn.Parameter("CODE") = cmbCode.Text               '  код контракта
    objParamUserIn.Parameter("INN") = txtINN.Text                 '  ИНН получателя платежа
    objParamUserIn.Parameter("BIC") = txtBic.Text                 '  БИК банка
    objParamUserIn.Parameter("CORRACC") = AccKorr.Text            '  к/с получателя платежа
    objParamUserIn.Parameter("ACC") = AccClient.Text              '  р/с получатела платежа
    objParamUserIn.Parameter("IDCLIENT") = m_IdClient             '  id клиента
    objParamUserIn.Parameter("PAYERFIO") = txtFIOPay.Text         '  ФИО плательщика
    objParamUserIn.Parameter("PAYERINN") = txtINNPay.Text         '  ИНН плательщика
    objParamUserIn.Parameter("PAYERADDRESS") = txtAdressPay.Text  '  адрес плательщика
    objParamUserIn.Parameter("RECIPIENTNAME") = txtRecip.Text     '  Наименование получателя
    objParamUserIn.Parameter("PURPOSE") = cmbPurpose.Text         '  назначение платежа
    objParamUserIn.Parameter("SUMMA") = curSumma.CurrencyValue    '  сумма
    objParamUserIn.Parameter("SUMMARATESEND") = curSummaRateSend.CurrencyValue  ' комиссия с плательщика
    objParamUserIn.Parameter("SUMMATOTAL") = curSummaTotal.CurrencyValue ' Итого к оплате

    'Если доп. поля есть на форме, то передаём их в виде входных параметров
    If objParamUserOut.ExistParameter("AddFields") Then
        varAddFields = objParamUserOut.Parameter("AddFields")
        For lngI = 0 To UBound(varAddFields, 2)
            objParamUserIn.Parameter(varAddFields(1, lngI)) = varAddFields(7, lngI)
        Next lngI
    End If

    UbsChannel.Run "Ut_CheckBeforeSave", objParamUserIn, objParamUserOut

    btnExit.Enabled = True
    strError = objParamUserOut.Parameter("Error")
    blnRes = CBool(objParamUserOut.Parameter("bRet"))
    If Len(strError) > 0 And blnRes Then
        If MsgBox(strError, vbInformation + vbYesNo, m_strCaptionForm) = vbNo Then
            Ut_CheckUserBeforeSave = False
        End If
    ElseIf Not blnRes Then
        If Len(strError) > 0 Then
            MsgBox strError, vbCritical, m_strCaptionForm
        End If
        btnSave.Enabled = False
        Ut_CheckUserBeforeSave = False
    End If

    Exit Function

Err_Proc:
    Ut_CheckUserBeforeSave = False
    m_blnSave = False
    objErr.UbsErrMsg "Ut_CheckUserBeforeSave", "ошибка выполнения"
End Function

'Проверка заблокированности паспорта
Function CheckLockPassport() As Boolean
    CheckLockPassport = True

    Dim ret As Boolean, objComCheck As Object

    If Len(Trim(m_strDocNumber)) <> 0 Or Len(Trim(m_strDocSeries)) <> 0 Then
        Set objComCheck = CreateObject("UbsCheck.UbsComCheck")
    
        'Dim clientFullName, firstName, lastName, patronymic
        'clientFullName = Split(Trim(txtFIOPay.Text), " ")
        '
        'firstName = clientFullName(1)
        'lastName = clientFullName(0)
        '
        'patronymic = ""
        'If UBound(clientFullName, 1) = 2 Then
        '        patronymic = clientFullName(2)
        'End If
        
        ' Проверка на заблокированные паспорта
        ret = objComCheck.CommonCheckPassport4GISMU(UbsChannel, CLng(m_IdClient), Empty)

        CheckLockPassport = ret
    End If

End Function


Function CheckIPDL()
    CheckIPDL = True

    Dim ret As Integer, objComCheck As Object
    
    Set objComCheck = CreateObject("UbsCheck.UbsComCheck")
    
    ret = objComCheck.CommonCheckIPDL(UbsChannel)

    If ret = 0 Then      ' не является ИПДЛ
        blnIPDL = False
    ElseIf ret = 1 Then  ' является ИПДЛ, разрешено
        blnIPDL = True
    Else                 ' является ИПДЛ, не разрешено
        blnIPDL = True
        CheckIPDL = False
    End If

End Function

' проверяется ввод в текстовое поле только цифр
Private Sub CheckInt(Control As TextBox, KeyCode As Integer)

    On Error GoTo ErrorCode

    Control.Locked = False

    If (KeyCode >= 48 And KeyCode <= 57) Or (KeyCode >= 96 And KeyCode <= 105) Or KeyCode = 8 Or KeyCode = 46 Then
        Control.Locked = False
    Else
        Control.Locked = True
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "CheckInt", "ошибка выполнения"
End Sub

Private Function NewRecord()

    btnSave.Enabled = True
    btnClient.Enabled = True
    cmbCode.Enabled = True

    objParamIn.Parameter("StrCommand") = "CLEAR"
    UbsChannel.Run "PAYMENT", objParamIn, objParamOut
    cmbPurpose.Clear
    cmbPurpose.Text = ""
    m_IdPayment = 0
    'blnForward = True
    m_blnNoMessage = False

    Call InitDoc()
    Call clearRecFieldsSend()
    Call clearRecFields()

    If txtFIOPay.Enabled Then
        txtFIOPay.SetFocus
    End If

End Function

' очищение полей плательщика, если требуется
Sub clearRecFieldsSend()

    On Error GoTo ErrorCode

    Dim IsClear As Boolean

    UbsChannel.Run "UtGetStateClearFieldSend", objParamIn, objParamOut
    IsClear = False

    If objParamOut.Parameter("bRetVal") = True Then
        IsClear = objParamOut.Parameter("IsClearSend")
    Else
        MsgBox objParamOut.Parameter("StrError"), 16, "Очищать данные клиента. " & m_strCaptionForm
        Exit Sub
    End If

    If CBool(IsClear) Then
        txtINNPay.Text = ""
        txtFIOPay.Text = ""
        txtInfoClient.Text = ""
        txtAdressPay.Text = ""
        m_IdClient = 0

    Else
        'txtFIOPay.Text = m_OldtxtFIOPay
        'txtInfoClient.Text = m_OldtxtInfoClient
        'txtINNPay.Text = m_OldtxtINNPay
        'txtAdressPay.Text = m_OldtxtAdressPay
    End If

    'Call CheckPayer(False)

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "clearRecFieldsSend", "ошибка выполнения"
End Sub

Sub DisableAllFields()
    txtFIOPay.Enabled = False
    btnClient.Enabled = False
    txtINNPay.Enabled = False
    txtAdressPay.Enabled = False
    cmbCode.Enabled = False
    txtComment.Enabled = False
    txtBic.Enabled = False
    AccKorr.Enabled = False
    txtNameBank.Enabled = False
    txtINN.Enabled = False
    AccClient.Enabled = False
    cmbPurpose.Enabled = False
    curSumma.Enabled = False
    btnSave.Enabled = False
    AddProperties.Enabled = False
    txtRecip.Enabled = False

End Sub

Sub EnableAllFields()

    txtFIOPay.Enabled = True
    btnClient.Enabled = True
    txtINNPay.Enabled = True
    txtAdressPay.Enabled = True
    cmbCode.Enabled = True
    txtComment.Enabled = True
    txtBic.Enabled = True
    AccKorr.Enabled = True
    txtNameBank.Enabled = True
    txtINN.Enabled = True
    AccClient.Enabled = True
    cmbPurpose.Enabled = True
    curSumma.Enabled = True
    btnSave.Enabled = True
    AddProperties.Enabled = True
    txtRecip.Enabled = True

End Sub

Sub clearRecFields()

    On Error GoTo ErrorCode

    Dim blnPurposeLock As Boolean

    cmbCode.ListIndex = -1
    txtComment.Text = ""
    txtBic.Text = ""
    txtBic.Enabled = True
    txtBic.Visible = True
    AccKorr.Text = "00000000000000000000"
    txtNameBank.Text = ""
    txtINN.Text = ""
    AccClient.Text = "00000000000000000000"
    AccClient.Enabled = True
    txtINN.Enabled = True

    UbsChannel.Run "UtReadSetupLockPurpose", objParamIn, objParamOut
    blnPurposeLock = objParamOut.Parameter("blnPurposeLock")
    If Not objParamOut.Parameter("bRetVal") Then
        MsgBox objParamOut.Parameter("strError"), vbOKOnly, "Платёж"
    Else
        cmbPurpose.Enabled = blnPurposeLock
    End If

    cmbPurpose.Text = ""
    curSumma.Text = "0"
    curSummaRateSend.Text = "0"
    curSummaTotal.Text = "0"
    'm_curSumRateRec = 0
    'm_curSumRec = 0

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "clearRecFieldsSend", "ошибка выполнения"
End Sub


Private Sub InitChannel()
    On Error GoTo ErrorCode

    UbsChannel.HostAddress = Parent.LoaderParamInfo(NumWin, "HostAddress")
    UbsChannel.UserGUID = Parent.LoaderParamInfo(NumWin, "GuidSession")
    UbsChannel.ParentHwnd = UserDocument.hWnd
    UbsChannel.LoadResource = "VBS:UBS_VBD\PS\UT\UtPaymentF.vbs"
 
    'Set objParamIn = CreateObject("Lib2.IUbsParam")
    'Set objParamOut = CreateObject("Lib2.IUbsParam")
     
    Set objStub.UbsChannel = UbsChannel
    AddProperties.UbsAddFields = objStub

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "InitChannel", "ошибка выполнения"
End Sub

