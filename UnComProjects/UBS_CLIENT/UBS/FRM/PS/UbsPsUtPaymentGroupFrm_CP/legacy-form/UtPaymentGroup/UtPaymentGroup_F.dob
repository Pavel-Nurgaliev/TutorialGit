'Считывание данных контракта
Sub ReadContract()

    On Error GoTo ErrorCode

    Dim dDateBeg As Date, dDateEnd As Date, strAccCode As String
    Dim StrNameRecip As String
    Dim i As Integer

    objParamOut.ClearParameters
    objParamIn.Parameter("StrCommand") = "READ"
    objParamIn.Parameter("IdPaym") = m_IdPayment

    UbsChannel.Run "Payment", objParamIn, objParamOut

    m_IdContract = objParamOut.Parameter("IdContract")
    m_IdClient = objParamOut.Parameter("IdClient")

    txtFIOPay.Text = objParamOut.Parameter("FIOSend")
    txtINNPay.Text = objParamOut.Parameter("PayerINN1")
    txtAdressPay.Text = objParamOut.Parameter("AdressSend")
    'txtCode.Text = objParamOut.Parameter("Code")

    'cmbCode.ItemData(cmbCode.ListIndex) = m_IdContract
    txtComment.Text = objParamOut.Parameter("Comment")
    txtBic.Text = objParamOut.Parameter("BIC")
    AccKorr.Text = objParamOut.Parameter("AccCorr")
    txtNameBank.Text = objParamOut.Parameter("NameBank")
    txtINN.Text = objParamOut.Parameter("INNRec1")
    AccClient.Text = objParamOut.Parameter("AccRec")
    cmbPurpose.Text = objParamOut.Parameter("Note")
    txtInfoClient.Text = objParamOut.Parameter("InfoClient")
    'txtRecip.Text = objParamOut.Parameter("RecipientName")
    StrNameRecip = objParamOut.Parameter("RecipientName")

    curSumma.CurrencyValue = objParamOut.Parameter("SummaPaym")
    curSummaRateSend.CurrencyValue = objParamOut.Parameter("SummaRateSend")
    curSummaTotal.CurrencyValue = objParamOut.Parameter("Summa")

    For i = 0 To UBound(GroupContract, 2)
        If GroupContract(0, i) = m_IdContract Then
            cmbCode.ListIndex = i
            Exit For
        End If
    Next
    'Call FindContractbyId

    txtRecip.Text = StrNameRecip

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "ReadContract", "ошибка выполнения"

End Sub


' расчет суммы комиссии
Function CalcSumCommiss()
    Dim intTypeSend As Integer
    Dim curSumRateSend As Currency, curSumTotal As Currency
    Dim curSumPaym As Currency, curPerSend As Currency
    Dim curMinSumSend As Currency, curMaxSumSend As Currency
    Dim arrStavka As Variant
    Dim strTarif As String
    Dim i As Integer
    Dim blnFind As Boolean

    On Error GoTo ErrorCode

    ' данные для расчета комиссии с плательщика
    intTypeSend = m_arrRateSend(0)   ' RateTypeSend
    curPerSend = m_arrRateSend(1)    ' RatePercentSend
    curMinSumSend = m_arrRateSend(2) ' MinSumSend
    curMaxSumSend = m_arrRateSend(3) ' MaxSumSend
    arrStavka = m_arrRateSend(5)
    strTarif = m_arrRateSend(4)

    curSumPaym = curSumma.CurrencyValue

    If IsArray(arrStavka) Then
        Select Case strTarif
            Case "ставка, %"
                intTypeSend = 1
            Case "фиксированная сумма"
                intTypeSend = 2
            Case Else
                Exit Function
        End Select

        If IsEmpty(arrStavka) Then
            Exit Function
        End If

        curPerSend = 0
        i = UBound(arrStavka, 2)
        blnFind = False
        Do
            If CCur(arrStavka(0, i)) <= CCur(curSumPaym) Then
                curPerSend = CCur(arrStavka(1, i))
                blnFind = True
            End If
            If i = 0 Then
                blnFind = True
            End If

            i = i - 1

        Loop While blnFind = False

    End If

    Select Case intTypeSend
        Case 0
            curSumRateSend = CCur(0)
        Case 1 ' % от суммы платежа
            curSumRateSend = objFormat.Round(CCur(curSumPaym) * CCur(curPerSend) / 100, 2)
        Case 2 ' фиксированная сумма
            curSumRateSend = objFormat.Round(curPerSend, 2)
    End Select

    If intTypeSend > 0 Then
        If curSumRateSend < curMinSumSend And curMinSumSend > 0 Then
            curSumRateSend = Round(curMinSumSend, 2)
        End If
        If curSumRateSend > curMaxSumSend And curMaxSumSend > 0 Then
            curSumRateSend = Round(curMaxSumSend, 2)
        End If
    End If

    curSumTotal = objFormat.Round(curSumPaym + curSumRateSend, 2) 'Round(curSumPaym, 2) + Round(curSumRateSend, 2)
    curSummaRateSend.Text = curSumRateSend
    curSummaTotal.Text = curSumTotal

    Exit Function
ErrorCode:
    objErr.UbsErrMsg "CalcSumCommiss", "ошибка выполнения"
End Function

Private Sub curSumma_TextChange()

    If m_IdContract > 0 Then
        Call CalcSumCommiss()
    End If

End Sub

Sub FormKeyPress(KeyAscii As Integer)
    If ((KeyAscii < 48 And KeyAscii <> 8 And KeyAscii <> 13) Or
        (KeyAscii > 57)) Then
        KeyAscii = 0
    End If
End Sub

Private Sub AccClient_LostFocus()

    Dim recCount As Integer, idArr

    On Error GoTo ErrorCode

    If cmbCode.ListIndex = -1 And (Trim(txtBic.Text) <> "" Or (Trim(AccClient.Text) <> "" And AccClient.Text <> "00000000000000000000")) Then

        objParamIn.Parameter("BIC") = Trim(txtBic.Text)
        objParamIn.Parameter("ACC") = AccClient.Text
        objParamIn.Parameter("INN") = txtINN.Text

        UbsChannel.Run "FindContrByBicAndAccount", objParamIn, objParamOut
         recCount = objParamOut.Parameter("RecCount")
        idArr = objParamOut.Parameter("IdArray")

        If recCount = 1 Then
            m_IdContract = idArr(0, 0)
            FindContractbyId()

            'If blnForward Then
            If cmbPurpose.Enabled And cmbPurpose.Visible Then
                cmbPurpose.SetFocus
            ElseIf curSumma.Enabled And curSumma.Visible Then
                curSumma.SetFocus
            End If
            'End If
        ElseIf recCount > 1 Then
            objInterfaces.GoToCtrl cmbCode
         '    btnContract_Click
        ElseIf recCount = 0 Then
            m_IdContract = 0
            'txtCode.Text = ""
            cmbCode.ListIndex = -1
        End If
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "AccClient_LostFocus", "ошибка выполнения"
End Sub

