Private Sub btnListAttributeRecip_Click()

    Dim nIdSelectedRecord As Variant
    Dim RetVal As Long, i As Integer

    On Error GoTo ErrorCode

    If NumChildWinAttributeRecip <> 0 Then
        Parent.SetFocusToWindow NumChildWinAttributeRecip
        Exit Sub
    End If

    Parent.GetWindow "UBS_FLT\PS\LIST_RECEIVER.flt", NumChildWinAttributeRecip

    If NumChildWinAttributeRecip <> 0 Then
        Dim InitParamGrid As Variant
        Dim GridF As Object
        Dim varCond As Variant
        ReDim InitParamGrid(5)
        
        Set GridF = Parent.ParamInfo(NumChildWinAttributeRecip, "UbsGridList")

        'этот код запишет условие и сделает повторный выбор не доступным
        GridF.GetWhereRS 1, varCond
        RetVal = 0

        If Not IsEmpty(varCond) Then
            For i = 0 To UBound(varCond, 2)
                If varCond(0, i) = "Идентификатор договора" Then
                    RetVal = varCond(4, i)
                End If
            Next
        End If

        'Установка условий фильтра
        If RetVal = 0 Then
            RetVal = GridF.AddWhereItem("Идентификатор договора", 4, m_IdContract)
        Else
            GridF.DelWhereItem RetVal
            RetVal = GridF.AddWhereItem("Идентификатор договора", 4, m_IdContract)
        End If

        GridF.WhereItemFlags(RetVal) = 0

        If Parent.IsExistParam(NumChildWinAttributeRecip, "InitParamGrid") Then
            nIdSelectedRecord = Empty
            InitParamGrid(0) = NumWin
            InitParamGrid(2) = True
            InitParamGrid(5) = 1 '2
            Parent.ParamInfo(NumChildWinAttributeRecip, "InitParamGrid") = InitParamGrid
            If Parent.IsExistParam(NumChildWinAttributeRecip, "SelectItem") Then
                Parent.ParamInfo(NumChildWinAttributeRecip, "SelectItem") = nIdSelectedRecord
            End If
            Parent.SetFocusToWindow NumChildWinAttributeRecip
        End If
        Set GridF = Nothing
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "Выбор атрибутов получателя", "ошибка выполнения"
End Sub

Private Sub btnSave_Click()
    Dim strGroupMess As String
    On Error GoTo ErrorCode

    m_blnNoMessage = True

    Dim RSChange As Variant, i As Integer
    Dim dDateBeg As Date, dDateEnd As Date
    Dim strKbk As String, strKbkSymbol As String

    m_blnSave = True
    btnExit.Enabled = False
    btnSave.Enabled = False

    'Если ФИО, ИНН и адрес плательщика пустые, то обнуляем ссылку на id клиента
    If (Len(Trim(txtFIOPay.Text)) = 0 And Len(Trim(txtINNPay.Text)) = 0 _
        And Len(Trim(txtAdressPay)) = 0) Then
        'And Len(Trim(txtAdressPay)) = 0) Or (Not CheckPayer(True)) Then
        m_IdClient = 0
    End If

    If CBool(m_blnSave) Then

        If Not CheckPayment() Then
            m_blnSave = False
            btnExit.Enabled = True
            btnSave.Enabled = True
            Exit Sub
        End If

        'При проверке в некоторых случаях кнопка сохранить раздизэйбливается, поэтому еще раз дизэйблим
        btnExit.Enabled = False
        btnSave.Enabled = False

        If m_IdClient <> 0 Then
            If Not CheckIPDL() Then
                MsgBox "Проверка ИПДЛ, сохранение запрещено!", 16, m_strCaptionForm
               m_blnSave = False
                btnExit.Enabled = True
                btnSave.Enabled = True
                Exit Sub
            Else
                objParamIn.Parameter("blnIPDL") = blnIPDL
            End If
        End If

        'Запуск пользовательской проверки перед сохранением
        If Not Ut_CheckUserBeforeSave() Then
            m_blnSave = False
            btnExit.Enabled = True
            btnSave.Enabled = True
            Exit Sub
        End If

        m_blnClickSave = False

        objParamIn.Parameter("IdContract") = m_IdContract
        objParamIn.Parameter("blnGuest") = blnGuest
        objParamIn.Parameter("ID_CLIENT") = m_IdClient
        objParamIn.Parameter("txtFIOPay") = txtFIOPay.Text
        objParamIn.Parameter("txtINNPay") = txtINNPay.Text
        objParamIn.Parameter("txtAdressPay") = txtAdressPay.Text
        objParamIn.Parameter("txtBic") = txtBic.Text
        objParamIn.Parameter("AccKorr") = AccKorr.Text
        objParamIn.Parameter("AccClient") = AccClient.Text
        objParamIn.Parameter("txtINN") = txtINN.Text
        objParamIn.Parameter("cmbPurpose") = cmbPurpose.Text
        If blnArbitrary Then
            objParamIn.Parameter("txtRecip") = txtRecip.Text
        End If

        'objParamIn.Parameter("SUMMAPENI") = 0


        objParamIn.Parameter("curSumma") = curSumma.CurrencyValue
        objParamIn.Parameter("curSummaRateSend") = curSummaRateSend.CurrencyValue
        objParamIn.Parameter("curSummaTotal") = curSummaTotal.CurrencyValue

        objParamIn.Parameter("COMMANDIN") = StrCommand
        objParamIn.Parameter("Address") = m_strAddress
        objParamIn.Parameter("StrCommand") = "ADD"
        objParamIn.Parameter("Group") = True

        objParamIn.Parameter("IdPaymentGroup") = m_IdPayment

        objParamIn.Parameter("blnTerror") = blnTerror

        ' ***********************************************
        ' СОХРАНЕНИЕ ПЛАТЕЖА  (VBD\PS\UT\UtPaymentF.vbs)
        UbsChannel.Run "Payment_Save", objParamIn, objParamOut
        ' ***********************************************

        If Len(objParamOut.Parameter("StrError")) = 0 Then
            blnNeedRefreshGrid = True
            Info.Caption = "Платеж сохранен в БД"
            Info.Show
        End If

        If Len(objParamOut.Parameter("StrError")) <> 0 Then
            MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
            Info.Caption = objParamOut.Parameter("StrError")
            Info.Show
        End If

        btnClient.Enabled = False
        'btnContract.Enabled = False

        subPayment.Tabs(1).Selected = True
        m_blnSave = False
        btnExit.Enabled = True

        '------------------------------
        strGroupMess = "Вы хотите продолжить ввод платежей в группу?"
        If MsgBox(strGroupMess, vbDefaultButton1 + vbApplicationModal + vbQuestion + vbYesNo, "Ввод группы платежей") = vbNo Then

        Else
            m_IdPayment = objParamOut.Parameter("IdPaym")

            Dim objScript1 As Object, varArr(0) As Variant
            varArr(0) = m_IdPayment
            Set objScript1 = CreateObject("URunScr.IUbsRunScript")
            objScript1.UbsChannel = UbsChannel
            objScript1.Parameter("Parent") = Parent
            objScript1.Parameter("Key") = varArr
            objScript1.Parameter("Идентификатор группового платежа") = objParamOut.Parameter("PAYMENTGROUPID")
            objScript1.Parameter("Идентификатор основного платежа") = m_IdPayment
            objScript1.LoadFiles "UBS_VBS\PS\PsPaymentIncomingReception.vbs"
            objScript1.ExecuteScript
            objScript1.ReleaseUbsChannel

            If objScript1.Parameter("EndGroup") Then
                btnSave.Enabled = False
            Else
                btnSave.Enabled = True
            End If
            
            Set objScript1 = Nothing
        End If

        '------------------------------
        StrCommand = "GROUP_EDIT"
        '============================
        'btnSave.Enabled = True
        btnClient.Enabled = True
        cmbCode.Enabled = True
        '============================
        'StrCommand = "ADD"
        'NewRecord

    End If

    Exit Sub
ErrorCode:
    btnExit.Enabled = True
    btnSave.Enabled = True
    m_blnSave = False
    objErr.UbsErrMsg "btnSave_Click", "ошибка выполнения"
End Sub

Private Sub btnSaveAttribute_Click()
    On Error GoTo ErrorCode

    objParamIn.ClearParameters
    objParamOut.ClearParameters

    objParamIn.Parameter("IdContract") = m_IdContract

    If txtRecip.Text = "" And txtBic.Text = "" And AccKorr.Text = "00000000000000000000" And
        txtNameBank.Text = "" And AccClient.Text = "00000000000000000000" And
        txtINN.Text = "" And cmbPurpose.Text = "" Then

        MsgBox "Реквизиты получателя не заданы!", vbInformation, m_strCaptionForm
    Else
        objParamIn.Parameter("Наименование получателя") = txtRecip.Text
        objParamIn.Parameter("БИК") = txtBic.Text
        objParamIn.Parameter("Корр. счет") = AccKorr.Text
        objParamIn.Parameter("Наименование банка") = txtNameBank.Text
        objParamIn.Parameter("Р/с") = AccClient.Text
        objParamIn.Parameter("ИНН") = txtINN.Text
        objParamIn.Parameter("Назначение") = cmbPurpose.Text

        UbsChannel.LoadResource = "VBS:UBS_VBD\PS\UT\UtPaymentF.vbs"
        UbsChannel.Run "SaveAttributeRecip", objParamIn, objParamOut

        If objParamOut.Parameter("bRetVal") Then
            MsgBox "Реквизиты получателя сохранены в справочнике", vbInformation, m_strCaptionForm
        End If
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "btnSaveAttribute_Click", "ошибка выполнения"
End Sub

Private Sub cmbCode_Click()
    On Error GoTo ErrorCode

    m_IdContract = cmbCode.ItemData(cmbCode.ListIndex)
    Call FindContractbyId()

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "cmbCode_Click", "ошибка выполнения"
End Sub

Private Sub txtNomerCardPay_KeyDown(KeyCode As Integer, Shift As Integer)

    On Error GoTo ErrorCode

    If KeyCode = 13 And Shift = 0 Then
        If Len(Trim(txtNomerCardPay.Text)) > 0 Then

            objParamIn.ClearParameters
            objParamIn.Parameter("NomerCard") = txtNomerCardPay.Text
            objParamIn.Parameter("IsGuest") = blnGuest
            'Вызвать переходник, который по номеру карты получит посетителя
            UbsChannel.Run "ReadClientFromNomerCard", objParamIn, objParamOut
            objParamIn.Parameter("IDCLIENT") = objParamOut.Parameter("IDCLIENT")
            If Len(Trim(objParamOut.Parameter("StrError"))) Then
                MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
                txtNomerCardPay.SetFocus
                Exit Sub
            End If

            ' получить посетителя Опер. кассы
            UbsChannel.Run "ReadClientFromIdOC", objParamIn, objParamOut
            If Len(Trim(objParamOut.Parameter("StrError"))) Then
                MsgBox objParamOut.Parameter("StrError"), 16, m_strCaptionForm
                Exit Sub
            End If

            m_IdClient = objParamIn.Parameter("IDCLIENT")
            txtINNPay.Text = objParamOut.Parameter("INN")
            txtInfoClient.Text = objParamOut.Parameter("InfoClient")
            txtFIOPay.Text = objParamOut.Parameter("NAME")
            txtAdressPay.Text = objParamOut.Parameter("ADRESS")

            'Call CheckPayer(False)
            'Получить тип, номер и серию документа
            m_strTypeDoc = objParamOut.Parameter("TypeDoc")
            m_strDocNumber = objParamOut.Parameter("NUMBER")
            m_strDocSeries = objParamOut.Parameter("SERIES")

            'GotoNextControlForEnter
        End If
    End If

    Exit Sub
ErrorCode:
    objErr.UbsErrMsg "txtNomerCardPay_KeyDown", "ошибка выполнения"
End Sub

