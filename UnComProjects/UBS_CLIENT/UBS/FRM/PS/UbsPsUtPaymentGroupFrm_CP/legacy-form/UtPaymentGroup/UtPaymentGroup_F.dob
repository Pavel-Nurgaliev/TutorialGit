Dim m_strCaptionForm As String
Dim blnGuest As Boolean
Dim m_IdPayment As Long     ' идентификатор платежа
Dim m_IdContract As Long    ' идентификатор договора с получателем
Dim m_blnChangeContract As Boolean
Dim intState As Integer        ' признак статуса договора

Dim m_IdClientOld As Long
Dim m_strFIOOld As String
Dim m_strAddressOld As String
Dim m_strINNOld As String
Public blnAlready As Boolean
Public m_blnNoMessage As Boolean
Dim m_blnClickSave As Boolean, m_blnSave As Boolean
